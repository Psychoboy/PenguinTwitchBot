{
  "profiles": {
    "DotNetTwitchBot": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7293;http://localhost:4000"
    },
    "DotNetTwitchBot (MariaDB)": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DATABASE_PROVIDER": "mariadb"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7293;http://localhost:4000"
    },
    "DotNetTwitchBot (PostgreSQL)": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DATABASE_PROVIDER": "postgres"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7293;http://localhost:4000"
    },
    "DotNetTwitchBot (SQLite)": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DATABASE_PROVIDER": "sqlite"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7293;http://localhost:4000"
    },
    "IIS Express": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Docker": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
      "publishAllPorts": true,
      "useSSL": true
    }
  },
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:42929",
      "sslPort": 44348
    }
  }
}