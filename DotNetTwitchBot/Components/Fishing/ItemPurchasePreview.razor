@using DotNetTwitchBot.Bot.Commands.Fishing
@using DotNetTwitchBot.Bot.Models.Fishing
@inject IFishingService FishingService
@inject IFishingAnalyticsService AnalyticsService

@if (ShopItem != null)
{
    <MudPaper Elevation="3" Class="pa-4">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h5">
                @ShopItem.Name
            </MudText>
            <MudText Typo="Typo.body2">@ShopItem.Description</MudText>

            <MudDivider />

            <MudStack Row="true" Spacing="2">
                <MudChip T="string" Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning">
                    @ShopItem.Cost Gold
                </MudChip>
                @if (ShopItem.EquipmentSlot.HasValue)
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.Build" Color="Color.Info">
                        @ShopItem.EquipmentSlot.Value Slot
                    </MudChip>
                }
                @if (ShopItem.IsConsumable && ShopItem.MaxUses.HasValue)
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.Timer" Color="Color.Secondary">
                        @ShopItem.MaxUses Uses
                    </MudChip>
                }
            </MudStack>

            <MudDivider />

            <MudText Typo="Typo.subtitle1" Class="mt-2">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                <strong>Boost Effect@(HasMultipleBoosts() ? "s" : "")</strong>
            </MudText>

            @* Show all boost types *@
            <MudStack Spacing="2">
                @* Primary Boost *@
                @RenderBoostAlert(ShopItem.BoostType, ShopItem.BoostAmount, ShopItem.TargetFishType)

                @* Secondary Boost *@
                @if (ShopItem.BoostType2.HasValue && ShopItem.BoostAmount2.HasValue)
                {
                    @RenderBoostAlert(ShopItem.BoostType2.Value, ShopItem.BoostAmount2.Value, null)
                }

                @* Tertiary Boost *@
                @if (ShopItem.BoostType3.HasValue && ShopItem.BoostAmount3.HasValue)
                {
                    @RenderBoostAlert(ShopItem.BoostType3.Value, ShopItem.BoostAmount3.Value, null)
                }
            </MudStack>

            @if (comparisonRows.Any())
            {
                <MudPaper Elevation="2" Class="pa-3 mt-2">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2">
                            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Size="Size.Small" />
                            Current vs If Equipped
                        </MudText>
                        <MudSimpleTable Dense="true">
                            <thead>
                                <tr>
                                    <th>Metric</th>
                                    <th>Current</th>
                                    <th>New</th>
                                    <th>Diff</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in comparisonRows)
                                {
                                    <tr>
                                        <td><strong>@row.Metric</strong></td>
                                        <td>@row.CurrentDisplay</td>
                                        <td>@row.NewDisplay</td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Color="@GetDiffColor(row.DiffValue)">
                                                @(row.DiffValue >= 0 ? "+" : "")@row.DiffDisplay
                                            </MudChip>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Preview replaces your currently equipped item in the same slot (if any), so numbers match real equip behavior.
                        </MudText>
                    </MudStack>
                </MudPaper>
            }

            @if (isLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public FishingShopItem? ShopItem { get; set; }
    [Parameter] public List<int> CurrentEquippedItemIds { get; set; } = new();
    [Parameter] public List<FishingShopItem> CurrentEquippedItems { get; set; } = new();

    private RarityProbability? currentRarityPreview;
    private RarityProbability? newRarityPreview;
    private Dictionary<int, FishProbability>? currentFishPreview;
    private Dictionary<int, FishProbability>? newFishPreview;
    private bool isLoading = false;

    private readonly List<MetricComparisonRow> comparisonRows = new();
    private readonly List<FishingShopItem> currentEquippedResolved = new();
    private readonly List<FishingShopItem> projectedEquippedResolved = new();

    private class MetricComparisonRow
    {
        public string Metric { get; set; } = string.Empty;
        public string CurrentDisplay { get; set; } = string.Empty;
        public string NewDisplay { get; set; } = string.Empty;
        public string DiffDisplay { get; set; } = string.Empty;
        public double DiffValue { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ShopItem != null)
        {
            await LoadProbabilityPreview();
        }
    }

    private async Task LoadProbabilityPreview()
    {
        if (ShopItem == null) return;

        isLoading = true;
        try
        {
            var settings = await FishingService.GetSettings();

            ResolveCurrentItems();
            ResolveProjectedItems();

            var currentItemIds = currentEquippedResolved.Select(i => i.Id).Distinct().ToList();
            var projectedItemIds = projectedEquippedResolved.Select(i => i.Id).Distinct().ToList();

            currentRarityPreview = await AnalyticsService.CalculateRarityProbabilities(
                settings?.BoostMode ?? false,
                settings?.BoostModeRarityMultiplier ?? 1.0,
                currentItemIds
            );

            newRarityPreview = await AnalyticsService.CalculateRarityProbabilities(
                settings?.BoostMode ?? false,
                settings?.BoostModeRarityMultiplier ?? 1.0,
                projectedItemIds
            );

            currentFishPreview = await AnalyticsService.CalculateCatchProbabilities(
                settings?.BoostMode ?? false,
                settings?.BoostModeRarityMultiplier ?? 1.0,
                currentItemIds
            );

            newFishPreview = await AnalyticsService.CalculateCatchProbabilities(
                settings?.BoostMode ?? false,
                settings?.BoostModeRarityMultiplier ?? 1.0,
                projectedItemIds
            );

            BuildComparisonRows();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResolveCurrentItems()
    {
        currentEquippedResolved.Clear();

        if (CurrentEquippedItems.Any())
        {
            currentEquippedResolved.AddRange(CurrentEquippedItems);
            return;
        }

        if (ShopItem == null)
            return;

        if (CurrentEquippedItemIds.Contains(ShopItem.Id))
        {
            currentEquippedResolved.Add(ShopItem);
        }
    }

    private void ResolveProjectedItems()
    {
        projectedEquippedResolved.Clear();
        projectedEquippedResolved.AddRange(currentEquippedResolved);

        if (ShopItem == null)
            return;

        if (ShopItem.EquipmentSlot.HasValue)
        {
            projectedEquippedResolved.RemoveAll(i => i.EquipmentSlot == ShopItem.EquipmentSlot);
        }

        if (!projectedEquippedResolved.Any(i => i.Id == ShopItem.Id))
        {
            projectedEquippedResolved.Add(ShopItem);
        }
    }

    private void BuildComparisonRows()
    {
        comparisonRows.Clear();
        if (ShopItem == null)
            return;

        if (HasGeneralRarityBoost() || HasSpecificFishBoost())
        {
            foreach (FishRarity rarity in Enum.GetValues(typeof(FishRarity)))
            {
                var currentChance = currentRarityPreview?.Probabilities.GetValueOrDefault(rarity, 0) ?? 0;
                var newChance = newRarityPreview?.Probabilities.GetValueOrDefault(rarity, 0) ?? 0;
                AddPercentRow($"{rarity} catch chance", currentChance, newChance);
            }
        }

        if (HasStarBoost())
        {
            var currentStarBoost = GetTotalBoost(currentEquippedResolved, FishingBoostType.StarBoost);
            var newStarBoost = GetTotalBoost(projectedEquippedResolved, FishingBoostType.StarBoost);

            var (currentOneStar, currentTwoStar, currentThreeStar) = CalculateStarChances(currentStarBoost);
            var (newOneStar, newTwoStar, newThreeStar) = CalculateStarChances(newStarBoost);

            AddPercentRow("1-star catch chance", currentOneStar, newOneStar);
            AddPercentRow("2-star catch chance", currentTwoStar, newTwoStar);
            AddPercentRow("3-star catch chance", currentThreeStar, newThreeStar);
        }

        if (HasWeightBoost())
        {
            var currentWeightBoost = GetTotalBoost(currentEquippedResolved, FishingBoostType.WeightBoost);
            var newWeightBoost = GetTotalBoost(projectedEquippedResolved, FishingBoostType.WeightBoost);
            AddPercentRow("Avg weight multiplier", (1.0 + currentWeightBoost) * 100.0, (1.0 + newWeightBoost) * 100.0);
        }

        if (HasSpecificFishBoost() && ShopItem.TargetFishTypeId.HasValue)
        {
            var targetId = ShopItem.TargetFishTypeId.Value;
            if (currentFishPreview != null && newFishPreview != null &&
                currentFishPreview.TryGetValue(targetId, out var currentTarget) &&
                newFishPreview.TryGetValue(targetId, out var newTarget))
            {
                AddPercentRow($"{currentTarget.FishName} catch chance", currentTarget.OverallChance, newTarget.OverallChance);
            }
        }
    }

    private void AddPercentRow(string metric, double currentValue, double newValue)
    {
        var diff = newValue - currentValue;
        comparisonRows.Add(new MetricComparisonRow
        {
            Metric = metric,
            CurrentDisplay = $"{currentValue:F3}%",
            NewDisplay = $"{newValue:F3}%",
            DiffDisplay = $"{Math.Abs(diff):F3}%",
            DiffValue = diff
        });
    }

    private static (double OneStar, double TwoStar, double ThreeStar) CalculateStarChances(double totalStarBoost)
    {
        var threeStarThreshold = 5.0 + (totalStarBoost * 100.0);
        var twoStarThreshold = 20.0 + (totalStarBoost * 100.0);

        var p3 = Math.Clamp(threeStarThreshold, 0.0, 100.0);
        var p3OrP2 = Math.Clamp(threeStarThreshold + twoStarThreshold, 0.0, 100.0);
        var p2 = Math.Max(0.0, p3OrP2 - p3);
        var p1 = Math.Max(0.0, 100.0 - p3 - p2);

        return (p1, p2, p3);
    }

    private static double GetTotalBoost(IEnumerable<FishingShopItem> items, FishingBoostType type)
    {
        double total = 0;
        foreach (var item in items)
        {
            if (item.BoostType == type) total += item.BoostAmount;
            if (item.BoostType2 == type) total += item.BoostAmount2 ?? 0;
            if (item.BoostType3 == type) total += item.BoostAmount3 ?? 0;
        }

        return total;
    }

    private bool HasSpecificFishBoost()
    {
        if (ShopItem == null) return false;
        return ShopItem.BoostType == FishingBoostType.SpecificFishBoost ||
               ShopItem.BoostType2 == FishingBoostType.SpecificFishBoost ||
               ShopItem.BoostType3 == FishingBoostType.SpecificFishBoost;
    }

    private Color GetDiffColor(double diff)
    {
        if (diff > 0) return Color.Success;
        if (diff < 0) return Color.Error;
        return Color.Default;
    }

    private string GetBoostDescription(FishingBoostType boostType, double boostAmount)
    {
        var percentage = (boostAmount * 100).ToString("F0");
        return boostType switch
        {
            FishingBoostType.GeneralRarityBoost => $"+{percentage}% chance to catch rare fish (all rarities)",
            FishingBoostType.WeightBoost => $"+{percentage}% to fish weight (catch bigger fish)",
            FishingBoostType.StarBoost => $"+{percentage}% chance for higher star quality",
            FishingBoostType.SpecificFishBoost => $"+{percentage}% chance to catch specific fish",
            _ => $"+{percentage}% boost"
        };
    }

    private bool HasMultipleBoosts()
    {
        if (ShopItem == null) return false;
        return ShopItem.BoostType2.HasValue || ShopItem.BoostType3.HasValue;
    }

    private bool HasWeightBoost()
    {
        if (ShopItem == null) return false;
        return ShopItem.BoostType == FishingBoostType.WeightBoost ||
               ShopItem.BoostType2 == FishingBoostType.WeightBoost ||
               ShopItem.BoostType3 == FishingBoostType.WeightBoost;
    }

    private bool HasStarBoost()
    {
        if (ShopItem == null) return false;
        return ShopItem.BoostType == FishingBoostType.StarBoost ||
               ShopItem.BoostType2 == FishingBoostType.StarBoost ||
               ShopItem.BoostType3 == FishingBoostType.StarBoost;
    }

    private bool HasGeneralRarityBoost()
    {
        if (ShopItem == null) return false;
        return ShopItem.BoostType == FishingBoostType.GeneralRarityBoost ||
               ShopItem.BoostType2 == FishingBoostType.GeneralRarityBoost ||
               ShopItem.BoostType3 == FishingBoostType.GeneralRarityBoost;
    }

    private Color GetRarityColor(FishRarity rarity) => rarity switch
    {
        FishRarity.Common => Color.Default,
        FishRarity.Uncommon => Color.Success,
        FishRarity.Rare => Color.Info,
        FishRarity.Epic => Color.Secondary,
        FishRarity.Legendary => Color.Warning,
        _ => Color.Default
    };
}

@code {
    private RenderFragment RenderBoostAlert(FishingBoostType boostType, double boostAmount, FishType? targetFish) => builder =>
    {
        builder.OpenComponent<MudAlert>(0);
        builder.AddAttribute(1, "Severity", Severity.Success);
        builder.AddAttribute(2, "Dense", true);

        if (boostType == FishingBoostType.SpecificFishBoost && targetFish != null)
        {
            builder.AddAttribute(3, "ChildContent", (RenderFragment)(childBuilder =>
            {
                childBuilder.AddContent(0, $"Targets: ");
                childBuilder.OpenElement(1, "strong");
                childBuilder.AddContent(2, targetFish.Name);
                childBuilder.CloseElement();
                childBuilder.AddContent(3, $" (+{(boostAmount * 100):F0}% catch chance)");
            }));
        }
        else
        {
            builder.AddAttribute(3, "ChildContent", (RenderFragment)(childBuilder =>
            {
                childBuilder.AddContent(0, GetBoostDescription(boostType, boostAmount));
            }));
        }

        builder.CloseComponent();
    };
}
