@using DotNetTwitchBot.Shared
@using DotNetTwitchBot.CustomMiddleware
@using DotNetTwitchBot.Helpers
@using Microsoft.AspNetCore.Authorization

<CascadingAuthenticationState>  
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                @{
                    var isViewerRolePage = RequiresViewerRole(routeData.PageType);
                }
                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                    <AuthorizeView>
                        <NotAuthorized Context="unauthorizedAuthState">
                            <MudPaper Elevation="6" Class="pa-6" Style="border: 2px solid var(--mud-palette-primary);">
                                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary">
                                        <strong>Sign In Required</strong>
                                    </MudText>
                                    <MudText Typo="Typo.body1" Align="Align.Center">
                                        @(isViewerRolePage
                                            ? "You are not signed in as a viewer. Sign in with Twitch to access this page."
                                            : "You are not signed in. Sign in with Twitch to continue.")
                                    </MudText>
                                    <MudButton OnClick="Signin"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               StartIcon="@Icons.Material.Filled.Login"
                                               Style="width: 300px;">
                                        Sign In with Twitch
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </NotAuthorized>
                        <Authorized Context="authorizedAuthState">
                            <MudPaper Elevation="6" Class="pa-6" Style="border: 2px solid var(--mud-palette-warning);">
                                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.NoAccounts" Size="Size.Large" Color="Color.Warning" />
                                    <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Warning">
                                        <strong>Access Restricted</strong>
                                    </MudText>
                                    <MudText Typo="Typo.body1" Align="Align.Center">
                                        You are signed in, but your account does not have permission to view this page.
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </Authorized>
                    </AuthorizeView>
                </MudContainer>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <NotFoundItem></NotFoundItem>
        </LayoutView>
    </NotFound>
</Router>
</CascadingAuthenticationState>

@code {
    [Parameter]
    public string? RemoteIpAddress { get; set; }

    [Inject]
    BlazorAppContext? BlazorAppContext { get; set; }

    [Inject]
    NavigationManager Navigation { get; set; } = null!;

    protected override Task OnInitializedAsync()
    {
        if (this.BlazorAppContext != null)
        {
            this.BlazorAppContext.CurrentUserIP = this.RemoteIpAddress;
        }
        return Task.CompletedTask;
    }

    private static bool RequiresViewerRole(Type pageType)
    {
        var authorizeAttributes = pageType
            .GetCustomAttributes(typeof(AuthorizeAttribute), inherit: true)
            .OfType<AuthorizeAttribute>();

        foreach (var attribute in authorizeAttributes)
        {
            if (string.IsNullOrWhiteSpace(attribute.Roles))
            {
                continue;
            }

            var roles = attribute.Roles.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (roles.Any(role => string.Equals(role, "Viewer", StringComparison.OrdinalIgnoreCase)))
            {
                return true;
            }
        }

        return false;
    }

    private void Signin()
    {
        Navigation.NavigateToSigninWithReturnUrl();
    }
}