@using DotNetTwitchBot.Circuit;
@using DotNetTwitchBot.CustomMiddleware
@using DotNetTwitchBot.Models;
@using Microsoft.AspNetCore.Components.Server.Circuits;
@using Microsoft.AspNetCore.SignalR.Client;
@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject ICircuitUserService UserService
@inject DotNetTwitchBot.Bot.Core.IServiceBackbone serviceBackbone
@inject CircuitHandler BlazorCircuitHandler
@implements IAsyncDisposable
@inject ISnackbar Snackbar
@inject ILogger<MainLayout> logger

<PageTitle>SPTV Twitch Bot</PageTitle>
<MudThemeProvider IsDarkMode=true />
<MudPopoverProvider/>
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    @if(!dataLoaded)
    {
        <MudMainContent>
        <MudOverlay Visible="!dataLoaded" DarkBackground="true" Absolute="true">
            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
        </MudOverlay>
        </MudMainContent>
    }
    else 
    {
        <MudAppBar>
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
            OnClick="@((e) => DrawerToggle())" />
            Super Waffle Bot
            <MudSpacer />
            @if(StreamOnline)
            {
                <MudAlert Severity="Severity.Success" NoIcon="true">Stream is Online</MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" NoIcon="true">Stream is Offline</MudAlert>
            }
            <div id="components-reconnect-modal" class="components-reconnect-hide">

                <div class="show">
                    <MudSpacer />
                    <MudAlert Severity="Severity.Warning" NoIcon="true">Attempting to reconnect or manually refresh.</MudAlert>
                </div>
                <div class="rejected failed">
                    <MudSpacer />
                    <MudAlert Severity="Severity.Warning" NoIcon="true">Reconnect failed. Please refresh.</MudAlert>
                </div>
            </div>
            <MudSpacer />
            <AuthorizeView>
                <Authorized Context="Auth">
                    <MudImage Width="48" Src="@ProfileImage" />
                    <MudMenu Label="@Username" AnchorOrigin="Origin.CenterCenter" TransformOrigin="Origin.TopCenter">
                        <MudMenuItem OnClick="Signout">Sign out</MudMenuItem>
                    </MudMenu>
                </Authorized>
                <NotAuthorized>
                    <MudLink OnClick="Signin">Sign In</MudLink>
                </NotAuthorized>
            </AuthorizeView>
        </MudAppBar>
        <MudDrawer @bind-Open="@_drawerOpen" Elevation="1">
            <NavMenu />
        </MudDrawer>
        <MudMainContent>
            @Body
        </MudMainContent>
    }
</MudLayout>
@code {
    bool _drawerOpen = true;
    private string Username = "";
    private string ProfileImage = "";
    private string UserId = "";
    private bool StreamOnline = false;
    private HubConnection? hubConnection;
    private CancellationTokenSource? _hubConnectionCts;
    [Inject]
    BlazorAppContext? BlazorAppContext { get; set; }

    private bool dataLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider
           .GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated && user.Identity.Name != null)
        {
            Username = user.Identity.Name;
            if (user.HasClaim(x => x.Type.Equals("DisplayName")))
            {
                Username = user.Claims.Where(x => x.Type.Equals("DisplayName")).First().Value;
            }

            if (user.HasClaim(x => x.Type.Equals("ProfilePicture")))
            {
                ProfileImage = user.Claims.Where(x => x.Type.Equals("ProfilePicture")).First().Value;
            }
            if (user.HasClaim(x => x.Type.Equals("UserId")))
            {
                UserId = user.Claims.Where(x => x.Type.Equals("UserId")).First().Value;
            }
        }
        var handler = (CircuitHandlerService)BlazorCircuitHandler;
        await UserService.Connect(handler.CircuitId, Username, UserId, BlazorAppContext?.CurrentUserIP);
        UserService.UpdateUserLastSeen(handler.CircuitId, Navigation.Uri);
        Navigation.LocationChanged += HandleLocationChanged;
        StreamOnline = serviceBackbone.IsOnline;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        _hubConnectionCts = new CancellationTokenSource();

        // Configure SignalR with automatic reconnect and retry policy
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/mainhub"), options =>
            {
                // Allow fallback to other transports if WebSockets fail
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false; // Ensure negotiation happens for transport selection
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        hubConnection.On<bool>("StreamChanged", (status) =>
        {
            StreamOnline = status;
            if (status)
            {
                Snackbar.Add("Stream is now online.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Stream is now offline.", Severity.Error);
            }
            InvokeAsync(StateHasChanged);
        });

        // Handle reconnection events
        hubConnection.Reconnecting += error =>
        {
            logger.LogWarning(error, "SignalR connection lost, attempting to reconnect...");
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += connectionId =>
        {
            logger.LogInformation("SignalR reconnected successfully");
            return InvokeAsync(() => Snackbar.Add("Connection restored.", Severity.Success));
        };

        hubConnection.Closed += async error =>
        {
            if (error != null)
            {
                logger.LogError(error, "SignalR connection closed with error");
            }
            // If initial connection never succeeded, attempt to reconnect (unless we're disposing)
            if (hubConnection.State == HubConnectionState.Disconnected && _hubConnectionCts != null && !_hubConnectionCts.Token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), _hubConnectionCts.Token);
                    await hubConnection.StartAsync(_hubConnectionCts.Token);
                    logger.LogDebug("SignalR connection re-established after initial failure");
                }
                catch (OperationCanceledException)
                {
                    // Disposal requested - this is expected
                }
                catch (ObjectDisposedException)
                {
                    // Component disposed during reconnection attempt - this is expected
                }
                catch (Exception ex)
                {
                    logger.LogDebug(ex, "Failed to re-establish SignalR connection");
                }
            }
        };

        // Retry initial connection with backoff
        var retryDelays = new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) };
        var attempt = 0;
        var connected = false;

        while (!connected && attempt < retryDelays.Length)
        {
            try
            {
                if (attempt > 0)
                {
                    await Task.Delay(retryDelays[attempt]);
                }
                await hubConnection.StartAsync();
                connected = true;
            }
            catch (Microsoft.AspNetCore.Http.Connections.Client.TransportFailedException ex)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    logger.LogWarning(ex, "SignalR initial connection failed after {Attempts} attempts", attempt);
                }
                else
                {
                    logger.LogDebug(ex, "SignalR initial connection attempt {Attempt} failed, retrying...", attempt);
                }
            }
            catch (TaskCanceledException)
            {
                logger.LogWarning("SignalR connection cancelled");
                break;
            }
            catch (Exception ex)
            {
                logger.LogWarning(ex, "Failed to connect to SignalR hub");
                break;
            }
        }

        if (!connected)
        {
            Snackbar.Add("Unable to establish live connection. Data may be delayed.", Severity.Warning);
        }

        dataLoaded = true;
        StateHasChanged();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var handler = (CircuitHandlerService)BlazorCircuitHandler;
        UserService.UpdateUserLastSeen(handler.CircuitId, Navigation.Uri);
    }

    private void Signin()
    {
        Navigation.NavigateTo("/signin?r=" + new Uri(Navigation.Uri).AbsoluteUri, true);
    }

    private void Signout()
    {
        Navigation.NavigateTo("/signout", true);
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= HandleLocationChanged;

        // Cancel any pending reconnection attempts
        _hubConnectionCts?.Cancel();

        if (hubConnection is not null)
        {
            try
            {
                // Stop the connection gracefully before disposing
                if (hubConnection.State == HubConnectionState.Connected)
                {
                    await hubConnection.StopAsync();
                }
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                // Log but don't throw - disposal should be silent to user
                logger.LogDebug(ex, "Exception during SignalR connection disposal (non-critical)");
            }
        }

        _hubConnectionCts?.Dispose();
    }
}
