@page "/actions/manage"
@using DotNetTwitchBot.Bot.Models.Actions
@using DotNetTwitchBot.Bot.Actions.SubActions.Types
@using DotNetTwitchBot.Bot.Models.Actions.Triggers
@using DotNetTwitchBot.Bot.Actions
@using DotNetTwitchBot.Pages.Components
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject IActionManagementService ActionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject DotNetTwitchBot.Bot.Queues.IQueueManager QueueManager

<PageTitle>SPTV Twitch Bot - Manage Actions</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Action Management</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">Create, edit, and manage actions with their triggers and subactions.</MudText>

    <MudGrid>
        <!-- Left Panel - Actions List -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Actions (@_actions.Count)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" 
                                       OnClick="CreateNewAction" />
                    </MudStack>

                    <MudTextField @bind-Value="_searchString" Placeholder="Search actions" 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                  IconSize="Size.Medium" Immediate="true" DebounceInterval="300" 
                                  OnDebounceIntervalElapsed="FilterActions" />

                    <MudSelect T="string" Value="@_filterGroup" ValueChanged="OnGroupFilterChanged" Label="Filter by Group" Dense="true">
                        <MudSelectItem T="string" Value="@("")">All Groups</MudSelectItem>
                        @foreach (var group in _groups)
                        {
                            <MudSelectItem T="string" Value="@group">@group</MudSelectItem>
                        }
                    </MudSelect>

                    <MudDivider />

                    @if (_filteredActions.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                            No actions found
                        </MudText>
                    }
                    else
                    {
                        <MudList T="ActionType" @bind-SelectedValue="_selectedAction" Dense="true">
                            @foreach (var group in _filteredActions.Select(a => (a.Group ?? string.Empty).Trim()).Distinct().Order())
                            {
                                <MudListItem Text="@(string.IsNullOrWhiteSpace(group) ? Ungrouped : group)">
                                    <NestedList>
                                @foreach (var action in _filteredActions.Where(a => (a.Group ?? string.Empty) == group))
                                {
                                    <MudListItem T="ActionType" Value="@action" OnClick="@(() => OnActionSelected(action))">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body1">@action.Name</MudText>
                                            <MudStack Row="true" Spacing="1">
                                                <MudChip T="string" Size="Size.Small" Color="@(action.Enabled ? Color.Success : Color.Error)">
                                                    @(action.Enabled ? "Enabled" : "Disabled")
                                                </MudChip>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                                    @action.SubActions.Count SubActions
                                                </MudChip>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">
                                                    @action.Triggers.Count Triggers
                                                </MudChip>
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />

                                }
                                    </NestedList>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Right Panel - Action Details -->
        <MudItem xs="12" md="8">
            @if (_selectedAction == null)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Select an action to view details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Or create a new action to get started</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                    <MudStack Spacing="3">
                        <!-- Action Header -->
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5">
                                @(_isNewAction ? "New Action" : _selectedAction.Name)
                            </MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                                           OnClick="SaveAction" StartIcon="@Icons.Material.Filled.Save">
                                    Save
                                </MudButton>
                                @if (!_isNewAction)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" 
                                               OnClick="DuplicateAction" StartIcon="@Icons.Material.Filled.ContentCopy">
                                        Duplicate
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Error" 
                                               OnClick="DeleteAction" StartIcon="@Icons.Material.Filled.Delete">
                                        Delete
                                    </MudButton>
                                }
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEdit">
                                    Cancel
                                </MudButton>
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        <!-- Action Configuration -->
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.h6" Class="mb-3">Action Configuration</MudText>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_selectedAction.Name" Label="Action Name" 
                                                  Required="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudAutocomplete T="string" @bind-Value="_selectedAction.Group" Label="Group" 
                                                     Variant="Variant.Outlined" 
                                                     SearchFunc="@SearchGroups"
                                                     Clearable="true"
                                                     CoerceText="true"
                                                     CoerceValue="false" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="_selectedAction.QueueName" Label="Queue Name" 
                                               Variant="Variant.Outlined" Required="true">
                                        @foreach (var queue in _availableQueues)
                                        {
                                            <MudSelectItem T="string" Value="@queue">@queue</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudStack Row="true" Spacing="3">
                                        <MudSwitch @bind-Value="_selectedAction.Enabled" Label="Enabled" Color="Color.Success" />
                                        <MudSwitch @bind-Value="_selectedAction.RandomAction" Label="Random Action" Color="Color.Primary" />
                                        <MudSwitch @bind-Value="_selectedAction.ConcurrentAction" Label="Concurrent" Color="Color.Info" />
                                        <MudSwitch @bind-Value="_selectedAction.OnlineOnly" Label="Online Only" Color="Color.Warning" />
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <!-- Triggers Section -->
                        <TriggerManagement ActionId="_selectedAction.Id" 
                                           ActionTriggers="_actionTriggers"
                                           ActionTriggersChanged="OnActionTriggersChanged" />

                        <!-- SubActions Section -->
                        <SubActionManagement SubActions="_selectedAction.SubActions" 
                                             SubActionsChanged="OnSubActionsChanged" />
                    </MudStack>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "actionId")]
    public int? ActionIdFromQuery { get; set; }

    private List<ActionType> _actions = new();
    private List<ActionType> _filteredActions = new();
    private List<string> _groups = new();
    private List<string> _availableQueues = new();
    private ActionType? _selectedAction;
    private List<TriggerType> _actionTriggers = new();
    private bool _isNewAction = false;
    private string _searchString = "";
    private string _filterGroup = "";
    private const string Ungrouped = "None";

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableQueues();
        await LoadActions();
    }

    private async Task LoadAvailableQueues()
    {
        var queueConfigs = await QueueManager.GetAllQueuesAsync();
        _availableQueues = queueConfigs.Select(q => q.Name).OrderBy(n => n).ToList();

        // Ensure "Default" is always in the list and at the top
        if (!_availableQueues.Contains("Default"))
        {
            _availableQueues.Insert(0, "Default");
        }
        else
        {
            _availableQueues.Remove("Default");
            _availableQueues.Insert(0, "Default");
        }
    }

    private async Task LoadActions()
    {
        _actions = await ActionService.GetAllActionsAsync();
        _groups = _actions.Select(a => a.Group).Where(g => !string.IsNullOrEmpty(g)).Distinct().OrderBy(g => g).ToList();
        FilterActions();

        // If actionId is provided in query string, select that action
        if (ActionIdFromQuery.HasValue)
        {
            var actionToSelect = _actions.FirstOrDefault(a => a.Id == ActionIdFromQuery.Value);
            if (actionToSelect != null)
            {
                await OnActionSelected(actionToSelect);
            }
        }
    }

    private void FilterActions()
    {
        _filteredActions = _actions.Where(a =>
        {
            bool matchesSearch = string.IsNullOrWhiteSpace(_searchString) || 
                                 a.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
            bool matchesGroup = string.IsNullOrWhiteSpace(_filterGroup) || 
                                a.Group == _filterGroup;
            return matchesSearch && matchesGroup;
        }).OrderBy(a => a.Name).ToList();
    }

    private void OnGroupFilterChanged(string group)
    {
        _filterGroup = group;
        FilterActions();
    }

    private Task<IEnumerable<string>> SearchGroups(string value, CancellationToken cancellationToken)
    {
        // If no search value, return all groups
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult<IEnumerable<string>>(_groups);
        }

        value = value.Trim();

        // Filter groups by search value
        var filteredGroups = _groups
            .Where(g => g.Contains(value, StringComparison.OrdinalIgnoreCase))
            .ToList();

        // If the typed value doesn't exist in the list, add it as the first option
        if (!string.IsNullOrWhiteSpace(value) && !filteredGroups.Any(g => g.Equals(value, StringComparison.OrdinalIgnoreCase)))
        {
            filteredGroups.Insert(0, value);
        }

        return Task.FromResult(filteredGroups.AsEnumerable());
    }

    private async Task OnActionSelected(ActionType? action)
    {
        if (action == null) return;

        _selectedAction = action;
        _isNewAction = false;

        // Triggers are already loaded by GetAllWithDetailsAsync, no need to query again
        _actionTriggers = _selectedAction.Triggers ?? new List<TriggerType>();
        await Task.CompletedTask; // Keep async signature for consistency
    }

    private void OnActionTriggersChanged(List<TriggerType> triggers)
    {
        _actionTriggers = triggers;
    }

    private void OnSubActionsChanged(List<SubActionType> subActions)
    {
        if (_selectedAction != null)
        {
            _selectedAction.SubActions = subActions;
        }
    }

    private void CreateNewAction()
    {
        _selectedAction = new ActionType
        {
            Name = "New Action",
            Group = "",
            Enabled = true,
            QueueName = "Default",
            SubActions = new List<SubActionType>()
        };
        _actionTriggers = new List<TriggerType>();
        _isNewAction = true;
    }

    private async Task SaveAction()
    {
        if (_selectedAction == null) return;

        try
        {
            // Ensure Group is never null (convert to empty string)
            _selectedAction.Group = _selectedAction.Group ?? string.Empty;

            // Sync triggers from the separate list back to the action
            _selectedAction.Triggers = _actionTriggers;

            if (_isNewAction || !_selectedAction.Id.HasValue)
            {
                _selectedAction = await ActionService.CreateActionAsync(_selectedAction);
                _isNewAction = false;
                Snackbar.Add($"Action '{_selectedAction.Name}' created successfully", Severity.Success);
            }
            else
            {
                await ActionService.UpdateActionAsync(_selectedAction);
                Snackbar.Add($"Action '{_selectedAction.Name}' updated successfully", Severity.Success);
            }

            await LoadActions();

            // Clear selection after successful save
            _selectedAction = null;
            _actionTriggers = new List<TriggerType>();
            _isNewAction = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving action: {ex.Message}", Severity.Error);
        }
    }

    private void DuplicateAction()
    {
        if (_selectedAction == null) return;

        // Create a deep copy of the action
        var duplicatedAction = new ActionType
        {
            Name = $"Copy of {_selectedAction.Name}",
            Group = _selectedAction.Group,
            Enabled = _selectedAction.Enabled,
            RandomAction = _selectedAction.RandomAction,
            ConcurrentAction = _selectedAction.ConcurrentAction,
            QueueName = _selectedAction.QueueName,
            SubActions = new List<SubActionType>(),
            Triggers = new List<TriggerType>()
        };

        // Deep copy SubActions
        foreach (var subAction in _selectedAction.SubActions)
        {
            // Use reflection to create a new instance of the same type
            var subActionType = subAction.GetType();
            var duplicatedSubAction = (SubActionType)Activator.CreateInstance(subActionType)!;

            // Copy common properties
            duplicatedSubAction.Id = 0; // New ID will be assigned on save
            duplicatedSubAction.Index = subAction.Index;
            duplicatedSubAction.Text = subAction.Text;
            duplicatedSubAction.Enabled = subAction.Enabled;
            duplicatedSubAction.SubActionTypes = subAction.SubActionTypes;

            // Copy all other properties using reflection
            foreach (var prop in subActionType.GetProperties())
            {
                if (prop.CanWrite && prop.CanRead && 
                    prop.Name != "Id" && prop.Name != "Index" && prop.Name != "Text" && 
                    prop.Name != "Enabled" && prop.Name != "SubActionTypes")
                {
                    var value = prop.GetValue(subAction);
                    prop.SetValue(duplicatedSubAction, value);
                }
            }

            duplicatedAction.SubActions.Add(duplicatedSubAction);
        }

        // Deep copy Triggers
        var duplicatedTriggers = new List<TriggerType>();
        foreach (var trigger in _actionTriggers)
        {
            var duplicatedTrigger = new TriggerType
            {
                Id = 0, // New ID will be assigned on save
                Name = trigger.Name,
                Type = trigger.Type,
                Configuration = trigger.Configuration,
                Enabled = trigger.Enabled,
                ActionId = null // Will be set when the action is saved
            };
            duplicatedTriggers.Add(duplicatedTrigger);
        }

        // Set the duplicated action as the current selection
        _selectedAction = duplicatedAction;
        _actionTriggers = duplicatedTriggers;
        _isNewAction = true;

        Snackbar.Add("Action duplicated. Click Save to create the copy.", Severity.Info);
    }

    private async Task DeleteAction()
    {
        if (_selectedAction == null || !_selectedAction.Id.HasValue) return;

        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Action",
            $"Are you sure you want to delete the action '{_selectedAction.Name}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await ActionService.DeleteActionAsync(_selectedAction.Id.Value);
                Snackbar.Add($"Action '{_selectedAction.Name}' deleted successfully", Severity.Success);
                _selectedAction = null;
                _actionTriggers = new List<TriggerType>();
                await LoadActions();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting action: {ex.Message}", Severity.Error);
            }
        }
    }

    private void CancelEdit()
    {
        _selectedAction = null;
        _actionTriggers = new List<TriggerType>();
        _isNewAction = false;
    }
}
