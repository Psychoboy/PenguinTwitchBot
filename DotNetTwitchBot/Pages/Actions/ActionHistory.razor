@page "/actions/history"
@using DotNetTwitchBot.Bot.Queues
@using DotNetTwitchBot.Bot.Models.Queues
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject IQueueManager QueueManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IActionExecutionLogger ExecutionLogger
@implements IAsyncDisposable

<PageTitle>SPTV Twitch Bot - Action History</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Action Execution History</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">View history of executed actions and their results.</MudText>

    <MudPaper Class="pa-4">
        @if (_treeViewMode)
        {
            <div style="padding: 16px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                    <MudText Typo="Typo.h6">Execution Logs - Tree View</MudText>
                    <div style="display: flex; gap: 8px; align-items: center;">
                        <MudTextField @bind-Value="_searchString" Placeholder="Search by action name" Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"
                                      DebounceInterval="300" OnDebounceIntervalElapsed="FilterLogs" Style="max-width: 300px;"></MudTextField>
                        <MudSelect T="ActionExecutionState?" Value="_filterState" Label="Filter by State" Style="min-width: 150px;"
                                   Dense="true" Margin="Margin.Dense" ValueChanged="OnFilterStateChanged">
                            <MudSelectItem T="ActionExecutionState?" Value="@((ActionExecutionState?)null)">All States</MudSelectItem>
                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Pending">Pending</MudSelectItem>
                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Running">Running</MudSelectItem>
                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Completed">Completed</MudSelectItem>
                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Failed">Failed</MudSelectItem>
                        </MudSelect>
                        <MudToggleIconButton @bind-Toggled="_treeViewMode" 
                                            Icon="@Icons.Material.Filled.TableRows" 
                                            ToggledIcon="@Icons.Material.Filled.AccountTree"
                                            Color="Color.Primary"
                                            Title="@GetViewModeTooltip()" />
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" OnClick="@LoadLogs" />
                    </div>
                </div>
                <MudTreeView T="object" Hover="true" Dense="true" Style="max-height: 70vh; overflow-y: auto;">
                    @foreach (var treeNode in _treeNodes)
                    {
                        <MudTreeViewItem T="object" Value="treeNode" @bind-Expanded="treeNode.IsExpanded">
                            <Content>
                                <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                                    <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" Size="Size.Small" />
                                    <MudText Typo="Typo.body1" Style="font-weight: 500;">@treeNode.ActionName</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(treeNode.State)">@treeNode.State.ToString()</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@treeNode.QueueName</MudChip>
                                    @if (treeNode.Duration.HasValue)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@FormatDuration(treeNode.Duration.Value)</MudChip>
                                    }
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-left: auto;">@treeNode.EnqueuedAt.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" 
                                               OnClick="@(() => ViewDetailsFromTree(treeNode.LogId))"
                                               StartIcon="@Icons.Material.Filled.Visibility">Details</MudButton>
                                </div>
                            </Content>
                            <ChildContent>
                                @foreach (var subAction in treeNode.SubActions)
                                {
                                    <MudTreeViewItem T="object" Value="subAction" @bind-Expanded="subAction.IsExpanded">
                                        <Content>
                                            <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                                                <MudIcon Icon="@GetSubActionIcon(subAction.Type)" Color="Color.Secondary" Size="Size.Small" />
                                                <MudText Typo="Typo.body2">#@subAction.Index - @subAction.Type</MudText>
                                                @if (!string.IsNullOrEmpty(subAction.Description))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">(@subAction.Description)</MudText>
                                                }
                                                <MudChip T="string" Size="Size.Small" Color="@GetSubActionStateColor(subAction.State)">@subAction.State</MudChip>
                                                @if (!string.IsNullOrEmpty(subAction.ErrorMessage))
                                                {
                                                    <MudTooltip Text="@subAction.ErrorMessage">
                                                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                                                    </MudTooltip>
                                                }
                                                @if (subAction.Messages.Count > 0)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@subAction.Messages.Count messages</MudChip>
                                                }
                                            </div>
                                        </Content>
                                        <ChildContent>
                                            @if (subAction.Messages.Count > 0)
                                            {
                                                @foreach (var message in subAction.Messages)
                                                {
                                                    <div style="padding: 4px 0 4px 24px;">
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@message</MudText>
                                                    </div>
                                                }
                                            }
                                            @if (subAction.ChildAction != null)
                                            {
                                                @RenderActionTreeNode(subAction.ChildAction)
                                            }
                                        </ChildContent>
                                    </MudTreeViewItem>
                                }
                            </ChildContent>
                        </MudTreeViewItem>
                    }
                </MudTreeView>
                @if (_treeNodes.Count == 0 && !_loading)
                {
                    <MudText Class="mt-4">No execution logs found.</MudText>
                }
            </div>
        }
        else
        {
            <MudTable Items="@_executionLogs" Hover="true" Dense="true" Loading="@_loading" LoadingProgressColor="Color.Primary"
                      T="ActionExecutionLog" FixedHeader="true" Height="70vh">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Execution Logs</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString" Placeholder="Search by action name" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"
                                  DebounceInterval="300" OnDebounceIntervalElapsed="FilterLogs"></MudTextField>
                    <MudSelect T="ActionExecutionState?" Value="_filterState" Label="Filter by State" Class="ml-4" Style="min-width: 150px;"
                               Dense="true" Margin="Margin.Dense" ValueChanged="OnFilterStateChanged">
                        <MudSelectItem T="ActionExecutionState?" Value="@((ActionExecutionState?)null)">All States</MudSelectItem>
                        <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Pending">Pending</MudSelectItem>
                        <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Running">Running</MudSelectItem>
                        <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Completed">Completed</MudSelectItem>
                        <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Failed">Failed</MudSelectItem>
                    </MudSelect>
                    <MudToggleIconButton @bind-Toggled="_treeViewMode" 
                                        Icon="@Icons.Material.Filled.TableRows" 
                                        ToggledIcon="@Icons.Material.Filled.AccountTree"
                                        Color="Color.Primary"
                                        Title="@GetViewModeTooltip()"
                                        Class="ml-2" />
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" OnClick="@LoadLogs" Class="ml-2" />
                </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>State</MudTh>
                <MudTh Style="text-align: right;">Variables</MudTh>
                <MudTh Style="text-align: right;">Duration</MudTh>
                <MudTh>Queue</MudTh>
                <MudTh>Queued At</MudTh>
                <MudTh>Started At</MudTh>
                <MudTh>Ended At</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        @if (context.ParentActionLogId.HasValue)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CallReceived" Color="Color.Secondary" Size="Size.Small" Title="Child Action" />
                        }
                        @if (context.ChildActionLogIds.Count > 0)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CallMade" Color="Color.Info" Size="Size.Small" Title="Has Child Actions" />
                        }
                        <MudText Typo="Typo.body2">@context.ActionName</MudText>
                        @if (context.SubActionLogs.Count > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                @context.SubActionLogs.Count SubActions
                            </MudChip>
                        }
                        @if (context.ChildActionLogIds.Count > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                @context.ChildActionLogIds.Count @(context.ChildActionLogIds.Count == 1 ? "Child" : "Children")
                            </MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="State">
                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(context.State)">
                        @context.State.ToString()
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Variables" Style="text-align: right;">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">
                        @context.VariablesBefore.Count/@context.VariablesAfter?.Count
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Duration" Style="text-align: right;">
                    @if (context.TotalTime.HasValue)
                    {
                        <MudText Typo="Typo.body2">@FormatDuration(context.TotalTime.Value)</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Queue">
                    <MudChip T="string" Size="Size.Small" Color="@(context.QueueName == "Default" ? Color.Primary : Color.Default)">
                        @context.QueueName
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Queued At">
                    <MudText Typo="Typo.body2">@context.EnqueuedAt.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText>
                </MudTd>
                <MudTd DataLabel="Started At">
                    @if (context.StartedAt.HasValue)
                    {
                        <MudText Typo="Typo.body2">@context.StartedAt.Value.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Ended At">
                    @if (context.CompletedAt.HasValue)
                    {
                        <MudText Typo="Typo.body2">@context.CompletedAt.Value.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" 
                               OnClick="@(() => ViewDetails(context))"
                               StartIcon="@Icons.Material.Filled.Visibility">
                        View Details
                    </MudButton>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No execution logs found.</MudText>
            </NoRecordsContent>
        </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private RenderFragment<ActionExecutionTreeNode> RenderActionTreeNode => (node) => __builder =>
    {
        <MudTreeViewItem T="object" Value="node" @bind-Expanded="node.IsExpanded">
            <Content>
                <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                    <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.body1" Style="font-weight: 500;">@node.ActionName</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(node.State)">@node.State.ToString()</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@node.QueueName</MudChip>
                    @if (node.Duration.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@FormatDuration(node.Duration.Value)</MudChip>
                    }
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-left: auto;">@node.EnqueuedAt.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" 
                               OnClick="@(() => ViewDetailsFromTree(node.LogId))"
                               StartIcon="@Icons.Material.Filled.Visibility">Details</MudButton>
                </div>
            </Content>
            <ChildContent>
                @foreach (var subAction in node.SubActions)
                {
                    <MudTreeViewItem T="object" Value="subAction" @bind-Expanded="subAction.IsExpanded">
                        <Content>
                            <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                                <MudIcon Icon="@GetSubActionIcon(subAction.Type)" Color="Color.Secondary" Size="Size.Small" />
                                <MudText Typo="Typo.body2">#@subAction.Index - @subAction.Type</MudText>
                                @if (!string.IsNullOrEmpty(subAction.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">(@subAction.Description)</MudText>
                                }
                                <MudChip T="string" Size="Size.Small" Color="@GetSubActionStateColor(subAction.State)">@subAction.State</MudChip>
                                @if (!string.IsNullOrEmpty(subAction.ErrorMessage))
                                {
                                    <MudTooltip Text="@subAction.ErrorMessage">
                                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                                    </MudTooltip>
                                }
                                @if (subAction.Messages.Count > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@subAction.Messages.Count messages</MudChip>
                                }
                            </div>
                        </Content>
                        <ChildContent>
                            @if (subAction.Messages.Count > 0)
                            {
                                @foreach (var message in subAction.Messages)
                                {
                                    <div style="padding: 4px 0 4px 24px;">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@message</MudText>
                                    </div>
                                }
                            }
                            @if (subAction.ChildAction != null)
                            {
                                @RenderActionTreeNode(subAction.ChildAction)
                            }
                        </ChildContent>
                    </MudTreeViewItem>
                }
            </ChildContent>
        </MudTreeViewItem>
    };
}

@code {
    private List<ActionExecutionLog> _executionLogs = new();
    private List<ActionExecutionLog> _allLogs = new();
    private List<ActionExecutionTreeNode> _treeNodes = new();
    private bool _loading = true;
    private HubConnection? _hubConnection;
    private bool _disposed;
    private string _searchString = "";
    private ActionExecutionState? _filterState = null;
    private bool _treeViewMode = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/mainHub"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<ActionExecutionLog>("ActionLogUpdated", async (log) =>
            {
                await InvokeAsync(() =>
                {
                    // Update or add the log in our collection
                    var existingLogIndex = _allLogs.FindIndex(l => l.Id == log.Id);
                    if (existingLogIndex >= 0)
                    {
                        _allLogs[existingLogIndex] = log;
                    }
                    else
                    {
                        _allLogs.Insert(0, log);
                        // Keep only last 100 logs
                        if (_allLogs.Count > 100)
                        {
                            _allLogs = _allLogs.Take(100).ToList();
                        }
                    }

                    FilterLogs();
                    StateHasChanged();
                });
            });

            try
            {
                await _hubConnection.StartAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lost connection to bot. Data may be inaccurate until refresh. Error: {ex.Message}", Severity.Warning);
            }
        }
    }

    private async Task LoadLogs()
    {
        if (_disposed) return;

        _loading = true;
        try
        {
            // Get recent logs (last 100)
            _allLogs = QueueManager.ExecutionLogger.GetRecentLogs(100).ToList();
            FilterLogs();
        }
        catch (Exception ex)
        {
            if (!_disposed)
            {
                Snackbar.Add($"Error loading execution logs: {ex.Message}", Severity.Error);
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void FilterLogs()
    {
        var filtered = _allLogs.AsEnumerable();

        // Filter by search string
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            filtered = filtered.Where(log => log.ActionName.Contains(_searchString, StringComparison.OrdinalIgnoreCase));
        }

        // Filter by state
        if (_filterState.HasValue)
        {
            filtered = filtered.Where(log => log.State == _filterState.Value);
        }

        _executionLogs = filtered.OrderByDescending(log => log.EnqueuedAt).ToList();

        // Build tree nodes from top-level actions (no parent)
        var topLevelLogs = _executionLogs.Where(log => !log.ParentActionLogId.HasValue).ToList();
        _treeNodes = topLevelLogs.Select(log => BuildActionTree(log)).ToList();
    }

    private void OnFilterStateChanged(ActionExecutionState? value)
    {
        _filterState = value;
        FilterLogs();
    }

    private async Task ViewDetails(ActionExecutionLog log)
    {
        var parameters = new DialogParameters<ActionVariablesDialog>
        {
            { x => x.Log, log }
        };

        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true, 
            MaxWidth = MaxWidth.Large, 
            FullWidth = true 
        };

        await DialogService.ShowAsync<ActionVariablesDialog>("Action Execution Details", parameters, options);
    }

    private Color GetStateColor(ActionExecutionState state)
    {
        return state switch
        {
            ActionExecutionState.Pending => Color.Warning,
            ActionExecutionState.Running => Color.Info,
            ActionExecutionState.Completed => Color.Success,
            ActionExecutionState.Failed => Color.Error,
            _ => Color.Default
        };
    }

    private string GetViewModeTooltip()
    {
        return _treeViewMode ? "Switch to Table View" : "Switch to Tree View";
    }

    private string FormatDuration(TimeSpan duration)
    {
        var totalMilliseconds = duration.TotalMilliseconds;

        if (totalMilliseconds < 1000)
            return $"{totalMilliseconds:F0}ms";

        if (duration.TotalSeconds < 60)
            return $"{duration.TotalSeconds:F2}s";

        return $"{duration.TotalMinutes:F2}m";
    }

    private ActionExecutionTreeNode BuildActionTree(ActionExecutionLog log, int level = 0)
    {
        var node = new ActionExecutionTreeNode
        {
            LogId = log.Id,
            ActionName = log.ActionName,
            State = log.State,
            QueueName = log.QueueName,
            EnqueuedAt = log.EnqueuedAt,
            StartedAt = log.StartedAt,
            CompletedAt = log.CompletedAt,
            Duration = log.TotalTime,
            ErrorMessage = log.ErrorMessage,
            VariableCount = log.VariablesBefore.Count,
            Level = level,
            IsExpanded = level < 2,
            ParentActionLogId = log.ParentActionLogId
        };

        // Build subaction nodes
        var subActionLogs = ExecutionLogger.GetSubActionLogsSnapshot(log.Id);
        foreach (var subActionLog in subActionLogs.OrderBy(s => s.Depth))
        {
            var subNode = new SubActionTreeNode
            {
                Index = subActionLog.Depth,
                Type = subActionLog.SubActionType,
                Description = subActionLog.Description,
                State = subActionLog.IsSuccess ? "Success" : (subActionLog.CompletedAt.HasValue ? "Failed" : "Running"),
                StartedAt = subActionLog.StartedAt,
                CompletedAt = subActionLog.CompletedAt,
                ErrorMessage = subActionLog.ErrorMessage,
                Messages = ExecutionLogger.GetSubActionMessagesSnapshot(log.Id, subActionLog.Depth),
                IsExpanded = level < 1
            };

            // If this subaction has a child action, recursively build that tree
            if (subActionLog.ChildActionLogId.HasValue)
            {
                var childLog = ExecutionLogger.GetLogById(subActionLog.ChildActionLogId.Value);
                if (childLog != null)
                {
                    subNode.ChildAction = BuildActionTree(childLog, level + 1);
                }
            }

            node.SubActions.Add(subNode);
        }

        return node;
    }

    private async Task ViewDetailsFromTree(Guid logId)
    {
        var log = ExecutionLogger.GetLogById(logId);
        if (log != null)
        {
            await ViewDetails(log);
        }
    }

    private string GetSubActionIcon(string subActionType)
    {
        return subActionType switch
        {
            "SendMessage" => Icons.Material.Filled.Message,
            "Delay" => Icons.Material.Filled.Timer,
            "LogicIfElse" => Icons.Material.Filled.AccountTree,
            "ExecuteAction" => Icons.Material.Filled.PlayArrow,
            "ExternalApi" => Icons.Material.Filled.Api,
            "ToggleCommandDisabled" => Icons.Material.Filled.ToggleOn,
            "TimerGroupSetEnabledState" => Icons.Material.Filled.Timer,
            "Break" => Icons.Material.Filled.Stop,
            _ => Icons.Material.Filled.Extension
        };
    }

    private Color GetSubActionStateColor(string state)
    {
        return state switch
        {
            "Success" => Color.Success,
            "Failed" => Color.Error,
            "Running" => Color.Info,
            _ => Color.Default
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (!_disposed)
        {
            _disposed = true;

            if (_hubConnection is not null)
            {
                await _hubConnection.DisposeAsync();
                _hubConnection = null;
            }
        }
    }
}
