@using DotNetTwitchBot.Bot.Models.Actions.SubActions
@using MudBlazor
@using Microsoft.AspNetCore.Components.Rendering

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            @if (_currentStep == WizardStep.SelectType)
            {
                <MudText Typo="Typo.h6">Select SubAction Type</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Choose the type of action you want to add</MudText>
                
                <MudTextField @bind-Value="_searchText" Placeholder="Search subactions..." 
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                              Immediate="true" Margin="Margin.Dense" />

                <div style="max-height: 400px; overflow-y: auto;">
                    <MudList T="string">
                        @foreach (var type in GetFilteredSubActionTypes())
                        {
                            <MudListItem T="string" OnClick="@(() => SelectType(type))">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@GetIconForType(type)" Color="@GetColorForType(type)" />
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body1"><b>@GetDisplayName(type)</b></MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@GetDescription(type)</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                </div>
            }
            else if (_currentStep == WizardStep.Configure)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudIcon Icon="@GetIconForType(_selectedType)" Color="@GetColorForType(_selectedType)" />
                    <MudText Typo="Typo.h6">Configure @GetDisplayName(_selectedType)</MudText>
                </MudStack>

                @RenderConfiguration()
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        @if (_currentStep == WizardStep.Configure)
        {
            <MudButton OnClick="BackToTypeSelection" StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
        }
        <MudButton OnClick="Cancel">Cancel</MudButton>
        @if (_currentStep == WizardStep.Configure)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" 
                       Disabled="@(!IsValid())">
                @(IsEditMode ? "Update" : "Add") SubAction
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] 
    public SubActionType? ExistingSubAction { get; set; }

    private enum WizardStep
    {
        SelectType,
        Configure
    }

    private WizardStep _currentStep = WizardStep.SelectType;
    private SubActionTypes _selectedType = SubActionTypes.None;
    private string _searchText = "";
    private bool IsEditMode => ExistingSubAction != null;

    // Configuration fields
    private string _text = "";
    private string _file = "";
    private bool _enabled = true;
    
    // SendMessage specific
    private bool _useBot = true;
    private bool _fallBack = true;
    private bool _streamOnly = true;
    
    // Alert specific
    private int _duration = 3;
    private float _volume = 0.8f;
    private string _css = "";
    
    // PlaySound specific
    // Note: PlaySoundType uses File property from base class

    // RandomInt specific
    private int _min = 0;
    private int _max = 100;
    
    // WriteFile specific
    private bool _append = false;
    
    // ExternalApi specific
    private string _httpMethod = "GET";
    private string _headers = "Accept: text/plain";

    protected override void OnInitialized()
    {
        if (IsEditMode && ExistingSubAction != null)
        {
            _selectedType = ExistingSubAction.SubActionTypes;
            _currentStep = WizardStep.Configure;
            LoadExistingSubAction(ExistingSubAction);
        }
    }

    private void LoadExistingSubAction(SubActionType subAction)
    {
        _text = subAction.Text;
        _file = subAction.File;
        _enabled = subAction.Enabled;

        switch (subAction)
        {
            case SendMessageType sm:
                _useBot = sm.UseBot;
                _fallBack = sm.FallBack;
                _streamOnly = sm.StreamOnly;
                break;
            case AlertType alert:
                _duration = alert.Duration;
                _volume = alert.Volume;
                _css = alert.CSS;
                break;
            case PlaySoundType sound:
                // PlaySoundType only uses File property
                break;
            case RandomIntType random:
                _min = random.Min;
                _max = random.Max;
                break;
            case WriteFileType writeFile:
                _append = writeFile.Append;
                break;
            case ExternalApiType api:
                _httpMethod = api.HttpMethod;
                _headers = api.Headers;
                break;
        }
    }

    private List<SubActionTypes> GetFilteredSubActionTypes()
    {
        var types = Enum.GetValues<SubActionTypes>()
            .Where(t => t != SubActionTypes.None)
            .ToList();

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            types = types.Where(t => 
                GetDisplayName(t).Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                GetDescription(t).Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }

        return types;
    }

    private void SelectType(SubActionTypes type)
    {
        _selectedType = type;
        _currentStep = WizardStep.Configure;
    }

    private void BackToTypeSelection()
    {
        _currentStep = WizardStep.SelectType;
    }

    private RenderFragment RenderConfiguration() => builder =>
    {
        switch (_selectedType)
        {
            case SubActionTypes.SendMessage:
            case SubActionTypes.ReplyToMessage:
                RenderSendMessageConfig(builder);
                break;
            case SubActionTypes.Alert:
                RenderAlertConfig(builder);
                break;
            case SubActionTypes.PlaySound:
                RenderPlaySoundConfig(builder);
                break;
            case SubActionTypes.RandomInt:
                RenderRandomIntConfig(builder);
                break;
            case SubActionTypes.WriteFile:
                RenderWriteFileConfig(builder);
                break;
            case SubActionTypes.ExternalApi:
                RenderExternalApiConfig(builder);
                break;
            case SubActionTypes.CurrentTime:
            case SubActionTypes.Followage:
            case SubActionTypes.Uptime:
            case SubActionTypes.WatchTime:
                RenderSimpleTextConfig(builder, "Format string (e.g., HH:mm:ss for time)");
                break;
            default:
                RenderBasicConfig(builder);
                break;
        }
    };

    private void RenderBasicConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", "Text/Value");
        builder.AddAttribute(2, "Value", _text);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _text = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "Lines", 3);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(10);
        builder.AddAttribute(11, "Label", "Enabled");
        builder.AddAttribute(12, "Value", _enabled);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(14, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderSimpleTextConfig(RenderTreeBuilder builder, string label)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", label);
        builder.AddAttribute(2, "Value", _text);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _text = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "HelperText", "Use variables like %user%, %target%, etc.");
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(10);
        builder.AddAttribute(11, "Label", "Enabled");
        builder.AddAttribute(12, "Value", _enabled);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(14, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderSendMessageConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", "Message");
        builder.AddAttribute(2, "Value", _text);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _text = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "Lines", 3);
        builder.AddAttribute(6, "Required", true);
        builder.AddAttribute(7, "HelperText", "Use variables like %user%, %target%, %random.1-100%, etc.");
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(10);
        builder.AddAttribute(11, "Label", "Use Bot Account");
        builder.AddAttribute(12, "Value", _useBot);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _useBot = v));
        builder.AddAttribute(14, "Color", Color.Primary);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(20);
        builder.AddAttribute(21, "Label", "Fall Back to Broadcaster");
        builder.AddAttribute(22, "Value", _fallBack);
        builder.AddAttribute(23, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _fallBack = v));
        builder.AddAttribute(24, "Color", Color.Primary);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(30);
        builder.AddAttribute(31, "Label", "Stream Only");
        builder.AddAttribute(32, "Value", _streamOnly);
        builder.AddAttribute(33, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _streamOnly = v));
        builder.AddAttribute(34, "Color", Color.Primary);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(40);
        builder.AddAttribute(41, "Label", "Enabled");
        builder.AddAttribute(42, "Value", _enabled);
        builder.AddAttribute(43, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(44, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderAlertConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", "Alert Text");
        builder.AddAttribute(2, "Value", _text);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _text = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "Required", true);
        builder.CloseComponent();

        builder.OpenComponent<MudTextField<string>>(10);
        builder.AddAttribute(11, "Label", "Image/Video File");
        builder.AddAttribute(12, "Value", _file);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _file = v));
        builder.AddAttribute(14, "Variant", Variant.Outlined);
        builder.AddAttribute(15, "HelperText", "Path to media file");
        builder.CloseComponent();

        builder.OpenComponent<MudNumericField<int>>(20);
        builder.AddAttribute(21, "Label", "Duration (seconds)");
        builder.AddAttribute(22, "Value", _duration);
        builder.AddAttribute(23, "ValueChanged", EventCallback.Factory.Create<int>(this, v => _duration = v));
        builder.AddAttribute(24, "Variant", Variant.Outlined);
        builder.AddAttribute(25, "Min", 1);
        builder.AddAttribute(26, "Max", 60);
        builder.CloseComponent();

        builder.OpenComponent<MudNumericField<float>>(30);
        builder.AddAttribute(31, "Label", "Volume");
        builder.AddAttribute(32, "Value", _volume);
        builder.AddAttribute(33, "ValueChanged", EventCallback.Factory.Create<float>(this, v => _volume = v));
        builder.AddAttribute(34, "Variant", Variant.Outlined);
        builder.AddAttribute(35, "Min", 0f);
        builder.AddAttribute(36, "Max", 1f);
        builder.AddAttribute(37, "Step", 0.1f);
        builder.CloseComponent();

        builder.OpenComponent<MudTextField<string>>(40);
        builder.AddAttribute(41, "Label", "Custom CSS");
        builder.AddAttribute(42, "Value", _css);
        builder.AddAttribute(43, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _css = v));
        builder.AddAttribute(44, "Variant", Variant.Outlined);
        builder.AddAttribute(45, "Lines", 2);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(50);
        builder.AddAttribute(51, "Label", "Enabled");
        builder.AddAttribute(52, "Value", _enabled);
        builder.AddAttribute(53, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(54, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderPlaySoundConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", "Sound File");
        builder.AddAttribute(2, "Value", _file);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _file = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "Required", true);
        builder.AddAttribute(6, "HelperText", "Path to audio file");
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(10);
        builder.AddAttribute(11, "Label", "Enabled");
        builder.AddAttribute(12, "Value", _enabled);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(14, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderRandomIntConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudNumericField<int>>(0);
        builder.AddAttribute(1, "Label", "Minimum Value");
        builder.AddAttribute(2, "Value", _min);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<int>(this, v => _min = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.CloseComponent();

        builder.OpenComponent<MudNumericField<int>>(10);
        builder.AddAttribute(11, "Label", "Maximum Value");
        builder.AddAttribute(12, "Value", _max);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<int>(this, v => _max = v));
        builder.AddAttribute(14, "Variant", Variant.Outlined);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(20);
        builder.AddAttribute(21, "Label", "Enabled");
        builder.AddAttribute(22, "Value", _enabled);
        builder.AddAttribute(23, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(24, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderWriteFileConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", "File Path");
        builder.AddAttribute(2, "Value", _file);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _file = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "Required", true);
        builder.CloseComponent();

        builder.OpenComponent<MudTextField<string>>(10);
        builder.AddAttribute(11, "Label", "Content");
        builder.AddAttribute(12, "Value", _text);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _text = v));
        builder.AddAttribute(14, "Variant", Variant.Outlined);
        builder.AddAttribute(15, "Lines", 3);
        builder.AddAttribute(16, "Required", true);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(20);
        builder.AddAttribute(21, "Label", "Append to File");
        builder.AddAttribute(22, "Value", _append);
        builder.AddAttribute(23, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _append = v));
        builder.AddAttribute(24, "Color", Color.Primary);
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(30);
        builder.AddAttribute(31, "Label", "Enabled");
        builder.AddAttribute(32, "Value", _enabled);
        builder.AddAttribute(33, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(34, "Color", Color.Success);
        builder.CloseComponent();
    }

    private void RenderExternalApiConfig(RenderTreeBuilder builder)
    {
        builder.OpenComponent<MudTextField<string>>(0);
        builder.AddAttribute(1, "Label", "URL");
        builder.AddAttribute(2, "Value", _text);
        builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _text = v));
        builder.AddAttribute(4, "Variant", Variant.Outlined);
        builder.AddAttribute(5, "Required", true);
        builder.AddAttribute(6, "HelperText", "Use variables like %user%, %target%, etc.");
        builder.CloseComponent();

        builder.OpenComponent<MudSelect<string>>(10);
        builder.AddAttribute(11, "Label", "HTTP Method");
        builder.AddAttribute(12, "Value", _httpMethod);
        builder.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _httpMethod = v));
        builder.AddAttribute(14, "Variant", Variant.Outlined);
        builder.AddAttribute(15, "ChildContent", CreateMethodSelectItems);
        builder.CloseComponent();

        builder.OpenComponent<MudTextField<string>>(20);
        builder.AddAttribute(21, "Label", "Headers");
        builder.AddAttribute(22, "Value", _headers);
        builder.AddAttribute(23, "ValueChanged", EventCallback.Factory.Create<string>(this, v => _headers = v));
        builder.AddAttribute(24, "Variant", Variant.Outlined);
        builder.AddAttribute(25, "Lines", 2);
        builder.AddAttribute(26, "HelperText", "One header per line (e.g., Accept: text/plain)");
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(30);
        builder.AddAttribute(31, "Label", "Enabled");
        builder.AddAttribute(32, "Value", _enabled);
        builder.AddAttribute(33, "ValueChanged", EventCallback.Factory.Create<bool>(this, v => _enabled = v));
        builder.AddAttribute(34, "Color", Color.Success);
        builder.CloseComponent();
    }

    private RenderFragment CreateMethodSelectItems => __builder =>
    {
        var methods = new[] { "GET", "POST", "PUT", "DELETE", "PATCH" };
        foreach (var method in methods)
        {
            __builder.OpenComponent<MudSelectItem<string>>(0);
            __builder.AddAttribute(1, "Value", method);
            __builder.AddAttribute(2, "ChildContent", (RenderFragment)(__builder2 => __builder2.AddContent(3, method)));
            __builder.CloseComponent();
        }
    };

    private bool IsValid()
    {
        return _selectedType switch
        {
            SubActionTypes.SendMessage or SubActionTypes.ReplyToMessage => !string.IsNullOrWhiteSpace(_text),
            SubActionTypes.Alert => !string.IsNullOrWhiteSpace(_text),
            SubActionTypes.PlaySound => !string.IsNullOrWhiteSpace(_file),
            SubActionTypes.RandomInt => _max > _min,
            SubActionTypes.WriteFile => !string.IsNullOrWhiteSpace(_file) && !string.IsNullOrWhiteSpace(_text),
            SubActionTypes.ExternalApi => !string.IsNullOrWhiteSpace(_text),
            _ => true
        };
    }

    private SubActionType CreateSubAction()
    {
        SubActionType subAction = _selectedType switch
        {
            SubActionTypes.SendMessage => new SendMessageType 
            { 
                UseBot = _useBot, 
                FallBack = _fallBack, 
                StreamOnly = _streamOnly 
            },
            SubActionTypes.ReplyToMessage => new SendMessageType 
            { 
                UseBot = _useBot, 
                FallBack = _fallBack, 
                StreamOnly = _streamOnly,
                SubActionTypes = SubActionTypes.ReplyToMessage
            },
            SubActionTypes.Alert => new AlertType 
            { 
                Duration = _duration, 
                Volume = _volume, 
                CSS = _css 
            },
            SubActionTypes.PlaySound => new PlaySoundType(),
            SubActionTypes.RandomInt => new RandomIntType 
            { 
                Min = _min, 
                Max = _max
            },
            SubActionTypes.WriteFile => new WriteFileType 
            { 
                Append = _append 
            },
            SubActionTypes.ExternalApi => new ExternalApiType 
            { 
                HttpMethod = _httpMethod, 
                Headers = _headers 
            },
            SubActionTypes.CurrentTime => new CurrentTimeType(),
            SubActionTypes.Followage => new FollowAgeType(),
            SubActionTypes.Uptime => new UptimeType(),
            SubActionTypes.WatchTime => new WatchTimeType(),
            _ => throw new InvalidOperationException($"Unsupported SubAction type: {_selectedType}")
        };

        subAction.Text = _text;
        subAction.File = _file;
        subAction.Enabled = _enabled;

        if (IsEditMode && ExistingSubAction != null)
        {
            subAction.Id = ExistingSubAction.Id;
            subAction.Index = ExistingSubAction.Index;
        }
        else
        {
            // New SubAction - ID will be assigned by the repository
            subAction.Id = 0;
        }

        return subAction;
    }

    private void Submit()
    {
        if (!IsValid()) return;
        
        var subAction = CreateSubAction();
        MudDialog.Close(DialogResult.Ok(subAction));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private string GetDisplayName(SubActionTypes type) => type switch
    {
        SubActionTypes.Alert => "Alert",
        SubActionTypes.PlaySound => "Play Sound",
        SubActionTypes.RandomInt => "Random Number",
        SubActionTypes.WriteFile => "Write File",
        SubActionTypes.CurrentTime => "Current Time",
        SubActionTypes.Followage => "Follow Age",
        SubActionTypes.Uptime => "Stream Uptime",
        SubActionTypes.ExternalApi => "External API Call",
        SubActionTypes.WatchTime => "Watch Time",
        SubActionTypes.SendMessage => "Send Message",
        SubActionTypes.ReplyToMessage => "Reply to Message",
        _ => type.ToString()
    };

    private string GetDescription(SubActionTypes type) => type switch
    {
        SubActionTypes.Alert => "Show an alert with text, image, or video",
        SubActionTypes.PlaySound => "Play an audio file",
        SubActionTypes.RandomInt => "Generate a random number for use in actions",
        SubActionTypes.WriteFile => "Write or append text to a file",
        SubActionTypes.CurrentTime => "Get the current time in a specified format",
        SubActionTypes.Followage => "Get how long a user has been following",
        SubActionTypes.Uptime => "Get how long the stream has been live",
        SubActionTypes.ExternalApi => "Call an external API endpoint",
        SubActionTypes.WatchTime => "Get a viewer's watch time",
        SubActionTypes.SendMessage => "Send a message to chat",
        SubActionTypes.ReplyToMessage => "Reply to the triggering message",
        _ => "Configure this subaction type"
    };

    private string GetIconForType(SubActionTypes type) => type switch
    {
        SubActionTypes.Alert => Icons.Material.Filled.Notifications,
        SubActionTypes.PlaySound => Icons.Material.Filled.VolumeUp,
        SubActionTypes.RandomInt => Icons.Material.Filled.Casino,
        SubActionTypes.WriteFile => Icons.Material.Filled.Save,
        SubActionTypes.CurrentTime => Icons.Material.Filled.Schedule,
        SubActionTypes.Followage => Icons.Material.Filled.Favorite,
        SubActionTypes.Uptime => Icons.Material.Filled.Timer,
        SubActionTypes.ExternalApi => Icons.Material.Filled.Api,
        SubActionTypes.WatchTime => Icons.Material.Filled.Visibility,
        SubActionTypes.SendMessage => Icons.Material.Filled.Message,
        SubActionTypes.ReplyToMessage => Icons.Material.Filled.Reply,
        _ => Icons.Material.Filled.Extension
    };

    private Color GetColorForType(SubActionTypes type) => type switch
    {
        SubActionTypes.Alert => Color.Error,
        SubActionTypes.PlaySound => Color.Info,
        SubActionTypes.RandomInt => Color.Warning,
        SubActionTypes.WriteFile => Color.Success,
        SubActionTypes.SendMessage => Color.Primary,
        SubActionTypes.ReplyToMessage => Color.Primary,
        SubActionTypes.ExternalApi => Color.Secondary,
        _ => Color.Default
    };
}
