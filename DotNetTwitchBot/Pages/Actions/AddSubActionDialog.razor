    private Color GetColorForType(SubActionTypes type)
    {
        var metadata = SubActionRegistry.GetMetadata(type);
        return metadata?.Color switch
        {
            "Primary" => Color.Primary,
            "Secondary" => Color.Secondary,
            "Success" => Color.Success,
            "Error" => Color.Error,
            "Info" => Color.Info,
            "Warning" => Color.Warning,
            _ => Color.Default
        };
    }
