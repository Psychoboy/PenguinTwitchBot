@using DotNetTwitchBot.Bot.Models.Queues
@using DotNetTwitchBot.Bot.Queues
@using MudBlazor
@inject IActionExecutionLogger ActionExecutionLogger
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.h6" GutterBottom="true">@Log.ActionName</MudText>
                <MudDivider Class="mb-4" />
            </MudItem>

            @if (Log.ParentActionLogId.HasValue && ParentLog != null)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <MudIcon Icon="@Icons.Material.Filled.CallReceived" Size="Size.Small" />
                            <MudText Typo="Typo.body2">
                                This action was called by:
                                <MudLink Color="Color.Primary" OnClick="@(() => OpenParentAction())" Style="cursor: pointer; text-decoration: underline;">
                                    <strong>@ParentLog.ActionName</strong>
                                </MudLink>
                            </MudText>
                        </div>
                    </MudAlert>
                </MudItem>
            }

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">State</MudText>
                <MudChip T="string" Size="Size.Small" Color="@GetStateColor()">@Log.State.ToString()</MudChip>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Queue</MudText>
                <MudChip T="string" Size="Size.Small" Color="@(Log.QueueName == "Default" ? Color.Primary : Color.Default)">
                    @Log.QueueName
                </MudChip>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Queued At</MudText>
                <MudText Typo="Typo.body2">@Log.EnqueuedAt.ToLocalTime().ToString("g")</MudText>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Started At</MudText>
                <MudText Typo="Typo.body2">
                    @(Log.StartedAt.HasValue ? Log.StartedAt.Value.ToLocalTime().ToString("g") : "Not started")
                </MudText>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Completed At</MudText>
                <MudText Typo="Typo.body2">
                    @(Log.CompletedAt.HasValue ? Log.CompletedAt.Value.ToLocalTime().ToString("g") : "Not completed")
                </MudText>
            </MudItem>

            @if (Log.WaitTime.HasValue)
            {
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Time to Start</MudText>
                    <MudText Typo="Typo.body2">@FormatDuration(Log.WaitTime.Value)</MudText>
                </MudItem>
            }

            @if (Log.ExecutionDuration.HasValue)
            {
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Execution Time</MudText>
                    <MudText Typo="Typo.body2">@FormatDuration(Log.ExecutionDuration.Value)</MudText>
                </MudItem>
            }

            @if (Log.TotalTime.HasValue)
            {
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Duration</MudText>
                    <MudText Typo="Typo.body2">@FormatDuration(Log.TotalTime.Value)</MudText>
                </MudItem>
            }

            @if (!string.IsNullOrEmpty(Log.ErrorMessage))
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Error" Dense="true">
                        <MudText Typo="Typo.subtitle2">Error Message</MudText>
                        <MudText Typo="Typo.body2">@Log.ErrorMessage</MudText>
                    </MudAlert>
                </MudItem>
            }

            @if (SubActionLogsSnapshot.Any())
            {
                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">SubAction Execution Flow (@SubActionLogsSnapshot.Count)</MudText>
                </MudItem>


                <MudItem xs="12">
                    <MudPaper Class="pa-2" Elevation="0" Style="background-color: var(--mud-palette-background-grey); max-height: 400px; overflow-y: auto;">
                        @foreach (var subAction in SubActionLogsSnapshot)
                        {
                            <MudPaper Class="pa-3 mb-2" Elevation="1" Style="@GetSubActionIndentStyle(subAction.Depth)">
                                <MudGrid Spacing="1">
                                    <MudItem xs="12">
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            @if (subAction.IsSuccess)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                                            }
                                            <MudText Typo="Typo.body1"><strong>@subAction.SubActionType</strong></MudText>
                                            @if (!string.IsNullOrEmpty(subAction.Description))
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">- @subAction.Description</MudText>
                                            }
                                            @if (subAction.Duration.HasValue)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@FormatDuration(subAction.Duration.Value)</MudChip>
                                            }
                                        </div>
                                    </MudItem>

                                    @if (!subAction.IsSuccess && !string.IsNullOrEmpty(subAction.ErrorMessage))
                                    {
                                        <MudItem xs="12">
                                            <MudAlert Severity="Severity.Error" Dense="true" Class="my-1">
                                                @subAction.ErrorMessage
                                            </MudAlert>
                                        </MudItem>
                                    }

                                    @if (subAction.Messages.Any())
                                    {
                                        <MudItem xs="12">
                                            <MudPaper Class="pa-2 mt-1" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                                                @foreach (var message in subAction.Messages)
                                                {
                                                    <div style="display: flex; align-items: start; gap: 4px; margin-bottom: 4px;">
                                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Secondary" Style="margin-top: 2px;" />
                                                        <MudText Typo="Typo.body2" Style="flex: 1;">@message</MudText>
                                                    </div>
                                                }
                                            </MudPaper>
                                        </MudItem>
                                    }

                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Started: @subAction.StartedAt.ToLocalTime().ToString("HH:mm:ss.fff")
                                            @if (subAction.CompletedAt.HasValue)
                                            {
                                                <text> | Completed: @subAction.CompletedAt.Value.ToLocalTime().ToString("HH:mm:ss.fff")</text>
                                            }
                                        </MudText>
                                    </MudItem>

                                    @if (subAction.ChildActionLogId.HasValue)
                                    {
                                        var childLog = ActionExecutionLogger.GetLogById(subAction.ChildActionLogId.Value);
                                        if (childLog != null)
                                        {
                                            <MudItem xs="12">
                                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                                    <div style="display: flex; align-items: center; gap: 8px;">
                                                        <MudIcon Icon="@Icons.Material.Filled.CallMade" Size="Size.Small" />
                                                        <MudText Typo="Typo.body2">
                                                            This subaction spawned a child action:
                                                            <MudLink Color="Color.Primary" OnClick="@(() => OpenChildAction(childLog))" Style="cursor: pointer; text-decoration: underline;">
                                                                <strong>@childLog.ActionName</strong>
                                                            </MudLink>
                                                        </MudText>
                                                        <MudChip T="string" Size="Size.Small" Color="@GetStateColor(childLog.State)">
                                                            @childLog.State.ToString()
                                                        </MudChip>
                                                    </div>
                                                </MudAlert>
                                            </MudItem>
                                        }
                                    }
                                </MudGrid>
                            </MudPaper>
                        }
                    </MudPaper>
                </MudItem>
            }

            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" GutterBottom="true">Variables Before Execution (@Log.VariablesBefore.Count)</MudText>
            </MudItem>

            @if (Log.VariablesBefore.Any())
            {
                <MudItem xs="12">
                    <MudTable Items="@Log.VariablesBefore" Hover="true" Dense="true" Striped="true" FixedHeader="true" Height="300px">
                        <HeaderContent>
                            <MudTh>Key</MudTh>
                            <MudTh>Value</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Key">
                                <MudText Typo="Typo.body2"><strong>@context.Key</strong></MudText>
                            </MudTd>
                            <MudTd DataLabel="Value">
                                <MudText Typo="Typo.body2" Style="word-break: break-word;">@context.Value</MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true">
                        No variables were passed to this action.
                    </MudAlert>
                </MudItem>
            }

            @if (Log.VariablesAfter != null)
            {
                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Variables After Execution (@Log.VariablesAfter.Count)</MudText>
                </MudItem>

                @if (Log.VariablesAfter.Any())
                {
                    <MudItem xs="12">
                        <MudTable Items="@Log.VariablesAfter" Hover="true" Dense="true" Striped="true" FixedHeader="true" Height="300px">
                            <HeaderContent>
                                <MudTh>Key</MudTh>
                                <MudTh>Value</MudTh>
                                <MudTh>Changed</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Key">
                                    <MudText Typo="Typo.body2"><strong>@context.Key</strong></MudText>
                                </MudTd>
                                <MudTd DataLabel="Value">
                                    <MudText Typo="Typo.body2" Style="word-break: break-word;">@context.Value</MudText>
                                </MudTd>
                                <MudTd DataLabel="Changed">
                                    @if (IsVariableChanged(context.Key, context.Value))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Modified</MudChip>
                                    }
                                    else if (!Log.VariablesBefore.ContainsKey(context.Key))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">New</MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                }
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ActionExecutionLog Log { get; set; } = null!;

    private ActionExecutionLog? ParentLog { get; set; }
    private List<SubActionExecutionLog> SubActionLogsSnapshot { get; set; } = new();

    protected override void OnInitialized()
    {
        if (Log.ParentActionLogId.HasValue)
        {
            ParentLog = ActionExecutionLogger.GetLogById(Log.ParentActionLogId.Value);
        }

        // Create thread-safe snapshot for UI rendering
        SubActionLogsSnapshot = ActionExecutionLogger.GetSubActionLogsSnapshot(Log.Id);
    }

    private Color GetStateColor()
    {
        return GetStateColor(Log.State);
    }

    private Color GetStateColor(ActionExecutionState state)
    {
        return state switch
        {
            ActionExecutionState.Pending => Color.Warning,
            ActionExecutionState.Running => Color.Info,
            ActionExecutionState.Completed => Color.Success,
            ActionExecutionState.Failed => Color.Error,
            _ => Color.Default
        };
    }

    private string FormatDuration(TimeSpan duration)
    {
        var totalMilliseconds = duration.TotalMilliseconds;

        if (totalMilliseconds < 1000)
            return $"{totalMilliseconds:F0}ms";

        if (duration.TotalSeconds < 60)
            return $"{duration.TotalSeconds:F2}s";

        return $"{duration.TotalMinutes:F2}m";
    }

    private string GetSubActionIndentStyle(int depth)
    {
        var leftMargin = depth * 20;
        return $"margin-left: {leftMargin}px; border-left: 2px solid var(--mud-palette-{GetDepthColor(depth)});";
    }

    private string GetDepthColor(int depth)
    {
        return (depth % 4) switch
        {
            0 => "primary",
            1 => "secondary",
            2 => "tertiary",
            3 => "info",
            _ => "primary"
        };
    }

    private bool IsVariableChanged(string key, string afterValue)
    {
        if (!Log.VariablesBefore.TryGetValue(key, out var beforeValue))
            return false; // New variable

        return beforeValue != afterValue;
    }

    private async Task OpenParentAction()
    {
        if (ParentLog != null)
        {
            // Close current dialog first
            MudDialog.Close();

            var parameters = new DialogParameters<ActionVariablesDialog>
            {
                { x => x.Log, ParentLog }
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true
            };

            await DialogService.ShowAsync<ActionVariablesDialog>($"Action Details: {ParentLog.ActionName}", parameters, options);
        }
    }

    private async Task OpenChildAction(ActionExecutionLog childLog)
    {
        // Close current dialog first
        MudDialog.Close();

        var parameters = new DialogParameters<ActionVariablesDialog>
        {
            { x => x.Log, childLog }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<ActionVariablesDialog>($"Action Details: {childLog.ActionName}", parameters, options);
    }

    private void Close()
    {
        MudDialog.Close();
    }
    }
}
