@page "/giveaway"
@attribute [Authorize(Roles = "Streamer, Editor")]
@using Microsoft.AspNetCore.SignalR.Client
@using DotNetTwitchBot.Bot.Models.Giveaway
@inject DotNetTwitchBot.Bot.Commands.Features.GiveawayFeature GiveawayFeature;
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<Giveaway> logger
@implements IAsyncDisposable

<PageTitle>SPTV Twitch Bot - Giveaway</PageTitle>

<MudContainer Class="pa-4" MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Large" Class="mr-2" />
            Giveaway Manager
        </MudText>

        <MudPaper Elevation="3" Class="pa-4">
            <MudStack Row="true" Spacing="2" Justify="Justify.Center" Class="flex-wrap">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" OnClick="Draw" 
                           StartIcon="@Icons.Material.Filled.Casino">
                    Draw Winner
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="Close" 
                           StartIcon="@Icons.Material.Filled.Lock">
                    Close Giveaway
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Large" OnClick="Reset" 
                           StartIcon="@Icons.Material.Filled.RestartAlt">
                    Reset Giveaway
                </MudButton>
            </MudStack>
        </MudPaper>

        @if (winners.Count > 0)
        {
            <MudPaper Elevation="8" Class="pa-6" Style="border: 4px solid var(--mud-palette-success);">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Justify="Justify.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Celebration" Color="Color.Error" Size="Size.Large" />
                        <MudText Typo="Typo.h3" Color="Color.Success">🎉 WINNERS! 🎉</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Celebration" Color="Color.Error" Size="Size.Large" />
                    </MudStack>

                    <MudGrid Spacing="3" Justify="Justify.Center">
                        @foreach (var winner in winners)
                        {
                            <MudItem xs="12" sm="6" md="@(winners.Count == 1 ? 12 : winners.Count == 2 ? 6 : 4)">
                                <MudCard Elevation="10" Style="border: 4px solid var(--mud-palette-success);">
                                    <MudCardContent Class="pa-6">
                                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Size="Size.Large" />
                                            <MudText Typo="Typo.h3" Color="Color.Success" Align="Align.Center">
                                                <strong>@winner.Username</strong>
                                            </MudText>
                                            <MudDivider />
                                            <MudStack Spacing="2" AlignItems="AlignItems.Start" Style="width: 100%;">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Medium" Color="Color.Primary" />
                                                    <MudText Typo="Typo.h5"><strong>Prize:</strong> @winner.Prize</MudText>
                                                </MudStack>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Medium" Color="Color.Warning" />
                                                    <MudText Typo="Typo.h6"><strong>Tier:</strong> @winner.PrizeTier</MudText>
                                                </MudStack>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudIcon Icon="@(winner.IsFollowing ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)" 
                                                             Size="Size.Medium" 
                                                             Color="@(winner.IsFollowing ? Color.Error : Color.Default)" />
                                                    <MudText Typo="Typo.h6"><strong>Following:</strong> @winner.IsFollowing</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                </MudStack>
            </MudPaper>
        }

        <MudPaper Elevation="5" Class="pa-6">
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Current Prize</MudText>
                </MudStack>
                <MudText Typo="Typo.h3" Align="Align.Center" Color="Color.Primary"><strong>@prize</strong></MudText>
                @if (!string.IsNullOrWhiteSpace(imageUrl))
                {
                    <MudImage Fluid="true" Class="rounded-lg" Src="@imageUrl" Style="max-width: 600px; max-height: 400px; object-fit: contain;" Elevation="3" />
                }
            </MudStack>
        </MudPaper>

        @if (pastWinners == null)
        {
            <MudPaper Elevation="3" Class="pa-4">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-2">Loading past winners...</MudText>
            </MudPaper>
        }
        else
        {
            <MudExpansionPanels>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Info" />
                            <MudText Typo="Typo.h6">Past Winners</MudText>
                            <MudBadge Content="@pastWinners.Count" Color="Color.Info" Overlap="true">
                                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Default" />
                            </MudBadge>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudPaper Elevation="0" Class="pa-2">
                            <MudTable Items="@pastWinners" Dense="true" Hover="true" Striped="true">
                                <HeaderContent>
                                    <MudTh>Winner</MudTh>
                                    <MudTh>Prize</MudTh>
                                    <MudTh>Date</MudTh>
                                    <MudTh>Tier</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Winner">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                            <MudText><strong>@context.Username</strong></MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Prize">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Small" Color="Color.Success" />
                                            <MudText>@context.Prize</MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Date">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Info" />
                                            <MudText>@context.WinningDate.ToShortDateString()</MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Tier">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                            <MudText>@context.PrizeTier</MudText>
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Info">
                                        No past winners yet
                                    </MudAlert>
                                </NoRecordsContent>
                            </MudTable>
                        </MudPaper>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </MudStack>
</MudContainer>
@code {
    private List<GiveawayWinner> winners = new List<GiveawayWinner>();
    private List<GiveawayWinner>? pastWinners;
    private string prize = "";
    private string? imageUrl;
    private HubConnection? hubConnection;
    private CancellationTokenSource? _hubConnectionCts;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject]
    private Bot.Core.Points.IPointsSystem pointsSystem { get; set; } = default!;
    protected override async Task OnInitializedAsync()
    {
        pastWinners = await GiveawayFeature.PastWinners();
        prize = await GiveawayFeature.GetPrize();
        imageUrl = await GiveawayFeature.GetImageUrl();

    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        _hubConnectionCts = new CancellationTokenSource();

        // Configure SignalR with automatic reconnect and retry policy
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/mainhub"), options =>
            {
                // Allow fallback to other transports if WebSockets fail
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false;
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        hubConnection.On<List<GiveawayWinner>>("Winners", (Winners) =>
        {
            winners = Winners;
            InvokeAsync(StateHasChanged);
        });
        hubConnection.On<string>("Prize", (Prize) =>
        {
            prize = Prize;
            InvokeAsync(StateHasChanged);
        });

        // Handle reconnection events
        hubConnection.Reconnecting += error =>
        {
            logger.LogWarning(error, "SignalR connection lost, attempting to reconnect...");
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += connectionId =>
        {
            logger.LogInformation("SignalR reconnected successfully");
            return InvokeAsync(() => Snackbar.Add("Connection restored.", Severity.Success));
        };

        hubConnection.Closed += async error =>
        {
            if (error != null)
            {
                logger.LogError(error, "SignalR connection closed with error");
            }
            // If initial connection never succeeded, attempt to reconnect (unless we're disposing)
            if (hubConnection.State == HubConnectionState.Disconnected && _hubConnectionCts != null && !_hubConnectionCts.Token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), _hubConnectionCts.Token);
                    await hubConnection.StartAsync(_hubConnectionCts.Token);
                    logger.LogDebug("SignalR connection re-established after initial failure");
                }
                catch (OperationCanceledException)
                {
                    // Disposal requested - this is expected
                }
                catch (ObjectDisposedException)
                {
                    // Component disposed during reconnection attempt - this is expected
                }
                catch (Exception ex)
                {
                    logger.LogDebug(ex, "Failed to re-establish SignalR connection");
                }
            }
        };

        // Retry initial connection with exponential backoff
        var retryDelays = new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) };
        var attempt = 0;
        var connected = false;

        while (!connected && attempt < retryDelays.Length)
        {
            try
            {
                if (attempt > 0)
                {
                    await Task.Delay(retryDelays[attempt]);
                }
                await hubConnection.StartAsync();
                connected = true;
            }
            catch (Microsoft.AspNetCore.Http.Connections.Client.TransportFailedException ex)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    logger.LogWarning(ex, "SignalR initial connection failed after {Attempts} attempts", attempt);
                }
                else
                {
                    logger.LogDebug(ex, "SignalR initial connection attempt {Attempt} failed, retrying...", attempt);
                }
            }
            catch (TaskCanceledException)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    Snackbar.Add("Connection attempt cancelled. Page may need refresh.", Severity.Warning);
                    logger.LogWarning("SignalR connection cancelled after {Attempts} attempts", attempt);
                }
            }
            catch (Exception ex)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    logger.LogWarning(ex, "Failed to connect to SignalR hub after {Attempts} attempts", attempt);
                }
                else
                {
                    logger.LogDebug(ex, "SignalR connection attempt {Attempt} failed, retrying...", attempt);
                }
            }
        }

        if (!connected)
        {
            Snackbar.Add("Unable to establish live connection. Data may be delayed.", Severity.Warning);
        }
    }

    private async Task Draw()
    {
        await GiveawayFeature.Draw();
        pastWinners = await GiveawayFeature.PastWinners();
        StateHasChanged();
    }

    private async Task Close()
    {
        await GiveawayFeature.Close();
    }

    private async Task Reset()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
        "Warning",
        "Are you should you want to reset the giveaway?",
        yesText: "Delete!", cancelText: "Cancel");
        if (result != null)
        {
            await GiveawayFeature.Reset();
            await pointsSystem.RemoveAllPointsForGame("GiveawayFeature");
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        // Cancel any pending reconnection attempts
        _hubConnectionCts?.Cancel();

        if (hubConnection is not null)
        {
            try
            {
                // Stop the connection gracefully before disposing
                if (hubConnection.State == HubConnectionState.Connected)
                {
                    await hubConnection.StopAsync();
                }
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                // Log but don't throw - disposal should be silent to user
                logger.LogDebug(ex, "Exception during SignalR connection disposal (non-critical)");
            }
        }

        _hubConnectionCts?.Dispose();
    }
}