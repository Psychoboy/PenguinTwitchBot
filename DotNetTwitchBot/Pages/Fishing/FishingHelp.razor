@page "/fishing/help"
@using DotNetTwitchBot.Bot.Models.Fishing
@using DotNetTwitchBot.Bot.Commands.Fishing

<PageTitle>Fishing Help</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Help" Size="Size.Large" />
        Fishing Guide
    </MudText>
    
    <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
        Learn everything you need to know about the fishing system!
    </MudText>

    @if (helpData == null)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
        <MudText Typo="Typo.body1" Color="Color.Secondary">Loading guide...</MudText>
    }
    else
    {
        <MudStack Spacing="4">
        
        <!-- Getting Started -->
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Success" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Phishing" />
                Getting Started
            </MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body1">
                            <strong>Basic Commands:</strong>
                        </MudText>
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                            <code>!fish</code> - Cast your line and catch a fish!
                        </MudAlert>
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                            <code>Fish 5x</code> - Channel point redemption to fish 5 times!
                        </MudAlert>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudStack Spacing="1">
                        <MudAlert Severity="Severity.Success" Dense="false">
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" Size="Size.Small" />
                                <strong>Pro Tip:</strong> Visit the Shop and Inventory pages on the website to manage your equipment and see detailed statistics!
                            </MudText>
                        </MudAlert>
                        <MudAlert Severity="Severity.Success" Dense="false">
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" Size="Size.Small" />
                                <strong>Hint:</strong> Every fish caught earns pasties! The higher gold, rare, and quality of fish you catch, the more pasties you earn! (Gold is only for fishing)
                            </MudText>
                        </MudAlert>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Fish Quality System -->
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Warning" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Star" />
                Fish Quality & Rewards
            </MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">Star Quality System</MudText>
                    <MudStack Spacing="2">
                        <MudCard Elevation="1" Class="pa-2">
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                <strong>3-Star Fish</strong>
                            </MudText>
                            <MudText Typo="Typo.caption">
                                • @(helpData.Gold.GoldRangePerStar.TryGetValue(3, out var g3) ? g3 : "1.25–1.41x base gold")<br/>
                                • Weight multiplier: @(helpData.StarWeight.WeightMultiplierPerStar.TryGetValue(3, out var w3) ? $"{w3:F1}x" : "1.5x")<br/>
                                • Perfect quality catch!
                            </MudText>
                        </MudCard>
                        <MudCard Elevation="1" Class="pa-2">
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Info" Size="Size.Small" />
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Info" Size="Size.Small" />
                                <MudIcon Icon="@Icons.Material.Filled.StarBorder" Color="Color.Default" Size="Size.Small" />
                                <strong>2-Star Fish</strong>
                            </MudText>
                            <MudText Typo="Typo.caption">
                                • @(helpData.Gold.GoldRangePerStar.TryGetValue(2, out var g2) ? g2 : "1.0–1.25x base gold")<br/>
                                • Weight multiplier: @(helpData.StarWeight.WeightMultiplierPerStar.TryGetValue(2, out var w2) ? $"{w2:F1}x" : "1.2x")<br/>
                                • Good quality catch
                            </MudText>
                        </MudCard>
                        <MudCard Elevation="1" Class="pa-2">
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Default" Size="Size.Small" />
                                <MudIcon Icon="@Icons.Material.Filled.StarBorder" Color="Color.Default" Size="Size.Small" />
                                <MudIcon Icon="@Icons.Material.Filled.StarBorder" Color="Color.Default" Size="Size.Small" />
                                <strong>1-Star Fish</strong>
                            </MudText>
                            <MudText Typo="Typo.caption">
                                • @(helpData.Gold.GoldRangePerStar.TryGetValue(1, out var g1) ? g1 : "0.75–1.0x base gold")<br/>
                                • Weight multiplier: @(helpData.StarWeight.WeightMultiplierPerStar.TryGetValue(1, out var w1) ? $"{w1:F1}x" : "1.0x")<br/>
                                • Standard catch
                            </MudText>
                        </MudCard>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">Weight Impact</MudText>
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudText Typo="Typo.body2" Class="mb-2">
                            <strong>How Weight Affects Gold:</strong>
                        </MudText>
                        <MudText Typo="Typo.caption">
                            @((MarkupString)helpData.Gold.WeightMultiplierNote)
                        </MudText>
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Color="Color.Success">Example Values:</MudText>
                        <MudStack Spacing="1" Class="mt-2">
                            @foreach (var example in helpData.Gold.ValueExamples)
                            {
                                <MudText Typo="Typo.caption">• @example</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Rarity System -->
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Info" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Diamond" />
                Rarity System
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                <strong>Current Baseline Rarity Percentages (without equipment boosts):</strong>
            </MudText>
            <MudGrid>
                @foreach (var kvp in helpData.RarityGuide.BaselinePercentages.OrderBy(k => (int)k.Key))
                {
                    var isLegendary = kvp.Key == FishRarity.Legendary;
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="@(isLegendary ? 3 : 1)" Class="pa-3">
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudChip T="string" Color="@GetRarityColor(kvp.Key)" Size="Size.Small" Icon="@Icons.Material.Filled.Diamond">
                                    @kvp.Key
                                </MudChip>
                                <MudText Typo="Typo.h6">@kvp.Value.ToString("F1")%</MudText>
                            </MudStack>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>

            @if (helpData.RarityGuide.BoostModeEnabled)
            {
                <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.TrendingUp" Class="mt-4">
                    <strong>Boost Mode is Currently Active!</strong> Rare+ rarities are multiplied by @(helpData.RarityGuide.BoostModeMultiplier)x.
                </MudAlert>
            }

            @if (helpData.RarityGuide.RarityBoostExamples.Any())
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Color="Color.Success" Class="mb-2">Rarity-Boosting Equipment Examples:</MudText>
                <MudGrid>
                    @foreach (var item in helpData.RarityGuide.RarityBoostExamples.Take(3))
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2"><strong>@item.Name</strong></MudText>
                                    <MudText Typo="Typo.caption">@item.Description</MudText>
                                    <MudDivider Class="my-1" />
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                        <MudText Typo="Typo.caption"><strong>@item.Cost g</strong></MudText>
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Color="Color.Info">
                                        <strong>@item.Boosts</strong>
                                    </MudText>
                                </MudStack>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }

            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                @((MarkupString)helpData.RarityGuide.EffectsNoteHtml)
            </MudAlert>
        </MudPaper>

        <!-- Equipment Slots -->
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Tertiary" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Backpack" />
                Equipment Slots
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Equip one item per slot to stack boosts. Different slots provide different bonuses:
            </MudText>
            <MudGrid>
                @foreach (var kvp in helpData.EquipmentMeta.SlotDescriptions.Take(6))
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="1" Class="pa-3">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                                    <strong>@kvp.Key</strong>
                                </MudText>
                                <MudText Typo="Typo.caption">@kvp.Value</MudText>
                            </MudStack>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>

        <!-- Consumable Items -->
        @if (helpData.ConsumableRoster.ConsumableItems.Any())
        {
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h4" Color="Color.Error" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
                    Consumable Items
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    @helpData.ConsumableRoster.ConsumableNote
                </MudText>
                <MudGrid>
                    @foreach (var item in helpData.ConsumableRoster.ConsumableItems.Take(6))
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2"><strong>@item.Name</strong></MudText>
                                    <MudText Typo="Typo.caption">@item.Description</MudText>
                                    <MudDivider Class="my-1" />
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                        <MudText Typo="Typo.caption"><strong>@item.Cost g</strong></MudText>
                                    </MudStack>
                                    @if (item.MaxUses > 0)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Warning">
                                            @item.MaxUses uses
                                        </MudText>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Boosts))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Info">
                                            <strong>@item.Boosts</strong>
                                        </MudText>
                                    }
                                </MudStack>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        <!-- Recommended Builds -->
        @if (helpData.MetaBuilds.Builds.Any())
        {
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h4" Color="Color.Success" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                    Recommended Playstyles
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Choose a playstyle that matches your goals!
                </MudText>
                <MudGrid>
                    @foreach (var build in helpData.MetaBuilds.Builds)
                    {
                        <MudItem xs="12" sm="6" md="6">
                            <MudCard Elevation="2" Class="pa-4">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.h6" Color="Color.Primary">
                                        @build.Name
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        <strong>Playstyle:</strong> @build.PlayStyle
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        <strong>Expected Outcome:</strong> @build.ExpectedOutcome
                                    </MudText>
                                    <MudDivider />
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Size="Size.Small" />
                                        <MudText Typo="Typo.caption">
                                            <strong>~@build.ApproximateCostToSetUp g to set up</strong>
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        <!-- Tips Section -->
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h4" Color="Color.Secondary" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Lightbulb" />
                Pro Tips
            </MudText>
            <MudStack Spacing="2">
                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Dense="false">
                    <strong>Stacking Boosts:</strong> Each equipped item's boost is multiplied against the baseline. Stack multiple items in different slots for maximum effect!
                </MudAlert>
                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Dense="false">
                    <strong>Specific Fish Gear:</strong> Some consumable bait and lures target specific fish types, dramatically increasing your chances of catching them.
                </MudAlert>
                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Dense="false">
                    <strong>Budget Planning:</strong> Start with Entry-tier equipment and work your way up. Early purchases give you the best return on investment.
                </MudAlert>
                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Dense="false">
                    <strong>Catch Tracking:</strong> Check your Inventory page regularly to see what you've caught and plan your next purchases!
                </MudAlert>
            </MudStack>
        </MudPaper>

        </MudStack>
    }
</MudContainer>

@code {
    [Inject] private IFishingHelpDataService helpDataService { get; set; } = null!;

    private FishingHelpData? helpData;

    protected override async Task OnInitializedAsync()
    {
        helpData = await helpDataService.GetHelpDataAsync();
    }

    private Color GetRarityColor(FishRarity rarity) => rarity switch
    {
        FishRarity.Common => Color.Default,
        FishRarity.Uncommon => Color.Success,
        FishRarity.Rare => Color.Info,
        FishRarity.Epic => Color.Secondary,
        FishRarity.Legendary => Color.Warning,
        _ => Color.Default
    };
}