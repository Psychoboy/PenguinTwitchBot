@page "/fishing/balance-analysis"
@using DotNetTwitchBot.Bot.Commands.Fishing
@using DotNetTwitchBot.Bot.Models.Fishing
@using System.Text.Json
@inject IFishingService FishingService
@inject IFishingShopService ShopService
@inject IFishingAnalyticsService AnalyticsService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Streamer, Editor")]

<PageTitle>Fishing Balance Analysis</PageTitle>

<MudContainer Class="pa-4" MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Class="mr-2" />
            Fishing Game Balance Analysis
        </MudText>

        <MudPaper Elevation="3" Class="pa-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Analysis Parameters</MudText>
                
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudDatePicker Label="Start Date" 
                                   @bind-Date="startDate" 
                                   Clearable="true"
                                   Placeholder="All time" />
                    <MudDatePicker Label="End Date" 
                                   @bind-Date="endDate" 
                                   Clearable="true"
                                   Placeholder="Now" />
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="RunAnalysis"
                               Disabled="isLoading">
                        @if (isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Analyzing...</span>
                        }
                        else
                        {
                            <span>Run Analysis</span>
                        }
                    </MudButton>
                </MudStack>

                @if (report != null)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Info" 
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="ExportToJson">
                            Export JSON
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Success" 
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RunAnalysis"
                                   Disabled="isLoading">
                            Refresh
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        @if (report != null)
        {
            <!-- Summary Statistics -->
            <MudPaper Elevation="3" Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-2" />
                        Summary Statistics
                    </MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Catches</MudText>
                                    <MudText Typo="Typo.h4">@report.TotalCatches.ToString("N0")</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Unique Users</MudText>
                                    <MudText Typo="Typo.h4">@report.UniqueUsers</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Gold Earned</MudText>
                                    <MudText Typo="Typo.h4">
                                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                        @report.TotalGoldEarned.ToString("N0")
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Avg Gold/Catch</MudText>
                                    <MudText Typo="Typo.h4">@report.AverageGoldPerCatch.ToString("N2")</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            <!-- Balance Recommendations -->
            @if (report.BalanceRecommendations.Any())
            {
                <MudPaper Elevation="3" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h5" Color="Color.Warning">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                            Balance Recommendations
                        </MudText>
                        @foreach (var recommendation in report.BalanceRecommendations)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@recommendation</MudAlert>
                        }
                    </MudStack>
                </MudPaper>
            }

            <!-- Dynamic Pricing Adjustment -->
            <MudPaper Elevation="3" Class="pa-4">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
                        Dynamic Pricing Adjustment
                    </MudText>

                    <MudAlert Severity="Severity.Info" Dense="true">
                        <MudText Typo="Typo.body2">
                            Set your target progression time for <strong>permanent equipment</strong> (excludes consumables).
                            The system will calculate the required price multiplier based on current data.
                        </MudText>
                    </MudAlert>

                    <MudAlert Severity="Severity.Success" Dense="true">
                        <MudText Typo="Typo.body2">
                            <strong>✓ Pricing Calculation:</strong> Using <strong>@GetPricingGoldSourceDisplay(pricingGoldSource)</strong> with <strong>@GetPricingScopeDisplay(pricingScope)</strong> scope.
                        </MudText>
                    </MudAlert>

                    <MudGrid>
                        <MudItem xs="12" md="3">
                            <MudSelect Label="Target Progression Time" @bind-Value="targetWeeks" Variant="Variant.Outlined">
                                <MudSelectItem Value="12">3 Months (12 weeks)</MudSelectItem>
                                <MudSelectItem Value="26">6 Months (26 weeks)</MudSelectItem>
                                <MudSelectItem Value="39">9 Months (39 weeks)</MudSelectItem>
                                <MudSelectItem Value="52">1 Year (52 weeks)</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4">
                                Gold source controls whether pricing follows actual report values or theoretical baselines.
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect Label="Gold Source" @bind-Value="pricingGoldSource" Variant="Variant.Outlined">
                                <MudSelectItem Value="@PricingGoldSource.ReportAverage">Report Average (matches table)</MudSelectItem>
                                <MudSelectItem Value="@PricingGoldSource.ReportMedian">Report Median (conservative)</MudSelectItem>
                                <MudSelectItem Value="@PricingGoldSource.ProgressiveBaseline">Progressive Baseline</MudSelectItem>
                                <MudSelectItem Value="@PricingGoldSource.PureBaseline">Pure Baseline</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect Label="Pricing Scope" @bind-Value="pricingScope" Variant="Variant.Outlined">
                                <MudSelectItem Value="@PricingScope.TopBySlot">Top Gear By Slot</MudSelectItem>
                                <MudSelectItem Value="@PricingScope.AllPermanent">All Permanent Items</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Gold Analysis</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Info">
                                        <strong>Baseline:</strong> Used for pricing
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                        Median (Actual): @report.MedianGoldPerCatch.ToString("F2")g/catch
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                        Mean (Actual): @report.AverageGoldPerCatch.ToString("F2")g/catch
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                        Using: @GetPricingGoldSourceDisplay(pricingGoldSource)
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Calculate"
                                       OnClick="CalculatePriceAdjustment"
                                       Disabled="isCalculating">
                                @if (isCalculating)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Calculating...</span>
                                }
                                else
                                {
                                    <span>Calculate Pricing</span>
                                }
                            </MudButton>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            @if (pricePreview != null)
                            {
                                <MudButton Variant="Variant.Filled" 
                                           Color="Color.Success" 
                                           StartIcon="@Icons.Material.Filled.Check"
                                           OnClick="ApplyPricing"
                                           Disabled="isApplying">
                                    @if (isApplying)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Applying...</span>
                                    }
                                    else
                                    {
                                        <span>Apply Pricing</span>
                                    }
                                </MudButton>
                            }
                        </MudItem>
                    </MudGrid>

                    @if (pricePreview != null)
                    {
                        <MudDivider />

                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                            <MudText Typo="Typo.caption">
                                <strong>@GetPricingGoldSourceDisplay(pricingGoldSource):</strong>
                                @if (pricingGoldSource == PricingGoldSource.ProgressiveBaseline)
                                {
                                    <text>Assumes player upgrades from no equipment → Entry tier → Mid tier → High tier → Top tier over @targetWeeks weeks.</text>
                                }
                                else if (pricingGoldSource == PricingGoldSource.PureBaseline)
                                {
                                    <text>Assumes player has NO equipment for all @targetWeeks weeks (conservative estimate).</text>
                                }
                                else if (pricingGoldSource == PricingGoldSource.ReportMedian)
                                {
                                    <text>Uses median gold/catch from the selected analysis range.</text>
                                }
                                else
                                {
                                    <text>Uses average gold/catch from the selected analysis range (matches item affordability table).</text>
                                }
                            </MudText>
                        </MudAlert>
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                            <MudText Typo="Typo.caption">
                                <strong>Pricing Scope:</strong> @GetPricingScopeDisplay(pricingScope) based on @pricePreview.ReferenceItemCount item(s).
                            </MudText>
                        </MudAlert>

                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudPaper Elevation="2" Class="pa-3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Baseline Gold/Catch</MudText>
                                        <MudText Typo="Typo.h6">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                            @pricePreview.GoldPerCatch.ToString("F2")g
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                            ~@pricePreview.CatchesPerSession.ToString("F1") catches × @pricePreview.SessionsPerWeek.ToString("F1") sessions/wk = @pricePreview.WeeklyIncome.ToString("F0")g/week
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudPaper Elevation="2" Class="pa-3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Current Total</MudText>
                                        <MudText Typo="Typo.h6">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Error" />
                                            @pricePreview.CurrentTotal.ToString("N0")g
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                                ~@pricePreview.CurrentWeeks.ToString("F1") weeks (@GetPricingScopeDisplay(pricePreview.Scope))
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudPaper Elevation="2" Class="pa-3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Target Total</MudText>
                                        <MudText Typo="Typo.h6">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Success" />
                                            @pricePreview.TargetTotal.ToString("N0")g
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                            @targetWeeks weeks
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudPaper Elevation="2" Class="pa-3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Multiplier</MudText>
                                        <MudText Typo="Typo.h6">
                                            <MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Small" Color="Color.Info" />
                                            @pricePreview.Multiplier.ToString("F4")x
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                            @if (pricePreview.Multiplier < 1)
                                            {
                                                <text>@((1 - pricePreview.Multiplier) * 100).ToString("F1")% decrease</text>
                                            }
                                            else
                                            {
                                                <text>@((pricePreview.Multiplier - 1) * 100).ToString("F1")% increase</text>
                                            }
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        <MudText Typo="Typo.h6" Class="mt-3">Price Preview (Permanent Items Only)</MudText>
                        <MudTable Items="@pricePreview.ItemPreviews" Dense="true" Hover="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Item Name</MudTh>
                                <MudTh>Slot</MudTh>
                                <MudTh>Current Price</MudTh>
                                <MudTh></MudTh>
                                <MudTh>New Price</MudTh>
                                <MudTh>Change</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.ItemName</MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Slot</MudChip>
                                </MudTd>
                                <MudTd>
                                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Error" />
                                    @context.OldPrice
                                </MudTd>
                                <MudTd>
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                </MudTd>
                                <MudTd>
                                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Success" />
                                    <strong>@context.NewPrice</strong>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" 
                                             Size="Size.Small" 
                                             Color="@(context.PriceDifference > 0 ? Color.Error : Color.Success)">
                                        @(context.PriceDifference > 0 ? "+" : "")@context.PriceDifference
                                    </MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudStack>
            </MudPaper>

            <MudTabs Elevation="2" Rounded="true" Color="Color.Primary">
                <!-- Rarity Distribution Tab -->
                <MudTabPanel Text="Rarity Distribution" Icon="@Icons.Material.Filled.BarChart">
                    <MudPaper Elevation="1" Class="pa-4 ma-2">
                        <MudText Typo="Typo.h6" Class="mb-3">Actual vs Expected Rarity Distribution</MudText>
                        <MudTable Items="@GetRarityData()" Dense="true" Hover="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Rarity</MudTh>
                                <MudTh>Count</MudTh>
                                <MudTh>Actual %</MudTh>
                                <MudTh>Expected %</MudTh>
                                <MudTh>Variance</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudChip T="string" Color="GetRarityColor(context.Rarity)" Size="Size.Small">
                                        @context.Rarity
                                    </MudChip>
                                </MudTd>
                                <MudTd>@context.Count.ToString("N0")</MudTd>
                                <MudTd>@context.ActualPercent.ToString("F2")%</MudTd>
                                <MudTd>@context.ExpectedPercent.ToString("F2")%</MudTd>
                                <MudTd>
                                    <MudText Color="@(Math.Abs(context.Variance) > 5 ? Color.Error : Color.Success)">
                                        @(context.Variance >= 0 ? "+" : "")@context.Variance.ToString("F2")%
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudTabPanel>

                <!-- Star Distribution Tab -->
                <MudTabPanel Text="Star Distribution" Icon="@Icons.Material.Filled.Star">
                    <MudPaper Elevation="1" Class="pa-4 ma-2">
                        <MudText Typo="Typo.h6" Class="mb-3">Star Quality Distribution</MudText>
                        <MudTable Items="@GetStarData()" Dense="true" Hover="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Stars</MudTh>
                                <MudTh>Count</MudTh>
                                <MudTh>Percentage</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    @for (int i = 0; i < context.Stars; i++)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                    }
                                </MudTd>
                                <MudTd>@context.Count.ToString("N0")</MudTd>
                                <MudTd>@context.Percent.ToString("F2")%</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudTabPanel>

                <!-- Item Affordability Tab -->
                <MudTabPanel Text="Item Affordability" Icon="@Icons.Material.Filled.ShoppingCart">
                    <MudPaper Elevation="1" Class="pa-4 ma-2">
                        <MudText Typo="Typo.h6" Class="mb-3">Shop Item Affordability Analysis</MudText>

                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2">
                                    <strong>Note:</strong> All calculations are based on <strong>real player engagement data</strong>.
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    <strong>Calculated from actual players:</strong> 
                                    Casual (~@report.CasualCatchesPerSession catches/session) | 
                                    Active (~@report.ActiveCatchesPerSession catches/session) | 
                                    Hardcore (~@report.HardcoreCatchesPerSession catches/session)
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                    Player types based on 25th, 50th (median), and 75th percentiles. Progression balanced for 2-3 sessions/week.
                                </MudText>
                            </MudStack>
                        </MudAlert>

                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Calculations based on current average gold/catch (@report.AverageGoldPerCatch.ToString("F1")g). Active player progression shown.
                        </MudText>
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            <MudText Typo="Typo.caption">
                                Effect columns show each item's single-item impact against the current global fishing settings, so you can compare baseline vs boosted outcomes directly.
                            </MudText>
                        </MudAlert>
                        <MudTable Items="@report.ItemAffordabilityAnalysis" Dense="false" Hover="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Item Name</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Cost</MudTh>
                                <MudTh>Cost/Use</MudTh>
                                <MudTh>Effect Metric</MudTh>
                                <MudTh>Base</MudTh>
                                <MudTh>With Item</MudTh>
                                <MudTh>Delta</MudTh>
                                <MudTh>Catches Needed</MudTh>
                                <MudTh>Sessions (Casual)</MudTh>
                                <MudTh>Sessions (Active)</MudTh>
                                <MudTh>Sessions (Hardcore)</MudTh>
                                <MudTh>Users Can Afford</MudTh>
                                <MudTh>Rating</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText>@context.ItemName</MudText>
                                        @if (!context.IsConsumable)
                                        {
                                            var tier = GetTierFromCost(context.Cost);
                                            var (tierColor, tierIcon) = GetTierDisplay(tier);
                                            <MudChip T="string" Color="@tierColor" Size="Size.Small" Icon="@tierIcon">@tier</MudChip>
                                        }
                                    </MudStack>
                                    @if (!string.IsNullOrEmpty(context.EquipmentSlot) && context.EquipmentSlot != "None")
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.EquipmentSlot</MudChip>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (context.IsConsumable)
                                    {
                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">
                                            Consumable (@(context.MaxUses?.ToString() ?? "∞") uses)
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Permanent</MudChip>
                                    }
                                </MudTd>
                                <MudTd>
                                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                    @context.Cost
                                </MudTd>
                                <MudTd>
                                    @if (context.IsConsumable)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                        <span>@context.CostPerUse.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">N/A</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (context.HasEffectPreview)
                                    {
                                        <MudText Typo="Typo.caption">@context.EffectMetric</MudText>
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (context.HasEffectPreview)
                                    {
                                        <MudText Typo="Typo.caption">@context.EffectBaselineValue.ToString("F2")%</MudText>
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (context.HasEffectPreview)
                                    {
                                        <MudText Typo="Typo.caption">@context.EffectWithItemValue.ToString("F2")%</MudText>
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (context.HasEffectPreview)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                            @(context.EffectRelativeChangePercent >= 0 ? "+" : "")@context.EffectRelativeChangePercent.ToString("F1")%
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>@context.CatchesNeededToBuy.ToString("F1")</MudTd>
                                <MudTd>
                                    @if (!context.IsConsumable && context.SessionsToAffordCasual > 0)
                                    {
                                        <span>@context.SessionsToAffordCasual.ToString("F1") sessions</span>
                                        @if (context.SessionsToAffordCasual >= 2)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                (~@((context.SessionsToAffordCasual / 2).ToString("F1")) weeks)
                                            </MudText>
                                        }
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (!context.IsConsumable && context.SessionsToAffordActive > 0)
                                    {
                                        <span>@context.SessionsToAffordActive.ToString("F1") sessions</span>
                                        @if (context.SessionsToAffordActive >= 2)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                (~@((context.SessionsToAffordActive / 2).ToString("F1")) weeks)
                                            </MudText>
                                        }
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    @if (!context.IsConsumable && context.SessionsToAffordHardcore > 0)
                                    {
                                        <span>@context.SessionsToAffordHardcore.ToString("F1") sessions</span>
                                        @if (context.SessionsToAffordHardcore >= 2)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                (~@((context.SessionsToAffordHardcore / 2).ToString("F1")) weeks)
                                            </MudText>
                                        }
                                    }
                                    else
                                    {
                                        <MudText Color="Color.Secondary">-</MudText>
                                    }
                                </MudTd>
                                <MudTd>@context.PercentageWhoCanAfford.ToString("F1")% (@context.UsersWhoCanAfford users)</MudTd>
                                <MudTd>
                                    @if (!context.IsConsumable && !string.IsNullOrEmpty(context.AffordabilityRating))
                                    {
                                        <MudChip T="string" Color="GetAffordabilityColor(context.AffordabilityRating)" Size="Size.Small">
                                            @context.AffordabilityRating
                                        </MudChip>
                                    }
                                    @if (context.IsConsumable && !string.IsNullOrEmpty(context.ValueRating))
                                    {
                                        <MudChip T="string" Color="GetValueRatingColor(context.ValueRating)" Size="Size.Small">
                                            @context.ValueRating
                                        </MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudTabPanel>

                <!-- Fish Distribution Tab -->
                <MudTabPanel Text="Fish Distribution" Icon="@Icons.Material.Filled.Phishing">
                    <MudPaper Elevation="1" Class="pa-4 ma-2">
                        <MudText Typo="Typo.h6" Class="mb-3">Most Caught Fish</MudText>
                        <MudTable Items="@GetTopFish()" Dense="true" Hover="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Rank</MudTh>
                                <MudTh>Fish Name</MudTh>
                                <MudTh>Count</MudTh>
                                <MudTh>Percentage</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    @if (context.Rank <= 3)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" 
                                                 Color="@(context.Rank == 1 ? Color.Warning : context.Rank == 2 ? Color.Default : Color.Tertiary)" />
                                    }
                                    else
                                    {
                                        <span>@context.Rank</span>
                                    }
                                </MudTd>
                                <MudTd>@context.Name</MudTd>
                                <MudTd>@context.Count.ToString("N0")</MudTd>
                                <MudTd>@context.Percent.ToString("F2")%</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudTabPanel>

                <!-- Equipment Usage Tab -->
                @if (report.MostCommonEquipment.Any())
                {
                    <MudTabPanel Text="Equipment Usage" Icon="@Icons.Material.Filled.Inventory">
                        <MudPaper Elevation="1" Class="pa-4 ma-2">
                            <MudText Typo="Typo.h6" Class="mb-3">Most Commonly Owned Equipment</MudText>
                            <MudTable Items="@GetEquipmentData()" Dense="true" Hover="true" Striped="true">
                                <HeaderContent>
                                    <MudTh>Item Name</MudTh>
                                    <MudTh>Users Owning</MudTh>
                                    <MudTh>Ownership %</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Name</MudTd>
                                    <MudTd>@context.Count</MudTd>
                                    <MudTd>@context.Percent.ToString("F1")%</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    </MudTabPanel>
                }

                <!-- Top Users Tab -->
                <MudTabPanel Text="Top Users" Icon="@Icons.Material.Filled.Leaderboard">
                    <MudPaper Elevation="1" Class="pa-4 ma-2">
                        <MudStack Spacing="3">
                            <div>
                                <MudText Typo="Typo.h6" Class="mb-3">Top Users by Catches</MudText>
                                <MudTable Items="@GetTopUsersByCatches()" Dense="true" Hover="true" Striped="true">
                                    <HeaderContent>
                                        <MudTh>Rank</MudTh>
                                        <MudTh>Username</MudTh>
                                        <MudTh>Catches</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Rank</MudTd>
                                        <MudTd>@context.Name</MudTd>
                                        <MudTd>@context.Count.ToString("N0")</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                            <div>
                                <MudText Typo="Typo.h6" Class="mb-3">Top Users by Gold Earned</MudText>
                                <MudTable Items="@GetTopUsersByGold()" Dense="true" Hover="true" Striped="true">
                                    <HeaderContent>
                                        <MudTh>Rank</MudTh>
                                        <MudTh>Username</MudTh>
                                        <MudTh>Gold Earned</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Rank</MudTd>
                                        <MudTd>@context.Name</MudTd>
                                        <MudTd>
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                            @context.Amount.ToString("N0")
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudTabPanel>
            </MudTabs>
        }
        else if (!isLoading)
        {
            <MudPaper Elevation="3" Class="pa-8">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary">
                        Click "Run Analysis" to generate a balance report
                    </MudText>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    private DateTime? startDate;
    private DateTime? endDate;
    private FishingBalanceReport? report;
    private bool isLoading = false;

    private async Task RunAnalysis()
    {
        isLoading = true;
        try
        {
            report = await AnalyticsService.AnalyzeGameBalance(startDate, endDate);
            Snackbar.Add("Analysis completed successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error running analysis: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExportToJson()
    {
        if (report == null) return;

        var jsonOptions = new JsonSerializerOptions 
        { 
            WriteIndented = true,
            PropertyNamingPolicy = JsonNamingPolicy.CamelCase
        };
        var json = JsonSerializer.Serialize(report, jsonOptions);
        var fileName = $"FishingBalanceReport_{DateTime.Now:yyyyMMdd_HHmmss}.json";
        
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, json);
        Snackbar.Add($"Report exported as {fileName}", Severity.Success);
    }

    private Color GetRarityColor(FishRarity rarity)
    {
        return rarity switch
        {
            FishRarity.Common => Color.Default,
            FishRarity.Uncommon => Color.Success,
            FishRarity.Rare => Color.Info,
            FishRarity.Epic => Color.Secondary,
            FishRarity.Legendary => Color.Warning,
            _ => Color.Default
        };
    }

    private Color GetAffordabilityColor(string rating)
    {
        return rating switch
        {
            "Too Cheap" => Color.Warning,
            "Starter Tier" => Color.Default,
            "Low Tier" => Color.Success,
            "Mid Tier" => Color.Info,
            "High Tier" => Color.Secondary,
            "Endgame Tier" => Color.Error,
            _ => Color.Default
        };
    }

    private Color GetValueRatingColor(string rating)
    {
        return rating switch
        {
            "Excellent Value" => Color.Success,
            "Good Value" => Color.Success,
            "Fair Trade" => Color.Info,
            "Moderate Sink" => Color.Warning,
            "Significant Gold Sink" => Color.Error,
            _ => Color.Default
        };
    }

    private class RarityRow
    {
        public FishRarity Rarity { get; set; }
        public int Count { get; set; }
        public double ActualPercent { get; set; }
        public double ExpectedPercent { get; set; }
        public double Variance { get; set; }
    }

    private class StarRow
    {
        public int Stars { get; set; }
        public int Count { get; set; }
        public double Percent { get; set; }
    }

    private class FishRow
    {
        public int Rank { get; set; }
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
        public double Percent { get; set; }
    }

    private class EquipmentRow
    {
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
        public double Percent { get; set; }
    }

    private class UserRow
    {
        public int Rank { get; set; }
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
        public int Amount { get; set; }
    }

    private List<RarityRow> GetRarityData()
    {
        if (report == null) return new List<RarityRow>();

        return report.RarityDistribution.Select(kvp => new RarityRow
        {
            Rarity = kvp.Key,
            Count = kvp.Value,
            ActualPercent = report.RarityPercentages.GetValueOrDefault(kvp.Key, 0),
            ExpectedPercent = report.ExpectedRarityPercentages.GetValueOrDefault(kvp.Key, 0),
            Variance = report.RarityVariance.GetValueOrDefault(kvp.Key, 0)
        })
        .OrderBy(r => (int)r.Rarity)
        .ToList();
    }

    private List<StarRow> GetStarData()
    {
        if (report == null) return new List<StarRow>();

        return report.StarDistribution.Select(kvp => new StarRow
        {
            Stars = kvp.Key,
            Count = kvp.Value,
            Percent = report.StarPercentages.GetValueOrDefault(kvp.Key, 0)
        })
        .OrderBy(s => s.Stars)
        .ToList();
    }

    private List<FishRow> GetTopFish()
    {
        if (report == null) return new List<FishRow>();

        return report.FishCatchCounts
            .OrderByDescending(f => f.Value)
            .Take(20)
            .Select((f, index) => new FishRow
            {
                Rank = index + 1,
                Name = f.Key,
                Count = f.Value,
                Percent = report.FishCatchPercentages.GetValueOrDefault(f.Key, 0)
            })
            .ToList();
    }

    private List<EquipmentRow> GetEquipmentData()
    {
        if (report == null) return new List<EquipmentRow>();

        return report.MostCommonEquipment.Select(e => new EquipmentRow
        {
            Name = e.Key,
            Count = e.Value,
            Percent = report.UniqueUsers > 0 ? (e.Value / (double)report.UniqueUsers) * 100 : 0
        })
        .ToList();
    }

    private List<UserRow> GetTopUsersByCatches()
    {
        if (report == null) return new List<UserRow>();

        return report.TopUsersByCatches
            .Select((u, index) => new UserRow
            {
                Rank = index + 1,
                Name = u.Key,
                Count = u.Value,
                Amount = 0
            })
            .ToList();
    }

    private List<UserRow> GetTopUsersByGold()
    {
        if (report == null) return new List<UserRow>();

        return report.TopUsersByGold
            .Select((u, index) => new UserRow
            {
                Rank = index + 1,
                Name = u.Key,
                Count = 0,
                Amount = u.Value
            })
            .ToList();
    }

    private EquipmentTier GetTierFromCost(int cost)
    {
        // Tiers aligned with 6-month progression: Entry=2wk, Mid=6wk, High=12wk, Top=26wk
        return cost switch
        {
            <= 200 => EquipmentTier.Entry,   // ~2 weeks for median player
            <= 500 => EquipmentTier.Mid,     // ~6 weeks cumulative
            <= 1500 => EquipmentTier.High,    // ~12 weeks cumulative
            _ => EquipmentTier.Top           // ~26 weeks cumulative
        };
    }

    private (Color color, string icon) GetTierDisplay(EquipmentTier tier)
    {
        return tier switch
        {
            EquipmentTier.Entry => (Color.Default, Icons.Material.Filled.Star),
            EquipmentTier.Mid => (Color.Info, Icons.Material.Filled.StarHalf),
            EquipmentTier.High => (Color.Secondary, Icons.Material.Filled.Stars),
            EquipmentTier.Top => (Color.Warning, Icons.Material.Filled.EmojiEvents),
            _ => (Color.Default, Icons.Material.Filled.ShoppingCart)
        };
    }

    // Dynamic Pricing State
    private int targetWeeks = 26; // Default to 6 months
    private enum PricingGoldSource
    {
        ReportAverage,
        ReportMedian,
        ProgressiveBaseline,
        PureBaseline
    }

    private enum PricingScope
    {
        TopBySlot,
        AllPermanent
    }

    private PricingGoldSource pricingGoldSource = PricingGoldSource.ReportAverage;
    private PricingScope pricingScope = PricingScope.TopBySlot;

    private bool isCalculating = false;
    private bool isApplying = false;
    private PricePreview? pricePreview;

    private class PricePreview
    {
        public double GoldPerCatch { get; set; }
        public double CatchesPerSession { get; set; }
        public double SessionsPerWeek { get; set; }
        public double WeeklyIncome { get; set; }
        public int CurrentTotal { get; set; }
        public int TargetTotal { get; set; }
        public double CurrentWeeks { get; set; }
        public double Multiplier { get; set; }
        public PricingScope Scope { get; set; }
        public int ReferenceItemCount { get; set; }
        public List<ItemPricePreview> ItemPreviews { get; set; } = new();
    }

    private static string GetPricingGoldSourceDisplay(PricingGoldSource source)
    {
        return source switch
        {
            PricingGoldSource.ReportAverage => "Report Average",
            PricingGoldSource.ReportMedian => "Report Median",
            PricingGoldSource.ProgressiveBaseline => "Progressive Baseline",
            PricingGoldSource.PureBaseline => "Pure Baseline",
            _ => "Unknown"
        };
    }

    private static string GetPricingScopeDisplay(PricingScope scope)
    {
        return scope switch
        {
            PricingScope.TopBySlot => "Top Gear By Slot",
            PricingScope.AllPermanent => "All Permanent Items",
            _ => "Unknown"
        };
    }

    private class ItemPricePreview
    {
        public string ItemName { get; set; } = string.Empty;
        public string Slot { get; set; } = string.Empty;
        public int OldPrice { get; set; }
        public int NewPrice { get; set; }
        public int PriceDifference { get; set; }
    }

    private async Task CalculatePriceAdjustment()
    {
        if (report == null)
        {
            Snackbar.Add("Please run analysis first", Severity.Warning);
            return;
        }

        isCalculating = true;
        try
        {
            // Get all shop items
            var allItems = await ShopService.GetAllShopItems();

            // Filter to permanent equipment only (exclude Bait and Lure slots)
            var permanentItems = allItems
                .Where(i => !i.IsConsumable && 
                           i.EquipmentSlot.HasValue && 
                           i.EquipmentSlot != EquipmentSlot.Bait && 
                           i.EquipmentSlot != EquipmentSlot.Lure)
                .ToList();

            if (!permanentItems.Any())
            {
                Snackbar.Add("No permanent equipment items found", Severity.Warning);
                return;
            }

            // Gold-per-catch source for pricing calculations.
            double goldPerCatch;
            if (pricingGoldSource == PricingGoldSource.ReportAverage)
            {
                goldPerCatch = report.AverageGoldPerCatch;
            }
            else if (pricingGoldSource == PricingGoldSource.ReportMedian)
            {
                goldPerCatch = report.MedianGoldPerCatch;
            }
            else if (pricingGoldSource == PricingGoldSource.ProgressiveBaseline)
            {
                goldPerCatch = await AnalyticsService.CalculateProgressiveBaselineGold(targetWeeks);
            }
            else
            {
                goldPerCatch = await AnalyticsService.CalculateBaselineExpectedGold();
            }

            // Use REAL player engagement from balance report instead of hardcoded 3 catches/session
            double catchesPerSession = report?.ActiveCatchesPerSession ?? 30.0; // Use median (active) player
            double sessionsPerWeek = 2.5; // Average of 2-3 sessions per week
            var weeklyIncome = goldPerCatch * catchesPerSession * sessionsPerWeek;

            var referenceItems = pricingScope == PricingScope.TopBySlot
                ? permanentItems
                    .Where(i => i.EquipmentSlot.HasValue)
                    .GroupBy(i => i.EquipmentSlot!.Value)
                    .Select(g => g.OrderByDescending(i => i.Cost).First())
                    .ToList()
                : permanentItems;

            var currentTotal = referenceItems.Sum(i => i.Cost);

            // Validate inputs to prevent division by zero / invalid calculations
            if (weeklyIncome <= 0)
            {
                Snackbar.Add("Invalid baseline gold calculation (0 or negative). Cannot calculate pricing.", Severity.Error);
                return;
            }

            if (currentTotal <= 0)
            {
                Snackbar.Add("Total item cost is 0. Please ensure shop items have valid prices.", Severity.Warning);
                return;
            }

            var targetTotal = (int)Math.Round(weeklyIncome * targetWeeks);
            var currentWeeks = currentTotal / weeklyIncome;
            var multiplier = targetTotal / (double)currentTotal;

            // Create preview
            pricePreview = new PricePreview
            {
                GoldPerCatch = goldPerCatch,
                CatchesPerSession = catchesPerSession,
                SessionsPerWeek = sessionsPerWeek,
                WeeklyIncome = weeklyIncome,
                CurrentTotal = currentTotal,
                TargetTotal = targetTotal,
                CurrentWeeks = currentWeeks,
                Multiplier = multiplier,
                Scope = pricingScope,
                ReferenceItemCount = referenceItems.Count
            };

            // Calculate new prices for each item
            foreach (var item in permanentItems.OrderBy(i => i.EquipmentSlot).ThenBy(i => i.Cost))
            {
                var newPrice = (int)Math.Round(item.Cost * multiplier);
                if (newPrice < 1) newPrice = 1; // Minimum price of 1

                pricePreview.ItemPreviews.Add(new ItemPricePreview
                {
                    ItemName = item.Name,
                    Slot = item.EquipmentSlot?.ToString() ?? "Unknown",
                    OldPrice = item.Cost,
                    NewPrice = newPrice,
                    PriceDifference = newPrice - item.Cost
                });
            }

            Snackbar.Add($"Calculated pricing for {permanentItems.Count} permanent items", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error calculating pricing: {ex.Message}", Severity.Error);
        }
        finally
        {
            isCalculating = false;
        }
    }

    private async Task ApplyPricing()
    {
        if (pricePreview == null)
        {
            Snackbar.Add("Please calculate pricing first", Severity.Warning);
            return;
        }

        isApplying = true;
        try
        {
            // Build dictionary of item-specific prices from the preview
            var priceUpdates = pricePreview.ItemPreviews
                .ToDictionary(p => p.ItemName, p => p.NewPrice);

            // Apply individual prices (preserves tier-based precision)
            var updatedCount = await ShopService.UpdateShopItemPrices(priceUpdates);

            Snackbar.Add($"Successfully updated {updatedCount} item prices!", Severity.Success);

            // Clear preview
            pricePreview = null;

            // Refresh the report to show new prices
            await RunAnalysis();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error applying pricing: {ex.Message}", Severity.Error);
        }
        finally
        {
            isApplying = false;
        }
    }
}
