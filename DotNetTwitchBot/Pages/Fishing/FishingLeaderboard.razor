@page "/fishing/leaderboard"
@using DotNetTwitchBot.Bot.Commands.Fishing
@using DotNetTwitchBot.Bot.Models.Fishing
@using DotNetTwitchBot.Helpers
@using DotNetTwitchBot.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Fishing Leaderboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Size="Size.Large" Class="mr-2" />
            Fishing Leaderboard
        </MudText>

        @if (isInitialLoading)
        {
            <MudPaper Elevation="4" Class="pa-8">
                <MudStack AlignItems="AlignItems.Center" Spacing="4">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary">Loading fishing leaderboards...</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Please wait while we fetch the data</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {        <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" Class="mt-4">
            <MudTabPanel Text="Fish Leaderboard" Icon="@Icons.Material.Filled.Leaderboard">
                        <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="RefreshLeaderboard"
                                       Disabled="@isLoadingFishLeaderboard"
                                       Size="Size.Small">
                                @if (isLoadingFishLeaderboard)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <text>Loading...</text>
                                }
                                else
                                {
                                    <text>Refresh</text>
                                }
                            </MudButton>
                        </MudStack>
                        @if (isLoadingFishLeaderboard)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                                <MudText Typo="Typo.body1" Color="Color.Secondary">Loading leaderboard...</MudText>
                            </MudStack>
                        }
                        else if (leaderboardFishTypes.Any())
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="mb-4 mt-4">
                                <MudSelect Value="@selectedFishTypeId" 
                                           ValueChanged="@(async (int value) => await OnFishTypeChanged(value))"
                                           Label="Select Fish Type" 
                                           Variant="Variant.Outlined"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.Phishing"
                                           Style="max-width: 500px; width: 100%;">
                                    @foreach (var fish in leaderboardFishTypes)
                                    {
                                        <MudSelectItem Value="@fish.Id">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudChip T="string" Color="GetRarityColor(fish.Rarity)" Size="Size.Small">@fish.Rarity</MudChip>
                                                <MudText>@fish.Name</MudText>
                                            </MudStack>
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudStack>

                            @if (selectedFishTypeId > 0)
                            {
                                var selectedFish = leaderboardFishTypes.FirstOrDefault(f => f.Id == selectedFishTypeId);
                                <MudPaper Elevation="5" Class="pa-5 mb-4">
                                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                        @if (!string.IsNullOrEmpty(selectedFish?.ImageFileName))
                                        {
                                            <MudImage Src="@FishImageHelper.GetImagePath(selectedFish.ImageFileName, ImageSize.Medium)" 
                                                      Alt="@selectedFish.Name" 
                                                      Width="150"
                                                      Height="150"
                                                      ObjectFit="ObjectFit.Contain"
                                                      Elevation="3"
                                                      Class="rounded-lg" />
                                        }
                                        <MudText Typo="Typo.h4">@selectedFish?.Name</MudText>
                                        <MudChip T="string" 
                                                 Color="GetRarityColor(selectedFish?.Rarity ?? FishRarity.Common)" 
                                                 Size="Size.Large">
                                            @selectedFish?.Rarity
                                        </MudChip>
                                    </MudStack>
                                </MudPaper>

                                <MudTable Items="@topCatches" Hover="true" Striped="true" Dense="true" Elevation="4">
                                    <HeaderContent>
                                        <MudTh>Rank</MudTh>
                                        <MudTh>Player</MudTh>
                                        <MudTh>Stars</MudTh>
                                        <MudTh>Weight</MudTh>
                                        <MudTh>Gold Earned</MudTh>
                                        <MudTh>Caught At</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="fishCatch">
                                        <MudTd DataLabel="Rank">
                                            @{
                                                var rank = topCatches.IndexOf(fishCatch) + 1;
                                                var rankColor = rank switch
                                                {
                                                    1 => Color.Warning,
                                                    2 => Color.Default,
                                                    3 => Color.Tertiary,
                                                    _ => Color.Default
                                                };
                                                var rankIcon = rank switch
                                                {
                                                    1 => Icons.Material.Filled.EmojiEvents,
                                                    2 => Icons.Material.Filled.WorkspacePremium,
                                                    3 => Icons.Material.Filled.MilitaryTech,
                                                    _ => Icons.Material.Filled.Tag
                                                };
                                            }
                                            <MudChip T="string" Color="@rankColor" Icon="@rankIcon">@rank</MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="Player">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                                <MudText><strong>@fishCatch.Username</strong></MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Stars">
                                            @for (int i = 0; i < fishCatch.Stars; i++)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Weight">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Info" />
                                                <MudText>@fishCatch.Weight kg</MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Gold Earned">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                                <MudText>@fishCatch.GoldEarned</MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Caught At">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Default" />
                                                <MudText>@fishCatch.CaughtAt.ToLocalTime().ToString("g")</MudText>
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">No fish have been caught yet. Be the first to catch one!</MudAlert>
                        }
                    </MudTabPanel>

                    <MudTabPanel Text="Total Gold" Icon="@Icons.Material.Filled.AttachMoney">
                        <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="RefreshGoldLeaderboard"
                                       Disabled="@isLoadingGoldLeaderboard"
                                       Size="Size.Small">
                                @if (isLoadingGoldLeaderboard)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <text>Loading...</text>
                                }
                                else
                                {
                                    <text>Refresh</text>
                                }
                            </MudButton>
                        </MudStack>
                        @if (isLoadingGoldLeaderboard)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                                <MudText Typo="Typo.body1" Color="Color.Secondary">Loading gold leaderboard...</MudText>
                            </MudStack>
                        }
                        else if (goldLeaderboard.Any())
                        {
                            <MudTable Items="@goldLeaderboard" Hover="true" Striped="true" Dense="true" Elevation="4">
                                <ToolBarContent>
                                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Class="mr-2" />
                                    <MudText Typo="Typo.h6">Top 50 - Total Gold Earned</MudText>
                                </ToolBarContent>
                                <HeaderContent>
                                    <MudTh>Rank</MudTh>
                                    <MudTh>Player</MudTh>
                                    <MudTh>Total Gold</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="position">
                                    <MudTd DataLabel="Rank">
                                        @RenderRankBadge(position.Rank)
                                    </MudTd>
                                    <MudTd DataLabel="Player">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                            <MudText><strong>@position.Name</strong></MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Total Gold">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                            <MudText>@position.Amount.ToString("n0")</MudText>
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">No players have earned gold yet. Be the first to fish!</MudAlert>
                        }
                    </MudTabPanel>

                    <MudTabPanel Text="Valuable Catches" Icon="@Icons.Material.Filled.Diamond">
                        <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="RefreshValuableCatchesLeaderboard"
                                       Disabled="@isLoadingValuableCatches"
                                       Size="Size.Small">
                                @if (isLoadingValuableCatches)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <text>Loading...</text>
                                }
                                else
                                {
                                    <text>Refresh</text>
                                }
                            </MudButton>
                        </MudStack>
                        @if (isLoadingValuableCatches)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                                <MudText Typo="Typo.body1" Color="Color.Secondary">Loading valuable catches...</MudText>
                            </MudStack>
                        }
                        else if (valuableCatchesLeaderboard.Any())
                        {
                            <MudTable Items="@valuableCatchesLeaderboard" Hover="true" Striped="true" Dense="true" Elevation="4">
                                <ToolBarContent>
                                    <MudIcon Icon="@Icons.Material.Filled.Diamond" Color="Color.Info" Class="mr-2" />
                                    <MudText Typo="Typo.h6">Top 50 - Most Valuable Catches</MudText>
                                </ToolBarContent>
                                <HeaderContent>
                                    <MudTh>Rank</MudTh>
                                    <MudTh>Player</MudTh>
                                    <MudTh>Image</MudTh>
                                    <MudTh>Fish</MudTh>
                                    <MudTh>Rarity</MudTh>
                                    <MudTh>Stars</MudTh>
                                    <MudTh>Weight</MudTh>
                                    <MudTh>Gold Earned</MudTh>
                                    <MudTh>Caught At</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="fishCatch">
                                    @{
                                        var rank = valuableCatchesLeaderboard.IndexOf(fishCatch) + 1;
                                    }
                                    <MudTd DataLabel="Rank">
                                        @RenderRankBadge(rank)
                                    </MudTd>
                                    <MudTd DataLabel="Player">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                            <MudText><strong>@fishCatch.Username</strong></MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Image">
                                        @if (!string.IsNullOrEmpty(fishCatch.FishType?.ImageFileName))
                                        {
                                            <MudImage Src="@FishImageHelper.GetImagePath(fishCatch.FishType.ImageFileName, ImageSize.Thumbnail)" 
                                                      Alt="@fishCatch.FishType.Name" 
                                                      Width="50"
                                                      Height="50"
                                                      ObjectFit="ObjectFit.Contain"
                                                      Elevation="2"
                                                      Class="rounded" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Medium" Color="Color.Default" Style="opacity: 0.3;" />
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Fish">
                                        <MudText>@fishCatch.FishType?.Name</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Rarity">
                                        <MudChip T="string" 
                                                 Color="GetRarityColor(fishCatch.FishType?.Rarity ?? FishRarity.Common)" 
                                                 Size="Size.Small">
                                            @fishCatch.FishType?.Rarity
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Stars">
                                        @for (int i = 0; i < fishCatch.Stars; i++)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Weight">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Info" />
                                            <MudText>@fishCatch.Weight kg</MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Gold Earned">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                            <MudText><strong>@fishCatch.GoldEarned</strong></MudText>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Caught At">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Default" />
                                            <MudText>@fishCatch.CaughtAt.ToLocalTime().ToString("g")</MudText>
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">No catches found yet. Start fishing!</MudAlert>
                        }
                    </MudTabPanel>

                    <MudTabPanel Text="Recent Catches" Icon="@Icons.Material.Filled.History">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudSwitch Value="@showPersonalCatches" 
                                           ValueChanged="@(async (bool value) => await OnShowPersonalCatchesChanged(value))"
                                           Label="@(showPersonalCatches ? "My Recent Catches" : "Global Recent Catches")" 
                                           Color="Color.Primary"
                                           ThumbIcon="@(showPersonalCatches ? Icons.Material.Filled.Person : Icons.Material.Filled.Public)" />
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary" 
                                           StartIcon="@Icons.Material.Filled.Refresh"
                                           OnClick="RefreshRecentCatches"
                                           Disabled="@isLoadingRecentCatches"
                                           Size="Size.Small">
                                    @if (isLoadingRecentCatches)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <text>Loading...</text>
                                    }
                                    else
                                    {
                                        <text>Refresh</text>
                                    }
                                </MudButton>
                            </MudStack>
                            @if (isLoadingRecentCatches)
                            {
                                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                                    <MudText Typo="Typo.body1" Color="Color.Secondary">Loading recent catches...</MudText>
                                </MudStack>
                            }
                            else if (recentCatches.Any())
                            {
                                <MudTable Items="@recentCatches" Hover="true" Striped="true" Dense="true" Elevation="4">
                                    <ToolBarContent>
                                        <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Success" Class="mr-2" />
                                        <MudText Typo="Typo.h6">@(showPersonalCatches ? $"Your Last {recentCatches.Count} Catches" : $"Last {recentCatches.Count} Catches")</MudText>
                                    </ToolBarContent>
                                    <HeaderContent>
                                        <MudTh>Player</MudTh>
                                        <MudTh>Image</MudTh>
                                        <MudTh>Fish</MudTh>
                                        <MudTh>Rarity</MudTh>
                                        <MudTh>Stars</MudTh>
                                        <MudTh>Weight</MudTh>
                                        <MudTh>Gold Earned</MudTh>
                                        <MudTh>Caught At</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="fishCatch">
                                        <MudTd DataLabel="Player">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                                <MudText><strong>@fishCatch.Username</strong></MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Image">
                                            @if (!string.IsNullOrEmpty(fishCatch.FishType?.ImageFileName))
                                            {
                                                <MudImage Src="@FishImageHelper.GetImagePath(fishCatch.FishType.ImageFileName, ImageSize.Thumbnail)" 
                                                          Alt="@fishCatch.FishType.Name" 
                                                          Width="50"
                                                          Height="50"
                                                          ObjectFit="ObjectFit.Contain"
                                                          Elevation="2"
                                                          Class="rounded" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Medium" Color="Color.Default" Style="opacity: 0.3;" />
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Fish">
                                            <MudText>@fishCatch.FishType?.Name</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="Rarity">
                                            <MudChip T="string" 
                                                     Color="GetRarityColor(fishCatch.FishType?.Rarity ?? FishRarity.Common)" 
                                                     Size="Size.Small">
                                                @fishCatch.FishType?.Rarity
                                            </MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="Stars">
                                            @for (int i = 0; i < fishCatch.Stars; i++)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Weight">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Info" />
                                                <MudText>@fishCatch.Weight kg</MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Gold Earned">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                                <MudText>@fishCatch.GoldEarned</MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Caught At">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Default" />
                                                <MudText>@fishCatch.CaughtAt.ToLocalTime().ToString("g")</MudText>
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">@(showPersonalCatches ? "You haven't caught any fish yet. Go fishing!" : "No catches found yet. Start fishing!")</MudAlert>
                            }
                        </MudStack>
                    </MudTabPanel>

                    <AuthorizeView>
                        <Authorized>
                            <MudTabPanel Text="Dex" Icon="@Icons.Material.Filled.MenuBook">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 mt-4">
                            <MudText Typo="Typo.h5">
                                <MudIcon Icon="@Icons.Material.Filled.Collections" Size="Size.Large" Class="mr-2" />
                                Your Fish Collection
                            </MudText>
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="RefreshDex"
                                       Disabled="@isLoadingDex"
                                       Size="Size.Small">
                                @if (isLoadingDex)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <text>Loading...</text>
                                }
                                else
                                {
                                    <text>Refresh</text>
                                }
                            </MudButton>
                        </MudStack>

                        @if (isLoadingDex)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                                <MudText Typo="Typo.body1" Color="Color.Secondary">Loading your fish collection...</MudText>
                            </MudStack>
                        }
                        else if (fishTypes.Any())
                        {
                            <MudGrid>
                                @foreach (var fish in fishTypes.OrderBy(f => (int)f.Rarity).ThenBy(f => f.Name))
                                {
                                    var userBest = userDexCatches.FirstOrDefault(c => c.FishTypeId == fish.Id);
                                    var hasCaught = userBest != null;
                                    var catchCount = userDexCatchCounts.GetValueOrDefault(fish.Id, 0);

                                    <MudItem xs="12" sm="6" md="4" lg="3">
                                        <MudCard Elevation="4" Class="@(hasCaught ? "" : "opacity-50")">
                                            <div style="height: 200px; display: flex; align-items: center; justify-content: center; padding: 8px; background: rgba(0,0,0,0.02);">
                                                @if (!string.IsNullOrEmpty(fish.ImageFileName))
                                                {
                                                    <MudImage Src="@FishImageHelper.GetImagePath(fish.ImageFileName, ImageSize.Medium)" 
                                                              Alt="@fish.Name" 
                                                              ObjectFit="ObjectFit.Contain"
                                                              Style="@($"max-width: 100%; max-height: 184px; width: auto; height: auto; {(hasCaught ? "" : "filter: grayscale(100%) brightness(0.7);")}")" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Size="Size.Large" Style="font-size: 100px; opacity: 0.3;" />
                                                }
                                            </div>
                                            <MudCardContent>
                                                <MudStack Spacing="2">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                        <MudText Typo="Typo.h6">@(hasCaught ? fish.Name : "???")</MudText>
                                                        <MudChip T="string" 
                                                                 Color="GetRarityColor(fish.Rarity)" 
                                                                 Size="Size.Small">
                                                            @fish.Rarity
                                                        </MudChip>
                                                    </MudStack>

                                                    @if (hasCaught && userBest != null)
                                                    {
                                                        <MudDivider />
                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                            <MudText Typo="Typo.subtitle2" Color="Color.Success">
                                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                                                Caught!
                                                            </MudText>
                                                            <MudChip T="string" Color="Color.Info" Size="Size.Small">
                                                                @catchCount @(catchCount == 1 ? "catch" : "catches")
                                                            </MudChip>
                                                        </MudStack>
                                                        <MudStack Spacing="1">
                                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                                <MudText Typo="Typo.body2"><strong>Best:</strong></MudText>
                                                                @for (int i = 0; i < userBest.Stars; i++)
                                                                {
                                                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                                                }
                                                            </MudStack>
                                                            <MudText Typo="Typo.body2">
                                                                <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Info" />
                                                                @userBest.Weight kg
                                                            </MudText>
                                                            <MudText Typo="Typo.body2">
                                                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                                                @userBest.GoldEarned gold
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                @userBest.CaughtAt.ToLocalTime().ToString("g")
                                                            </MudText>
                                                        </MudStack>
                                                    }
                                                    else
                                                    {
                                                        <MudDivider />
                                                        <MudText Typo="Typo.subtitle2" Color="Color.Default">
                                                            <MudIcon Icon="@Icons.Material.Filled.Help" Size="Size.Small" />
                                                            Not caught yet
                                                        </MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            Base Weight: @fish.BaseWeight kg
                                                        </MudText>
                                                    }
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                }
                            </MudGrid>

                            <MudPaper Elevation="3" Class="pa-4 mt-4">
                                <MudStack Row="true" Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Class="flex-wrap">
                                    <MudStack AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.h4">@userDexCatches.Count</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Caught</MudText>
                                    </MudStack>
                                    <MudDivider Vertical="true" FlexItem="true" />
                                    <MudStack AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.h4">@fishTypes.Count</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Fish</MudText>
                                    </MudStack>
                                    <MudDivider Vertical="true" FlexItem="true" />
                                    <MudStack AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.h4">@GetCompletionPercentage()%</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Completion</MudText>
                                    </MudStack>
                                </MudStack>
                                <MudProgressLinear Color="Color.Success" 
                                                   Value="@GetCompletionPercentage()" 
                                                   Class="mt-4" 
                                                   Size="Size.Large" />
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">No fish types have been configured yet.</MudAlert>
                        }
                                </MudTabPanel>
                            </Authorized>
                        </AuthorizeView>
                    </MudTabs>

                    <AuthorizeView>
                        <NotAuthorized>
                            <MudPaper Elevation="6" Class="pa-6 mt-4" Style="border: 2px solid var(--mud-palette-primary);">
                                <MudStack Spacing="4" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary">
                                        <strong>Unlock Your Personal Dex</strong>
                                    </MudText>
                                    <MudText Typo="Typo.body1" Align="Align.Center">
                                        Sign in to track your personal fish collection, access the shop, and purchase boosts to improve your fishing odds!
                                    </MudText>
                                    <MudStack Row="true" Spacing="2" Class="flex-wrap" Justify="Justify.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Info" />
                                        <MudText Typo="Typo.body2" Color="Color.Info"><strong>Personal Dex</strong></MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.Store" Color="Color.Success" />
                                        <MudText Typo="Typo.body2" Color="Color.Success"><strong>Shop Access</strong></MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Warning" />
                                        <MudText Typo="Typo.body2" Color="Color.Warning"><strong>Fishing Boosts</strong></MudText>
                                    </MudStack>
                            <MudButton OnClick="Signin"
                                               Variant="Variant.Filled" 
                                               Color="Color.Primary" 
                                               Size="Size.Large"
                                               StartIcon="@Icons.Material.Filled.Login"
                                               Style="width: 300px;">
                                        Sign In with Twitch
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </NotAuthorized>
                    </AuthorizeView>
        }
    </MudStack>
</MudContainer>

@code {
    [Inject] private IFishingService fishingService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private List<FishType> fishTypes = new();
    private List<FishType> leaderboardFishTypes = new();
    private List<FishCatch> topCatches = new();
    private List<FishCatch> userDexCatches = new();
    private Dictionary<int, int> userDexCatchCounts = new();
    private int selectedFishTypeId = 0;
    private string currentUserId = string.Empty;

    // New leaderboards
    private List<LeaderPosition> goldLeaderboard = new();
    private List<FishCatch> valuableCatchesLeaderboard = new();
    private List<FishCatch> recentCatches = new();
    private bool showPersonalCatches = false;

    // Loading states
    private bool isLoadingFishLeaderboard = false;
    private bool isLoadingGoldLeaderboard = false;
    private bool isLoadingValuableCatches = false;
    private bool isLoadingDex = false;
    private bool isLoadingRecentCatches = false;
    private bool isInitialLoading = true;

    // SignalR connection
    private IJSObjectReference? signalRModule;
    private DotNetObjectReference<FishingLeaderboard>? dotNetReference;

    protected override async Task OnInitializedAsync()
    {
        isInitialLoading = true;
        try
        {
            fishTypes = await fishingService.GetAllFishTypes();
            leaderboardFishTypes = await fishingService.GetFishTypesWithCatches();

            if (leaderboardFishTypes.Any())
            {
                selectedFishTypeId = leaderboardFishTypes.First().Id;
                await LoadLeaderboard();
            }

            // Load new leaderboards
            await LoadGoldLeaderboard();
            await LoadValuableCatchesLeaderboard();
            await LoadRecentCatches();

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                currentUserId = authState.User.FindFirst("sub")?.Value 
                    ?? authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value 
                    ?? string.Empty;

                if (!string.IsNullOrEmpty(currentUserId))
                {
                    await LoadUserData();
                }
            }

            // Setup SignalR connection for real-time updates
            await SetupSignalR();
        }
        finally
        {
            isInitialLoading = false;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (selectedFishTypeId > 0)
        {
            await LoadLeaderboard();
        }
    }

    private async Task LoadLeaderboard()
    {
        isLoadingFishLeaderboard = true;
        try
        {
            topCatches = await fishingService.GetTopCatchesForFishType(selectedFishTypeId, 100);
        }
        finally
        {
            isLoadingFishLeaderboard = false;
        }
    }

    private async Task LoadUserData()
    {
        await LoadUserDex();
    }

    private async Task LoadUserDex()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        isLoadingDex = true;
        try
        {
            var bestCatchesDict = await fishingService.GetUserBestCatchesForAllFishTypes(currentUserId);
            userDexCatches = bestCatchesDict.Values.ToList();
            userDexCatchCounts = await fishingService.GetUserCatchCountsForAllFishTypes(currentUserId);
        }
        finally
        {
            isLoadingDex = false;
        }
    }

    private async Task OnFishTypeChanged(int newFishTypeId)
    {
        selectedFishTypeId = newFishTypeId;
        await LoadLeaderboard();
    }

    private async Task RefreshLeaderboard()
    {
        await RefreshAllData();
    }

    private async Task RefreshDex()
    {
        await RefreshAllData();
    }

    private async Task RefreshGoldLeaderboard()
    {
        await RefreshAllData();
    }

    private async Task RefreshValuableCatchesLeaderboard()
    {
        await RefreshAllData();
    }

    private async Task RefreshAllData()
    {
        // Set all loading states
        isLoadingFishLeaderboard = true;
        isLoadingGoldLeaderboard = true;
        isLoadingValuableCatches = true;
        isLoadingRecentCatches = true;
        if (!string.IsNullOrEmpty(currentUserId))
        {
            isLoadingDex = true;
        }

        try
        {
            // Reload core data
            fishTypes = await fishingService.GetAllFishTypes();
            leaderboardFishTypes = await fishingService.GetFishTypesWithCatches();

            // Reload all leaderboards in parallel for better performance
            var tasks = new List<Task>
            {
                LoadLeaderboard(),
                LoadGoldLeaderboard(),
                LoadValuableCatchesLeaderboard(),
                LoadRecentCatches()
            };

            if (!string.IsNullOrEmpty(currentUserId))
            {
                tasks.Add(LoadUserDex());
            }

            await Task.WhenAll(tasks);
        }
        catch (Exception)
        {
            // Reset all loading states on error
            isLoadingFishLeaderboard = false;
            isLoadingGoldLeaderboard = false;
            isLoadingValuableCatches = false;
            isLoadingDex = false;
            isLoadingRecentCatches = false;
            throw;
        }
    }

    private int GetCompletionPercentage()
    {
        if (fishTypes.Count == 0) return 0;
        return (int)Math.Round((double)userDexCatches.Count / fishTypes.Count * 100);
    }

    private Color GetRarityColor(FishRarity rarity) => rarity switch
    {
        FishRarity.Common => Color.Default,
        FishRarity.Uncommon => Color.Success,
        FishRarity.Rare => Color.Info,
        FishRarity.Epic => Color.Secondary,
        FishRarity.Legendary => Color.Warning,
        _ => Color.Default
    };

    private async Task LoadGoldLeaderboard()
    {
        isLoadingGoldLeaderboard = true;
        try
        {
            goldLeaderboard = await fishingService.GetTotalGoldLeaderboard(50);
        }
        finally
        {
            isLoadingGoldLeaderboard = false;
        }
    }

    private async Task LoadValuableCatchesLeaderboard()
    {
        isLoadingValuableCatches = true;
        try
        {
            valuableCatchesLeaderboard = await fishingService.GetMostValuableCatchesLeaderboard(50);
        }
        finally
        {
            isLoadingValuableCatches = false;
        }
    }

    private async Task LoadRecentCatches()
    {
        isLoadingRecentCatches = true;
        try
        {
            if (showPersonalCatches && !string.IsNullOrEmpty(currentUserId))
            {
                recentCatches = await fishingService.GetUserRecentCatches(currentUserId, 50);
            }
            else
            {
                recentCatches = await fishingService.GetRecentCatches(50);
            }
        }
        finally
        {
            isLoadingRecentCatches = false;
        }
    }

    private async Task RefreshRecentCatches()
    {
        await LoadRecentCatches();
    }

    private async Task OnShowPersonalCatchesChanged(bool value)
    {
        showPersonalCatches = value;
        await LoadRecentCatches();
    }

    private async Task SetupSignalR()
    {
        try
        {
            dotNetReference = DotNetObjectReference.Create(this);
            signalRModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/fishingSignalR.js");
            await signalRModule.InvokeVoidAsync("setupFishingConnection", dotNetReference);
        }
        catch (Exception ex)
        {
            // Log but don't fail if SignalR setup fails
            Console.WriteLine($"Failed to setup SignalR: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnFishCaught(string userId, string username, string fishName, string fishRarity, int stars, double weight, int goldEarned)
    {
        // Determine if we should add this catch to our recent list
        bool shouldAdd = !showPersonalCatches || (showPersonalCatches && userId == currentUserId);

        if (shouldAdd)
        {
            // Reload recent catches to get the latest data
            await LoadRecentCatches();
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (signalRModule != null)
        {
            try
            {
                await signalRModule.InvokeVoidAsync("disconnectFishing");
                await signalRModule.DisposeAsync();
            }
            catch { /* Ignore disposal errors */ }
        }

        dotNetReference?.Dispose();
    }

    private RenderFragment RenderRankBadge(int rank) => __builder =>
    {
        if (rank == 1)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Size="Size.Small" />
                <MudText><strong>#@rank</strong></MudText>
            </MudStack>
        }
        else if (rank == 2)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: silver;" Size="Size.Small" />
                <MudText><strong>#@rank</strong></MudText>
            </MudStack>
        }
        else if (rank == 3)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: #CD7F32;" Size="Size.Small" />
                <MudText><strong>#@rank</strong></MudText>
            </MudStack>
        }
        else
        {
            <MudText><strong>#@rank</strong></MudText>
        }
    };

    private void Signin()
    {
        Navigation.NavigateTo("/signin?r=" + new Uri(Navigation.Uri).AbsoluteUri, true);
    }
}
