    private Color GetUsesColor(UserFishingBoost item)
    {
        if (item.RemainingUses < 0) return Color.Success;
        var maxUses = shopItemsById.TryGetValue(item.ShopItemId, out var shopItem) ? shopItem.MaxUses ?? 1 : 1;
        var percentage = (double)item.RemainingUses / maxUses;
        return percentage switch
        {
            > 0.5 => Color.Success,
            > 0.25 => Color.Warning,
            _ => Color.Error
        };
    }

    private async Task SellItem(int userBoostId)
    {
        if (sellingBoostId.HasValue)
        {
            return;
        }

        var boost = userBoosts.FirstOrDefault(b => b.Id == userBoostId);
        if (boost == null)
        {
            Snackbar.Add("Item not found", Severity.Error);
            return;
        }

        var shopItem = boost.ShopItem ?? (shopItemsById.TryGetValue(boost.ShopItemId, out var lookupItem) ? lookupItem : null);
        var sellEligibility = FishingInventorySellRules.GetSellEligibility(boost, shopItem);
        if (sellEligibility != SellEligibilityReason.Eligible)
        {
            Snackbar.Add(FishingInventorySellRules.GetSellFailureMessage(sellEligibility), Severity.Error);
            return;
        }

        bool? result = await DialogService.ShowMessageBoxAsync(
            "Confirm Sale",
            $"Are you sure you want to sell this item for {FishingInventorySellRules.GetSellPrice(shopItem)} gold? This action cannot be undone.",
            yesText: "Sell",
            noText: "Cancel",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (result != true)
        {
            return;
        }

        sellingBoostId = userBoostId;
        try
        {
            await inventoryService.SellItem(userId, userBoostId);
            Snackbar.Add("Item sold successfully", Severity.Success);
            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to sell item. Please try again.", Severity.Error);
        }
        finally
        {
            sellingBoostId = null;
        }
    }

