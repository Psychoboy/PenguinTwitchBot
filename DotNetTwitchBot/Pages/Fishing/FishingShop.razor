@page "/fishing/shop"
@using DotNetTwitchBot.Bot.Commands.Fishing
@using DotNetTwitchBot.Bot.Models.Fishing
@using DotNetTwitchBot.Components.Fishing
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize]

<PageTitle>Fishing Shop</PageTitle>

<MudContainer Class="pa-2" MaxWidth="MaxWidth.ExtraLarge">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h4" Align="Align.Center">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Medium" Class="mr-1" />
            Fishing Shop
        </MudText>

        <MudPaper Elevation="2" Class="pa-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Warning" Size="Size.Medium" />
                    <MudText Typo="Typo.h6">Gold: <MudChip T="string" Color="Color.Warning" Size="Size.Medium">@userGold</MudChip></MudText>
                </MudStack>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RefreshShop"
                               Disabled="@isLoading"
                               Size="Size.Small">
                        @if (isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Loading...</text>
                        }
                        else
                        {
                            <text>Refresh</text>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Inventory"
                               Href="/fishing/inventory">
                        View Inventory
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">Loading shop items...</MudText>
            </MudStack>
        }
        else if (shopItems.Any(i => i.Enabled))
        {
            <MudPaper Elevation="2" Class="pa-3 mb-2">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="EquipmentSlot?" 
                                   @bind-Value="filterSlot" 
                                   Label="Equipment Slot" 
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   dense="true"
                                   AdornmentIcon="@Icons.Material.Filled.Category">
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)null)">All Slots</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Rod)">Rod</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Reel)">Reel</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Line)">Line</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Lure)">Lure</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Bait)">Bait</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Hook)">Hook</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.TackleBox)">Tackle Box</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Net)">Net</MudSelectItem>
                            <MudSelectItem T="EquipmentSlot?" Value="@((EquipmentSlot?)EquipmentSlot.Special)">Special</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="FishingBoostType?" 
                                   @bind-Value="filterBoostType" 
                                   Label="Boost Type" 
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   dense="true"
                                   AdornmentIcon="@Icons.Material.Filled.TrendingUp">
                            <MudSelectItem T="FishingBoostType?" Value="@((FishingBoostType?)null)">All Types</MudSelectItem>
                            <MudSelectItem T="FishingBoostType?" Value="@((FishingBoostType?)FishingBoostType.GeneralRarityBoost)">Rarity Boost</MudSelectItem>
                            <MudSelectItem T="FishingBoostType?" Value="@((FishingBoostType?)FishingBoostType.StarBoost)">Star Boost</MudSelectItem>
                            <MudSelectItem T="FishingBoostType?" Value="@((FishingBoostType?)FishingBoostType.WeightBoost)">Weight Boost</MudSelectItem>
                            <MudSelectItem T="FishingBoostType?" Value="@((FishingBoostType?)FishingBoostType.SpecificFishBoost)">Fish-Specific</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="bool?" 
                                   @bind-Value="filterConsumable" 
                                   Label="Item Type" 
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   dense="true"
                                   AdornmentIcon="@Icons.Material.Filled.FilterList">
                            <MudSelectItem T="bool?" Value="@((bool?)null)">All Items</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)false)">Permanent</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)true)">Consumable</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField T="string" 
                                      @bind-Value="filterSearch" 
                                      Label="Search" 
                                      Variant="Variant.Outlined"
                                      dense="true"
                                      Immediate="true"
                                      DebounceInterval="300"
                                      Clearable="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Store" Color="Color.Primary" Size="Size.Medium" Class="mr-1" />
                    Available Items (@filteredShopItems.Count)
                </MudText>

                <MudTable Items="@filteredShopItems" dense="true" Hover="true" Striped="true" Elevation="1">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Type/Target</MudTh>
                        <MudTh>Boost</MudTh>
                        <MudTh>Slot/Uses</MudTh>
                        <MudTh>Cost</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Item">
                            <MudStack Spacing="0">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.body2"><strong>@context.Name</strong></MudText>
                                    @if (!context.IsConsumable)
                                    {
                                        var tier = tierMap.ContainsKey(context.Id) ? tierMap[context.Id] : context.GetTier();
                                        var (tierColor, tierIcon) = GetTierDisplay(tier);
                                        <MudChip T="string" Color="@tierColor" Size="Size.Small" Icon="@tierIcon">@tier</MudChip>

                                        var tierComparison = GetTierComparisonIndicator(context);
                                        if (tierComparison.HasValue)
                                        {
                                            var (indicatorColor, indicatorIcon, indicatorText) = tierComparison.Value;
                                            <MudChip T="string" Color="@indicatorColor" Size="Size.Small" Icon="@indicatorIcon">@indicatorText</MudChip>
                                        }
                                    }
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Type/Target">
                            <MudStack Spacing="0">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(context.BoostType)</MudChip>
                                @if (context.BoostType2.HasValue)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(context.BoostType2.Value)</MudChip>
                                }
                                @if (context.BoostType3.HasValue)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(context.BoostType3.Value)</MudChip>
                                }
                                @if (context.TargetFishTypeId.HasValue)
                                {
                                    if (fishTypeLookup.TryGetValue(context.TargetFishTypeId.Value, out var fishName))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">→ @fishName</MudText>
                                    }
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Boost">
                            <MudStack Spacing="0">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">+@((context.BoostAmount * 100).ToString("F0"))%</MudChip>
                                @if (context.BoostType2.HasValue && context.BoostAmount2.HasValue)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">+@((context.BoostAmount2.Value * 100).ToString("F0"))%</MudChip>
                                }
                                @if (context.BoostType3.HasValue && context.BoostAmount3.HasValue)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">+@((context.BoostAmount3.Value * 100).ToString("F0"))%</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Slot/Uses">
                            <MudStack Spacing="0">
                                @if (context.EquipmentSlot.HasValue)
                                {
                                    <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Icon="@GetSlotIcon(context.EquipmentSlot.Value)">@context.EquipmentSlot.Value</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Permanent</MudChip>
                                }
                                @if (context.MaxUses.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.MaxUses uses</MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Success">Unlimited</MudText>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Cost">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Warning"><strong>@context.Cost</strong></MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Outlined" 
                                     Color="Color.Info" 
                                     Size="Size.Small"
                                     StartIcon="@Icons.Material.Filled.Info"
                                     OnClick="@(() => ShowItemPreview(context))">Preview</MudButton>
                            <MudButton Variant="Variant.Filled" 
                                     Color="Color.Primary" 
                                     Size="Size.Small"
                                     StartIcon="@Icons.Material.Filled.ShoppingCart"
                                     Disabled="@IsPurchaseButtonDisabled(context)"
                                     OnClick="@(() => PurchaseItem(context.Id))">
                                @GetPurchaseButtonText(context)
                            </MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudStack>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
                No shop items available yet. Check back later!
            </MudAlert>
        }

        @if (userBoosts.Any())
        {
            <MudStack Spacing="1" Class="mt-3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Success" Size="Size.Medium" Class="mr-1" />
                    Your Items (@userBoosts.Count)
                </MudText>

                <MudTable Items="@userBoosts" Striped="true" Hover="true" dense="true" Elevation="1">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Slot</MudTh>
                        <MudTh>Type/Target</MudTh>
                        <MudTh>Boost</MudTh>
                        <MudTh>Uses</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Purchased</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="boost">
                        @{
                            shopItemsById.TryGetValue(boost.ShopItemId, out var shopItem);
                            FishType? fishType = null;
                            if (shopItem?.TargetFishTypeId.HasValue == true)
                            {
                                fishTypesById.TryGetValue(shopItem.TargetFishTypeId.Value, out fishType);
                            }
                        }
                        <MudTd DataLabel="Item">
                            <MudStack Spacing="0">
                                <MudText><strong>@shopItem?.Name</strong></MudText>
                                @if (fishType != null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">→ @fishType.Name</MudText>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Slot">
                            @if (shopItem?.EquipmentSlot.HasValue == true)
                            {
                                <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Icon="@GetSlotIcon(shopItem.EquipmentSlot.Value)">
                                    @shopItem.EquipmentSlot.Value
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Permanent</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Boost Type">
                            <MudStack Spacing="0">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(shopItem?.BoostType ?? FishingBoostType.GeneralRarityBoost)</MudChip>
                                @if (shopItem?.BoostType2.HasValue == true)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(shopItem.BoostType2.Value)</MudChip>
                                }
                                @if (shopItem?.BoostType3.HasValue == true)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(shopItem.BoostType3.Value)</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Boost">
                            <MudStack Spacing="0">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">+@((shopItem?.BoostAmount * 100 ?? 0).ToString("F0"))%</MudChip>
                                @if (shopItem?.BoostType2.HasValue == true && shopItem?.BoostAmount2.HasValue == true)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">+@((shopItem.BoostAmount2.Value * 100).ToString("F0"))%</MudChip>
                                }
                                @if (shopItem?.BoostType3.HasValue == true && shopItem?.BoostAmount3.HasValue == true)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">+@((shopItem.BoostAmount3.Value * 100).ToString("F0"))%</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Uses">
                            @if (boost.RemainingUses >= 0)
                            {
                                <MudText Typo="Typo.body2" Color="@GetUsesColor(boost)">@boost.RemainingUses / @(shopItem?.MaxUses ?? 0)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Success">∞</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Status">
                            @if (boost.IsEquipped)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                            else if (shopItem?.IsConsumable == true && boost.RemainingUses == 0)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Default" Size="Size.Small" />
                            }
                        </MudTd>
                        <MudTd DataLabel="Purchased">
                            <MudText Typo="Typo.caption">@boost.PurchasedAt.ToString("MM/dd")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @if (shopItem?.IsConsumable == true && boost.RemainingUses == 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error">Depleted</MudText>
                            }
                            else if (boost.IsEquipped)
                            {
                                <MudButton Variant="Variant.Text" 
                                          Color="Color.Error" 
                                          Size="Size.Small"
                                          StartIcon="@Icons.Material.Filled.Remove"
                                          OnClick="@(() => UnequipItem(boost.Id))">
                                    Unequip
                                </MudButton>
                            }
                            else
                            {
                                @if (FishingInventorySellRules.CanSell(boost, shopItem))
                                {
                                    <MudTooltip Text="@($"Sell for {FishingInventorySellRules.GetSellPrice(shopItem)} gold")">
                                        <MudButton Variant="Variant.Text"
                                                  Color="Color.Info"
                                                  Size="Size.Small"
                                                  StartIcon="@Icons.Material.Filled.Sell"
                                                  Disabled="@(sellingBoostId == boost.Id)"
                                                  OnClick="@(() => SellItem(boost.Id))">
                                            @(sellingBoostId == boost.Id ? "Selling..." : "Sell")
                                        </MudButton>
                                    </MudTooltip>
                                }

                                <MudButton Variant="Variant.Text" 
                                          Color="Color.Success" 
                                          Size="Size.Small"
                                          StartIcon="@Icons.Material.Filled.Add"
                                          OnClick="@(() => EquipItem(boost.Id))">
                                    Equip
                                </MudButton>
                            }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudStack>
        }
    </MudStack>
</MudContainer>

<MudDialog @bind-Visible="previewDialogVisible" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Preview" Class="mr-1" />
            Item Preview
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (selectedPreviewItem != null)
        {
            <ItemPurchasePreview ShopItem="@selectedPreviewItem"
                                 CurrentEquippedItemIds="@equippedItemIds"
                                 CurrentEquippedItems="@equippedItems" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => previewDialogVisible = false)" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IFishingService fishingService { get; set; } = null!;
    [Inject] private IFishingShopService shopService { get; set; } = null!;
    [Inject] private IFishingInventoryService inventoryService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private IHttpContextAccessor HttpContextAccessor { get; set; } = null!;

    private string userId = string.Empty;
    private List<FishType> fishTypes = new();
    private List<FishingShopItem> shopItems = new();
    private List<UserFishingBoost> userBoosts = new();
    private int userGold = 0;
    private bool isPurchasing = false;
    private int? confirmingPurchaseItemId = null;
    private int? sellingBoostId = null;
    private bool isLoading = false;

    // Preview dialog
    private bool previewDialogVisible = false;
    private FishingShopItem? selectedPreviewItem = null;
    private DialogOptions dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Filter state with cache invalidation
    private EquipmentSlot? _filterSlot = null;
    private EquipmentSlot? filterSlot
    {
        get => _filterSlot;
        set
        {
            if (_filterSlot == value)
            {
                return;
            }

            _filterSlot = value;
            ApplyFilters();
        }
    }

    private FishingBoostType? _filterBoostType = null;
    private FishingBoostType? filterBoostType
    {
        get => _filterBoostType;
        set
        {
            if (_filterBoostType == value)
            {
                return;
            }

            _filterBoostType = value;
            ApplyFilters();
        }
    }

    private bool? _filterConsumable = null;
    private bool? filterConsumable
    {
        get => _filterConsumable;
        set
        {
            if (_filterConsumable == value)
            {
                return;
            }

            _filterConsumable = value;
            ApplyFilters();
        }
    }

    private string _filterSearch = string.Empty;
    private string filterSearch
    {
        get => _filterSearch;
        set
        {
            if (string.Equals(_filterSearch, value, StringComparison.Ordinal))
            {
                return;
            }

            _filterSearch = value;
            ApplyFilters();
        }
    }

    // Performance optimization: cached filter results and lookups
    private List<FishingShopItem> filteredShopItems = new();
    private Dictionary<int, string> fishTypeLookup = new();
    private Dictionary<int, FishType> fishTypesById = new();
    private Dictionary<int, FishingShopItem> shopItemsById = new();
    private Dictionary<EquipmentSlot, FishingShopItem> equippedShopItemBySlot = new();
    private Dictionary<int, EquipmentTier> tierMap = new(); // Dynamic tier assignments
    private List<int> equippedItemIds = new();
    private List<FishingShopItem> equippedItems = new();

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        userId = user?.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        if (!string.IsNullOrEmpty(userId))
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            fishTypes = await fishingService.GetAllFishTypes();
            shopItems = await shopService.GetAllShopItems();
            tierMap = shopService.CalculateDynamicTiers(shopItems); // Use overload to avoid extra DB query
            userBoosts = await inventoryService.GetUserBoosts(userId);
            var goldData = await fishingService.GetUserGold(userId);
            userGold = goldData?.TotalGold ?? 0;

            // Build lookups for O(1) access in render paths
            fishTypeLookup = fishTypes.ToDictionary(f => f.Id, f => f.Name);
            fishTypesById = fishTypes.ToDictionary(f => f.Id, f => f);
            shopItemsById = shopItems.ToDictionary(i => i.Id, i => i);

            // Cache equipped item lists to avoid repeated LINQ on every render
            equippedItemIds = userBoosts.Where(b => b.IsEquipped).Select(b => b.ShopItemId).ToList();
            equippedItems = userBoosts.Where(b => b.IsEquipped && b.ShopItem != null).Select(b => b.ShopItem!).ToList();
            equippedShopItemBySlot = userBoosts
                .Where(b => b.IsEquipped && b.ShopItem?.EquipmentSlot.HasValue == true)
                .Select(b => b.ShopItem!)
                .GroupBy(i => i.EquipmentSlot!.Value)
                .ToDictionary(g => g.Key, g => g.First());

            ApplyFilters();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshShop()
    {
        await LoadData();
    }

    private void ShowItemPreview(FishingShopItem item)
    {
        selectedPreviewItem = item;
        previewDialogVisible = true;
    }

    private async Task PurchaseItem(int shopItemId)
    {
        if (isPurchasing || confirmingPurchaseItemId == shopItemId) return;

        if (!shopItemsById.TryGetValue(shopItemId, out var itemToBuy))
        {
            Snackbar.Add("Item not found.", Severity.Error);
            return;
        }

        try
        {
            confirmingPurchaseItemId = shopItemId;

            bool? result = await DialogService.ShowMessageBoxAsync(
                "Confirm Purchase",
                $"Buy {itemToBuy.Name} for {itemToBuy.Cost} gold?",
                yesText: "Buy",
                cancelText: "Cancel");

            if (result != true)
            {
                return;
            }

            isPurchasing = true;
            await inventoryService.PurchaseBoost(userId, shopItemId);
            Snackbar.Add("Item purchased successfully!", Severity.Success);
            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to purchase item. Please try again.", Severity.Error);
        }
        finally
        {
            isPurchasing = false;
            confirmingPurchaseItemId = null;
        }
    }

    private bool IsPurchaseButtonDisabled(FishingShopItem item)
    {
        return userGold < item.Cost || confirmingPurchaseItemId == item.Id;
    }

    private string GetPurchaseButtonText(FishingShopItem item)
    {
        if (userGold < item.Cost)
        {
            return "No Gold";
        }

        if (isPurchasing && confirmingPurchaseItemId == item.Id)
        {
            return "Buying...";
        }

        if (confirmingPurchaseItemId == item.Id)
        {
            return "Confirming...";
        }

        return "Buy";
    }

    private void ApplyFilters()
    {
        // Start with enabled items that are not admin-only
        var filtered = shopItems.Where(i => i.Enabled && !i.IsAdminOnly);

        // Filter by slot
        if (filterSlot.HasValue)
        {
            filtered = filtered.Where(i => i.EquipmentSlot == filterSlot.Value);
        }

        // Filter by boost type
        if (filterBoostType.HasValue)
        {
            filtered = filtered.Where(i => 
                i.BoostType == filterBoostType.Value ||
                i.BoostType2 == filterBoostType.Value ||
                i.BoostType3 == filterBoostType.Value);
        }

        // Filter by consumable/permanent
        if (filterConsumable.HasValue)
        {
            filtered = filtered.Where(i => i.IsConsumable == filterConsumable.Value);
        }

        // Filter by search text using culture-insensitive comparison
        if (!string.IsNullOrWhiteSpace(filterSearch))
        {
            filtered = filtered.Where(i =>
            {
                // Search in name and description using OrdinalIgnoreCase
                if (i.Name.Contains(filterSearch, StringComparison.OrdinalIgnoreCase))
                    return true;

                if (i.Description?.Contains(filterSearch, StringComparison.OrdinalIgnoreCase) == true)
                    return true;

                // Search in target fish name using lookup dictionary (O(1) instead of O(n))
                if (i.TargetFishTypeId.HasValue &&
                    fishTypeLookup.TryGetValue(i.TargetFishTypeId.Value, out var fishName) &&
                    fishName.Contains(filterSearch, StringComparison.OrdinalIgnoreCase))
                    return true;

                return false;
            });
        }

        filteredShopItems = filtered.OrderBy(i => i.Cost).ToList();
    }

