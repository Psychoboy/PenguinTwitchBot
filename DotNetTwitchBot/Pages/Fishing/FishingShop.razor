            TierComparisonResult.Equipped => (Color.Success, Icons.Material.Filled.CheckCircle, "Equipped"),
            TierComparisonResult.Upgrade => (Color.Success, Icons.Material.Filled.ArrowUpward, "Upgrade"),
            TierComparisonResult.Downgrade => (Color.Error, Icons.Material.Filled.ArrowDownward, "Downgrade"),
            TierComparisonResult.Sidegrade => (Color.Default, Icons.Material.Filled.SwapHoriz, "Sidegrade"),
            _ => null
        };
    }

