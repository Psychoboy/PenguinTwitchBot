    private async Task SaveFish()
    {
        if (editingFish == null) return;

        try
        {
            var fishesPath = Path.Combine(WebHostEnvironment.WebRootPath, "fishes");
            Directory.CreateDirectory(fishesPath);

            // Use sanitized fish name as base filename
            var baseFileName = SanitizeFileName(editingFish.Name);

            // Save uploaded image file
            if (pendingImageFile != null)
            {
                // Delete old image variants if name changed
                if (!string.IsNullOrEmpty(editingFish.ImageFileName))
                {
                    var oldBaseFileName = FishImageHelper.GetBaseName(editingFish.ImageFileName);
                    if (oldBaseFileName != baseFileName)
                    {
                        ImageProcessor.DeleteImageAndVariants(fishesPath, oldBaseFileName);
                    }
                }

                // Process and save the new image with optimized variants
                using (var stream = pendingImageFile.OpenReadStream(maxAllowedSize: 10485760))
                {
                    var result = await ImageProcessor.ProcessImageAsync(stream, fishesPath, baseFileName);

                    // Store the medium size as the default image file name
                    if (result.ProcessedFiles.TryGetValue("medium", out var mediumFileName))
                    {
                        editingFish.ImageFileName = mediumFileName;
                    }

                    Snackbar.Add($"Image processed: {result.ProcessedFiles.Count} sizes created", Severity.Success);
                }
            }

            // Save sound file if provided (independent of image upload)
            if (pendingSoundFile != null)
            {
                var soundExtension = Path.GetExtension(pendingSoundFile.Name);
                var soundFileName = $"{baseFileName}{soundExtension}";
                var soundPath = Path.Combine(fishesPath, soundFileName);

                using (var stream = new FileStream(soundPath, FileMode.Create))
                {
                    await pendingSoundFile.OpenReadStream(maxAllowedSize: 10485760).CopyToAsync(stream);
                }
            }

            if (editingFish.Id == 0)
            {
                await fishingService.AddFishType(editingFish);
                Snackbar.Add("Fish type added successfully", Severity.Success);
            }
            else
            {
                await fishingService.UpdateFishType(editingFish);
                Snackbar.Add("Fish type updated successfully", Severity.Success);
            }

            await LoadData();
            fishDialogVisible = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving fish type: {ex.Message}", Severity.Error);
        }
    }

    private string SanitizeFileName(string fileName)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var sanitized = string.Join("_", fileName.Split(invalid, StringSplitOptions.RemoveEmptyEntries)).TrimEnd('.');
        return sanitized.ToLowerInvariant().Replace(" ", "_");
    }

