    private async Task<IEnumerable<FishingGold>> SearchPlayers(string searchString, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return allPlayers;

        return allPlayers.Where(p => 
            p.Username.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
            p.UserId.Contains(searchString, StringComparison.OrdinalIgnoreCase));
    }

    private async Task AddGoldToPlayer()
    {
        if (selectedPlayer == null || goldAmount <= 0) return;

        goldConfirmAction = "add";
        goldConfirmMessage = $"Are you sure you want to add {goldAmount} gold to {selectedPlayer.Username}?";
        goldConfirmVisible = true;
    }

    private async Task RemoveGoldFromPlayer()
    {
        if (selectedPlayer == null || goldAmount <= 0) return;

        if (selectedPlayer.TotalGold < goldAmount)
        {
            Snackbar.Add($"Player only has {selectedPlayer.TotalGold} gold", Severity.Warning);
            return;
        }

        goldConfirmAction = "remove";
        goldConfirmMessage = $"Are you sure you want to remove {goldAmount} gold from {selectedPlayer.Username}?";
        goldConfirmVisible = true;
    }

    private async Task SetPlayerGold()
    {
        if (selectedPlayer == null || goldAmount < 0) return;

        goldConfirmAction = "set";
        goldConfirmMessage = $"Are you sure you want to set {selectedPlayer.Username}'s gold to {goldAmount}?";
        goldConfirmVisible = true;
    }

    private async Task ExecuteGoldOperation()
    {
        if (selectedPlayer == null || isProcessing) return;

        isProcessing = true;
        try
        {
            switch (goldConfirmAction)
            {
                case "add":
                    await fishingService.AddGoldToUser(selectedPlayer.UserId, selectedPlayer.Username, goldAmount);
                    selectedPlayer.TotalGold += goldAmount;
                    Snackbar.Add($"Added {goldAmount} gold to {selectedPlayer.Username}", Severity.Success);
                    break;

                case "remove":
                    await fishingService.RemoveGoldFromUser(selectedPlayer.UserId, goldAmount);
                    selectedPlayer.TotalGold -= goldAmount;
                    Snackbar.Add($"Removed {goldAmount} gold from {selectedPlayer.Username}", Severity.Success);
                    break;

                case "set":
                    await fishingService.SetUserGold(selectedPlayer.UserId, selectedPlayer.Username, goldAmount);
                    selectedPlayer.TotalGold = goldAmount;
                    Snackbar.Add($"Set {selectedPlayer.Username}'s gold to {goldAmount}", Severity.Success);
                    break;
            }

            goldConfirmVisible = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error processing gold operation: {ex.Message}", Severity.Error);
        }
        finally
        {
            isProcessing = false;
        }
    }

    private Color GetGoldConfirmColor() => goldConfirmAction switch
    {
        "add" => Color.Success,
        "remove" => Color.Warning,
        "set" => Color.Info,
        _ => Color.Primary
    };

    private async Task GiveItemToPlayer()
    {
        if (selectedPlayer == null || !selectedItemToGive.HasValue || isProcessing) return;

        isProcessing = true;
        try
        {
            await inventoryService.GiveItemToUser(selectedPlayer.UserId, selectedItemToGive.Value);
            var item = shopItems.FirstOrDefault(i => i.Id == selectedItemToGive.Value);
            Snackbar.Add($"Gave {item?.Name ?? "item"} to {selectedPlayer.Username}", Severity.Success);
            selectedItemToGive = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error giving item: {ex.Message}", Severity.Error);
        }
        finally
        {
            isProcessing = false;
        }
    }

    // ===== PRICE UPDATE FUNCTIONALITY =====
    private bool showPriceUpdateDialog = false;
    private string priceUpdatePreset = "recommended";
    private double customMultiplier = 2.0;
    private bool updatePermanentOnly = true;
    private EquipmentSlot? updateSpecificSlot = null;
    private bool isUpdatingPrices = false;
    private Dictionary<string, int> calculatedRecommendations = new();
    private bool isCalculatingRecommendations = false;
    private int targetWeeksForEndgame = 26;

    private async Task ApplyPriceUpdates()
    {
        if (isUpdatingPrices) return;

        isUpdatingPrices = true;
        try
        {
            int updatedCount = 0;

            if (priceUpdatePreset == "recommended")
            {
                // Use calculated recommendations from real data
                var priceUpdates = await GetRecommendedPriceUpdates();
                updatedCount = await shopService.UpdateShopItemPrices(priceUpdates);
            }
            else if (priceUpdatePreset == "multiplier")
            {
                // Apply custom multiplier to selected items
                updatedCount = await shopService.ApplyPriceMultiplier(
                    customMultiplier, 
                    updatePermanentOnly, 
                    updateSpecificSlot
                );
            }

            if (updatedCount > 0)
            {
                Snackbar.Add($"Successfully updated {updatedCount} item prices", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("No items were updated", Severity.Info);
            }

            showPriceUpdateDialog = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating prices: {ex.Message}", Severity.Error);
        }
        finally
        {
            isUpdatingPrices = false;
        }
    }

    private async Task<Dictionary<string, int>> GetRecommendedPriceUpdates()
    {
        // Calculate pricing based on CURRENT real player engagement data
        return await analyticsService.CalculateRecommendedPricing(targetWeeksForEndgame);
    }

    private async Task CalculateRecommendations()
    {
        isCalculatingRecommendations = true;
        try
        {
            calculatedRecommendations = await analyticsService.CalculateRecommendedPricing(targetWeeksForEndgame);

            // Force UI refresh
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error calculating recommendations: {ex.Message}", Severity.Error);
        }
        finally
        {
            isCalculatingRecommendations = false;
        }
    }
}

<MudDialog @bind-Visible="showPriceUpdateDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Warning">
                <strong>Important:</strong> This will update shop item prices. Users who already own items will keep them at the original price - only future purchases will use new prices.
            </MudAlert>

            <MudText Typo="Typo.h6">Price Update Strategy</MudText>

            <MudRadioGroup @bind-Value="priceUpdatePreset">
                <MudRadio Value="@("recommended")" Color="Color.Primary">
                    <MudStack Spacing="1">
                        <MudText><strong>Data-Driven Balance Recommendations</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Based on CURRENT player engagement data. Calculates pricing from real catch rates and gold earnings to achieve balanced progression timeline.
                        </MudText>
                    </MudStack>
                </MudRadio>
                <MudRadio Value="@("multiplier")" Color="Color.Secondary">
                    <MudStack Spacing="1">
                        <MudText><strong>Custom Multiplier</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Apply a custom multiplier to selected item categories.
                        </MudText>
                    </MudStack>
                </MudRadio>
            </MudRadioGroup>

            @if (priceUpdatePreset == "recommended")
            {
                <MudNumericField @bind-Value="targetWeeksForEndgame" 
                                 Label="Target Weeks for Endgame Gear" 
                                 Min="4" 
                                 Max="52" 
                                 Step="1"
                                 Variant="Variant.Outlined"
                                 HelperText="How many weeks should it take an active player to afford top-tier equipment?" />

                <MudButton OnClick="CalculateRecommendations"
                           Color="Color.Info"
                           Variant="Variant.Filled"
                           Disabled="@isCalculatingRecommendations"
                           FullWidth="true">
                    @if (isCalculatingRecommendations)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>Calculating from real data...</text>
                    }
                    else
                    {
                        <text>Calculate Pricing from Current Data</text>
                    }
                </MudButton>

                @if (calculatedRecommendations.Any())
                {
                    <MudPaper Class="pa-3" Elevation="1" Style="background-color: var(--mud-palette-info-lighten);">
                        <MudText Typo="Typo.caption" Color="Color.Info">
                            <strong>🔍 Debug Info:</strong> Pricing calculated from current player data. 
                            If these prices seem wrong, check the Output window (View → Output → select ".NET App Modernization" or "Build") for detailed [PRICING] logs showing the calculation breakdown.
                        </MudText>
                    </MudPaper>

                    <MudPaper Class="pa-3" Elevation="2">
                        <MudText Typo="Typo.subtitle2" Class="mb-2"><strong>Calculated Recommendations (@calculatedRecommendations.Count items):</strong></MudText>
                        <MudStack Spacing="1">
                            @{
                                var entryItems = calculatedRecommendations.Where(kvp => kvp.Key.Contains("Bamboo") || kvp.Key.Contains("Basic") || kvp.Key.Contains("Monofilament") || kvp.Key.Contains("Standard") || kvp.Key.Contains("Landing")).ToList();
                                var midItems = calculatedRecommendations.Where(kvp => kvp.Key.Contains("Fiberglass") || kvp.Key.Contains("Precision") || kvp.Key.Contains("Braided") || kvp.Key.Contains("Circle") || kvp.Key.Contains("Pro") || kvp.Key.Contains("Knotless")).ToList();
                                var highItems = calculatedRecommendations.Where(kvp => kvp.Key.Contains("Carbon") || kvp.Key.Contains("Professional") || kvp.Key.Contains("Fluorocarbon") || kvp.Key.Contains("Treble") || kvp.Key.Contains("Master") || kvp.Key.Contains("Tournament")).ToList();
                                var topItems = calculatedRecommendations.Where(kvp => kvp.Key.Contains("Legendary") || kvp.Key.Contains("Titanium") || kvp.Key.Contains("Diamond")).ToList();
                            }

                            @if (entryItems.Any())
                            {
                                var minEntry = entryItems.Min(x => x.Value);
                                var maxEntry = entryItems.Max(x => x.Value);
                                var sampleEntry = entryItems.First();
                                var currentEntry = shopItems.FirstOrDefault(i => i.Name == sampleEntry.Key);
                                <MudText Typo="Typo.body2">
                                    • <strong>Entry Tier (~2 weeks):</strong> @minEntry - @maxEntry gold
                                    @if (currentEntry != null)
                                    {
                                        var change = sampleEntry.Value - currentEntry.Cost;
                                        var changePercent = currentEntry.Cost > 0 ? (change / (double)currentEntry.Cost * 100) : 0;
                                        <span style="color: @(change > 0 ? "green" : "red");">
                                            (e.g., @sampleEntry.Key: @currentEntry.Cost → @sampleEntry.Value, @(change > 0 ? "+" : "")@change gold, @changePercent.ToString("F0")%)
                                        </span>
                                    }
                                </MudText>
                            }

                            @if (midItems.Any())
                            {
                                var minMid = midItems.Min(x => x.Value);
                                var maxMid = midItems.Max(x => x.Value);
                                var sampleMid = midItems.First();
                                var currentMid = shopItems.FirstOrDefault(i => i.Name == sampleMid.Key);
                                <MudText Typo="Typo.body2">
                                    • <strong>Mid Tier (~6 weeks):</strong> @minMid - @maxMid gold
                                    @if (currentMid != null)
                                    {
                                        var change = sampleMid.Value - currentMid.Cost;
                                        var changePercent = currentMid.Cost > 0 ? (change / (double)currentMid.Cost * 100) : 0;
                                        <span style="color: @(change > 0 ? "green" : "red");">
                                            (e.g., @sampleMid.Key: @currentMid.Cost → @sampleMid.Value, @(change > 0 ? "+" : "")@change gold, @changePercent.ToString("F0")%)
                                        </span>
                                    }
                                </MudText>
                            }

                            @if (highItems.Any())
                            {
                                var minHigh = highItems.Min(x => x.Value);
                                var maxHigh = highItems.Max(x => x.Value);
                                var sampleHigh = highItems.First();
                                var currentHigh = shopItems.FirstOrDefault(i => i.Name == sampleHigh.Key);
                                <MudText Typo="Typo.body2">
                                    • <strong>High Tier (~12 weeks):</strong> @minHigh - @maxHigh gold
                                    @if (currentHigh != null)
                                    {
                                        var change = sampleHigh.Value - currentHigh.Cost;
                                        var changePercent = currentHigh.Cost > 0 ? (change / (double)currentHigh.Cost * 100) : 0;
                                        <span style="color: @(change > 0 ? "green" : "red");">
                                            (e.g., @sampleHigh.Key: @currentHigh.Cost → @sampleHigh.Value, @(change > 0 ? "+" : "")@change gold, @changePercent.ToString("F0")%)
                                        </span>
                                    }
                                </MudText>
                            }

                            @if (topItems.Any())
                            {
                                var minTop = topItems.Min(x => x.Value);
                                var maxTop = topItems.Max(x => x.Value);
                                var sampleTop = topItems.First();
                                var currentTop = shopItems.FirstOrDefault(i => i.Name == sampleTop.Key);
                                <MudText Typo="Typo.body2">
                                    • <strong>Top Tier (~@targetWeeksForEndgame weeks):</strong> @minTop - @maxTop gold
                                    @if (currentTop != null)
                                    {
                                        var change = sampleTop.Value - currentTop.Cost;
                                        var changePercent = currentTop.Cost > 0 ? (change / (double)currentTop.Cost * 100) : 0;
                                        <span style="color: @(change > 0 ? "green" : "red");">
                                            (e.g., @sampleTop.Key: @currentTop.Cost → @sampleTop.Value, @(change > 0 ? "+" : "")@change gold, @changePercent.ToString("F0")%)
                                        </span>
                                    }
                                </MudText>
                            }

                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.caption" Color="Color.Info">
                                💡 Green = price increase (fixes "too cheap" items), Red = price decrease. Click "Apply Price Updates" to use these values.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Click "Calculate Pricing" to generate recommendations based on current player data.
                    </MudAlert>
                }
            }

            @if (priceUpdatePreset == "multiplier")
            {
                <MudNumericField @bind-Value="customMultiplier" 
                                 Label="Price Multiplier" 
                                 Min="0.1" 
                                 Max="10" 
                                 Step="0.1"
                                 Adornment="Adornment.End"
                                 AdornmentText="x"
                                 Variant="Variant.Outlined" />

                <MudSwitch @bind-Value="updatePermanentOnly" Color="Color.Primary" Label="Permanent Equipment Only (Don't update consumables)" />

                @if (!updatePermanentOnly)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        <strong>Note:</strong> Consumables are already well-balanced according to production data. Consider updating permanent items only.
                    </MudAlert>
                }

                <MudSelect T="EquipmentSlot?" @bind-Value="updateSpecificSlot" 
                           Label="Equipment Slot (Optional)" 
                           Variant="Variant.Outlined"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@((EquipmentSlot?)null)">All Slots</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Rod">Rods</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Reel">Reels</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Line">Lines</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Hook">Hooks</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.TackleBox">Tackle Boxes</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Net">Nets</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Bait">Bait</MudSelectItem>
                    <MudSelectItem Value="@EquipmentSlot.Lure">Lures</MudSelectItem>
                </MudSelect>

                <MudPaper Class="pa-3" Elevation="2">
                    <MudText Typo="Typo.subtitle2" Class="mb-2"><strong>Will Update:</strong></MudText>
                    <MudText Typo="Typo.body2">
                        @if (updatePermanentOnly)
                        {
                            <text>Permanent Equipment Only</text>
                        }
                        else
                        {
                            <text>All Items</text>
                        }
                        @if (updateSpecificSlot.HasValue)
                        {
                            <text> in @updateSpecificSlot.Value slot</text>
                        }
                        <text> by @customMultiplier.ToString("F1")x</text>
                    </MudText>
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => showPriceUpdateDialog = false" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="ApplyPriceUpdates" 
                   Color="Color.Warning" 
                   Variant="Variant.Filled"
                   Disabled="@isUpdatingPrices">
            @if (isUpdatingPrices)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <text>Updating...</text>
            }
            else
            {
                <text>Apply Price Updates</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
