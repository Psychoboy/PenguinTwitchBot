@page "/fishing/admin"
@using DotNetTwitchBot.Bot.Commands.Fishing
@using DotNetTwitchBot.Bot.Models.Fishing
@using DotNetTwitchBot.Helpers
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Roles = "Streamer, Editor")]

<PageTitle>Fishing Game</PageTitle>

<MudContainer Class="pa-4" MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Phishing" Size="Size.Large" Class="mr-2" />
            Fishing Game Manager
        </MudText>

        <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" Class="mt-4">
            <MudTabPanel Text="Fish Types" Icon="@Icons.Material.Filled.Phishing">
                <MudPaper Elevation="3" Class="pa-4 ma-2">
                    <MudStack Spacing="3">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   @onclick="AddNewFish">
                            Add Fish Type
                        </MudButton>
                        <MudTable Items="@fishTypes" Hover="true" Striped="true" Dense="true" Elevation="2">
                            <HeaderContent>
                                <MudTh>Image</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Rarity</MudTh>
                                <MudTh>Base Weight</MudTh>
                                <MudTh>Base Gold</MudTh>
                                <MudTh>Enabled</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Image">
                                    @if (!string.IsNullOrEmpty(context.ImageFileName))
                                    {
                                        <MudImage Src="@FishImageHelper.GetImagePath(context.ImageFileName, ImageSize.Small)" 
                                                  Alt="@context.Name" 
                                                  Width="50" 
                                                  Height="50" 
                                                  ObjectFit="ObjectFit.Cover"
                                                  Class="rounded" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Default" Size="Size.Large" />
                                    }
                                </MudTd>
                                <MudTd DataLabel="Name">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Phishing" Size="Size.Small" Color="Color.Primary" />
                                        <MudText><strong>@context.Name</strong></MudText>
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="Rarity">
                                    <MudChip T="string" Color="GetRarityColor(context.Rarity)" Size="Size.Small">@context.Rarity</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Base Weight">@context.BaseWeight kg</MudTd>
                                <MudTd DataLabel="Base Gold">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                        <MudText>@context.BaseGold</MudText>
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="Enabled">
                                    <MudCheckBox @bind-Value="context.Enabled" ReadOnly="true" Color="Color.Success" />
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                                   Color="Color.Primary"
                                                   Size="Size.Small" 
                                                   OnClick="() => EditFish(context)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Color="Color.Error"
                                                   Size="Size.Small" 
                                                   OnClick="() => DeleteFish(context)" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>
            </MudTabPanel>

    <MudTabPanel Text="Shop Items" Icon="@Icons.Material.Filled.ShoppingCart">
        <MudPaper Elevation="3" Class="pa-4 ma-2">
            <MudStack Spacing="3">
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Add"
                               @onclick="AddNewShopItem">
                        Add Shop Item
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Secondary" 
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.AutoAwesome"
                               OnClick="GenerateDefaultItems"
                               Disabled="@isGeneratingItems">
                        @if (isGeneratingItems)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Generating...</text>
                        }
                        else
                        {
                            <text>Generate Default Items</text>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Warning" 
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.TrendingUp"
                               OnClick="() => showPriceUpdateDialog = true">
                        Update Item Prices
                    </MudButton>
                </MudStack>
                <MudTable Items="@shopItems" Hover="true" Striped="true" Dense="true" Elevation="2">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Cost</MudTh>
                        <MudTh>Boost Type</MudTh>
                        <MudTh>Boost Amount</MudTh>
                        <MudTh>Equipment Slot</MudTh>
                        <MudTh>Uses</MudTh>
                        <MudTh>Admin Only</MudTh>
                        <MudTh>Enabled</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Size="Size.Small" Color="Color.Primary" />
                                <MudText><strong>@context.Name</strong></MudText>
                                @if (context.IsConsumable)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.DeleteForever">Consumable</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Description">@context.Description</MudTd>
                        <MudTd DataLabel="Cost">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                                <MudText>@context.Cost</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Boost Type">
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(context.BoostType)</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Boost Amount">+@((context.BoostAmount * 100).ToString("F0"))%</MudTd>
                        <MudTd DataLabel="Equipment Slot">
                            @if (context.EquipmentSlot.HasValue)
                            {
                                <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Icon="@GetSlotIcon(context.EquipmentSlot.Value)">
                                    @context.EquipmentSlot.Value
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Permanent</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Uses">
                            @if (context.MaxUses.HasValue)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Numbers">
                                    @context.MaxUses uses
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.AllInclusive">
                                    Unlimited
                                </MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Admin Only">
                            @if (context.IsAdminOnly)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Public</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Enabled">
                            <MudCheckBox @bind-Value="context.Enabled" ReadOnly="true" Color="Color.Success" />
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                           Color="Color.Primary"
                                           Size="Size.Small" 
                                           OnClick="() => EditShopItem(context)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                           Color="Color.Error"
                                           Size="Size.Small" 
                                           OnClick="() => DeleteShopItem(context)" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudStack>
        </MudPaper>
    </MudTabPanel>

    <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
        <MudPaper Elevation="3" Class="pa-4 ma-2">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h5">Fishing Settings</MudText>
                </MudStack>
                <MudDivider />
                <MudSwitch @bind-Value="settings.Enabled" 
                           Label="Enable Fishing" 
                           Color="Color.Success"
                           ThumbIcon="@(settings.Enabled ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" />
                <MudNumericField @bind-Value="settings.DisplayDurationMs" 
                                 Label="Display Duration (ms)" 
                                 HelperText="How long the fishing result appears on overlay"
                                 Min="1000" 
                                 Max="30000"
                                 Adornment="Adornment.End"
                                 AdornmentIcon="@Icons.Material.Filled.Timer" />
                <MudDivider />
                <MudStack Spacing="1">
                    <MudSwitch @bind-Value="settings.BoostMode" 
                               Label="Boost Mode" 
                               Color="Color.Warning"
                               ThumbIcon="@(settings.BoostMode ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Temporarily increase rare fish catch rates</MudText>
                </MudStack>
                <MudNumericField @bind-Value="settings.BoostModeRarityMultiplier" 
                                 Label="Boost Mode Multiplier" 
                                 HelperText="Multiplier applied to rarity when boost mode is active"
                                 Min="1.0" 
                                 Max="10.0" 
                                 Step="0.1"
                                 Adornment="Adornment.End"
                                 AdornmentText="x" />

                <MudDivider Class="my-4" />

                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Diamond" Color="Color.Warning" Size="Size.Medium" />
                        <MudText Typo="Typo.h6">Rarity Thresholds</MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Define the BaseGold values that determine each rarity tier. Fish rarity is auto-calculated based on these thresholds when editing fish or using the sync button.
                    </MudText>

                    <MudGrid>
                        <MudItem xs="6" sm="3">
                            <MudNumericField @bind-Value="settings.RarityUncommonThreshold" 
                                             Label="Uncommon (≥)" 
                                             Min="1"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.AttachMoney">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Style="position: absolute; right: 8px; top: 8px;">Uncommon</MudChip>
                            </MudNumericField>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudNumericField @bind-Value="settings.RarityRareThreshold" 
                                             Label="Rare (≥)" 
                                             Min="1"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.AttachMoney">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Style="position: absolute; right: 8px; top: 8px;">Rare</MudChip>
                            </MudNumericField>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudNumericField @bind-Value="settings.RarityEpicThreshold" 
                                             Label="Epic (≥)" 
                                             Min="1"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.AttachMoney">
                                <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Style="position: absolute; right: 8px; top: 8px;">Epic</MudChip>
                            </MudNumericField>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudNumericField @bind-Value="settings.RarityLegendaryThreshold" 
                                             Label="Legendary (≥)" 
                                             Min="1"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.AttachMoney">
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Style="position: absolute; right: 8px; top: 8px;">Legendary</MudChip>
                            </MudNumericField>
                        </MudItem>
                    </MudGrid>

                    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Dense="true">
                        Common rarity applies to all fish with BaseGold below the Uncommon threshold (@settings.RarityUncommonThreshold)
                    </MudAlert>

                    <MudStack Row="true" Spacing="2" Class="mt-2">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Tertiary" 
                                   Size="Size.Medium"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   OnClick="SyncFishRarities" 
                                   Disabled="isSyncing">
                            @(isSyncing ? "Syncing..." : "Sync All Fish Rarities")
                        </MudButton>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="align-self: center;">
                            Recalculates rarity for all fish based on current thresholds
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveSettings" 
                           Class="mt-4">
                    Save Settings
                </MudButton>

                <MudDivider Class="mt-6 mb-4" />

                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" Size="Size.Large" />
                        <MudText Typo="Typo.h5" Color="Color.Error">Danger Zone</MudText>
                    </MudStack>
                    <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Warning">
                        <strong>Warning:</strong> The following action will permanently delete all user catches, gold, and purchased boosts. Fish types and shop items will remain. This cannot be undone!
                    </MudAlert>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Error" 
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               OnClick="ShowResetConfirmation"
                               Disabled="isResetting">
                        @(isResetting ? "Resetting..." : "Reset All User Data")
                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudTabPanel>

                    <MudTabPanel Text="Simulator" Icon="@Icons.Material.Filled.Science">
                        <MudPaper Elevation="3" Class="pa-4 ma-2">
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Science" Color="Color.Info" Size="Size.Large" />
                                    <MudText Typo="Typo.h5">Fishing Simulator</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Test fishing mechanics without affecting the database. Run multiple simulations to see catch distributions.
                                </MudText>

                                <MudDivider />

                                <MudNumericField @bind-Value="simIterations" 
                                                 Label="Number of Simulations" 
                                                 HelperText="How many fishing attempts to simulate"
                                                 Min="1" 
                                                 Max="10000"
                                                 Variant="Variant.Outlined"
                                                 Adornment="Adornment.Start"
                                                 AdornmentIcon="@Icons.Material.Filled.Replay" />

                                <MudStack Spacing="2">
                                    <MudSwitch @bind-Value="simUseBoostMode" 
                                               Label="Use Boost Mode" 
                                               Color="Color.Warning"
                                               ThumbIcon="@(simUseBoostMode ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingFlat)" />

                                    @if (simUseBoostMode)
                                    {
                                        <MudNumericField @bind-Value="simBoostMultiplier" 
                                                         Label="Boost Mode Multiplier" 
                                                         Min="1.0" 
                                                         Max="10.0" 
                                                         Step="0.1"
                                                         Variant="Variant.Outlined"
                                                         Adornment="Adornment.End"
                                                         AdornmentText="x" />
                                    }
                                </MudStack>

                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.subtitle2">Equipped Items (Optional)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Select shop items to simulate their effects
                                    </MudText>
                                    <MudSelect T="int"
                                               @bind-SelectedValues="simSelectedItems" 
                                               Label="Select Items" 
                                               MultiSelection="true"
                                               Variant="Variant.Outlined">
                                        @foreach (var item in shopItems.Where(i => i.Enabled))
                                        {
                                            <MudSelectItem T="int" Value="@item.Id">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(item.BoostType)</MudChip>
                                                    <MudText>@item.Name</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">(+@(item.BoostAmount * 100)%)</MudText>
                                                </MudStack>
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudStack>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Large"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="RunSimulation"
                                           Disabled="isSimulating">
                                    @if (isSimulating)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Simulating...</span>
                                    }
                                    else
                                    {
                                        <span>Run Simulation</span>
                                    }
                                </MudButton>

                                @if (simulationResult != null)
                                {
                                    <MudDivider Class="my-4" />

                                    <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                        <MudText Typo="Typo.body1"><strong>Simulation Complete!</strong></MudText>
                                        <MudText Typo="Typo.body2">@simulationResult.TotalIterations catches simulated</MudText>
                                    </MudAlert>

                                    <MudExpansionPanels>
                                        <MudExpansionPanel Text="Rarity Distribution" IsInitiallyExpanded="true">
                                            <MudSimpleTable Dense="true" Striped="true">
                                                <thead>
                                                    <tr>
                                                        <th>Rarity</th>
                                                        <th>Count</th>
                                                        <th>Percentage</th>
                                                        <th>Visual</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var kvp in simulationResult.RarityCounts.OrderBy(k => (int)k.Key))
                                                    {
                                                        var percentage = Math.Round((double)kvp.Value / simulationResult.TotalIterations * 100, 2);
                                                        <tr>
                                                            <td>
                                                                <MudChip T="string" Color="GetRarityColor(kvp.Key)" Size="Size.Small">@kvp.Key</MudChip>
                                                            </td>
                                                            <td><strong>@kvp.Value</strong></td>
                                                            <td>@percentage%</td>
                                                            <td>
                                                                <MudProgressLinear Color="GetRarityColor(kvp.Key)" Value="@percentage" Size="Size.Medium" />
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudExpansionPanel>

                                        <MudExpansionPanel Text="Star Quality Distribution">
                                            <MudSimpleTable Dense="true" Striped="true">
                                                <thead>
                                                    <tr>
                                                        <th>Stars</th>
                                                        <th>Count</th>
                                                        <th>Percentage</th>
                                                        <th>Visual</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var kvp in simulationResult.StarCounts.OrderByDescending(k => k.Key))
                                                    {
                                                        var percentage = Math.Round((double)kvp.Value / simulationResult.TotalIterations * 100, 2);
                                                        <tr>
                                                            <td>
                                                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                                                    @for (int i = 0; i < kvp.Key; i++)
                                                                    {
                                                                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                                                    }
                                                                </MudStack>
                                                            </td>
                                                            <td><strong>@kvp.Value</strong></td>
                                                            <td>@percentage%</td>
                                                            <td>
                                                                <MudProgressLinear Color="Color.Warning" Value="@percentage" Size="Size.Medium" />
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudExpansionPanel>

                                        <MudExpansionPanel Text="Most Common Fish">
                                            <MudSimpleTable Dense="true" Striped="true">
                                                <thead>
                                                    <tr>
                                                        <th>Fish Name</th>
                                                        <th>Count</th>
                                                        <th>Percentage</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var kvp in simulationResult.FishCounts.OrderByDescending(k => k.Value).Take(10))
                                                    {
                                                        var percentage = Math.Round((double)kvp.Value / simulationResult.TotalIterations * 100, 2);
                                                        <tr>
                                                            <td><strong>@kvp.Key</strong></td>
                                                            <td>@kvp.Value</td>
                                                            <td>@percentage%</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudExpansionPanel>

                                        <MudExpansionPanel Text="Statistics Summary">
                                            <MudGrid>
                                                <MudItem xs="6" sm="4">
                                                    <MudPaper Elevation="2" Class="pa-3">
                                                        <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Size="Size.Large" />
                                                            <MudText Typo="Typo.caption">Avg Gold</MudText>
                                                            <MudText Typo="Typo.h6">@simulationResult.AverageGold</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                </MudItem>
                                                <MudItem xs="6" sm="4">
                                                    <MudPaper Elevation="2" Class="pa-3">
                                                        <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                                            <MudIcon Icon="@Icons.Material.Filled.Scale" Color="Color.Info" Size="Size.Large" />
                                                            <MudText Typo="Typo.caption">Avg Weight</MudText>
                                                            <MudText Typo="Typo.h6">@simulationResult.AverageWeight kg</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                </MudItem>
                                                <MudItem xs="6" sm="4">
                                                    <MudPaper Elevation="2" Class="pa-3">
                                                        <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Success" Size="Size.Large" />
                                                            <MudText Typo="Typo.caption">Total Gold</MudText>
                                                            <MudText Typo="Typo.h6">@simulationResult.TotalGold</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                </MudItem>
                                                <MudItem xs="6" sm="4">
                                                    <MudPaper Elevation="2" Class="pa-3">
                                                        <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Default" Size="Size.Large" />
                                                            <MudText Typo="Typo.caption">Min Weight</MudText>
                                                            <MudText Typo="Typo.h6">@simulationResult.MinWeight kg</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                </MudItem>
                                                <MudItem xs="6" sm="4">
                                                    <MudPaper Elevation="2" Class="pa-3">
                                                        <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Error" Size="Size.Large" />
                                                            <MudText Typo="Typo.caption">Max Weight</MudText>
                                                            <MudText Typo="Typo.h6">@simulationResult.MaxWeight kg</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                </MudItem>
                                                <MudItem xs="12" sm="4">
                                                    <MudPaper Elevation="2" Class="pa-3">
                                                        <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                                            <MudIcon Icon="@Icons.Material.Filled.Phishing" Color="Color.Primary" Size="Size.Large" />
                                                            <MudText Typo="Typo.caption">Heaviest</MudText>
                                                            <MudText Typo="Typo.h6">@simulationResult.HeaviestFish</MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                </MudItem>
                                            </MudGrid>

                                            @if (simulationResult.ItemsUsed.Any())
                                            {
                                                <MudDivider Class="my-3" />
                                                <MudText Typo="Typo.subtitle2">Items Used:</MudText>
                                                <MudStack Row="true" Spacing="1">
                                                    @foreach (var item in simulationResult.ItemsUsed)
                                                    {
                                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@item</MudChip>
                                                    }
                                                </MudStack>
                                            }

                                            @if (simulationResult.BoostModeUsed)
                                            {
                                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                                    <MudText Typo="Typo.body2">
                                                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                                                        <strong>Boost Mode:</strong> @(simulationResult.BoostModeMultiplier)x multiplier active
                                                    </MudText>
                                                </MudAlert>
                                            }
                                        </MudExpansionPanel>
                                    </MudExpansionPanels>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudTabPanel>

                    <MudTabPanel Text="Player Management" Icon="@Icons.Material.Filled.People">
                        <MudPaper Elevation="3" Class="pa-4 ma-2">
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" />
                                    <MudText Typo="Typo.h5">Player Management</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Give gold and items to players who have participated in the fishing game.
                                </MudText>

                                <MudDivider />

                                <MudAutocomplete T="FishingGold"
                                                 @bind-Value="selectedPlayer"
                                                 SearchFunc="SearchPlayers"
                                                 ToStringFunc="@(p => p?.Username ?? "")"
                                                 Label="Select Player"
                                                 Variant="Variant.Outlined"
                                                 ResetValueOnEmptyText="true"
                                                 CoerceText="true"
                                                 CoerceValue="true"
                                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                                 Adornment="Adornment.Start">
                                    <ItemTemplate Context="player">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                            <MudText><strong>@player.Username</strong></MudText>
                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.AttachMoney">
                                                @player.TotalGold gold
                                            </MudChip>
                                        </MudStack>
                                    </ItemTemplate>
                                </MudAutocomplete>

                                @if (selectedPlayer != null)
                                {
                                    <MudPaper Elevation="2" Class="pa-3">
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Large" />
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.h6">@selectedPlayer.Username</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">User ID: @selectedPlayer.UserId</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudDivider />
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Warning" Size="Size.Medium" />
                                                <MudText Typo="Typo.h6">Current Gold: @selectedPlayer.TotalGold</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>

                                    <MudDivider />

                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.h6" Color="Color.Primary">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Medium" Class="mr-1" />
                                            Manage Gold
                                        </MudText>

                                        <MudStack Row="true" Spacing="2">
                                            <MudNumericField @bind-Value="goldAmount"
                                                             Label="Gold Amount"
                                                             Variant="Variant.Outlined"
                                                             Min="0"
                                                             Style="flex: 1;"
                                                             Adornment="Adornment.Start"
                                                             AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                                        </MudStack>

                                        <MudStack Row="true" Spacing="2">
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Success"
                                                       StartIcon="@Icons.Material.Filled.Add"
                                                       OnClick="AddGoldToPlayer"
                                                       Disabled="isProcessing || goldAmount <= 0">
                                                Add Gold
                                            </MudButton>
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Warning"
                                                       StartIcon="@Icons.Material.Filled.Remove"
                                                       OnClick="RemoveGoldFromPlayer"
                                                       Disabled="isProcessing || goldAmount <= 0">
                                                Remove Gold
                                            </MudButton>
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Info"
                                                       StartIcon="@Icons.Material.Filled.Settings"
                                                       OnClick="SetPlayerGold"
                                                       Disabled="isProcessing">
                                                Set Gold
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>

                                    <MudDivider />

                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.h6" Color="Color.Primary">
                                            <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Medium" Class="mr-1" />
                                            Give Item
                                        </MudText>

                                        <MudSelect @bind-Value="selectedItemToGive"
                                                   Label="Select Item to Give"
                                                   Variant="Variant.Outlined"
                                                   Clearable="true"
                                                   AdornmentIcon="@Icons.Material.Filled.LocalOffer"
                                                   Adornment="Adornment.Start">
                                            @foreach (var item in shopItems.Where(i => i.Enabled))
                                            {
                                                <MudSelectItem T="int?" Value="@((int?)item.Id)">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        @if (item.IsAdminOnly)
                                                        {
                                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin</MudChip>
                                                        }
                                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(item.BoostType)</MudChip>
                                                        <MudText><strong>@item.Name</strong></MudText>
                                                        @if (item.EquipmentSlot.HasValue)
                                                        {
                                                            <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Icon="@GetSlotIcon(item.EquipmentSlot.Value)">
                                                                @item.EquipmentSlot.Value
                                                            </MudChip>
                                                        }
                                                    </MudStack>
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Large"
                                                   StartIcon="@Icons.Material.Filled.CardGiftcard"
                                                   OnClick="GiveItemToPlayer"
                                                   Disabled="isProcessing || !selectedItemToGive.HasValue">
                                            Give Item to Player
                                        </MudButton>

                                        <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Dense="true">
                                            Items marked with "Admin" badge are admin-only and not visible in the player shop.
                                        </MudAlert>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
                                        Select a player to manage their gold and items. Only players who have fished at least once will appear in the list.
                                    </MudAlert>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudTabPanel>
                </MudTabs>
    </MudStack>
</MudContainer>

<MudDialog @bind-Visible="fishDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@(editingFish?.Id == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@(editingFish?.Id == 0 ? "Add" : "Edit") Fish Type</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (editingFish != null)
        {
            <MudStack Spacing="3">
                <MudTextField @bind-Value="editingFish.Name" 
                              Label="Name" 
                              Required="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Phishing" />

                <MudSelect @bind-Value="editingFish.Rarity" 
                           Label="Rarity" 
                           Required="true"
                           Variant="Variant.Outlined">
                    @foreach (FishRarity rarity in Enum.GetValues(typeof(FishRarity)))
                    {
                        <MudSelectItem Value="@rarity">
                            <MudChip T="string" Color="GetRarityColor(rarity)" Size="Size.Small">@rarity</MudChip>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField @bind-Value="editingFish.BaseWeight" 
                                 Label="Base Weight (kg)" 
                                 HelperText="Actual weight will vary between 0.8x and 1.13x of base, modified by stars"
                                 Min="0.1" 
                                 Step="0.1"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.End"
                                 AdornmentText="kg" />

                <MudNumericField Value="@editingFish.BaseGold"
                                 ValueChanged="@((int value) => OnBaseGoldChanged(value))"
                                 Label="Base Gold" 
                                 Min="1"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                 HelperText="Rarity will be set automatically based on gold value" />

                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2">Fish Image & Sound</MudText>
                    <MudStack Spacing="2">
                        <MudPaper Elevation="0" Class="pa-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudButton HtmlTag="label"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.CloudUpload">
                                    Upload Image
                                    <InputFile id="image-upload" OnChange="OnImageFilesChanged" accept=".png,.jpg,.jpeg,.gif,.webp" hidden />
                                </MudButton>
                                @if (!string.IsNullOrEmpty(uploadedImageFileName))
                                {
                                    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small">
                                        @uploadedImageFileName
                                    </MudChip>
                                }
                            </MudStack>
                        </MudPaper>
                        <MudPaper Elevation="0" Class="pa-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudButton HtmlTag="label"
                                           Variant="Variant.Filled"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.AudioFile">
                                    Upload Sound (Optional)
                                    <InputFile id="sound-upload" OnChange="OnSoundFilesChanged" accept=".mp3,.wav,.ogg,.webm" hidden />
                                </MudButton>
                                @if (!string.IsNullOrEmpty(uploadedSoundFileName))
                                {
                                    <MudChip T="string" Color="Color.Info" Icon="@Icons.Material.Filled.MusicNote" Size="Size.Small">
                                        @uploadedSoundFileName
                                    </MudChip>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudStack>
                </MudStack>

                @if (!string.IsNullOrEmpty(editingFish.ImageFileName))
                {
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Current Image</MudText>
                            <MudImage Src="@FishImageHelper.GetImagePath(editingFish.ImageFileName, ImageSize.Large)" 
                                      Alt="Fish Preview" 
                                      Width="200"
                                      Height="200"
                                      ObjectFit="ObjectFit.Contain"
                                      Elevation="3"
                                      Class="rounded" />
                            <MudText Typo="Typo.caption">@editingFish.ImageFileName</MudText>
                        </MudStack>
                    </MudPaper>
                }

                <MudSwitch @bind-Value="editingFish.Enabled" 
                           Label="Enabled" 
                           Color="Color.Success"
                           ThumbIcon="@(editingFish.Enabled ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" />
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelFishDialog" 
                   StartIcon="@Icons.Material.Filled.Cancel">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" 
                   OnClick="SaveFish"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="shopItemDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@(editingShopItem?.Id == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@(editingShopItem?.Id == 0 ? "Add" : "Edit") Shop Item</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (editingShopItem != null)
        {
            <MudStack Spacing="3">
                <MudTextField @bind-Value="editingShopItem.Name" 
                              Label="Name" 
                              Required="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.LocalOffer" />

                <MudTextField @bind-Value="editingShopItem.Description" 
                              Label="Description" 
                              Lines="3"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Description" />

                <MudNumericField @bind-Value="editingShopItem.Cost" 
                                 Label="Cost (gold)" 
                                 Min="1"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney" />

                <MudSelect @bind-Value="editingShopItem.BoostType" 
                           Label="Boost Type" 
                           Required="true"
                           Variant="Variant.Outlined">
                    @foreach (FishingBoostType type in Enum.GetValues(typeof(FishingBoostType)))
                    {
                        <MudSelectItem Value="@type">
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@GetBoostTypeDisplay(type)</MudChip>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField @bind-Value="editingShopItem.BoostAmount" 
                                 Label="Boost Amount" 
                                 HelperText="Enter as decimal (0.05 = 5%)"
                                 Min="0.01" 
                                 Max="5.0" 
                                 Step="0.01"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.End"
                                 AdornmentIcon="@Icons.Material.Filled.TrendingUp" />

                @if (editingShopItem.BoostType == FishingBoostType.SpecificFishBoost)
                {
                    <MudSelect @bind-Value="editingShopItem.TargetFishTypeId" 
                               Label="Target Fish"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@((int?)null)">None</MudSelectItem>
                        @foreach (var fish in fishTypes)
                        {
                            <MudSelectItem Value="@((int?)fish.Id)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudChip T="string" Color="GetRarityColor(fish.Rarity)" Size="Size.Small">@fish.Rarity</MudChip>
                                    <MudText>@fish.Name</MudText>
                                </MudStack>
                            </MudSelectItem>
                        }
                    </MudSelect>
                }

                <MudDivider />

                <MudText Typo="Typo.h6" Color="Color.Primary">Equipment Settings</MudText>

                <MudSelect @bind-Value="editingShopItem.EquipmentSlot" 
                           Label="Equipment Slot" 
                           Variant="Variant.Outlined"
                           Clearable="true"
                           HelperText="Assign to a slot (only 1 item per slot can be equipped)">
                    <MudSelectItem Value="@((EquipmentSlot?)null)">None (Permanent Boost)</MudSelectItem>
                    @foreach (EquipmentSlot slot in Enum.GetValues(typeof(EquipmentSlot)))
                    {
                        <MudSelectItem Value="@((EquipmentSlot?)slot)">
                            <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Icon="@GetSlotIcon(slot)">@slot</MudChip>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudCheckBox @bind-Value="hasMaxUses" 
                                 Label="Limited Uses" 
                                 Color="Color.Warning" />
                    @if (hasMaxUses)
                    {
                        <MudNumericField @bind-Value="maxUsesValue" 
                                         Label="Max Uses" 
                                         Min="1"
                                         Variant="Variant.Outlined"
                                         HelperText="Number of times item can be used"
                                         Style="flex: 1;" />
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Unlimited uses</MudText>
                    }
                </MudStack>

                <MudStack Spacing="1">
                    <MudSwitch @bind-Value="editingShopItem.IsConsumable" 
                               Label="Consumable" 
                               Color="Color.Error"
                               ThumbIcon="@(editingShopItem.IsConsumable ? Icons.Material.Filled.DeleteForever : Icons.Material.Filled.Loop)" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">If enabled, item is removed from inventory when uses run out</MudText>
                </MudStack>

                <MudDivider />

                <MudStack Spacing="1">
                    <MudSwitch @bind-Value="editingShopItem.IsAdminOnly" 
                               Label="Admin Only" 
                               Color="Color.Warning"
                               ThumbIcon="@(editingShopItem.IsAdminOnly ? Icons.Material.Filled.AdminPanelSettings : Icons.Material.Filled.Store)" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">If enabled, item will not appear in player shop and can only be given by admins</MudText>
                </MudStack>

                <MudSwitch @bind-Value="editingShopItem.Enabled"
                           Label="Enabled" 
                           Color="Color.Success"
                           ThumbIcon="@(editingShopItem.Enabled ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" />
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelShopItemDialog"
                   StartIcon="@Icons.Material.Filled.Cancel">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" 
                   OnClick="SaveShopItem"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="resetConfirmVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6" Color="Color.Error">Confirm Reset</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Error">
                <strong>This action cannot be undone!</strong>
            </MudAlert>
            <MudText Typo="Typo.body1">
                Are you sure you want to reset all user data? This will permanently delete:
            </MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">
                    All fish catches from all users
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">
                    All user gold balances
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">
                    All purchased boosts
                </MudListItem>
            </MudList>
            <MudText Typo="Typo.body2" Color="Color.Success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                Fish types and shop items will be preserved.
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => resetConfirmVisible = false" 
                   StartIcon="@Icons.Material.Filled.Cancel"
                   Disabled="isResetting">
            Cancel
        </MudButton>
        <MudButton Color="Color.Error" 
                   OnClick="ResetAllUserData"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   Disabled="isResetting">
            @(isResetting ? "Resetting..." : "Yes, Reset Everything")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="goldConfirmVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Confirm Gold Operation</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Info">
                Please confirm this gold operation
            </MudAlert>
            <MudText Typo="Typo.body1">
                @goldConfirmMessage
            </MudText>
            @if (selectedPlayer != null)
            {
                <MudPaper Elevation="2" Class="pa-3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body2"><strong>Player:</strong> @selectedPlayer.Username</MudText>
                        <MudText Typo="Typo.body2"><strong>Current Gold:</strong> @selectedPlayer.TotalGold</MudText>
                        @if (goldConfirmAction == "set")
                        {
                            <MudText Typo="Typo.body2" Color="Color.Info"><strong>New Gold:</strong> @goldAmount</MudText>
                        }
                        else if (goldConfirmAction == "add")
                        {
                            <MudText Typo="Typo.body2" Color="Color.Success"><strong>After Operation:</strong> @(selectedPlayer.TotalGold + goldAmount)</MudText>
                        }
                        else if (goldConfirmAction == "remove")
                        {
                            <MudText Typo="Typo.body2" Color="Color.Warning"><strong>After Operation:</strong> @(selectedPlayer.TotalGold - goldAmount)</MudText>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => goldConfirmVisible = false" 
                   StartIcon="@Icons.Material.Filled.Cancel"
                   Disabled="isProcessing">
            Cancel
        </MudButton>
        <MudButton Color="@GetGoldConfirmColor()" 
                   OnClick="ExecuteGoldOperation"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Check"
                   Disabled="isProcessing">
            @(isProcessing ? "Processing..." : "Confirm")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IFishingService fishingService { get; set; } = null!;
    [Inject] private IFishingShopService shopService { get; set; } = null!;
    [Inject] private IFishingInventoryService inventoryService { get; set; } = null!;
    [Inject] private IFishingAnalyticsService analyticsService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private IWebHostEnvironment WebHostEnvironment { get; set; } = null!;
