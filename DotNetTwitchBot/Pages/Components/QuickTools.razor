@attribute [Authorize(Roles = "Streamer, Editor")]
@inject DotNetTwitchBot.Bot.Commands.Moderation.Admin Admin
@inject DotNetTwitchBot.Bot.Commands.Features.IViewerFeature viewerFeature
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject DotNetTwitchBot.Bot.Core.IChatHistory ChatHistory
@inject DotNetTwitchBot.Circuit.IpLog ipLog
@inject DotNetTwitchBot.Bot.StreamSchedule.ISchedule Schedule
@inject DotNetTwitchBot.Bot.TwitchServices.ITwitchWebsocketHostedService TwitchWebsocketHostedService
@inject DotNetTwitchBot.Bot.Queues.IQueueManager QueueManager
@inject MudBlazor.ISnackbar Snackbar

<CascadingAuthenticationState> 
    <AuthorizeView Roles="Streamer">
        <Authorized>
            <MudContainer Class="pa-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PauseAlerts">Pause Alerts</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResumeAlerts">Resume Alerts</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Reconnect">Reconnect</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ForceOnline">Force Online</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ForceOffline">Force Offline</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="UpdateSchedule">Update Events</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="UpdatePostedSchedule">Update Schedule</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UpdateEditors">Update Editors</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CleanUpChat">Force Cleanup Chat Logs and IP Logs</MudButton>
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle2" GutterBottom="true">Testing Tools</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="EnqueueTestActions">Enqueue Test Actions</MudButton>
            </MudContainer>
        </Authorized>
        <NotAuthorized>
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>
@code {
    private async Task UpdateEditors()
    {
        await viewerFeature.UpdateEditors();
    }
    private async Task UpdatePostedSchedule()
    {
        await Schedule.PostSchedule();
    }
    private async Task PauseAlerts()
    {
        await Admin.PauseAlerts();
    }

    private async Task ResumeAlerts()
    {
        await Admin.ResumeAlerts();
    }

    private async Task Reconnect()
    {
        await TwitchWebsocketHostedService.Reconnect();
    }

    private async Task ForceOnline()
    {
        await TwitchWebsocketHostedService.StreamOnline();
    }

    private async Task ForceOffline()
    {
        await TwitchWebsocketHostedService.StreamOffline();
    }

    private async Task UpdateSchedule()
    {
        await Schedule.UpdateEvents();
    }

    private async Task CleanUpChat()
    {
        var tasks = new List<Task>
            {
                ChatHistory.CleanOldLogs(),
                ipLog.CleanupOldIpLogs()
            };
        await Task.WhenAll(tasks);
    }

    private async Task EnqueueTestActions()
    {
        try
        {
            // Test Action 1: Simple action with basic variables
            var action1 = new DotNetTwitchBot.Bot.Models.Actions.ActionType
            {
                Name = "Test_SimpleAction",
                Enabled = true,
                SubActions = new List<DotNetTwitchBot.Bot.Models.Actions.SubActions.SubActionType>
                {
                    new DotNetTwitchBot.Bot.Models.Actions.SubActions.SendMessageType
                    {
                        Text = "Test action 1 executed with user: %user%",
                        UseBot = true
                    }
                }
            };

            var variables1 = new Dictionary<string, string>
            {
                { "user", "TestUser1" },
                { "message", "Hello World" },
                { "timestamp", DateTime.UtcNow.ToString("o") }
            };

            // Test Action 2: Action with more complex variables
            var action2 = new DotNetTwitchBot.Bot.Models.Actions.ActionType
            {
                Name = "Test_ComplexAction",
                Enabled = true,
                SubActions = new List<DotNetTwitchBot.Bot.Models.Actions.SubActions.SubActionType>
                {
                    new DotNetTwitchBot.Bot.Models.Actions.SubActions.SendMessageType
                    {
                        Text = "Processing data for %user% - Points: %points%, Level: %level%",
                        UseBot = true
                    }
                }
            };

            var variables2 = new Dictionary<string, string>
            {
                { "user", "TestUser2" },
                { "points", "1500" },
                { "level", "Gold" },
                { "subscription_tier", "Tier 3" },
                { "follow_months", "24" }
            };

            // Test Action 3: Quick action with minimal variables
            var action3 = new DotNetTwitchBot.Bot.Models.Actions.ActionType
            {
                Name = "Test_QuickAction",
                Enabled = true,
                SubActions = new List<DotNetTwitchBot.Bot.Models.Actions.SubActions.SubActionType>
                {
                    new DotNetTwitchBot.Bot.Models.Actions.SubActions.SendMessageType
                    {
                        Text = "Quick test: %id%",
                        UseBot = true
                    }
                }
            };

            var variables3 = new Dictionary<string, string>
            {
                { "id", Guid.NewGuid().ToString() }
            };

            // Test Action 4: Action with empty variables (to test edge case)
            var action4 = new DotNetTwitchBot.Bot.Models.Actions.ActionType
            {
                Name = "Test_NoVariables",
                Enabled = true,
                SubActions = new List<DotNetTwitchBot.Bot.Models.Actions.SubActions.SubActionType>
                {
                    new DotNetTwitchBot.Bot.Models.Actions.SubActions.SendMessageType
                    {
                        Text = "Action with no variables",
                        UseBot = true
                    }
                }
            };

            // Test Action 5: Action for CurrentTime
            var action5 = new DotNetTwitchBot.Bot.Models.Actions.ActionType
            {
                Name = "Test_CurrentTime",
                Enabled = true,
                SubActions = new List<DotNetTwitchBot.Bot.Models.Actions.SubActions.SubActionType>
                {
                    new DotNetTwitchBot.Bot.Models.Actions.SubActions.CurrentTimeType
                    {
                        
                    }
                }
            };

            var variables4 = new Dictionary<string, string>();

            // Enqueue actions to different queues
            var defaultQueue = await QueueManager.GetQueueAsync("Default");
            /*
            await defaultQueue.EnqueueAsync(action1, variables1);
            await Task.Delay(100); // Small delay to ensure different timestamps

            await defaultQueue.EnqueueAsync(action2, variables2);
            await Task.Delay(100);

            await defaultQueue.EnqueueAsync(action3, variables3);
            await Task.Delay(100);

            await defaultQueue.EnqueueAsync(action4, variables4);
            await Task.Delay(100);*/

            await defaultQueue.EnqueueAsync(action5, new Dictionary<string, string>());

            Snackbar.Add("Successfully enqueued 4 test actions to Default queue", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error enqueuing test actions: {ex.Message}", MudBlazor.Severity.Error);
        }
    }
}
