@*
    CommandSelector - A reusable component for selecting or creating commands

    Usage:
    <CommandSelector SelectedCommandId="_selectedCommandId" 
                     SelectedCommandIdChanged="OnCommandSelected"
                     OnCommandCreated="OnCommandCreated"
                     SelectLabel="Select Command"
                     Required="true"
                     AllowNone="true"
                     AllowCreate="true" />

    Parameters:
    - SelectedCommandId: The currently selected command ID (two-way binding)
    - SelectedCommandIdChanged: Event callback when command selection changes
    - OnCommandCreated: Event callback when a new command is created
    - SelectLabel: Label for the select dropdown (default: "Select Command")
    - Required: Whether selection is required (default: true)
    - AllowNone: Whether to show "None" option (default: true)
    - AllowCreate: Whether to show "Create New" option (default: true)
*@
@using DotNetTwitchBot.Bot.Models.Commands
@using DotNetTwitchBot.Bot.Commands
@using DotNetTwitchBot.Bot.Models.Points
@using DotNetTwitchBot.Bot.Core.Points
@using DotNetTwitchBot.Pages.Components
@inject IActionCommandService CommandService
@inject IPointsSystem PointSystem
@inject MudBlazor.ISnackbar Snackbar
@inject IDialogService DialogService

<MudStack Spacing="3">
    @if (!_showCreateForm)
    {
        <!-- Selection Mode -->
        <MudSelect T="int?" Value="_selectedCommandId" Label="@SelectLabel" Variant="Variant.Outlined" 
                   Required="@Required" 
                   ValueChanged="OnCommandSelectedInternal">
            @if (AllowNone)
            {
                <MudSelectItem T="int?" Value="null">None</MudSelectItem>
            }
            @foreach (var command in _commands)
            {
                <MudSelectItem T="int?" Value="@command.Id">!@command.CommandName</MudSelectItem>
            }
        </MudSelect>

        @if (AllowCreate)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Or create a new command
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Add" OnClick="ShowCreateForm">
                    Create New
                </MudButton>
            </MudStack>
        }
    }
    else
    {
        <!-- Creation Mode -->
        <CommandEditor Command="_newCommand" 
                       OnSave="CreateCommand"
                       OnCancel="CancelCreate"
                       IsNewCommand="true"
                       ShowActions="true" />
    }
</MudStack>

@code {
    [Parameter] public int? SelectedCommandId { get; set; }
    [Parameter] public EventCallback<int?> SelectedCommandIdChanged { get; set; }
    [Parameter] public EventCallback<ActionCommand> OnCommandCreated { get; set; }
    [Parameter] public string SelectLabel { get; set; } = "Select Command";
    [Parameter] public bool Required { get; set; } = true;
    [Parameter] public bool AllowNone { get; set; } = true;
    [Parameter] public bool AllowCreate { get; set; } = true;

    private List<ActionCommand> _commands = new();
    private int? _selectedCommandId;
    private bool _showCreateForm = false;
    private ActionCommand _newCommand = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCommands();
        _selectedCommandId = SelectedCommandId;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_selectedCommandId != SelectedCommandId)
        {
            _selectedCommandId = SelectedCommandId;
        }
    }

    private async Task LoadCommands()
    {
        _commands = (await CommandService.GetAllAsync()).OrderBy(c => c.CommandName).ToList();
    }

    private async Task OnCommandSelectedInternal(int? commandId)
    {
        _selectedCommandId = commandId;
        await SelectedCommandIdChanged.InvokeAsync(commandId);
    }

    private void ShowCreateForm()
    {
        _newCommand = new ActionCommand
        {
            CommandName = "",
            Category = "",
            Description = "",
            Disabled = false,
            UserCooldown = 0,
            GlobalCooldown = 0,
            Cost = 0,
            MinimumRank = Rank.Viewer,
            SayCooldown = true,
            SayRankRequirement = false,
            ExcludeFromUi = false,
            SourceOnly = true
        };
        _showCreateForm = true;
    }

    private void CancelCreate()
    {
        _showCreateForm = false;
        _newCommand = new ActionCommand();
    }

    private async Task CreateCommand(ActionCommand command)
    {
        try
        {
            // Check if command already exists
            if (await CommandService.CommandExistsAsync(command.CommandName))
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    $"Command '!{command.CommandName}' already exists. Do you want to continue?",
                    yesText: "Yes", cancelText: "Cancel");

                if (result != true) return;
            }

            // Create the command
            var createdCommand = await CommandService.AddAsync(command);
            Snackbar.Add($"Command '!{createdCommand.CommandName}' created successfully", Severity.Success);

            // Reload commands
            await LoadCommands();

            // Select the newly created command
            _selectedCommandId = createdCommand.Id;
            await SelectedCommandIdChanged.InvokeAsync(createdCommand.Id);
            await OnCommandCreated.InvokeAsync(createdCommand);

            // Reset form
            _showCreateForm = false;
            _newCommand = new ActionCommand();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating command: {ex.Message}", Severity.Error);
        }
    }
}
