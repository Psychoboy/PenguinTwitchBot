@using DotNetTwitchBot.Bot.Actions
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="_searchString" Placeholder="Search actions" 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" Immediate="true" DebounceInterval="300"
                          OnDebounceIntervalElapsed="@((_) => FilterActions())" />

            @if (_filteredActions.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                    No actions found
                </MudText>
            }
            else
            {
                <MudList T="ActionType" SelectionMode="SelectionMode.SingleSelection" @bind-SelectedValue="_selectedAction" Dense="true" Style="max-height: 400px; overflow-y: auto;">
                    @foreach (var action in _filteredActions)
                    {
                        <MudListItem T="ActionType" Value="@action">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body1">@action.Name</MudText>
                                <MudStack Row="true" Spacing="1">
                                    @if (!string.IsNullOrEmpty(action.Group))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@action.Group</MudChip>
                                    }
                                    <MudChip T="string" Size="Size.Small" Color="@(action.Enabled ? Color.Success : Color.Error)">
                                        @(action.Enabled ? "Enabled" : "Disabled")
                                    </MudChip>
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Select" Disabled="@(_selectedAction == null)">Select</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public List<ActionType> Actions { get; set; } = new();

    private string _searchString = "";
    private List<ActionType> _filteredActions = new();
    private ActionType? _selectedAction;

    protected override void OnInitialized()
    {
        FilterActions();
    }

    protected override void OnParametersSet()
    {
        FilterActions();
    }

    private void FilterActions()
    {
        _filteredActions = Actions.Where(a =>
        {
            if (string.IsNullOrWhiteSpace(_searchString)) return true;
            
            return a.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                   (a.Group?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
        }).OrderBy(a => a.Name).ToList();
    }

    private void Cancel() => MudDialog.Cancel();
    private void Select() => MudDialog.Close(DialogResult.Ok(_selectedAction));
}
