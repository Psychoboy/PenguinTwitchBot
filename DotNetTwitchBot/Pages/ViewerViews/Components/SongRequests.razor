@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject DotNetTwitchBot.Bot.Commands.Music.YtPlayer YtPlayer
@inject ISnackbar Snackbar
@inject ILogger<SongRequests> logger
@implements IAsyncDisposable
<MudPaper Class="pa-5" Elevation="3">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.QueueMusic" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.h5" class="mud-contrast-text">@Title</MudText>
            </MudStack>
            @if(IsPreview)
            {
                <MudButton Href="songrequests" 
                           Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.ArrowForward">
                    View All
                </MudButton>
            }
        </MudStack>
        <MudDivider />
        @if (!dataLoaded)
        {
            <MudSkeleton Height="200px" />
            <MudOverlay Visible="!dataLoaded" DarkBackground="true" Absolute="true">
                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
            </MudOverlay>
        }
        else if (!songRequests.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Icon="@Icons.Material.Filled.MusicNote">
                No songs in the queue. Be the first to request a song!
            </MudAlert>
        }
        else
        {
            <MudTable Items="@songRequests" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Title</MudTh>
                    <MudTh>Length</MudTh>
                    <MudTh>Requested By</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Title">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Small" Color="Color.Secondary" />
                            <MudText>@context.Title</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Duration">@context.Duration</MudTd>
                    <MudTd DataLabel="Requested By">@context.RequestedBy</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudPaper>
@code {
    private List<Song> songRequests = new();
    private HubConnection? hubConnection;
    private CancellationTokenSource? _hubConnectionCts;

    [Parameter]
    public int LimitNumberOfSongs { get; set; }

    [Parameter]
    public string Title { get; set; } = "Song Requests";

    [Parameter]
    public bool IsPreview { get; set; } = false;

    private bool dataLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        UpdateSongList(await YtPlayer.GetRequestedSongs());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        _hubConnectionCts = new CancellationTokenSource();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/ythub"), options =>
            {
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false;
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        hubConnection.On<List<Song>>("CurrentSongRequests", (playlist) =>
        {
            if (songRequests.Count == 0 && playlist.Count == 0) return;
            UpdateSongList(playlist);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync(_hubConnectionCts.Token);
        }
        catch (OperationCanceledException)
        {
            // Expected during disposal
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to establish SignalR connection");
            Snackbar.Add("Lost connection to bot. Data may be inaccurate until refresh.", Severity.Warning);
        }

        dataLoaded = true;
        StateHasChanged();
    }

    private void UpdateSongList(List<Song> songs)
    {
        if (LimitNumberOfSongs > 0 && songs.Count > LimitNumberOfSongs)
        {
            songs = songs.Slice(0, LimitNumberOfSongs);
        }
        songRequests = songs;
    }

    private string GetYoutubeLink(string songId)
    {
        return $"https://youtu.be/{songId}";
    }

    public async ValueTask DisposeAsync()
    {
        _hubConnectionCts?.Cancel();

        if (hubConnection is not null)
        {
            try
            {
                if (hubConnection.State == HubConnectionState.Connected)
                {
                    await hubConnection.StopAsync();
                }
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                logger.LogDebug(ex, "Exception during SignalR connection disposal (non-critical)");
            }
        }

        _hubConnectionCts?.Dispose();
    }
}
