@page "/songrequests"
@using DotNetTwitchBot.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject DotNetTwitchBot.Bot.Commands.Music.YtPlayer YtPlayer
@implements IAsyncDisposable
@inject ISnackbar Snackbar
@inject ILogger<SongRequests> logger

<PageTitle>SPTV Twitch Bot - Song Requests</PageTitle>
<MudContainer Class="pa-4 pa-md-6" MaxWidth="MaxWidth.ExtraLarge">

    <MudStack Spacing="3">
        <MudText Typo="Typo.h4" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.QueueMusic" Class="mr-2" />
            Song Requests
        </MudText>

        @if (currentSong != null)
        {
            <MudPaper Elevation="3" Class="pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Color="Color.Success">Now Playing</MudText>
                    </MudStack>
                    <MudDivider />
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle1"><strong>@currentSong.Title</strong></MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.body2">Requested by <strong>@currentSong.RequestedBy</strong></MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Info" />
                            <MudText Typo="Typo.body2">@currentSong.Duration</MudText>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info">
                No song is currently playing
            </MudAlert>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <DotNetTwitchBot.Pages.ViewerViews.Components.LastPlayedSongs />
            </MudItem>

            <MudItem xs="12" sm="6">
                <DotNetTwitchBot.Pages.ViewerViews.Components.SongRequests />
            </MudItem>

            <MudItem xs="12" sm="6">
                <DotNetTwitchBot.Pages.ViewerViews.Components.TopRequestedSongs />
            </MudItem>
        </MudGrid>
    </MudStack>
</MudContainer>


@code {
    private Song? currentSong;
    private HubConnection? hubConnection;
    private CancellationTokenSource? _hubConnectionCts;

    protected override void OnInitialized()
    {
        currentSong = YtPlayer.GetCurrentSong();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        _hubConnectionCts = new CancellationTokenSource();

        // Configure SignalR with automatic reconnect and retry policy
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/ythub"), options =>
            {
                // Allow fallback to other transports if WebSockets fail
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false;
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        hubConnection.On<Song?>("CurrentSongUpdate", (song) =>
        {
            currentSong = song;
            InvokeAsync(StateHasChanged);
        });

        // Handle reconnection events
        hubConnection.Reconnecting += error =>
        {
            logger.LogWarning(error, "SignalR connection lost, attempting to reconnect...");
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += connectionId =>
        {
            logger.LogInformation("SignalR reconnected successfully");
            return InvokeAsync(() => Snackbar.Add("Connection restored.", Severity.Success));
        };

        hubConnection.Closed += async error =>
        {
            if (error != null)
            {
                logger.LogError(error, "SignalR connection closed with error");
            }
            // If initial connection never succeeded, attempt to reconnect (unless we're disposing)
            if (hubConnection.State == HubConnectionState.Disconnected && _hubConnectionCts != null && !_hubConnectionCts.Token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), _hubConnectionCts.Token);
                    await hubConnection.StartAsync(_hubConnectionCts.Token);
                    logger.LogDebug("SignalR connection re-established after initial failure");
                }
                catch (OperationCanceledException)
                {
                    // Disposal requested - this is expected
                }
                catch (ObjectDisposedException)
                {
                    // Component disposed during reconnection attempt - this is expected
                }
                catch (Exception ex)
                {
                    logger.LogDebug(ex, "Failed to re-establish SignalR connection");
                }
            }
        };

        // Retry initial connection with exponential backoff
        var retryDelays = new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) };
        var attempt = 0;
        var connected = false;

        while (!connected && attempt < retryDelays.Length)
        {
            try
            {
                if (attempt > 0)
                {
                    await Task.Delay(retryDelays[attempt]);
                }
                await hubConnection.StartAsync();
                connected = true;
            }
            catch (Microsoft.AspNetCore.Http.Connections.Client.TransportFailedException ex)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    logger.LogWarning(ex, "SignalR initial connection failed after {Attempts} attempts", attempt);
                }
                else
                {
                    logger.LogDebug(ex, "SignalR initial connection attempt {Attempt} failed, retrying...", attempt);
                }
            }
            catch (TaskCanceledException)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    Snackbar.Add("Connection attempt cancelled. Page may need refresh.", Severity.Warning);
                    logger.LogWarning("SignalR connection cancelled after {Attempts} attempts", attempt);
                }
            }
            catch (Exception ex)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    logger.LogWarning(ex, "Failed to connect to SignalR hub after {Attempts} attempts", attempt);
                }
                else
                {
                    logger.LogDebug(ex, "SignalR connection attempt {Attempt} failed, retrying...", attempt);
                }
            }
        }

        if (!connected)
        {
            Snackbar.Add("Unable to establish live connection. Data may be delayed.", Severity.Warning);
        }
    }

    public async ValueTask DisposeAsync()
    {
        // Cancel any pending reconnection attempts
        _hubConnectionCts?.Cancel();

        if (hubConnection is not null)
        {
            try
            {
                // Stop the connection gracefully before disposing
                if (hubConnection.State == HubConnectionState.Connected)
                {
                    await hubConnection.StopAsync();
                }
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                // Log but don't throw - disposal should be silent to user
                logger.LogDebug(ex, "Exception during SignalR connection disposal (non-critical)");
            }
        }

        _hubConnectionCts?.Dispose();
    }
}
