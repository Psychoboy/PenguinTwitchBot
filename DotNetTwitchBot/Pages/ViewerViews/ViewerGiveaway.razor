@page "/viewergiveaway"

@using System.Security.Claims
@using DotNetTwitchBot.Pages.ViewerViews.Components
@using Microsoft.AspNetCore.SignalR.Client
@using DotNetTwitchBot.Bot.Models.Giveaway
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject DotNetTwitchBot.Bot.Commands.Features.GiveawayFeature GiveawayFeature;
@inject DotNetTwitchBot.Bot.Core.Points.IPointsSystem PointSystem;
@inject DotNetTwitchBot.Bot.Core.Points.ITwitchEventsBonus twitchEventsBonus
@inject DotNetTwitchBot.Bot.Commands.Features.ITicketsFeature ticketsFeature;
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<ViewerGiveaway> logger
@implements IAsyncDisposable

<PageTitle>SPTV Twitch Bot - Giveaway</PageTitle>

<style> 
    .mud-contrast-text {
        color: var(--mud-palette-white);
    }

    .stat-card {
        transition: transform 0.2s ease-in-out;
    }

    .stat-card:hover {
        transform: translateY(-4px);
    }
</style>

<MudContainer Class="pa-4 pa-md-6" MaxWidth="MaxWidth.ExtraLarge">
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6">
            <MudStack Spacing="3">
                <BonusTickets/>
                <MudPaper Class="pa-4 stat-card" Elevation="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Large" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle2" class="mud-contrast-text">Total Entrants</MudText>
                            <MudText Typo="Typo.h3" Color="Color.Info">@entrants</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-4 stat-card" Elevation="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Color="Color.Success" Size="Size.Large" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle2" class="mud-contrast-text">Total Tickets Entered</MudText>
                            <MudText Typo="Typo.h3" Color="Color.Success">@entries</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            <AuthorizeView>
                <Authorized Context="Auth">
                    <MudPaper Class="pa-4 stat-card" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.LocalActivity" Color="Color.Warning" Size="Size.Large" />
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2" class="mud-contrast-text">Your Available Tickets</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Warning">@userTickets</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                    <MudPaper Class="pa-5" Elevation="3">
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Input" Color="Color.Primary" />
                                <MudText Typo="Typo.h6" class="mud-contrast-text">Enter Giveaway</MudText>
                            </MudStack>
                            <MudDivider />
                            @if(isClosed)
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Lock">
                                    Giveaway is currently closed. Please wait for the next giveaway to open.
                                </MudAlert>
                            }
                            else
                            {
                                <EditForm Model="@model" OnValidSubmit="EnterTickets">
                                    <DataAnnotationsValidator />
                                    <MudStack Spacing="2">
                                        <MudNumericField @bind-Value="model.EnterAmount" 
                                                         For="@(() => model.EnterAmount)" 
                                                         Label="Number of Tickets to Enter"
                                                         HelperText="@userEntriesText" 
                                                         Variant="Variant.Outlined"
                                                         Disabled="@isSubmitting"
                                                         Immediate="true" />
                                        <MudButton ButtonType="ButtonType.Submit" 
                                                   Variant="Variant.Filled" 
                                                   Color="Color.Primary"
                                                   FullWidth="true"
                                                   Size="Size.Large"
                                                   StartIcon="@Icons.Material.Filled.Send"
                                                   Disabled="@isSubmitting">
                                            @(isSubmitting ? "Entering..." : "Enter Giveaway")
                                        </MudButton>
                                    </MudStack>
                                </EditForm>
                            }
                            @if (!string.IsNullOrWhiteSpace(AlertText))
                            {
                                <MudAlert Severity="@AlertSeverity" Variant="Variant.Filled">@AlertText</MudAlert>
                            }
                            <MudDivider />
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                    <MudLink Href="https://twitch.tv/subs/SuperPenguinTV" Target="_blank" Color="Color.Primary">
                                        Subscribe today to earn even more tickets
                                    </MudLink>
                                </MudText>
                                <MudText Typo="Typo.body2">
                                    <MudIcon Icon="@Icons.Material.Filled.Help" Size="Size.Small" Color="Color.Info" />
                                    <MudLink Href="/viewergiveaway#howtoearn" Color="Color.Primary">
                                        How to earn tickets
                                    </MudLink>
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </Authorized>
                <NotAuthorized>
                    <MudPaper Class="pa-5" Elevation="3">
                        <MudStack Spacing="3" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Large" Color="Color.Info" />
                            <MudText Typo="Typo.h6" Align="Align.Center">Sign in to participate</MudText>
                                <MudButton OnClick="Signin"
                                       Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.Login"
                                       FullWidth="true">
                                Sign In with Twitch
                            </MudButton>
                            <MudDivider />
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Align="Align.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                    <MudLink Href="https://twitch.tv/subs/SuperPenguinTV" Target="_blank" Color="Color.Primary">
                                        Subscribe to earn more tickets
                                    </MudLink>
                                </MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Help" Size="Size.Small" Color="Color.Info" />
                                    <MudLink Href="/viewergiveaway#howtoearn" Color="Color.Primary">
                                        How to earn tickets
                                    </MudLink>
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </NotAuthorized>
            </AuthorizeView>
            </MudStack>

        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Class="pa-6" Elevation="3">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h4" class="mud-contrast-text" Align="Align.Center">Current Giveaway</MudText>
                    </MudStack>
                    <MudDivider />
                    @if (string.IsNullOrEmpty(prize))
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Height="40px" />
                    }
                    else
                    {
                        <MudText Typo="Typo.h5" Align="Align.Center"><strong>@prize</strong></MudText>
                    }
                    @if (string.IsNullOrEmpty(imageUrl))
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="300px" Class="rounded" />
                    }
                    else
                    {
                        <MudImage Fluid="true" Class="rounded-lg" Src="@imageUrl" Elevation="2" />
                    }
                    @if(!string.IsNullOrEmpty(prizeAdditionalDetails))
                    {
                        <MudPaper Class="pa-3" Elevation="0" Style="background-color: rgba(255,255,255,0.05);">
                            <MudMarkdown Value="@prizeAdditionalDetails" />
                        </MudPaper>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <Bookmark BookmarkName="howtoearn">
                <MudPaper Class="pa-5 mb-3" Elevation="3" id="howtoearn">
                    <MudStack Spacing="3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Success" Size="Size.Large" />
                            <MudText Typo="Typo.h5" class="mud-contrast-text">How to Earn Tickets</MudText>
                        </MudStack>
                        <MudDivider />
                        <MudText Typo="Typo.h6" Color="Color.Primary">Instant Rewards</MudText>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Subscriptions" Color="Color.Secondary" />
                                <MudText><strong>@TicketsPerSub tickets</strong> for every subscription</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Color="Color.Secondary" />
                                <MudText><strong>@TicketsPerSub tickets</strong> for every gifted sub</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Diamond" Color="Color.Secondary" />
                                <MudText><strong>@((int)@BitsPerPoint) tickets</strong> per 100 bits cheered</MudText>
                            </MudStack>
                        </MudStack>

                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-2">Passive Earnings (Every 5 Minutes)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Default">Earn tickets automatically while watching the stream:</MudText>
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Info" />
                                <MudText><strong>+@pointsForEveryone ticket</strong> - Everyone watching</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Forum" Color="Color.Success" />
                                <MudText><strong>+@pointsForActive tickets</strong> - Active viewers (chatting recently)</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                <MudText><strong>+@pointsForSubs tickets</strong> - Subscribers</MudText>
                            </MudStack>
                        </MudStack>

                        <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.TrendingUp">
                            <strong>Subscribers earn @(pointsForActive + pointsForEveryone + pointsForSubs) tickets every 5 minutes!</strong>
                            <MudLink Href="https://twitch.tv/subs/SuperPenguinTV" Target="_blank" Style="color: white; text-decoration: underline;">
                                Subscribe today
                            </MudLink>
                        </MudAlert>

                        <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                            <MudText Typo="Typo.body2">
                                <strong>What is an Active Viewer?</strong> Someone who has participated in chat within the last 15 minutes through messages, commands, follows, subs, bits, or channel point redemptions. Subscribers are always considered active.
                            </MudText>
                        </MudAlert>
                    </MudStack>
                </MudPaper>
            </Bookmark>
            <MudPaper Class="pa-5 mb-3" Elevation="3">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Warning" Size="Size.Large" />
                        <MudText Typo="Typo.h5" class="mud-contrast-text">Giveaway Rules</MudText>
                    </MudStack>
                    <MudDivider />
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                            <MudText>Winners do <strong>NOT</strong> need to be present during the drawing</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Error" />
                            <MudText>Multiple accounts (botting) will result in <strong>exclusion from all giveaways</strong></MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Error" />
                            <MudText>Banned users (Discord or Twitch) are <strong>not eligible</strong></MudText>
                        </MudStack>
                    </MudStack>

                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-2">Prize Tiers & Cooldowns</MudText>
                    <MudText Typo="Typo.body2">After winning, you'll have a cooldown before being eligible for standard giveaways again (special giveaways always eligible). For Star Citizen this is not melt value but normal purchase price.</MudText>
                    <MudSimpleTable Dense="true" Hover="true" Style="background-color: rgba(255,255,255,0.03);">
                        <thead>
                            <tr>
                                <th>Tier</th>
                                <th>Prize Value</th>
                                <th>Cooldown Period</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><MudText Color="Color.Success"><strong>Tier 1</strong></MudText></td>
                                <td>Less than $75</td>
                                <td>1 month or next giveaway</td>
                            </tr>
                            <tr>
                                <td><MudText Color="Color.Warning"><strong>Tier 2</strong></MudText></td>
                                <td>$75 - $115</td>
                                <td>2 months or next 2 giveaways</td>
                            </tr>
                            <tr>
                                <td><MudText Color="Color.Error"><strong>Tier 3</strong></MudText></td>
                                <td>Greater than $115</td>
                                <td>3 months or next 3 giveaways</td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudStack>
            </MudPaper>
            <MudPaper Class="pa-5 mb-3" Elevation="3">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.h5" class="mud-contrast-text">Terms & Conditions</MudText>
                    </MudStack>
                    <MudDivider />
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Warning" />
                            <MudText>Winners have <strong>48 hours</strong> to whisper SuperPenguinTV on Twitch to claim their prize</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Info" />
                            <MudText>Winners announced live on stream and in 
                            <MudLink Href="https://discord.gg/4zVq4DyBFS" Target="_blank" Color="Color.Primary">Discord</MudLink> 
                            (#giveaway-winners channel)</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Success" />
                            <MudText><strong>Subscribers</strong> auto-claim and will be whispered directly</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Default" />
                            <MudText>SuperPenguinTV reserves the right to change giveaways at any time</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                            <MudText>Must be <strong>18+</strong> to participate</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Public" Color="Color.Default" />
                            <MudText>Void where prohibited by law</MudText>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

</MudContainer>

@code {
    private HubConnection? hubConnection;
    private CancellationTokenSource? _hubConnectionCts;
    private List<GiveawayWinner> winners = new List<GiveawayWinner>();
    private string prize = "";
    private string? imageUrl;
    private string prizeAdditionalDetails = "";
    private int entries;
    private int entrants;
    private long userTickets;
    private long userEntries;
    private string Username = "";
    private string AlertText = "";
    private string userEntriesText = "";
    private MudBlazor.Severity AlertSeverity = Severity.Info;
    private bool isSubmitting;
    private int TicketsPerSub;
    private double BitsPerPoint;
    private int pointsForEveryone { get; set; }
    private int pointsForActive { get; set; }
    private int pointsForSubs { get; set; }

    private bool isClosed { get; set; } = false;

    private EnterTicketsForm model = new();

    public class EnterTicketsForm
    {
        [Range(1, 1000000)]
        public int EnterAmount { get; set; } = 1;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider
           .GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated && user.Identity.Name != null)
        {
            Username = user.Identity.Name;
            userTickets = (await PointSystem.GetUserPointsByUsernameAndGame(Username, "GiveawayFeature")).Points;
            userEntries = await GiveawayFeature.GetEntriesCount(Username);
            userEntriesText = $"You are participating with {userEntries} tickets.";
        }
        prize = await GiveawayFeature.GetPrize();
        imageUrl = await GiveawayFeature.GetImageUrl();
        prizeAdditionalDetails = (await GiveawayFeature.GetPrizeAdditionalDetails()).Trim();
        entries = await GiveawayFeature.GetEntriesCount();
        entrants = await GiveawayFeature.GetEntrantsCount();
        TicketsPerSub = await twitchEventsBonus.GetPointsPerSub();
        BitsPerPoint = await twitchEventsBonus.GetBitsPerPoint();
        pointsForEveryone = await ticketsFeature.GetPointsForEveryone();
        pointsForActive = await ticketsFeature.GetPointsForActiveUsers();
        pointsForSubs = await ticketsFeature.GetPointsForSubs();
        isClosed = GiveawayFeature.IsClosed();
        if (BitsPerPoint > 0) BitsPerPoint = 100 * BitsPerPoint;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        _hubConnectionCts = new CancellationTokenSource();

        // Configure SignalR with automatic reconnect and retry policy
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/mainhub"), options =>
            {
                // Allow fallback to other transports if WebSockets fail
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false;
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        hubConnection.On<List<GiveawayWinner>>("Winners", (Winners) =>
        {
            winners = Winners;
            InvokeAsync(StateHasChanged);
        });
        hubConnection.On<string>("Prize", (Prize) =>
        {
            prize = Prize;
            InvokeAsync(StateHasChanged);
        });
        hubConnection.On<string>("PrizeAdditionalDetails", (PrizeAdditionalDetails) =>
        {
            prizeAdditionalDetails = PrizeAdditionalDetails.Trim();
            InvokeAsync(StateHasChanged);
        });
        hubConnection.On<int, int>("UpdateTickets", (curEntries, curEntrants) =>
        {
            entries = curEntries;
            entrants = curEntrants;
            userEntriesText = $"You are participating with {userEntries} tickets.";
            InvokeAsync(StateHasChanged);
        });
        hubConnection.On<bool>("GiveawayIsClosed", (isClosed) =>
        {
            this.isClosed = isClosed;
            InvokeAsync(StateHasChanged);
        });

        // Handle reconnection events
        hubConnection.Reconnecting += error =>
        {
            logger.LogWarning(error, "SignalR connection lost, attempting to reconnect...");
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += connectionId =>
        {
            logger.LogInformation("SignalR reconnected successfully");
            return InvokeAsync(() => Snackbar.Add("Connection restored.", Severity.Success));
        };

        hubConnection.Closed += async error =>
        {
            if (error != null)
            {
                logger.LogError(error, "SignalR connection closed with error");
            }
            // If initial connection never succeeded, attempt to reconnect (unless we're disposing)
            if (hubConnection.State == HubConnectionState.Disconnected && _hubConnectionCts != null && !_hubConnectionCts.Token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), _hubConnectionCts.Token);
                    await hubConnection.StartAsync(_hubConnectionCts.Token);
                    logger.LogDebug("SignalR connection re-established after initial failure");
                }
                catch (OperationCanceledException)
                {
                    // Disposal requested - this is expected
                }
                catch (ObjectDisposedException)
                {
                    // Component disposed during reconnection attempt - this is expected
                }
                catch (Exception ex)
                {
                    logger.LogDebug(ex, "Failed to re-establish SignalR connection");
                }
            }
        };

        // Retry initial connection with backoff
        var retryDelays = new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) };
        var attempt = 0;
        var connected = false;

        while (!connected && attempt < retryDelays.Length)
        {
            try
            {
                if (attempt > 0)
                {
                    await Task.Delay(retryDelays[attempt]);
                }
                await hubConnection.StartAsync();
                connected = true;
            }
            catch (Microsoft.AspNetCore.Http.Connections.Client.TransportFailedException ex)
            {
                attempt++;
                if (attempt >= retryDelays.Length)
                {
                    logger.LogWarning(ex, "SignalR initial connection failed after {Attempts} attempts", attempt);
                }
                else
                {
                    logger.LogDebug(ex, "SignalR initial connection attempt {Attempt} failed, retrying...", attempt);
                }
            }
            catch (TaskCanceledException)
            {
                logger.LogWarning("SignalR connection cancelled");
                break;
            }
            catch (Exception ex)
            {
                logger.LogWarning(ex, "Failed to connect to SignalR hub");
                break;
            }
        }

        if (!connected)
        {
            Snackbar.Add("Unable to establish live connection. Data may be delayed.", Severity.Warning);
        }
    }

    private static MarkupString RenderMultiline(string textWithLineBreaks)
    {
        var encodedLines = (textWithLineBreaks ?? string.Empty)
            .Split(new char[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(line => System.Web.HttpUtility.HtmlEncode(line))
            .ToArray();
        return (MarkupString)string.Join("<br />", encodedLines);
    }

    private async Task EnterTickets()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        try
        {
            var result = await GiveawayFeature.Enter(Username, model.EnterAmount.ToString(), true);
            AlertText = result;
            AlertSeverity = Severity.Success;
            userTickets = (await PointSystem.GetUserPointsByUsernameAndGame(Username, "GiveawayFeature")).Points;
            userEntries = await GiveawayFeature.GetEntriesCount(Username);
            userEntriesText = $"You are participating with {userEntries} tickets.";
        } catch (SkipCooldownException ex)
        {
            AlertText = ex.Message;
            AlertSeverity = Severity.Error;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        // Cancel any pending reconnection attempts
        _hubConnectionCts?.Cancel();

        if (hubConnection is not null)
        {
            try
            {
                // Stop the connection gracefully before disposing
                if (hubConnection.State == HubConnectionState.Connected)
                {
                    await hubConnection.StopAsync();
                }
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                // Log but don't throw - disposal should be silent to user
                logger.LogDebug(ex, "Exception during SignalR connection disposal (non-critical)");
            }
        }

        _hubConnectionCts?.Dispose();
    }

    private void Signin()
    {
        Navigation.NavigateTo("/signin?r=" + new Uri(Navigation.Uri).AbsoluteUri, true);
    }
}
