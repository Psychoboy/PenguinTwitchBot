@page "/actioncommands"
@using DotNetTwitchBot.Bot.Models.Commands
@using DotNetTwitchBot.Bot.Models.Points
@using DotNetTwitchBot.Bot.Commands
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject DotNetTwitchBot.Bot.Commands.IActionCommandService CommandService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject DotNetTwitchBot.Bot.Core.Points.IPointsSystem PointSystem

<PageTitle>SPTV Twitch Bot - Action Commands</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Action Commands</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">Manage action commands for the bot.</MudText>

    <MudGrid>
        <!-- Left Panel - Commands List -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Commands (@_commands.Count)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" 
                                       OnClick="CreateNewCommand" />
                    </MudStack>

                    <MudTextField @bind-Value="_searchString" Placeholder="Search commands" 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                  IconSize="Size.Medium" Immediate="true" DebounceInterval="300" 
                                  OnDebounceIntervalElapsed="FilterCommands" />

                    <MudSelect T="string" Value="@_filterCategory" ValueChanged="OnCategoryFilterChanged" Label="Filter by Category" Dense="true">
                        <MudSelectItem T="string" Value="@("")">All Categories</MudSelectItem>
                        @foreach (var category in _categories)
                        {
                            <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                        }
                    </MudSelect>

                    <MudDivider />

                    @if (_filteredCommands.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                            No commands found
                        </MudText>
                    }
                    else
                    {
                        <MudList T="ActionCommand" @bind-SelectedValue="_selectedCommand" Dense="true">
                            @foreach (var command in _filteredCommands)
                            {
                                <MudListItem T="ActionCommand" Value="@command" OnClick="@(() => OnCommandSelected(command))">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body1">!@command.CommandName</MudText>
                                        <MudStack Row="true" Spacing="1">
                                            @if (!string.IsNullOrEmpty(command.Category))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@command.Category</MudChip>
                                            }
                                            <MudChip T="string" Size="Size.Small" Color="@(command.Disabled ? Color.Error : Color.Success)">
                                                @(command.Disabled ? "Disabled" : "Enabled")
                                            </MudChip>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Right Panel - Command Details -->
        <MudItem xs="12" md="8">
            @if (_selectedCommand == null)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Select a command to view details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Or create a new command to get started</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                    <MudStack Spacing="3">
                        <!-- Command Header -->
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5">
                                @(_isNewCommand ? "New Command" : $"!{_selectedCommand.CommandName}")
                            </MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                                           OnClick="SaveCommand" StartIcon="@Icons.Material.Filled.Save">
                                    Save
                                </MudButton>
                                @if (!_isNewCommand)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Error" 
                                               OnClick="DeleteCommand" StartIcon="@Icons.Material.Filled.Delete">
                                        Delete
                                    </MudButton>
                                }
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEdit">
                                    Cancel
                                </MudButton>
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        <!-- Command Configuration -->
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.h6" Class="mb-3">Command Configuration</MudText>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_selectedCommand.CommandName" Label="Command Name" 
                                                  Required="true" Variant="Variant.Outlined" 
                                                  HelperText="Do not include the ! prefix" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudAutocomplete T="string" @bind-Value="_selectedCommand.Category" Label="Category" 
                                                     Variant="Variant.Outlined" 
                                                     SearchFunc="@SearchCategories"
                                                     Clearable="true"
                                                     CoerceText="true"
                                                     CoerceValue="false" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_selectedCommand.Description" Label="Description" 
                                                  Lines="3" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_selectedCommand.UserCooldown" Label="User Cooldown (seconds)" 
                                                     Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_selectedCommand.GlobalCooldown" Label="Global Cooldown (seconds)" 
                                                     Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_selectedCommand.Cost" Label="Cost" 
                                                     Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="PointType" @bind-Value="_selectedPointType" Label="Point Type" 
                                               Variant="Variant.Outlined"
                                               Required="@(_selectedCommand.Cost > 0)"
                                               ToStringFunc="@(p => p?.Name ?? "None")">
                                        <MudSelectItem T="PointType" Value="@null">None</MudSelectItem>
                                        @foreach (var pointType in _pointTypes)
                                        {
                                            <MudSelectItem Value="@pointType">@pointType.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Rank" @bind-Value="_selectedCommand.MinimumRank" Label="Minimum Rank" 
                                               Variant="Variant.Outlined">
                                        @foreach (Rank rank in Enum.GetValues(typeof(Rank)))
                                        {
                                            <MudSelectItem Value="@rank">@rank</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_selectedCommand.SpecificUserOnly" Label="Specific User Only" 
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.body2">Specific Users Only</MudText>
                                        <MudStack Row="true" Spacing="1">
                                            <MudTextField @bind-Value="_newSpecificUser" Label="Add User" 
                                                          Variant="Variant.Outlined" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" 
                                                           OnClick="AddSpecificUser" />
                                        </MudStack>
                                        @if (_selectedCommand.SpecificUsersOnly.Any())
                                        {
                                            <MudStack Row="true" Spacing="1">
                                                @foreach (var user in _selectedCommand.SpecificUsersOnly)
                                                {
                                                    <MudChip T="string" OnClose="@(() => RemoveSpecificUser(user))">@user</MudChip>
                                                }
                                            </MudStack>
                                        }
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudSelect T="Rank" Label="Specific Ranks" MultiSelection="true" 
                                               SelectedValues="_selectedRanks" SelectedValuesChanged="OnSelectedRanksChanged" Variant="Variant.Outlined">
                                        @foreach (Rank rank in Enum.GetValues(typeof(Rank)))
                                        {
                                            <MudSelectItem Value="@rank">@rank</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudStack Row="true" Spacing="3">
                                        <MudSwitch @bind-Value="_selectedCommand.Disabled" Label="Disabled" Color="Color.Error" />
                                        <MudSwitch @bind-Value="_selectedCommand.SayCooldown" Label="Say Cooldown" Color="Color.Info" />
                                        <MudSwitch @bind-Value="_selectedCommand.SayRankRequirement" Label="Say Rank Requirement" Color="Color.Info" />
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudStack Row="true" Spacing="3">
                                        <MudSwitch @bind-Value="_selectedCommand.ExcludeFromUi" Label="Exclude from UI" Color="Color.Warning" />
                                        <MudSwitch @bind-Value="_selectedCommand.SourceOnly" Label="Source Only" Color="Color.Warning" />
                                        <MudSwitch @bind-Value="_selectedCommand.RunFromBroadcasterOnly" Label="Broadcaster Only" Color="Color.Warning" />
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudStack>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<ActionCommand> _commands = new();
    private List<ActionCommand> _filteredCommands = new();
    private List<string> _categories = new();
    private List<PointType> _pointTypes = new();
    private ActionCommand? _selectedCommand;
    private PointType? _selectedPointType;
    private IReadOnlyCollection<Rank> _selectedRanks = new List<Rank>();
    private bool _isNewCommand = false;
    private string _searchString = "";
    private string _filterCategory = "";
    private string _newSpecificUser = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCommands();
        await LoadPointTypes();
    }

    private async Task LoadCommands()
    {
        _commands = await CommandService.GetAllAsync();
        _categories = _commands.Select(c => c.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c).ToList();
        FilterCommands();
    }

    private async Task LoadPointTypes()
    {
        _pointTypes = (await PointSystem.GetPointTypes()).ToList();
    }

    private void FilterCommands()
    {
        _filteredCommands = _commands.Where(c =>
        {
            bool matchesSearch = string.IsNullOrWhiteSpace(_searchString) || 
                                 c.CommandName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                                 (c.Description?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
            bool matchesCategory = string.IsNullOrWhiteSpace(_filterCategory) || 
                                    c.Category == _filterCategory;
            return matchesSearch && matchesCategory;
        }).OrderBy(c => c.CommandName).ToList();
    }

    private void OnCategoryFilterChanged(string category)
    {
        _filterCategory = category;
        FilterCommands();
    }

    private Task<IEnumerable<string>> SearchCategories(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult<IEnumerable<string>>(_categories);
        }

        value = value.Trim();

        var filteredCategories = _categories
            .Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase))
            .ToList();

        // If the typed value doesn't exist in the list, add it as the first option
        if (!string.IsNullOrWhiteSpace(value) && !filteredCategories.Any(c => c.Equals(value, StringComparison.OrdinalIgnoreCase)))
        {
            filteredCategories.Insert(0, value);
        }

        return Task.FromResult(filteredCategories.AsEnumerable());
    }

    private void OnCommandSelected(ActionCommand? command)
    {
        if (command == null) return;

        _selectedCommand = command;
        _isNewCommand = false;

        // Load related data
        _selectedPointType = command.PointType;
        _selectedRanks = command.SpecificRanks;
    }

    private void OnSelectedRanksChanged(IEnumerable<Rank> ranks)
    {
        _selectedRanks = ranks.ToList();
        if (_selectedCommand != null)
        {
            _selectedCommand.SpecificRanks = _selectedRanks.ToList();
        }
    }

    private void CreateNewCommand()
    {
        _selectedCommand = new ActionCommand
        {
            CommandName = "",
            Category = "",
            Description = "",
            Disabled = false,
            UserCooldown = 0,
            GlobalCooldown = 0,
            Cost = 0,
            MinimumRank = Rank.Viewer,
            SayCooldown = true,
            SayRankRequirement = false,
            ExcludeFromUi = false,
            SourceOnly = true,
            RunFromBroadcasterOnly = false
        };
        _selectedPointType = null;
        _selectedRanks = new List<Rank>();
        _isNewCommand = true;
    }

    private void AddSpecificUser()
    {
        if (string.IsNullOrWhiteSpace(_newSpecificUser) || _selectedCommand == null) return;

        if (!_selectedCommand.SpecificUsersOnly.Contains(_newSpecificUser))
        {
            _selectedCommand.SpecificUsersOnly.Add(_newSpecificUser);
            _newSpecificUser = "";
        }
    }

    private void RemoveSpecificUser(string user)
    {
        _selectedCommand?.SpecificUsersOnly.Remove(user);
    }

    private async Task SaveCommand()
    {
        if (_selectedCommand == null || string.IsNullOrWhiteSpace(_selectedCommand.CommandName)) 
        {
            Snackbar.Add("Command name is required", Severity.Error);
            return;
        }

        if (_selectedCommand.Cost > 0 && _selectedPointType == null)
        {
            Snackbar.Add("Point type is required when cost is set", Severity.Error);
            return;
        }

        try
        {
            // Ensure category is never null
            _selectedCommand.Category = _selectedCommand.Category ?? string.Empty;

            // Update references from the UI selections
            _selectedCommand.PointTypeId = _selectedPointType?.Id;
            _selectedCommand.PointType = _selectedPointType;
            _selectedCommand.SpecificRanks = _selectedRanks.ToList();

            if (_isNewCommand)
            {
                // Check if command already exists
                if (await CommandService.CommandExistsAsync(_selectedCommand.CommandName))
                {
                    bool? result = await DialogService.ShowMessageBoxAsync(
                        "Warning",
                        "This command already exists. Continue?",
                        yesText: "Yes", cancelText: "Cancel");

                    if (result != true) return;
                }

                await CommandService.AddAsync(_selectedCommand);
                _isNewCommand = false;
                Snackbar.Add($"Command '!{_selectedCommand.CommandName}' created successfully", Severity.Success);
            }
            else
            {
                await CommandService.UpdateAsync(_selectedCommand);
                Snackbar.Add($"Command '!{_selectedCommand.CommandName}' updated successfully", Severity.Success);
            }

            await LoadCommands();
            _selectedCommand = null;
            _selectedPointType = null;
            _selectedRanks = new List<Rank>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving command: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteCommand()
    {
        if (_selectedCommand == null || !_selectedCommand.Id.HasValue) return;

        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Command",
            $"Are you sure you want to delete the command '!{_selectedCommand.CommandName}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await CommandService.DeleteAsync(_selectedCommand.Id.Value);
                Snackbar.Add($"Command '!{_selectedCommand.CommandName}' deleted successfully", Severity.Success);
                _selectedCommand = null;
                _selectedPointType = null;
                _selectedRanks = new List<Rank>();
                await LoadCommands();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting command: {ex.Message}", Severity.Error);
            }
        }
    }

    private void CancelEdit()
    {
        _selectedCommand = null;
        _selectedPointType = null;
        _selectedRanks = new List<Rank>();
        _isNewCommand = false;
    }
}
