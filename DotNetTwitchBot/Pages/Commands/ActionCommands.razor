@page "/actioncommands"
@using DotNetTwitchBot.Bot.Models.Commands
@using DotNetTwitchBot.Bot.Models.Points
@using DotNetTwitchBot.Bot.Commands
@using DotNetTwitchBot.Pages.Components
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject DotNetTwitchBot.Bot.Commands.IActionCommandService CommandService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject DotNetTwitchBot.Bot.Core.Points.IPointsSystem PointSystem

<PageTitle>SPTV Twitch Bot - Action Commands</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Action Commands</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">Manage action commands for the bot.</MudText>

    <MudGrid>
        <!-- Left Panel - Commands List -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Commands (@_commands.Count)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" 
                                       OnClick="CreateNewCommand" />
                    </MudStack>

                    <MudTextField @bind-Value="_searchString" Placeholder="Search commands" 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                  IconSize="Size.Medium" Immediate="true" DebounceInterval="300" 
                                  OnDebounceIntervalElapsed="FilterCommands" />

                    <MudSelect T="string" Value="@_filterCategory" ValueChanged="OnCategoryFilterChanged" Label="Filter by Category" Dense="true">
                        <MudSelectItem T="string" Value="@("")">All Categories</MudSelectItem>
                        @foreach (var category in _categories)
                        {
                            <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                        }
                    </MudSelect>

                    <MudDivider />

                    @if (_filteredCommands.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                            No commands found
                        </MudText>
                    }
                    else
                    {
                        <MudList T="ActionCommand" @bind-SelectedValue="_selectedCommand" Dense="true">
                            @foreach (var command in _filteredCommands)
                            {
                                <MudListItem T="ActionCommand" Value="@command" OnClick="@(() => OnCommandSelected(command))">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body1">!@command.CommandName</MudText>
                                        <MudStack Row="true" Spacing="1">
                                            @if (!string.IsNullOrEmpty(command.Category))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@command.Category</MudChip>
                                            }
                                            <MudChip T="string" Size="Size.Small" Color="@(command.Disabled ? Color.Error : Color.Success)">
                                                @(command.Disabled ? "Disabled" : "Enabled")
                                            </MudChip>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Right Panel - Command Details -->
        <MudItem xs="12" md="8">
            @if (_selectedCommand == null)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Select a command to view details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Or create a new command to get started</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                    <CommandEditor Command="_selectedCommand"
                                   OnSave="SaveCommand"
                                   OnCancel="CancelEdit"
                                   OnDelete="DeleteCommand"
                                   IsNewCommand="_isNewCommand"
                                   ShowActions="true" />
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<ActionCommand> _commands = new();
    private List<ActionCommand> _filteredCommands = new();
    private List<string> _categories = new();
    private ActionCommand? _selectedCommand;
    private bool _isNewCommand = false;
    private string _searchString = "";
    private string _filterCategory = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCommands();
    }

    private async Task LoadCommands()
    {
        _commands = await CommandService.GetAllAsync();
        _categories = _commands.Select(c => c.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c).ToList();
        FilterCommands();
    }

    private void FilterCommands()
    {
        _filteredCommands = _commands.Where(c =>
        {
            bool matchesSearch = string.IsNullOrWhiteSpace(_searchString) || 
                                 c.CommandName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                                 (c.Description?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
            bool matchesCategory = string.IsNullOrWhiteSpace(_filterCategory) || 
                                    c.Category == _filterCategory;
            return matchesSearch && matchesCategory;
        }).OrderBy(c => c.CommandName).ToList();
    }

    private void OnCategoryFilterChanged(string category)
    {
        _filterCategory = category;
        FilterCommands();
    }

    private void OnCommandSelected(ActionCommand? command)
    {
        if (command == null) return;
        _selectedCommand = command;
        _isNewCommand = false;
    }

    private void CreateNewCommand()
    {
        _selectedCommand = new ActionCommand
        {
            CommandName = "",
            Category = "",
            Description = "",
            Disabled = false,
            UserCooldown = 0,
            GlobalCooldown = 0,
            Cost = 0,
            MinimumRank = Rank.Viewer,
            SayCooldown = true,
            SayRankRequirement = false,
            ExcludeFromUi = false,
            SourceOnly = true
        };
        _isNewCommand = true;
    }

    private async Task SaveCommand(ActionCommand command)
    {
        if (command == null || string.IsNullOrWhiteSpace(command.CommandName)) 
        {
            Snackbar.Add("Command name is required", Severity.Error);
            return;
        }

        try
        {
            if (_isNewCommand)
            {
                // Check if command already exists
                if (await CommandService.CommandExistsAsync(command.CommandName))
                {
                    bool? result = await DialogService.ShowMessageBoxAsync(
                        "Warning",
                        "This command already exists. Continue?",
                        yesText: "Yes", cancelText: "Cancel");

                    if (result != true) return;
                }

                await CommandService.AddAsync(command);
                _isNewCommand = false;
                Snackbar.Add($"Command '!{command.CommandName}' created successfully", Severity.Success);
            }
            else
            {
                await CommandService.UpdateAsync(command);
                Snackbar.Add($"Command '!{command.CommandName}' updated successfully", Severity.Success);
            }

            await LoadCommands();
            _selectedCommand = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving command: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteCommand(ActionCommand command)
    {
        if (command == null || !command.Id.HasValue) return;

        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Command",
            $"Are you sure you want to delete the command '!{command.CommandName}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await CommandService.DeleteAsync(command.Id.Value);
                Snackbar.Add($"Command '!{command.CommandName}' deleted successfully", Severity.Success);
                _selectedCommand = null;
                await LoadCommands();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting command: {ex.Message}", Severity.Error);
            }
        }
    }

    private void CancelEdit()
    {
        _selectedCommand = null;
        _isNewCommand = false;
    }
}
