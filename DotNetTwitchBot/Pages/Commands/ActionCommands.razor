@page "/actions/commands"
@using DotNetTwitchBot.Bot.Models.Commands
@using DotNetTwitchBot.Bot.Models.Points
@using DotNetTwitchBot.Bot.Commands
@using DotNetTwitchBot.Pages.Components
@using DotNetTwitchBot.Bot.Actions
@using DotNetTwitchBot.Bot.Models.Actions.Triggers
@implements IDisposable
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject DotNetTwitchBot.Bot.Commands.IActionCommandService CommandService
@inject IActionManagementService ActionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject DotNetTwitchBot.Bot.Core.Points.IPointsSystem PointSystem

<PageTitle>SPTV Twitch Bot - Action Commands</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Action Commands</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">Manage action commands for the bot.</MudText>

    <MudGrid>
        <!-- Left Panel - Commands List -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Commands (@_commands.Count)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" 
                                       OnClick="CreateNewCommand" />
                    </MudStack>

                    <MudTextField @bind-Value="_searchString" Placeholder="Search commands" 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                  IconSize="Size.Medium" Immediate="true" DebounceInterval="300" 
                                  OnDebounceIntervalElapsed="FilterCommands" />

                    <MudSelect T="string" Value="@_filterCategory" ValueChanged="OnCategoryFilterChanged" Label="Filter by Category" Dense="true">
                        <MudSelectItem T="string" Value="@("")">All Categories</MudSelectItem>
                        @foreach (var category in _categories)
                        {
                            <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                        }
                    </MudSelect>

                    <MudDivider />

                    @if (_filteredCommands.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                            No commands found
                        </MudText>
                    }
                    else
                    {
                        <MudList T="ActionCommand" @bind-SelectedValue="_selectedCommand" Dense="true">
                            @foreach (var category in _filteredCommands.Select(a => (a.Category).Trim()).Distinct().Order())
                            {
                                <MudListItem Text="@(string.IsNullOrWhiteSpace(category) ? None : category)" Expanded="@(string.IsNullOrWhiteSpace(category) ? _commandCategory == None : _commandCategory == category)">
                                    <NestedList>
                                        @foreach (var command in _filteredCommands.Where(c => (c.Category ?? string.Empty).Trim() == category))
                                        {
                                            <MudListItem T="ActionCommand" Value="@command" OnClick="@(() => OnCommandSelected(command))">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body1">!@command.CommandName</MudText>
                                                    <MudStack Row="true" Spacing="1">
                                                        <MudChip T="string" Size="Size.Small" Color="@(command.Disabled ? Color.Error : Color.Success)">
                                                            @(command.Disabled ? "Disabled" : "Enabled")
                                                        </MudChip>
                                                    </MudStack>
                                                </MudStack>
                                            </MudListItem>
                                            <MudDivider />
                                        }
                                    </NestedList>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Right Panel - Command Details -->
        <MudItem xs="12" md="8">
            @if (_isLoading)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Loading commands...</MudText>
                    </MudStack>
                </MudPaper>
            }
            else if (_selectedCommand == null)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Select a command to view details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Or create a new command to get started</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                    <MudStack Spacing="3">
                        @if (!_isNewCommand && _selectedCommand?.Id.HasValue == true)
                        {
                            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="mr-2" />
                                        Actions Triggered by This Command
                                    </MudText>

                                    @if (_triggeredActions == null)
                                    {
                                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                                    }
                                    else if (_triggeredActions.Count == 0)
                                    {
                                        <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
                                            This command does not trigger any actions yet. 
                                            You can associate actions with this command by adding Command triggers in Action Management.
                                        </MudAlert>
                                    }
                                    else
                                    {
                                        <MudList T="ActionType" Dense="true">
                                            @foreach (var action in _triggeredActions)
                                            {
                                                <MudListItem T="ActionType">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                        <MudStack Spacing="0">
                                                            <MudLink Href="@($"/actions/manage?actionId={action.Id}")">
                                                                <MudText Typo="Typo.body1">@action.Name</MudText>
                                                            </MudLink>
                                                            @if (!string.IsNullOrEmpty(action.Group))
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Group: @action.Group</MudText>
                                                            }
                                                        </MudStack>
                                                        <MudStack Row="true" Spacing="1">
                                                            <MudChip T="string" Size="Size.Small" Color="@(action.Enabled ? Color.Success : Color.Error)">
                                                                @(action.Enabled ? "Enabled" : "Disabled")
                                                            </MudChip>
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                                                @action.SubActions.Count SubActions
                                                            </MudChip>
                                                        </MudStack>
                                                    </MudStack>
                                                </MudListItem>
                                                <MudDivider />
                                            }
                                        </MudList>
                                    }
                                </MudStack>
                            </MudPaper>

                            <MudDivider />
                        }

                        <CommandEditor Command="_selectedCommand"
                                       OnSave="SaveCommand"
                                       OnCancel="CancelEdit"
                                       OnDelete="DeleteCommand"
                                       IsNewCommand="_isNewCommand"
                                       ShowActions="true" />
                    </MudStack>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "commandId")]
    public int? CommandIdFromQuery { get; set; }
    public string None => "None";

    private List<ActionCommand> _commands = new();
    private List<ActionCommand> _filteredCommands = new();
    private List<string> _categories = new();
    private ActionCommand? _selectedCommand;
    private bool _isNewCommand = false;
    private bool _isLoading = true;
    private bool _isNavigating = false;
    private string _searchString = "";
    private string _filterCategory = "";
    public string? _commandCategory = null;
    private List<ActionType>? _triggeredActions = null;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to location changes for browser back/forward button support
        NavigationManager.LocationChanged += OnLocationChanged;
        await LoadCommands();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Skip if we're already handling a navigation
        if (_isNavigating) return;

        // Parse the new URL to get the commandId parameter
        var uri = new Uri(e.Location);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var commandIdStr = query["commandId"];

        if (int.TryParse(commandIdStr, out var commandId))
        {
            // Select the command from the URL
            var commandToSelect = _commands.FirstOrDefault(c => c.Id == commandId);
            if (commandToSelect != null && commandToSelect.Id != _selectedCommand?.Id)
            {
                _isNavigating = true;
                _selectedCommand = commandToSelect;
                _isNewCommand = false;
                _isNavigating = false;
                _commandCategory = commandToSelect.Category ?? None;

                // Load triggered actions
                _ = LoadTriggeredActionsAsync();

                InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            // No commandId in URL, clear selection only if not creating a new command
            if (_selectedCommand != null && !_isNewCommand)
            {
                _isNavigating = true;
                _selectedCommand = null;
                _isNewCommand = false;
                _triggeredActions = null;
                _isNavigating = false;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private async Task LoadCommands()
    {
        _isLoading = true;
        try
        {
            _commands = await CommandService.GetAllAsync();
            _categories = _commands.Select(c => c.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c).ToList();
            FilterCommands();

            // If commandId is provided in query string, select that command
            if (CommandIdFromQuery.HasValue)
            {
                var commandToSelect = _commands.FirstOrDefault(c => c.Id == CommandIdFromQuery.Value);
                if (commandToSelect != null)
                {
                    OnCommandSelected(commandToSelect, true);
                }
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void FilterCommands()
    {
        _filteredCommands = _commands.Where(c =>
        {
            bool matchesSearch = string.IsNullOrWhiteSpace(_searchString) || 
                                 c.CommandName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                                 (c.Description?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
            bool matchesCategory = string.IsNullOrWhiteSpace(_filterCategory) || 
                                    c.Category == _filterCategory;
            return matchesSearch && matchesCategory;
        }).OrderBy(c => c.CommandName).ToList();
    }

    private void OnCategoryFilterChanged(string category)
    {
        _filterCategory = category;
        FilterCommands();
    }

    private void OnCommandSelected(ActionCommand? command, bool autoExpand = false)
    {
        if (command == null) return;
        _selectedCommand = command;
        _isNewCommand = false;
        if (autoExpand)
        {
            _commandCategory = string.IsNullOrWhiteSpace(command.Category) ? None : command.Category;
        }
        // Load triggered actions for this command
        _ = LoadTriggeredActionsAsync();

        // Update URL with commandId for browser history support (only if not already navigating via back/forward)
        if (command.Id.HasValue && !_isNavigating)
        {
            NavigationManager.NavigateTo($"/actions/commands?commandId={command.Id.Value}", false);
        }
    }

    private async Task LoadTriggeredActionsAsync()
    {
        if (_selectedCommand?.Id == null)
        {
            _triggeredActions = new List<ActionType>();
            return;
        }

        // Capture the command ID to detect if selection changes during async operations
        var commandId = _selectedCommand.Id.Value;

        try
        {
            _triggeredActions = null; // Set to null to show loading indicator
            StateHasChanged();

            // Check if command selection changed
            if (_selectedCommand?.Id != commandId)
                return;

            // Get all triggers for this command
            var triggers = await ActionService.GetAllTriggersAsync();

            // Check if command selection changed after await
            if (_selectedCommand?.Id != commandId)
                return;

            var commandTriggers = triggers
                .Where(t => t.Type == TriggerTypes.Command && t.CommandId == commandId)
                .ToList();

            // Get unique action IDs
            var actionIds = commandTriggers
                .Where(t => t.ActionId.HasValue)
                .Select(t => t.ActionId!.Value)
                .Distinct()
                .ToList();

            // Load all actions
            if (actionIds.Any())
            {
                var allActions = await ActionService.GetAllActionsAsync();

                // Check if command selection changed after await
                if (_selectedCommand?.Id != commandId)
                    return;

                _triggeredActions = allActions
                    .Where(a => actionIds.Contains(a.Id!.Value))
                    .OrderBy(a => a.Name)
                    .ToList();
            }
            else
            {
                _triggeredActions = new List<ActionType>();
            }

            // Final check before updating UI
            if (_selectedCommand?.Id == commandId)
            {
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            // Only show error if we're still on the same command
            if (_selectedCommand?.Id == commandId)
            {
                Snackbar.Add($"Error loading triggered actions: {ex.Message}", Severity.Error);
                _triggeredActions = new List<ActionType>();
            }
        }
    }

    private void CreateNewCommand()
    {
        _selectedCommand = new ActionCommand
        {
            CommandName = "",
            Category = "",
            Description = "",
            Disabled = false,
            UserCooldown = 0,
            GlobalCooldown = 0,
            Cost = 0,
            MinimumRank = Rank.Viewer,
            SayCooldown = true,
            SayRankRequirement = false,
            ExcludeFromUi = false,
            SourceOnly = true
        };
        _isNewCommand = true;
        _triggeredActions = null;

        // Clear URL parameter when creating a new command
        _isNavigating = true;
        NavigationManager.NavigateTo("/actions/commands", false);
        _isNavigating = false;
    }

    private async Task SaveCommand(ActionCommand command)
    {
        if (command == null || string.IsNullOrWhiteSpace(command.CommandName)) 
        {
            Snackbar.Add("Command name is required", Severity.Error);
            return;
        }

        try
        {
            if (_isNewCommand)
            {
                // Check if command already exists
                if (await CommandService.CommandExistsAsync(command.CommandName))
                {
                    bool? result = await DialogService.ShowMessageBoxAsync(
                        "Warning",
                        "This command already exists. Continue?",
                        yesText: "Yes", cancelText: "Cancel");

                    if (result != true) return;
                }

                await CommandService.AddAsync(command);
                _isNewCommand = false;
                Snackbar.Add($"Command '!{command.CommandName}' created successfully", Severity.Success);
            }
            else
            {
                await CommandService.UpdateAsync(command);
                Snackbar.Add($"Command '!{command.CommandName}' updated successfully", Severity.Success);
            }

            await LoadCommands();

            // Clear selection and URL after save
            _selectedCommand = null;
            _triggeredActions = null;
            NavigationManager.NavigateTo("/actions/commands", false);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving command: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteCommand(ActionCommand command)
    {
        if (command == null || !command.Id.HasValue) return;

        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Command",
            $"Are you sure you want to delete the command '!{command.CommandName}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await CommandService.DeleteAsync(command.Id.Value);
                Snackbar.Add($"Command '!{command.CommandName}' deleted successfully", Severity.Success);
                _selectedCommand = null;
                _triggeredActions = null;
                await LoadCommands();

                // Clear URL after delete
                NavigationManager.NavigateTo("/actions/commands", false);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting command: {ex.Message}", Severity.Error);
            }
        }
    }

    private void CancelEdit()
    {
        _selectedCommand = null;
        _isNewCommand = false;
        _triggeredActions = null;

        // Clear URL when canceling
        NavigationManager.NavigateTo("/actions/commands", false);
    }
}
