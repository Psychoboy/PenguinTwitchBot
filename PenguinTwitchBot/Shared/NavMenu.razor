@inject NavigationManager Navigation
@inject IVersionCheckService VersionCheck
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PenguinTwitchBot.Bot.Features.IFeatureRuntimeCoordinator FeatureRuntimeCoordinator
@using PenguinTwitchBot.Helpers
@using PenguinTwitchBot.Bot.Features
@using PenguinTwitchBot.Services
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

<div style="height:100%; display:flex; flex-direction:column;">
<MudNavMenu Style="flex:1; overflow:auto;">
<CascadingAuthenticationState>  
    
    <MudNavLink Icon="@Icons.Material.Filled.Home" Href="/" Match="NavLinkMatch.All">Home</MudNavLink>
    <AuthorizeView Roles="Streamer, Editor">
        <Authorized>
            @{
                var quickLinks = GetFilteredQuickLinks().Take(8).ToList();
            }
            <MudPaper Outlined="true" Class="mb-4 pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.overline" Class="px-2">Quick Jump</MudText>
                    <MudTextField @bind-Value="_navSearchText"
                                  Placeholder="Search streamer and editor pages"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  DebounceInterval="200"
                                  Clearable="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                    @if (quickLinks.Count > 0)
                    {
                        <MudStack Spacing="1" Class="px-1 pb-1">
                            @foreach (var quickLink in quickLinks)
                            {
                                <MudButton OnClick="() => NavigateToQuickLink(quickLink.Href)"
                                           Variant="Variant.Text"
                                           StartIcon="@quickLink.Icon"
                                           FullWidth="true"
                                           Style="justify-content:flex-start; text-transform:none;">
                                    @quickLink.Title
                                </MudButton>
                            }
                        </MudStack>
                    }
                    else if (!string.IsNullOrWhiteSpace(_navSearchText))
                    {
                        <MudText Typo="Typo.caption" Class="px-2 pb-1 mud-text-secondary">No matching pages.</MudText>
                    }
                </MudStack>
            </MudPaper>

            <MudNavGroup Icon="@Icons.Material.Filled.LiveTv" Title="Stream Tools" Expanded="@GetGroupExpanded("streamTools", "raidhistory", "musicplayer", "playlists", "overlay/editor")">
                <MudNavLink Icon="@Icons.Material.Filled.Groups" Href="/raidhistory" Match="NavLinkMatch.Prefix">Raid History</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.PlayCircle" Href="/musicplayer" Match="NavLinkMatch.Prefix" Target="_blank">Music Player</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.QueueMusic" Href="/playlists" Match="NavLinkMatch.Prefix">Playlists</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Layers" Href="/overlay/editor" Match="NavLinkMatch.Prefix">Overlay Editor</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Icon="@Icons.Material.Filled.Code" Title="Commands" Expanded="@GetGroupExpanded("commands", "commands/default", "commands/aliases", "commands/cooldowns", "commands/external", "actions/commands", "actions/keywords", "actions/audiocommands")">
                <MudNavLink Icon="@Icons.Material.Filled.Code" Href="/commands/default" Match="NavLinkMatch.Prefix">Default Commands</MudNavLink>
                @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.Alias))
                {
                    <MudNavLink Icon="@Icons.Material.Filled.SwapHoriz" Href="/commands/aliases" Match="NavLinkMatch.Prefix">Aliases</MudNavLink>
                }
                <MudNavLink Icon="@Icons.Material.Filled.Extension" Href="/commands/external" Match="NavLinkMatch.Prefix">External Commands</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Bolt" Href="/actions/commands" Match="NavLinkMatch.Prefix">Action Commands</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Key" Href="/actions/keywords" Match="NavLinkMatch.Prefix">Keywords</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.AudioFile" Href="/actions/audiocommands" Match="NavLinkMatch.Prefix">Audio Commands</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Schedule" Href="/commands/cooldowns" Match="NavLinkMatch.Prefix">Command Cooldowns</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Icon="@Icons.Material.Filled.PlayArrow" Title="Actions" Expanded="@GetGroupExpanded("actions", "actions/timers", "actions/manage", "actions/globalvariables", "actions/history", "actions/queues")">
                <MudNavLink Icon="@Icons.Material.Filled.Tune" Href="/actions/manage" Match="NavLinkMatch.Prefix">Manage Actions</MudNavLink>
                @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.AutoTimer))
                {
                    <MudNavLink Icon="@Icons.Material.Filled.Timer" Href="/actions/timers" Match="NavLinkMatch.Prefix">Action Timers</MudNavLink>
                }
                <MudNavLink Icon="@Icons.Material.Filled.Storage" Href="/actions/globalvariables" Match="NavLinkMatch.Prefix">Global Variables</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.ViewList" Href="/actions/queues" Match="NavLinkMatch.Prefix">Queues</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.History" Href="/actions/history" Match="NavLinkMatch.Prefix">History</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Icon="@Icons.Material.Filled.Group" Title="Community" Expanded="@GetGroupExpanded("community", "community/viewers", "community/connected-viewers", "community/auto-shoutouts", "community/known-bots", "blacklist")">
                <MudNavLink Icon="@Icons.Material.Filled.People" Href="/community/viewers" Match="NavLinkMatch.Prefix">Viewers</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.ConnectWithoutContact" Href="/community/connected-viewers" Match="NavLinkMatch.Prefix">Connected Viewers</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Campaign" Href="/community/auto-shoutouts" Match="NavLinkMatch.Prefix">Auto Shoutouts</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.FmdBad" Href="/community/known-bots" Match="NavLinkMatch.Prefix">Known Bots</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Block" Href="/blacklist" Match="NavLinkMatch.Prefix">Blacklist</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Icon="@Icons.Material.Filled.CardGiftcard" Title="Giveaways" Expanded="@GetGroupExpanded("giveaways", "giveaway", "wheelspin")">
                @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.GiveawayFeature))
                {
                    <MudNavLink Icon="@Icons.Material.Filled.Public" Href="/giveaway" Match="NavLinkMatch.All">Viewer Giveaway Page</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Redeem" Href="/giveaway/draw" Match="NavLinkMatch.Prefix">Draw Giveaway</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Settings" Href="/giveaway/settings" Match="NavLinkMatch.Prefix">Giveaway Settings</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.History" Href="/giveaway/history" Match="NavLinkMatch.Prefix">Giveaway History</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Block" Href="/giveaway/exclusions" Match="NavLinkMatch.Prefix">Giveaway Exclusions</MudNavLink>
                }
                @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.WheeledGame))
                {
                    <MudNavLink Icon="@Icons.Material.Filled.Casino" Href="/wheelspin" Match="NavLinkMatch.Prefix">Wheel Spin</MudNavLink>
                }
            </MudNavGroup>
            <MudNavGroup Icon="@Icons.Material.Filled.Settings" Title="Configuration" Expanded="@GetGroupExpanded("configuration", "settings/bot-auth", "voices", "tools", "backups", "validation-status", "settings/channel-points", "settings/loyalty-bonuses", "settings/points", "settings/games", "obs/connections", "settings/updates")">
                <MudNavGroup Icon="@Icons.Material.Filled.SettingsApplications" Title="Settings" Expanded="@GetGroupExpanded("settings", "settings/bot-auth", "voices", "settings/integrations", "settings/app")">
                    <MudNavLink Icon="@Icons.Material.Filled.Security" Href="/settings/bot-auth" Match="NavLinkMatch.Prefix">Bot Authentication</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.SettingsSuggest" Href="/settings/app" Match="NavLinkMatch.Prefix">Bot Settings</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Extension" Href="/settings/integrations" Match="NavLinkMatch.Prefix">Integrations</MudNavLink>
                    @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.TTS))
                    {
                        <MudNavLink Icon="@Icons.Material.Filled.RecordVoiceOver" Href="/voices" Match="NavLinkMatch.Prefix">Voices</MudNavLink>
                    }
                </MudNavGroup>
                <MudNavGroup Icon="@Icons.Material.Filled.Build" Title="Tools" Expanded="@GetGroupExpanded("tools", "settings/updates", "backups", "validation-status")">
                    <MudNavLink Icon="@Icons.Material.Filled.Update" Href="/settings/updates" Match="NavLinkMatch.Prefix">Updates & Logs</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Backup" Href="/backups" Match="NavLinkMatch.Prefix">Backups</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.BugReport" Href="/validation-status" Match="NavLinkMatch.Prefix">Validation Status</MudNavLink>
                </MudNavGroup>
                <MudNavGroup Icon="@Icons.Material.Filled.SportsEsports" Title="Points & Rewards" Expanded="@GetGroupExpanded("pointsRewards", "settings/points", "settings/games", "settings/loyalty-bonuses", "settings/channel-points")">
                    <MudNavLink Icon="@Icons.Material.Filled.Stars" Href="/settings/channel-points" Match="NavLinkMatch.Prefix">Channel Points</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Loyalty" Href="/settings/loyalty-bonuses" Match="NavLinkMatch.Prefix">Loyalty Bonuses</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Money" Href="/settings/points" Match="NavLinkMatch.Prefix">Point Settings</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Games" Href="/settings/games" Match="NavLinkMatch.Prefix">Game Settings</MudNavLink>
                </MudNavGroup>
                <MudNavLink Icon="@Icons.Material.Filled.Videocam" Href="/obs/connections" Match="NavLinkMatch.Prefix">OBS Connections</MudNavLink>
            </MudNavGroup>
            @if( FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.Fishing))
            {
            <MudNavGroup Icon="@Icons.Material.Filled.Phishing" Title="Fishing Admin" Expanded="@GetGroupExpanded("fishingAdmin", "fishing/admin", "fishing/imageprocessing", "fishing/balance-analysis")">
                <MudNavLink Icon="@Icons.Material.Filled.List" Href="/fishing/admin" Match="NavLinkMatch.Prefix">Manage Fish & Shop</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.List" Href="/fishing/imageprocessing" Match="NavLinkMatch.Prefix">Manage Images</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Analytics" Href="/fishing/balance-analysis" Match="NavLinkMatch.Prefix">Balance Analysis</MudNavLink>
            </MudNavGroup>
            }
        </Authorized>
        <NotAuthorized>
            
        </NotAuthorized>
    </AuthorizeView>
    <AuthorizeView Roles="Streamer, Moderator">
        <Authorized>
                <MudNavGroup Icon="@Icons.Material.Filled.Shield" Title="Moderator" Expanded="@GetGroupExpanded("moderator", "community/viewers", "community/known-bots", "community/connected-viewers")">
                    <MudNavLink Icon="@Icons.Material.Filled.People" Href="/community/viewers" Match="NavLinkMatch.Prefix">Viewers</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.FmdBad" Href="/community/known-bots" Match="NavLinkMatch.Prefix">Known Bots</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.ConnectWithoutContact" Href="/community/connected-viewers" Match="NavLinkMatch.Prefix">Connected Viewers</MudNavLink>
                </MudNavGroup>
        </Authorized>
        <NotAuthorized>

        </NotAuthorized>
    </AuthorizeView>
    <MudNavLink Href="/commands" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ChatBubble">Commands</MudNavLink>
    <MudNavLink Href="/acommands" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AudioFile">Audio Commands</MudNavLink>
    @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.GiveawayFeature))
    {
        <MudNavLink Href="/giveaway" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.CardGiftcard">Giveaway</MudNavLink>
    }
    @if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.QuoteSystem))
    {
        <MudNavLink Href="/quotes" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FormatQuote">Quotes</MudNavLink>
    }
    <MudNavLink Href="/songrequests" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QueueMusic">Song Requests</MudNavLink>
    <MudNavLink Href="/leaderboards" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Leaderboard">Leaderboards</MudNavLink>
    
    @if( FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.Fishing))
    {
        <MudNavGroup Icon="@Icons.Material.Filled.Phishing" Title="Fishing" Expanded="@GetGroupExpanded("fishing", "fishing/leaderboard", "fishing/tournaments", "fishing/shop", "fishing/inventory", "fishing/help")">
            <MudNavLink Href="/fishing/leaderboard" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Leaderboard">Leaderboard</MudNavLink>
            <MudNavLink Href="/fishing/tournaments" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EmojiEvents">Tournaments</MudNavLink>
            <AuthorizeView>
                <Authorized>
                    <MudNavLink Href="/fishing/shop" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ShoppingCart">Shop</MudNavLink>
                    <MudNavLink Href="/fishing/inventory" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory">My Inventory</MudNavLink>
                </Authorized>
            </AuthorizeView>
                <MudNavLink Href="/fishing/help" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Help">Help Guide</MudNavLink>
        </MudNavGroup>
    }
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/signout" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Logout">Log Out</MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink OnClick="Signin" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
    </NotAuthorized>
    </AuthorizeView>

</CascadingAuthenticationState>
</MudNavMenu>
<div class="pa-3" style="border-top: 1px solid var(--mud-palette-lines-default);">
    <MudStack Spacing="1">
        <MudLink Href="https://github.com/Psychoboy/PenguinTwitchBot" Target="_blank">
            <MudIcon Icon="@Icons.Material.Filled.Code" Class="mr-2" />GitHub
        </MudLink>
        <MudLink Href="@StarCitizenReferralUrl" Target="_blank">
            <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Class="mr-2" />Star Citizen Referral
        </MudLink>
        @if (_showUpgradeLink)
        {
            <MudLink Href="/settings/updates" Typo="Typo.caption">
                v@(VersionCheck.CurrentVersion) - <strong>Upgrade available</strong>
            </MudLink>
        }
        else if (_isStreamer)
        {
            <MudLink Href="/settings/updates" Typo="Typo.caption" Class="mud-text-gray">
                v@(VersionCheck.CurrentVersion)
            </MudLink>
        }
        else
        {
            <MudText Typo="Typo.caption" Class="mud-text-gray">v@(VersionCheck.CurrentVersion)</MudText>
        }
    </MudStack>
</div>
</div>

@code {
    private const string DefaultStarCitizenReferralUrl = "https://www.robertsspaceindustries.com/enlist?referral=STAR-6564-JQ7N";
    private Dictionary<string, bool> _groupExpandedState = new();
    private string _navSearchText = string.Empty;
    private string CurrentUrl => Navigation.ToBaseRelativePath(Navigation.Uri);
    private string StarCitizenReferralUrl => string.IsNullOrWhiteSpace(AppConfiguration["SupportLinks:StarCitizenReferral"]) ? DefaultStarCitizenReferralUrl : AppConfiguration["SupportLinks:StarCitizenReferral"]!;
    private bool _isStreamer;
    private bool _showUpgradeLink =>
        _isStreamer &&
        FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.VersionCheck) &&
        !VersionCheck.IsUpToDate &&
        !string.IsNullOrWhiteSpace(VersionCheck.LatestVersion);
    private bool _disposed;

    private bool GetGroupExpanded(string groupKey, params string[] routes)
    {
        bool shouldBeExpanded = routes.Any(route => CurrentUrl.StartsWith(route.TrimStart('/'), StringComparison.OrdinalIgnoreCase));

        // Only auto-expand, never auto-collapse
        if (shouldBeExpanded && (!_groupExpandedState.ContainsKey(groupKey) || !_groupExpandedState[groupKey]))
        {
            _groupExpandedState[groupKey] = true;
        }

        return _groupExpandedState.GetValueOrDefault(groupKey, false);
    }

    private IEnumerable<NavQuickLink> GetFilteredQuickLinks()
    {
        if (string.IsNullOrWhiteSpace(_navSearchText))
        {
            return Enumerable.Empty<NavQuickLink>();
        }

        string search = _navSearchText.Trim();
        return GetQuickLinks()
            .Where(link => link.SearchText.Contains(search, StringComparison.OrdinalIgnoreCase))
            .OrderBy(link => link.Title.Contains(search, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ThenBy(link => link.Group)
            .ThenBy(link => link.Title);
    }

    private IEnumerable<NavQuickLink> GetQuickLinks()
    {
        var links = new List<NavQuickLink>
        {
            CreateQuickLink("Raid History", "/raidhistory", Icons.Material.Filled.Groups, "Stream Tools"),
            CreateQuickLink("Music Player", "/musicplayer", Icons.Material.Filled.PlayCircle, "Stream Tools", "music"),
            CreateQuickLink("Playlists", "/playlists", Icons.Material.Filled.QueueMusic, "Stream Tools", "music", "playlist"),
            CreateQuickLink("Overlay Editor", "/overlay/editor", Icons.Material.Filled.Layers, "Stream Tools", "overlay"),
            CreateQuickLink("Default Commands", "/commands/default", Icons.Material.Filled.Code, "Commands", "chat commands"),
            CreateQuickLink("Command Cooldowns", "/commands/cooldowns", Icons.Material.Filled.Schedule, "Commands", "cooldown"),
            CreateQuickLink("External Commands", "/commands/external", Icons.Material.Filled.Extension, "Commands", "chat commands"),
            CreateQuickLink("Action Commands", "/actions/commands", Icons.Material.Filled.Bolt, "Commands", "actions chat commands"),
            CreateQuickLink("Keywords", "/actions/keywords", Icons.Material.Filled.Key, "Commands", "chat interactions"),
            CreateQuickLink("Audio Commands", "/actions/audiocommands", Icons.Material.Filled.AudioFile, "Commands", "chat interactions"),
            CreateQuickLink("Manage Actions", "/actions/manage", Icons.Material.Filled.Tune, "Actions", "automation"),
            CreateQuickLink("Global Variables", "/actions/globalvariables", Icons.Material.Filled.Storage, "Actions", "automation"),
            CreateQuickLink("Action History", "/actions/history", Icons.Material.Filled.History, "Actions", "automation"),
            CreateQuickLink("Queues", "/actions/queues", Icons.Material.Filled.ViewList, "Actions", "automation"),
            CreateQuickLink("Blacklist", "/blacklist", Icons.Material.Filled.Block, "Community", "moderation"),
            CreateQuickLink("Viewers", "/community/viewers", Icons.Material.Filled.People, "Community"),
            CreateQuickLink("Connected Viewers", "/community/connected-viewers", Icons.Material.Filled.ConnectWithoutContact, "Community", "current users"),
            CreateQuickLink("Auto Shoutouts", "/community/auto-shoutouts", Icons.Material.Filled.Campaign, "Community", "shoutouts"),
            CreateQuickLink("Known Bots", "/community/known-bots", Icons.Material.Filled.FmdBad, "Community"),
            CreateQuickLink("Bot Authentication", "/settings/bot-auth", Icons.Material.Filled.Security, "Configuration", "auth signin"),
            CreateQuickLink("Bot Settings", "/settings/app", Icons.Material.Filled.SettingsSuggest, "Configuration", "app settings"),
            CreateQuickLink("Integrations", "/settings/integrations", Icons.Material.Filled.Extension, "Configuration"),
            CreateQuickLink("Updates & Logs", "/settings/updates", Icons.Material.Filled.Update, "Configuration", "updates logs"),
            CreateQuickLink("Backups", "/backups", Icons.Material.Filled.Backup, "Configuration"),
            CreateQuickLink("Validation Status", "/validation-status", Icons.Material.Filled.BugReport, "Configuration", "validation"),
            CreateQuickLink("Channel Points", "/settings/channel-points", Icons.Material.Filled.Stars, "Configuration", "points rewards"),
            CreateQuickLink("Loyalty Bonuses", "/settings/loyalty-bonuses", Icons.Material.Filled.Loyalty, "Configuration", "points rewards"),
            CreateQuickLink("Point Settings", "/settings/points", Icons.Material.Filled.Money, "Configuration", "games points rewards"),
            CreateQuickLink("Game Settings", "/settings/games", Icons.Material.Filled.Games, "Configuration", "games points rewards"),
            CreateQuickLink("OBS Connections", "/obs/connections", Icons.Material.Filled.Videocam, "Configuration", "obs")
            
        };

        if(FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.Alias))
        {
            CreateQuickLink("Aliases", "/commands/aliases", Icons.Material.Filled.SwapHoriz, "Commands", "chat commands");
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.GiveawayFeature))
        {
            links.Add(CreateQuickLink("Viewer Giveaway Page", "/giveaway", Icons.Material.Filled.Public, "Giveaways", "viewer giveaway public"));
            links.Add(CreateQuickLink("Draw Giveaway", "/giveaway/draw", Icons.Material.Filled.Redeem, "Giveaways", "drawing admin control"));
            links.Add(CreateQuickLink("Giveaway Settings", "/giveaway/settings", Icons.Material.Filled.Settings, "Giveaways"));
            links.Add(CreateQuickLink("Giveaway History", "/giveaway/history", Icons.Material.Filled.History, "Giveaways"));
            links.Add(CreateQuickLink("Giveaway Exclusions", "/giveaway/exclusions", Icons.Material.Filled.Block, "Giveaways", "bots exclusions"));
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.WheeledGame))
        {
            links.Add(CreateQuickLink("Wheel Spin", "/wheelspin", Icons.Material.Filled.Casino, "Giveaways", "wheel"));
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.AutoTimer))
        {
            links.Add(CreateQuickLink("Action Timers", "/actions/timers", Icons.Material.Filled.Timer, "Actions", "automation timers"));
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.TTS))
        {
            links.Add(CreateQuickLink("Voices", "/voices", Icons.Material.Filled.RecordVoiceOver, "Configuration", "tts"));
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.Fishing))
        {
            links.Add(CreateQuickLink("Manage Fish & Shop", "/fishing/admin", Icons.Material.Filled.List, "Fishing Admin", "fishing shop"));
            links.Add(CreateQuickLink("Manage Images", "/fishing/imageprocessing", Icons.Material.Filled.List, "Fishing Admin", "fishing images"));
            links.Add(CreateQuickLink("Balance Analysis", "/fishing/balance-analysis", Icons.Material.Filled.Analytics, "Fishing Admin", "fishing balance"));
        }

        return links;
    }

    private static NavQuickLink CreateQuickLink(string title, string href, string icon, string group, params string[] additionalTerms)
    {
        string searchText = string.Join(' ', new[] { title, group, href }.Concat(additionalTerms));
        return new NavQuickLink(title, href, icon, group, searchText);
    }

    private void NavigateToQuickLink(string href)
    {
        _navSearchText = string.Empty;

        if (string.Equals(CurrentUrl, href.TrimStart('/'), StringComparison.OrdinalIgnoreCase))
        {
            StateHasChanged();
            return;
        }

        Navigation.NavigateTo(href);
    }

    private void Signin()
    {
        Navigation.NavigateToSigninWithReturnUrl();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if(authState != null)
        {
            _isStreamer = authState.User.IsInRole("Streamer");
        }
        VersionCheck.VersionStatusChanged += HandleVersionStatusChanged;
        FeatureRuntimeCoordinator.StateChanged += HandleFeatureStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void HandleVersionStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void HandleFeatureStateChanged()
    {
        if (_disposed)
        {
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _disposed = true;
        VersionCheck.VersionStatusChanged -= HandleVersionStatusChanged;
        FeatureRuntimeCoordinator.StateChanged -= HandleFeatureStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private sealed record NavQuickLink(string Title, string Href, string Icon, string Group, string SearchText);
}
