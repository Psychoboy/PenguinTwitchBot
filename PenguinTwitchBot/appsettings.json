{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System.Net.Http.HttpClient.OtlpTraceExporter": "Fatal",
        "System.Net.Http.HttpClient": "Warning",
        "PenguinTwitchBot": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByExcluding",
                "Args": {
                  "expression": "StartsWith(SourceContext, 'Discord.')"
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "configureLogger": {
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "Logs/default_.log",
                  "outputTemplate": "{Timestamp:o} [{Level:u3}] ({SourceContext}) {Message}{NewLine}{Exception}",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 60,
                  "shared": true
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "(@l = 'Error' or @l = 'Fatal' or @l = 'Warning' )"
                }
              }
            ],
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "Logs/error_.log",
                  "outputTemplate": "{Timestamp:o} [{Level:u3}] ({SourceContext}) {Message}{NewLine}{Exception}",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 60,
                  "shared": true
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "Logs/json_.log",
                  "formatter": {
                    "type": "Serilog.Formatting.Json.JsonFormatter, Serilog",
                    "renderMessage": true
                  },
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 60,
                  "shared": true
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "Logs/all_.log",
                  "outputTemplate": "{Timestamp:o} [{Level:u3}] ({SourceContext}) {Message}{NewLine}{Exception}",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 60,
                  "shared": true
                }
              }
            ]
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*",
  "ApplicationTitle": "Penguin Twitch Bot",
  "ConnectionStrings": {
    "SqliteConnection": ""
  },
  "Secrets": {
    "SecretsConf": "appsettings.secrets.json"
  },
  "Discord": {
    "DiscordServerId": 0,
    "BroadcastChannel": 0,
    "PingRoleWhenLive": 0,
    "RoleIdToAssignMemberWhenLive": 0
  },
  "Weather": {
    "DefaultLocation": "85234"
  },
  "SupportLinks": {
    "StarCitizenReferral": "https://www.robertsspaceindustries.com/enlist?referral=STAR-6564-JQ7N"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Observability": {
    "Prometheus": {
      "Enabled": false,
      "Port": 4999
    },
    "OpenTelemetry": {
      "Enabled": false,
      "Endpoint": "http://localhost:4318"
    }
  }
}