@page "/timergroups"
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject Microsoft.AspNetCore.Components.NavigationManager navigationManager

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Timers (Redirecting...)</PageTitle>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        navigationManager.NavigateTo("/actions/timers", false);
    }
}