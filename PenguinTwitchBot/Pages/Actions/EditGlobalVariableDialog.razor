@using PenguinTwitchBot.Database.Bot.Models
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">@(IsEditMode ? "Edit Global Variable" : "Add Global Variable")</MudText>
            <MudTextField @bind-Value="Model.Name" Label="Variable Name" Variant="Variant.Outlined" Required="true"
                          HelperText="Use the name directly, without % signs." />
            <MudTextField @bind-Value="Model.Value" Label="Value" Variant="Variant.Outlined" Lines="4"
                          HelperText="Use %localVariable% to substitute from the current action context." />
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public GlobalVariable Model { get; set; } = new();

    private string _error = string.Empty;

    private bool IsEditMode => Model.Id.HasValue && Model.Id.Value > 0;

    private void Save()
    {
        _error = string.Empty;

        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            _error = "Variable name is required.";
            return;
        }

        Model.Name = Model.Name.Trim().ToLowerInvariant();
        Model.Value ??= string.Empty;

        MudDialog.Close(DialogResult.Ok(Model));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}