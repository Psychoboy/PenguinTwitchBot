@page "/actions/manage"
@using System.Text.Json
@using PenguinTwitchBot.Database.Bot.Actions.SubActions.Types
@using PenguinTwitchBot.Database.Bot.Models.Actions.Triggers
@using PenguinTwitchBot.Database.Bot.Models.Queues
@using PenguinTwitchBot.Bot.Actions
@using PenguinTwitchBot.Pages.Components
@implements IDisposable
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject IActionManagementService ActionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject PenguinTwitchBot.Bot.Queues.IQueueManager QueueManager
@inject PenguinTwitchBot.Bot.Actions.IAction ActionExecutor

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Manage Actions</PageTitle>

<NavigationLock ConfirmExternalNavigation="HasUnsavedChanges"
                OnBeforeInternalNavigation="ConfirmInternalNavigation" />

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" GutterBottom="true">Action Management</MudText>
            <MudText Typo="Typo.body2">Create, edit, and manage actions with their triggers and subactions.</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileUpload" OnClick="OpenImportDialog">
                Import
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileDownload" OnClick="OpenExportDialog">
                Export
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Casino" OnClick="OpenCreateRaffleDialog">
                Create Raffle
            </MudButton>
        </MudStack>
    </MudStack>

    <MudGrid>
        <!-- Left Panel - Actions List -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Actions (@_actions.Count)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" 
                                       OnClick="CreateNewAction" />
                    </MudStack>

                    <MudTextField @bind-Value="_searchString" Placeholder="Search actions" 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                  IconSize="Size.Medium" Immediate="true" DebounceInterval="300" 
                                  OnDebounceIntervalElapsed="FilterActions" />

                    <MudSelect T="string" Value="@_filterGroup" ValueChanged="OnGroupFilterChanged" Label="Filter by Group" Dense="true">
                        <MudSelectItem T="string" Value="@("")">All Groups</MudSelectItem>
                        @foreach (var group in _groups)
                        {
                            <MudSelectItem T="string" Value="@group">@group</MudSelectItem>
                        }
                    </MudSelect>

                    <MudDivider />

                    @if (_filteredActions.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                            No actions found
                        </MudText>
                    }
                    else
                    {
                        <MudList T="int?" SelectedValue="_selectedActionIdInList" Dense="true" @key="_actionsListRenderVersion">
                            @foreach (var group in _filteredActions.Select(a => (a.Group ?? string.Empty).Trim()).Distinct().Order())
                            {
                                <MudListItem Text="@(string.IsNullOrWhiteSpace(group) ? Ungrouped : group)" Expanded="@(GetNormalizedGroup(group) == _expandedGroupInList)">
                                    <NestedList>
                                @foreach (var action in _filteredActions.Where(a => (a.Group ?? string.Empty) == group))
                                {
                                    <MudListItem T="int?" Value="@action.Id" OnClick="@(() => OnActionSelected(action))">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body1">@action.Name</MudText>
                                            <MudStack Row="true" Spacing="1">
                                                <MudChip T="string" Size="Size.Small" Color="@(action.Enabled ? Color.Success : Color.Error)">
                                                    @(action.Enabled ? "Enabled" : "Disabled")
                                                </MudChip>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                                    @action.SubActions.Count SubActions
                                                </MudChip>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">
                                                    @action.Triggers.Count Triggers
                                                </MudChip>
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />

                                }
                                    </NestedList>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Right Panel - Action Details -->
        <MudItem xs="12" md="8">
            @if (_isLoading)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Loading actions...</MudText>
                    </MudStack>
                </MudPaper>
            }
            else if (_selectedAction == null)
            {
                <MudPaper Class="pa-4" Style="height: 80vh; display: flex; align-items: center; justify-content: center;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Select an action to view details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Or create a new action to get started</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-4" Style="height: 80vh; overflow-y: auto;">
                    <MudStack Spacing="3">
                        <!-- Action Header -->
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5">
                                @(_isNewAction ? "New Action" : _selectedAction.Name)
                            </MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                                           OnClick="SaveAction" StartIcon="@Icons.Material.Filled.Save">
                                    Save
                                </MudButton>
                                @if (!_isNewAction)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" 
                                               OnClick="DuplicateAction" StartIcon="@Icons.Material.Filled.ContentCopy">
                                        Duplicate
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Error" 
                                               OnClick="DeleteAction" StartIcon="@Icons.Material.Filled.Delete">
                                        Delete
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="RunAction" StartIcon="@Icons.Material.Filled.PlayArrow">
                                        Test
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="OpenSelectedActionHistory" StartIcon="@Icons.Material.Filled.History">
                                        History
                                    </MudButton>
                                }
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEdit">
                                    Cancel
                                </MudButton>
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        <!-- Action Configuration -->
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.h6" Class="mb-3">Action Configuration</MudText>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_selectedAction.Name" Label="Action Name" 
                                                  Required="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudAutocomplete T="string" @bind-Value="_selectedAction.Group" Label="Group" 
                                                     Variant="Variant.Outlined" 
                                                     SearchFunc="@SearchGroups"
                                                     Clearable="true"
                                                     CoerceText="false"
                                                     CoerceValue="true"
                                                     MaxItems="null"/>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="_selectedAction.QueueName" Label="Queue Name" 
                                               Variant="Variant.Outlined" Required="true">
                                        @foreach (var queue in _availableQueues)
                                        {
                                            <MudSelectItem T="string" Value="@queue">@queue</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudStack Row="true" Spacing="3" Style="flex-wrap: wrap;">
                                        <MudSwitch @bind-Value="_selectedAction.Enabled" Label="Enabled" Color="Color.Success" />
                                        <MudSwitch @bind-Value="_selectedAction.RandomAction" Label="Random Action" Color="Color.Primary" />
                                        <MudSwitch @bind-Value="_selectedAction.ConcurrentAction" Label="Concurrent" Color="Color.Info" />
                                        <MudSwitch @bind-Value="_selectedAction.OnlineOnly" Label="Online Only" Color="Color.Warning" />
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <!-- Triggers Section -->
                        <TriggerManagement ActionId="_selectedAction.Id" 
                                           ActionTriggers="_actionTriggers"
                                           ActionTriggersChanged="OnActionTriggersChanged" />

                        <!-- SubActions Section -->
                        <SubActionManagement SubActions="_selectedAction.SubActions" 
                                             SubActionsChanged="OnSubActionsChanged" />

                        <!-- Catch SubActions Section -->
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.h6">Catch SubActions</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    These execute when an error is found in the main subactions. Useful for error handling or notifications.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                        <SubActionManagement SubActions="_selectedAction.CatchSubActions"
                                             SubActionsChanged="OnCatchSubActionsChanged" />

                        @if (!_isNewAction && _selectedAction.Id.HasValue)
                        {
                            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.h6">Recent Executions</MudText>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@_selectedActionExecutionLogs.Count shown</MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Color="Color.Default" OnClick="LoadSelectedActionHistory" />
                                        </MudStack>
                                    </MudStack>

                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="flex-wrap: wrap;">
                                        <MudTextField @bind-Value="_selectedActionHistorySearchString" Placeholder="Search execution logs"
                                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                                      Immediate="true" DebounceInterval="300" OnDebounceIntervalElapsed="FilterSelectedActionHistory"
                                                      Margin="Margin.Dense" />

                                        <MudSelect T="ActionExecutionState?" Value="_selectedActionHistoryFilterState" Label="State" Dense="true" Margin="Margin.Dense"
                                                   ValueChanged="OnSelectedActionHistoryStateChanged" Style="min-width: 160px;">
                                            <MudSelectItem T="ActionExecutionState?" Value="@((ActionExecutionState?)null)">All States</MudSelectItem>
                                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Pending">Pending</MudSelectItem>
                                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Running">Running</MudSelectItem>
                                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Completed">Completed</MudSelectItem>
                                            <MudSelectItem T="ActionExecutionState?" Value="@ActionExecutionState.Failed">Failed</MudSelectItem>
                                        </MudSelect>
                                    </MudStack>

                                    <MudTable Items="_selectedActionExecutionLogs" Dense="true" Hover="true" Striped="true" T="ActionExecutionLog">
                                        <HeaderContent>
                                            <MudTh>State</MudTh>
                                            <MudTh>Queued</MudTh>
                                            <MudTh>Duration</MudTh>
                                            <MudTh>Error</MudTh>
                                            <MudTh Style="text-align: right;">Actions</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="State">
                                                <MudChip T="string" Size="Size.Small" Color="@GetExecutionStateColor(context.State)">@context.State</MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="Queued">@context.EnqueuedAt.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudTd>
                                            <MudTd DataLabel="Duration">@(context.TotalTime.HasValue ? FormatDuration(context.TotalTime.Value) : "-")</MudTd>
                                            <MudTd DataLabel="Error">
                                                @if (string.IsNullOrWhiteSpace(context.ErrorMessage))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2">@TrimForPreview(context.ErrorMessage, 100)</MudText>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Actions" Style="text-align: right;">
                                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                                           OnClick="@(() => OpenExecutionHistory(context))"
                                                           StartIcon="@Icons.Material.Filled.History">
                                                    View Details
                                                </MudButton>
                                            </MudTd>
                                        </RowTemplate>
                                        <NoRecordsContent>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">No execution history found for this action.</MudText>
                                        </NoRecordsContent>
                                    </MudTable>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "actionId")]
    public int? ActionIdFromQuery { get; set; }

    private List<ActionType> _actions = new();
    private List<ActionType> _filteredActions = new();
    private List<string> _groups = new();
    private List<string> _availableQueues = new();
    private ActionType? _selectedAction;
    private List<TriggerType> _actionTriggers = new();
    private bool _isNewAction = false;
    private bool _isLoading = true;
    private bool _isNavigating = false;
    private bool _skipNextNavigationPrompt = false;
    private int? _selectedActionIdInList;
    private int _actionsListRenderVersion;
    private string _expandedGroupInList = string.Empty;
    private string _searchString = "";
    private string _filterGroup = "";
    private string _selectedActionHistorySearchString = "";
    private ActionExecutionState? _selectedActionHistoryFilterState;
    private List<ActionExecutionLog> _selectedActionExecutionLogs = new();
    private List<ActionExecutionLog> _selectedActionExecutionLogsAll = new();
    private string _originalActionSnapshot = string.Empty;
    private const string Ungrouped = "None";

    private bool HasUnsavedChanges =>
        _selectedAction != null &&
        (_isNewAction || !string.Equals(_originalActionSnapshot, CreateCurrentSnapshot(), StringComparison.Ordinal));

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        await LoadAvailableQueues();
        await LoadActions();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_isNavigating) return;

        var uri = new Uri(e.Location);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var actionIdStr = query["actionId"];

        if (int.TryParse(actionIdStr, out var actionId))
        {
            if (actionId != _selectedAction?.Id)
            {
                _isNavigating = true;
                var reloadedAction = await ActionService.GetActionByIdAsync(actionId);
                if (reloadedAction != null)
                {
                    _selectedAction = reloadedAction;
                    _isNewAction = false;
                    _selectedActionIdInList = _selectedAction.Id;
                    _expandedGroupInList = GetNormalizedGroup(_selectedAction.Group);
                    _actionTriggers = _selectedAction.Triggers ?? new List<TriggerType>();
                    CaptureOriginalSnapshot();
                }
                _isNavigating = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            if (_selectedAction != null && !_isNewAction)
            {
                _isNavigating = true;
                _selectedAction = null;
                _isNewAction = false;
                _selectedActionIdInList = null;
                _expandedGroupInList = string.Empty;
                _actionTriggers = new List<TriggerType>();
                _originalActionSnapshot = string.Empty;
                _isNavigating = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task ConfirmInternalNavigation(LocationChangingContext context)
    {
        if (_skipNextNavigationPrompt)
        {
            _skipNextNavigationPrompt = false;
            return;
        }

        if (!HasUnsavedChanges)
        {
            return;
        }

        bool? discardChanges = await DialogService.ShowMessageBoxAsync(
            "Unsaved Changes",
            "You have unsaved changes. Leave this page and discard those changes?",
            yesText: "Discard",
            cancelText: "Stay");

        if (discardChanges != true)
        {
            context.PreventNavigation();
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private async Task LoadAvailableQueues()
    {
        var queueConfigs = await QueueManager.GetAllQueuesAsync();
        _availableQueues = queueConfigs.Select(q => q.Name).OrderBy(n => n).ToList();

        if (!_availableQueues.Contains("Default"))
        {
            _availableQueues.Insert(0, "Default");
        }
        else
        {
            _availableQueues.Remove("Default");
            _availableQueues.Insert(0, "Default");
        }
    }

    private async Task LoadActions()
    {
        _isLoading = true;
        try
        {
            _actions = await ActionService.GetAllActionsAsync();
            _groups = _actions.Select(a => a.Group).Where(g => !string.IsNullOrEmpty(g)).Distinct().OrderBy(g => g).ToList();
            FilterActions();

            if (ActionIdFromQuery.HasValue)
            {
                var actionToSelect = _actions.FirstOrDefault(a => a.Id == ActionIdFromQuery.Value);
                if (actionToSelect != null)
                {
                    await OnActionSelected(actionToSelect);
                }
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void FilterActions()
    {
        _filteredActions = _actions.Where(a =>
        {
            bool matchesSearch = string.IsNullOrWhiteSpace(_searchString) || 
                                 a.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
            bool matchesGroup = string.IsNullOrWhiteSpace(_filterGroup) || 
                                a.Group == _filterGroup;
            return matchesSearch && matchesGroup;
        }).OrderBy(a => a.Name).ToList();
    }

    private void OnGroupFilterChanged(string group)
    {
        _filterGroup = group;
        FilterActions();
    }

    private Task<IEnumerable<string>> SearchGroups(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult<IEnumerable<string>>(_groups);
        }

        value = value.Trim();

        var filteredGroups = _groups
            .Where(g => g.Contains(value, StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (!string.IsNullOrWhiteSpace(value) && !filteredGroups.Any(g => g.Equals(value, StringComparison.OrdinalIgnoreCase)))
        {
            filteredGroups.Insert(0, value);
        }

        return Task.FromResult(filteredGroups.AsEnumerable());
    }

    private async Task OnActionSelected(ActionType? action)
    {
        if (action == null) return;

        if (!_isNewAction && _selectedAction?.Id == action.Id)
        {
            return;
        }

        if (!await ConfirmDiscardChangesAsync())
        {
            ResetActionsListSelectionVisual();
            await InvokeAsync(StateHasChanged);
            return;
        }

        ActionType? actionToEdit = action;
        if (action.Id.HasValue)
        {
            actionToEdit = await ActionService.GetActionByIdAsync(action.Id.Value);
            if (actionToEdit == null)
            {
                Snackbar.Add("Unable to load action details.", Severity.Error);
                return;
            }
        }

        _selectedAction = actionToEdit;
        _selectedAction.CatchSubActions ??= new List<SubActionType>();
        _isNewAction = !_selectedAction.Id.HasValue;
        _selectedActionIdInList = _selectedAction.Id;
        _expandedGroupInList = GetNormalizedGroup(_selectedAction.Group);

        _actionTriggers = _selectedAction.Triggers ?? new List<TriggerType>();
        CaptureOriginalSnapshot();
        LoadSelectedActionHistory();

        if (action.Id.HasValue && !_isNavigating)
        {
            _skipNextNavigationPrompt = true;
            NavigationManager.NavigateTo($"/actions/manage?actionId={action.Id.Value}", false);
        }
    }

    private void OnActionTriggersChanged(List<TriggerType> triggers)
    {
        _actionTriggers = triggers;
    }

    private void OnSubActionsChanged(List<SubActionType> subActions)
    {
        if (_selectedAction != null)
        {
            _selectedAction.SubActions = subActions;
        }
    }

    private void OnCatchSubActionsChanged(List<SubActionType> subActions)
    {
        if (_selectedAction != null)
        {
            _selectedAction.CatchSubActions = subActions;
        }
    }

    private async Task CreateNewAction()
    {
        if (!await ConfirmDiscardChangesAsync())
        {
            return;
        }

        _selectedAction = new ActionType
        {
            Name = "New Action",
            Group = "",
            Enabled = true,
            QueueName = "Default",
            SubActions = new List<SubActionType>(),
            CatchSubActions = new List<SubActionType>()
        };
        _actionTriggers = new List<TriggerType>();
        _isNewAction = true;
        _selectedActionIdInList = null;
        _expandedGroupInList = string.Empty;
        _selectedActionExecutionLogsAll.Clear();
        _selectedActionExecutionLogs.Clear();
        _originalActionSnapshot = string.Empty;

        _isNavigating = true;
        _skipNextNavigationPrompt = true;
        NavigationManager.NavigateTo("/actions/manage", false);
        _isNavigating = false;
    }

    private async Task OpenExportDialog()
    {
        var exportGroup = _filterGroup;
        if (string.IsNullOrWhiteSpace(exportGroup) && !string.IsNullOrWhiteSpace(_selectedAction?.Group))
            exportGroup = _selectedAction.Group;

        var parameters = new DialogParameters<ExportActionsDialog>
        {
            { x => x.AllActions, _actions },
            { x => x.SelectedAction, _selectedAction },
            { x => x.SelectedGroup, exportGroup }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<ExportActionsDialog>("Export Actions", parameters, options);
    }

    private async Task OpenImportDialog()
    {
        var parameters = new DialogParameters<ImportActionsDialog>
        {
            { x => x.AvailableQueues, _availableQueues },
            { x => x.Groups, _groups }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ImportActionsDialog>("Import Actions", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: int importedCount } && importedCount > 0)
        {
            await LoadActions();
            Snackbar.Add($"{importedCount} action(s) imported successfully.", Severity.Success);
        }
    }

    private async Task OpenCreateRaffleDialog()
    {
        var parameters = new DialogParameters<CreateRaffleDialog>
        {
            { x => x.AvailableQueues, _availableQueues }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateRaffleDialog>("Create Raffle", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled || result.Data is not RaffleSetupResult raffleSetup)
        {
            return;
        }

        await LoadActions();

        var actionIdToSelect = raffleSetup.StartActionId ?? raffleSetup.JoinActionId ?? raffleSetup.EndActionId;
        if (actionIdToSelect.HasValue)
        {
            var createdAction = _actions.FirstOrDefault(a => a.Id == actionIdToSelect.Value);
            if (createdAction != null)
            {
                await OnActionSelected(createdAction);
            }
        }

        Snackbar.Add($"Raffle '{raffleSetup.RaffleKey}' created with commands '!{raffleSetup.StartCommandName}', '!{raffleSetup.JoinCommandName}', and '!{raffleSetup.EndCommandName}'.", Severity.Success);
    }

    private async Task RunAction()
    {
        if (_selectedAction == null || !_selectedAction.Id.HasValue) return;
        try
        {
            var variables = new System.Collections.Concurrent.ConcurrentDictionary<string, string>
            {
                ["user"] = "Manual Trigger",
                ["userid"] = "0",
                ["displayname"] = "Manual Trigger",
                ["triggertype"] = "Manual",
                ["source"] = "ManageActions"
            };

            await ActionExecutor.EnqueueAction(variables, _selectedAction);
            Snackbar.Add($"Action '{_selectedAction.Name}' added to queue '{_selectedAction.QueueName}'.", Severity.Success);
            LoadSelectedActionHistory();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error executing action: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAction()
    {
        if (_selectedAction == null) return;

        try
        {
            var savedGroup = GetNormalizedGroup(_selectedAction.Group);

            _selectedAction.Group = _selectedAction.Group ?? string.Empty;

            _selectedAction.Triggers = _actionTriggers;

            if (_isNewAction || !_selectedAction.Id.HasValue)
            {
                _selectedAction = await ActionService.CreateActionAsync(_selectedAction);
                _isNewAction = false;
                Snackbar.Add($"Action '{_selectedAction.Name}' created successfully", Severity.Success);
            }
            else
            {
                await ActionService.UpdateActionAsync(_selectedAction);
                Snackbar.Add($"Action '{_selectedAction.Name}' updated successfully", Severity.Success);
            }

            await LoadActions();

            _selectedAction = null;
            _selectedActionIdInList = null;
            _expandedGroupInList = savedGroup;
            _actionTriggers = new List<TriggerType>();
            _selectedActionExecutionLogsAll.Clear();
            _selectedActionExecutionLogs.Clear();
            _isNewAction = false;
            _originalActionSnapshot = string.Empty;
            _skipNextNavigationPrompt = true;
            NavigationManager.NavigateTo("/actions/manage", false);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving action: {ex.Message}", Severity.Error);
        }
    }

    private void DuplicateAction()
    {
        if (_selectedAction == null) return;

        var duplicatedAction = new ActionType
        {
            Name = $"Copy of {_selectedAction.Name}",
            Group = _selectedAction.Group,
            Enabled = _selectedAction.Enabled,
            RandomAction = _selectedAction.RandomAction,
            ConcurrentAction = _selectedAction.ConcurrentAction,
            QueueName = _selectedAction.QueueName,
            SubActions = new List<SubActionType>(),
            CatchSubActions = new List<SubActionType>(),
            Triggers = new List<TriggerType>()
        };

        foreach (var subAction in _selectedAction.SubActions)
        {
            var subActionType = subAction.GetType();
            var duplicatedSubAction = (SubActionType)Activator.CreateInstance(subActionType)!;

            duplicatedSubAction.Id = 0;
            duplicatedSubAction.Index = subAction.Index;
            duplicatedSubAction.Text = subAction.Text;
            duplicatedSubAction.Enabled = subAction.Enabled;
            duplicatedSubAction.SubActionTypes = subAction.SubActionTypes;

            foreach (var prop in subActionType.GetProperties())
            {
                if (prop.CanWrite && prop.CanRead && 
                    prop.Name != "Id" && prop.Name != "Index" && prop.Name != "Text" && 
                    prop.Name != "Enabled" && prop.Name != "SubActionTypes")
                {
                    var value = prop.GetValue(subAction);
                    prop.SetValue(duplicatedSubAction, value);
                }
            }

            duplicatedAction.SubActions.Add(duplicatedSubAction);
        }

        foreach (var subAction in _selectedAction.CatchSubActions)
        {
            var subActionType = subAction.GetType();
            var duplicatedSubAction = (SubActionType)Activator.CreateInstance(subActionType)!;

            duplicatedSubAction.Id = 0;
            duplicatedSubAction.Index = subAction.Index;
            duplicatedSubAction.Text = subAction.Text;
            duplicatedSubAction.Enabled = subAction.Enabled;
            duplicatedSubAction.SubActionTypes = subAction.SubActionTypes;

            foreach (var prop in subActionType.GetProperties())
            {
                if (prop.CanWrite && prop.CanRead &&
                    prop.Name != "Id" && prop.Name != "Index" && prop.Name != "Text" &&
                    prop.Name != "Enabled" && prop.Name != "SubActionTypes")
                {
                    var value = prop.GetValue(subAction);
                    prop.SetValue(duplicatedSubAction, value);
                }
            }

            duplicatedAction.CatchSubActions.Add(duplicatedSubAction);
        }

        var duplicatedTriggers = new List<TriggerType>();
        foreach (var trigger in _actionTriggers)
        {
            var duplicatedTrigger = new TriggerType
            {
                Id = 0,
                Name = trigger.Name,
                Type = trigger.Type,
                Configuration = trigger.Configuration,
                Enabled = trigger.Enabled,
                ActionId = null
            };
            duplicatedTriggers.Add(duplicatedTrigger);
        }

        _selectedAction = duplicatedAction;
        _actionTriggers = duplicatedTriggers;
        _isNewAction = true;
        _selectedActionIdInList = null;
        _expandedGroupInList = string.Empty;
        _originalActionSnapshot = string.Empty;

        _isNavigating = true;
        _skipNextNavigationPrompt = true;
        NavigationManager.NavigateTo("/actions/manage", false);
        _isNavigating = false;

        Snackbar.Add("Action duplicated. Click Save to create the copy.", Severity.Info);
    }

    private async Task DeleteAction()
    {
        if (_selectedAction == null || !_selectedAction.Id.HasValue) return;

        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Action",
            $"Are you sure you want to delete the action '{_selectedAction.Name}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await ActionService.DeleteActionAsync(_selectedAction.Id.Value);
                Snackbar.Add($"Action '{_selectedAction.Name}' deleted successfully", Severity.Success);
                _selectedAction = null;
                _selectedActionIdInList = null;
                _expandedGroupInList = string.Empty;
                _actionTriggers = new List<TriggerType>();
                _selectedActionExecutionLogsAll.Clear();
                _selectedActionExecutionLogs.Clear();
                _originalActionSnapshot = string.Empty;
                await LoadActions();

                _skipNextNavigationPrompt = true;
                NavigationManager.NavigateTo("/actions/manage", false);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting action: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task CancelEdit()
    {
        if (!await ConfirmDiscardChangesAsync())
        {
            return;
        }

        _selectedAction = null;
        _selectedActionIdInList = null;
        _expandedGroupInList = string.Empty;
        _actionTriggers = new List<TriggerType>();
        _selectedActionExecutionLogsAll.Clear();
        _selectedActionExecutionLogs.Clear();
        _isNewAction = false;
        _originalActionSnapshot = string.Empty;

        _skipNextNavigationPrompt = true;
        NavigationManager.NavigateTo("/actions/manage", false);
    }

    private async Task<bool> ConfirmDiscardChangesAsync()
    {
        if (!HasUnsavedChanges)
        {
            return true;
        }

        bool? discardChanges = await DialogService.ShowMessageBoxAsync(
            "Unsaved Changes",
            "You have unsaved changes. Discard them?",
            yesText: "Discard",
            cancelText: "Stay");

        return discardChanges == true;
    }

    private void CaptureOriginalSnapshot()
    {
        _originalActionSnapshot = CreateCurrentSnapshot();
    }

    private void ResetActionsListSelectionVisual()
    {
        _selectedActionIdInList = _selectedAction?.Id;
        _expandedGroupInList = GetNormalizedGroup(_selectedAction?.Group);
        _actionsListRenderVersion++;
    }

    private static string GetNormalizedGroup(string? group)
    {
        return (group ?? string.Empty).Trim();
    }

    private string CreateCurrentSnapshot()
    {
        if (_selectedAction == null)
        {
            return string.Empty;
        }

        var snapshot = new
        {
            _selectedAction.Name,
            _selectedAction.Group,
            _selectedAction.Enabled,
            _selectedAction.RandomAction,
            _selectedAction.ConcurrentAction,
            _selectedAction.OnlineOnly,
            _selectedAction.QueueName,
            SubActions = _selectedAction.SubActions
                .Select(subAction => JsonSerializer.SerializeToElement(subAction, subAction.GetType()))
                .ToList(),
            CatchSubActions = _selectedAction.CatchSubActions
                .Select(subAction => JsonSerializer.SerializeToElement(subAction, subAction.GetType()))
                .ToList(),
            Triggers = _actionTriggers
        };

        return JsonSerializer.Serialize(snapshot);
    }

    private void OpenSelectedActionHistory()
    {
        if (_selectedAction?.Id is int actionId)
        {
            NavigationManager.NavigateTo($"/actions/history?actionId={actionId}");
        }
    }

    private void OpenExecutionHistory(ActionExecutionLog executionLog)
    {
        var actionId = executionLog.ActionId ?? _selectedAction?.Id;
        if (actionId.HasValue)
        {
            NavigationManager.NavigateTo($"/actions/history?actionId={actionId.Value}");
        }
    }

    private void LoadSelectedActionHistory()
    {
        _selectedActionExecutionLogsAll.Clear();

        if (_selectedAction?.Id is not int actionId)
        {
            _selectedActionExecutionLogs.Clear();
            return;
        }

        var totalLogCount = QueueManager.ExecutionLogger.GetLogCount();
        var logsToRetrieve = Math.Min(totalLogCount, 2000);
        _selectedActionExecutionLogsAll = QueueManager.ExecutionLogger
            .GetRecentLogs(logsToRetrieve)
            .ToList();

        FilterSelectedActionHistory();
    }

    private void OnSelectedActionHistoryStateChanged(ActionExecutionState? value)
    {
        _selectedActionHistoryFilterState = value;
        FilterSelectedActionHistory();
    }

    private void FilterSelectedActionHistory()
    {
        if (_selectedAction?.Id is not int actionId)
        {
            _selectedActionExecutionLogs.Clear();
            return;
        }

        _selectedActionExecutionLogs = QueueManager.ExecutionLogger
            .GetRecentLogs(Math.Min(QueueManager.ExecutionLogger.GetLogCount(), 2000))
            .ToList();

        _selectedActionExecutionLogs = PenguinTwitchBot.Bot.Queues.ActionExecutionLogFilter
            .Apply(_selectedActionExecutionLogs, _selectedActionHistorySearchString, _selectedActionHistoryFilterState, actionId)
            .Take(50)
            .ToList();
    }

    private static Color GetExecutionStateColor(ActionExecutionState state)
    {
        return state switch
        {
            ActionExecutionState.Pending => Color.Warning,
            ActionExecutionState.Running => Color.Info,
            ActionExecutionState.Completed => Color.Success,
            ActionExecutionState.Failed => Color.Error,
            _ => Color.Default
        };
    }

    private static string FormatDuration(TimeSpan duration)
    {
        var totalMilliseconds = duration.TotalMilliseconds;

        if (totalMilliseconds < 1000)
            return $"{totalMilliseconds:F0}ms";

        if (duration.TotalSeconds < 60)
            return $"{duration.TotalSeconds:F2}s";

        return $"{duration.TotalMinutes:F2}m";
    }

    private static string TrimForPreview(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value;
        }

        return value[..maxLength] + "...";
    }
}
