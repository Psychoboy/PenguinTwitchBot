    private static int Clamp(int value, int min, int max)
    {
        return value < min ? min : value > max ? max : value;
    }

    private void OnCronBuilderTargetJobChanged(string value)
    {
        _cronBuilderTargetJob = value;
        SyncCronHelperFromTargetJob();
    }

    private void SyncCronHelperFromTargetJob()
    {
        var cron = GetCronForJob(_cronBuilderTargetJob);
        _cronBuilderOutput = cron;
        ParseCronIntoHelper(cron);
    }

    private string GetCronForJob(string jobName)
    {
        return jobName switch
        {
            IScheduledJobSettingsService.TriggerBackupJobName => _backupCron,
            IScheduledJobSettingsService.CleanupClipsJobName => _cleanupClipsCron,
            IScheduledJobSettingsService.CleanupChatLogsJobName => _cleanupChatLogsCron,
            IScheduledJobSettingsService.CleanupIpLogsJobName => _cleanupIpLogsCron,
            IScheduledJobSettingsService.CleanupCooldownsJobName => _cleanupCooldownsCron,
            IScheduledJobSettingsService.TtsCleanupJobName => _ttsCleanupCron,
            IScheduledJobSettingsService.UpdateDiscordEventsJobName => _updateDiscordEventsCron,
            IScheduledJobSettingsService.PostScheduleJobName => _postScheduleCron,
            IScheduledJobSettingsService.UpdatePostedScheduleJobName => _updatePostedScheduleCron,
            IScheduledJobSettingsService.ValidationSanityCheckJobName => _validationSanityCheckCron,
            _ => DefaultCleanupChatLogsCron
        };
    }

    private void ParseCronIntoHelper(string cron)
    {
        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length != 6)
        {
            return;
        }

        if (parts[1].StartsWith("0/", StringComparison.Ordinal))
        {
            if (int.TryParse(parts[1].AsSpan(2), out var everyMinutes))
            {
                _cronBuilderPattern = CronBuilderPatternEveryNMinutes;
                _cronBuilderIntervalMinutes = Clamp(everyMinutes, 1, 59);
            }
            return;
        }

        if (parts[2] == "*" && parts[3] == "*" && parts[4] == "*" && parts[5] == "?")
        {
            _cronBuilderPattern = CronBuilderPatternHourly;
            if (int.TryParse(parts[1], out var hourlyMinute))
            {
                _cronBuilderMinute = Clamp(hourlyMinute, 0, 59);
            }
            return;
        }

        if (parts[3] == "*" && parts[4] == "*" && parts[5] == "?")
        {
            _cronBuilderPattern = CronBuilderPatternDaily;
            if (int.TryParse(parts[1], out var dailyMinute))
            {
                _cronBuilderMinute = Clamp(dailyMinute, 0, 59);
            }
            if (int.TryParse(parts[2], out var dailyHour))
            {
                _cronBuilderHour = Clamp(dailyHour, 0, 23);
            }
            return;
        }

        if (parts[3] == "?" && parts[4] == "*")
        {
            _cronBuilderPattern = CronBuilderPatternWeekly;
            if (int.TryParse(parts[1], out var weeklyMinute))
            {
                _cronBuilderMinute = Clamp(weeklyMinute, 0, 59);
            }
            if (int.TryParse(parts[2], out var weeklyHour))
            {
                _cronBuilderHour = Clamp(weeklyHour, 0, 23);
            }

            var dayOfWeek = parts[5].ToUpperInvariant();
            _cronBuilderDayOfWeek = dayOfWeek switch
            {
                "MON" or "TUE" or "WED" or "THU" or "FRI" or "SAT" or "SUN" => dayOfWeek,
                _ => _cronBuilderDayOfWeek
            };
            return;
        }

        if (parts[4] == "*" && parts[5] == "?")
        {
            _cronBuilderPattern = CronBuilderPatternMonthly;
            if (int.TryParse(parts[1], out var monthlyMinute))
            {
                _cronBuilderMinute = Clamp(monthlyMinute, 0, 59);
            }
            if (int.TryParse(parts[2], out var monthlyHour))
            {
                _cronBuilderHour = Clamp(monthlyHour, 0, 23);
            }
            if (int.TryParse(parts[3], out var monthlyDay))
            {
                _cronBuilderDayOfMonth = Clamp(monthlyDay, 1, 31);
            }
        }
    }

    private void GenerateCronFromHelper()
    {
        _cronBuilderOutput = BuildCronFromHelper();
    }

    private string BuildCronFromHelper()
    {
        var minute = Clamp(_cronBuilderMinute, 0, 59);
        var hour = Clamp(_cronBuilderHour, 0, 23);
        var intervalMinutes = Clamp(_cronBuilderIntervalMinutes, 1, 59);
        var dayOfMonth = Clamp(_cronBuilderDayOfMonth, 1, 31);

        return _cronBuilderPattern switch
        {
            CronBuilderPatternEveryNMinutes => $"0 0/{intervalMinutes} * * * ?",
            CronBuilderPatternHourly => $"0 {minute} * * * ?",
            CronBuilderPatternDaily => $"0 {minute} {hour} * * ?",
            CronBuilderPatternWeekly => $"0 {minute} {hour} ? * {_cronBuilderDayOfWeek}",
            CronBuilderPatternMonthly => $"0 {minute} {hour} {dayOfMonth} * ?",
            _ => DefaultCleanupChatLogsCron
        };
    }

    private void ApplyGeneratedCronToTarget()
    {
        var generatedCron = BuildCronFromHelper();
        if (!CronExpression.IsValidExpression(generatedCron))
        {
            Snackbar.Add($"Generated cron is invalid: {generatedCron}", Severity.Error);
            return;
        }

        _cronBuilderOutput = generatedCron;

        switch (_cronBuilderTargetJob)
        {
            case IScheduledJobSettingsService.TriggerBackupJobName:
                _backupCron = generatedCron;
                break;
            case IScheduledJobSettingsService.CleanupClipsJobName:
                _cleanupClipsCron = generatedCron;
                break;
            case IScheduledJobSettingsService.CleanupChatLogsJobName:
                _cleanupChatLogsCron = generatedCron;
                break;
            case IScheduledJobSettingsService.CleanupIpLogsJobName:
                _cleanupIpLogsCron = generatedCron;
                break;
            case IScheduledJobSettingsService.CleanupCooldownsJobName:
                _cleanupCooldownsCron = generatedCron;
                break;
            case IScheduledJobSettingsService.TtsCleanupJobName:
                _ttsCleanupCron = generatedCron;
                break;
            case IScheduledJobSettingsService.UpdateDiscordEventsJobName:
                _updateDiscordEventsCron = generatedCron;
                break;
            case IScheduledJobSettingsService.PostScheduleJobName:
                _postScheduleCron = generatedCron;
                break;
            case IScheduledJobSettingsService.UpdatePostedScheduleJobName:
                _updatePostedScheduleCron = generatedCron;
                break;
            case IScheduledJobSettingsService.ValidationSanityCheckJobName:
                _validationSanityCheckCron = generatedCron;
                break;
            default:
                Snackbar.Add("Please choose a target job.", Severity.Warning);
                return;
        }

        Snackbar.Add("Cron applied to selected job field.", Severity.Success);
    }

    private bool ValidateCronSetting(string label, string cronExpression)
    {
        if (string.IsNullOrWhiteSpace(cronExpression) || !CronExpression.IsValidExpression(cronExpression))
        {
            Snackbar.Add($"Invalid cron for {label}: {cronExpression}", Severity.Error);
            return false;
        }

        return true;
    }
