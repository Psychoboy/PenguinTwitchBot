@using PenguinTwitchBot.Bot.Features
@inject IFeatureRuntimeCoordinator FeatureRuntimeCoordinator
@inject PenguinTwitchBot.Bot.Commands.Features.IGiveawayFeature GiveawayFeature;
@implements IDisposable
<FeatureGate FeatureKey="@FeatureKeys.GiveawayFeature">
    <ChildContent>
<MudPaper Class="pa-5" Elevation="3">
    
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5" class="mud-contrast-text">Current Giveaway</MudText>
            </MudStack>
            <MudButton Href="viewergiveaway" 
                       Variant="Variant.Text" 
                       Color="Color.Primary" 
                       EndIcon="@Icons.Material.Filled.ArrowForward">
                View Details
            </MudButton>
        </MudStack>
        <MudDivider />
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            @if (string.IsNullOrEmpty(prize))
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Height="32px" />
            }
            else
            {
                <MudText Typo="Typo.h6" Align="Align.Center"><strong>@prize</strong></MudText>
            }
            @if (string.IsNullOrEmpty(imageUrl))
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="250px" Class="rounded" />
            }
            else
            {
                <MudImage Fluid="true" Class="rounded-lg" Src="@imageUrl" Elevation="2" />
            }
        </MudStack>
    </MudStack>
    
</MudPaper>
</ChildContent>
<DisabledContent></DisabledContent>
</FeatureGate>
@code {
    private string prize = "";
    private string? imageUrl;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        FeatureRuntimeCoordinator.StateChangedAsync += HandleFeatureStateChangedAsync;

        await RefreshAsync();
    }

    private Task HandleFeatureStateChangedAsync()
    {
        return InvokeAsync(RefreshAsync);
    }

    private async Task RefreshAsync()
    {
        if (_disposed)
        {
            return;
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.GiveawayFeature))
        {
            prize = await GiveawayFeature.GetPrize();
            imageUrl = await GiveawayFeature.GetImageUrl();
        }
        else
        {
            prize = string.Empty;
            imageUrl = null;
        }

        if (!_disposed)
        {
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _disposed = true;
        FeatureRuntimeCoordinator.StateChangedAsync -= HandleFeatureStateChangedAsync;
    }
}
