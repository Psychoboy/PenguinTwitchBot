@using PenguinTwitchBot.Bot.Features
@using PenguinTwitchBot.Bot.Commands.TicketGames
@using PenguinTwitchBot.Bot.Core.Points
@using PenguinTwitchBot.Helpers
@using Microsoft.AspNetCore.SignalR.Client
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IBonusTickets bonusTickets
@inject IPointsSystem pointsSystem
@inject PenguinTwitchBot.Bot.Core.IServiceBackbone serviceBackbone
@inject NavigationManager Navigation
@inject ILogger<BonusTickets> logger
@inject IFeatureRuntimeCoordinator FeatureRuntimeCoordinator
@implements IAsyncDisposable
<FeatureGate FeatureKey="@FeatureKeys.BonusTickets">
    <ChildContent>
<MudPaper Class="pa-5" Elevation="3">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Stars" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h5" class="mud-contrast-text">Bonus @BonusPointsName</MudText>
        </MudStack>
        <MudDivider />
        @if (!dataLoaded)
        {
            <MudOverlay Visible="!dataLoaded" DarkBackground="true" Absolute="true">
                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
            </MudOverlay>
            <MudSkeleton Height="80px" />
        }
        else 
        {
            <MudText Typo="Typo.body1">Click the button once per stream while LIVE to claim your bonus @bonusPointsNameLower!</MudText>
            <AuthorizeView>
                <Authorized>
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        @if(disabled || StreamOnline == false)
                        {
                            @if (StreamOnline == false)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.PowerOff" Dense="true">
                                    Stream is currently offline. Come back when live!
                                </MudAlert>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.CheckCircle" Dense="true">
                                    Bonus claimed! Come back next stream for more.
                                </MudAlert>
                            }
                        } 
                        else
                        {
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Success" 
                                       FullWidth="true"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.Redeem"
                                       Disabled="@disabled" 
                                       @onclick="() => ClaimBonus()">
                                Claim Bonus @BonusPointsName
                            </MudButton>
                        }
                    </MudStack>
                </Authorized>
                <NotAuthorized>
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton OnClick="Signin"
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   FullWidth="true"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Login">
                            Sign In to Claim Bonus
                        </MudButton>
                    </MudStack>
                </NotAuthorized>
            </AuthorizeView>
        }
    </MudStack>
</MudPaper>
    </ChildContent>
    <DisabledContent></DisabledContent>
</FeatureGate>
@code {

    private bool disabled = true;
    private string Username = "";
    private string BonusPointsName = "Points";
    private string bonusPointsNameLower => BonusPointsName.ToLowerInvariant();
    private bool StreamOnline = false;
    private HubConnection? hubConnection;
    private CancellationTokenSource? _hubConnectionCts;
    private bool dataLoaded = false;
    private bool _disposed;
    protected override async Task OnInitializedAsync()
    {
        FeatureRuntimeCoordinator.StateChangedAsync += HandleFeatureStateChangedAsync;
        if(!FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.BonusTickets))
        {
            await base.OnInitializedAsync();
            return;
        }
        await RefreshAsync();
        await base.OnInitializedAsync();
    }

    private async Task HandleFeatureStateChangedAsync()
    {
        if (!FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.BonusTickets))
        {
            return;
        }

        await InvokeAsync(async () =>
        {
            await RefreshAsync();
            await EnsureHubConnectionAsync();
        });
    }

    private async Task RefreshAsync()
    {
        if (_disposed)
        {
            return;
        }
        if (!FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.BonusTickets))
        {
            return;
        }
        var pointType = await pointsSystem.GetPointTypeForGame(PenguinTwitchBot.Bot.Commands.TicketGames.BonusTickets.GAMENAME);
        if (string.IsNullOrWhiteSpace(pointType.Name) == false)
        {
            BonusPointsName = pointType.Name;
        }
        var authState = await AuthenticationStateProvider
           .GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is not null && user.Identity.IsAuthenticated && user.Identity.Name != null)
        {
            Username = user.Identity.Name;
            disabled = await bonusTickets.DidUserRedeemBonus(Username);
        }
        StreamOnline = serviceBackbone.IsOnline;
        if (!_disposed)
        {
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        if (!FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.BonusTickets))
        {
            return;
        }

        await EnsureHubConnectionAsync();

        dataLoaded = true;
        StateHasChanged();
    }

    private async Task EnsureHubConnectionAsync()
    {
        if (_disposed)
        {
            return;
        }

        if (!FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.BonusTickets))
        {
            return;
        }

        if (hubConnection is not null)
        {
            return;
        }

        _hubConnectionCts = new CancellationTokenSource();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(SignalRConnectionHelper.ResolveHubUri(AppConfiguration, Navigation, "/mainhub"), options =>
            {
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false;
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        hubConnection.On<bool>("StreamChanged", (status) =>
        {
            StreamOnline = status;
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartWithExpectedExceptionHandlingAsync(logger, cancellationToken: _hubConnectionCts.Token);
    }

    private async Task ClaimBonus()
    {
        if (string.IsNullOrWhiteSpace(Username)) return;
        disabled = true;
        await bonusTickets.RedeemBonus(Username);
        StateHasChanged();
    }

    private void Signin()
    {
        Navigation.NavigateToSigninWithReturnUrl();
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _hubConnectionCts?.Cancel();

        await hubConnection.DisposeGracefullyAsync(logger);

        _hubConnectionCts?.Dispose();
        FeatureRuntimeCoordinator.StateChangedAsync -= HandleFeatureStateChangedAsync;
    }
}
