@page "/quotes"
@using PenguinTwitchBot.Bot.Features
@inject PenguinTwitchBot.Bot.Commands.Misc.QuoteSystem QuoteSystem
@inject IFeatureRuntimeCoordinator FeatureRuntimeCoordinator
@implements IDisposable

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Quotes</PageTitle>
<FeatureGate FeatureKey="@FeatureKeys.QuoteSystem">
    <ChildContent>
        <MudContainer Class="pa-4 pa-md-6" MaxWidth="MaxWidth.ExtraLarge">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h4" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Class="mr-2" />
                    Quotes
                </MudText>

                <MudPaper Elevation="3">
                    @if (!dataLoaded)
                    {
                        <MudStack Class="pa-4" Spacing="2">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="22%" Height="28px" />
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="250px" Height="44px" Class="rounded" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100%" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="94%" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="98%" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="91%" />
                        </MudStack>
                    }
                    else
                    {
                    <MudTable Items="@items" Filter="new Func<FilteredQuoteType,bool>(FilterFunc1)" Dense="true" Hover="true">
                        <ToolBarContent>
                            <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Color="Color.Primary" Class="mr-2" />
                            <MudText Typo="Typo.h6">All Quotes</MudText>
                            <MudSpacer />
                            <MudTextField DebounceInterval="1000" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="searchString1" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Style="min-width: 250px;"></MudTextField>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Id</MudTh>
                            <MudTh>Quote</MudTh>
                            <MudTh>Game</MudTh>
                            <MudTh>Created By</MudTh>
                            <MudTh>Created On</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Id">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Color="Color.Info" />
                                    <MudText><strong>@context.Id</strong></MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Quote">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText>@context.Quote</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Game">
                                @if (!string.IsNullOrWhiteSpace(context.Game))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Small" Color="Color.Tertiary" />
                                        <MudText>@context.Game</MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudText Color="Color.Default" Class="fst-italic">No game</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="CreatedBy">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Success" />
                                    <MudText>@context.CreatedBy</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="CreatedOn">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Default" />
                                    <MudText>@context.CreatedOn.ToShortDateString()</MudText>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.SearchOff">
                                No quotes found matching your search.
                            </MudAlert>
                        </NoRecordsContent>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                    }
                </MudPaper>
            </MudStack>
        </MudContainer>
    </ChildContent>
    <DisabledContent>
        <MudContainer Class="pa-4 pa-md-6" MaxWidth="MaxWidth.Medium">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.PowerOff">
                Quotes are currently disabled by the streamer.
            </MudAlert>
        </MudContainer>
    </DisabledContent>
</FeatureGate>

@code {
    private IEnumerable<FilteredQuoteType> items = new List<FilteredQuoteType>();
    private string searchString1 = "";
    private bool dataLoaded = false;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        FeatureRuntimeCoordinator.StateChanged += HandleFeatureStateChanged;
        await LoadQuotesAsync();
    }

    private async Task LoadQuotesAsync()
    {
        if (_disposed)
        {
            return;
        }

        if (FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.QuoteSystem))
        {
            items = (await QuoteSystem.GetQuotes()).OrderByDescending(x => x.Id).ToList();
        }
        else
        {
            items = [];
        }

        dataLoaded = true;
        if (!_disposed)
        {
            StateHasChanged();
        }
    }

    private void HandleFeatureStateChanged()
    {
        if (_disposed)
        {
            return;
        }

        _ = InvokeAsync(LoadQuotesAsync);
    }

    private bool FilterFunc1(FilteredQuoteType element) => FilterFunc(element, searchString1);

    private bool FilterFunc(FilteredQuoteType element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Quote.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.CreatedBy.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.Id}".Contains(searchString))
            return true;
        if (element.Game.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    public void Dispose()
    {
        _disposed = true;
        FeatureRuntimeCoordinator.StateChanged -= HandleFeatureStateChanged;
    }
}
