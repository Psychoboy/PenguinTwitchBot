    private string GetPointTypeName(int pointTypeId)
    {
        return pointTypes.FirstOrDefault(pointType => pointType.Id == pointTypeId)?.Name ?? "Select a point type";
    }

    private static string FormatPlacementLabel(int placement)
    {
        return placement switch
        {
            1 => "1st place",
            2 => "2nd place",
            3 => "3rd place",
            4 => "4th place",
            5 => "5th place",
            6 => "6th place",
            7 => "7th place",
            8 => "8th place",
            9 => "9th place",
            10 => "10th place",
            _ => $"Top {placement}"
        };
    }

    private static DateTime? ParseUtcDateTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal, out var dateTimeOffset))
        {
            return dateTimeOffset.UtcDateTime;
        }

        if (DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal, out var dateTime))
        {
            return DateTime.SpecifyKind(dateTime, DateTimeKind.Utc);
        }

        return null;
    }
