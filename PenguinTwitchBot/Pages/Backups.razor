@page "/backups"
@using PenguinTwitchBot.Services
@using System.IO
@inject PenguinTwitchBot.Bot.Commands.Moderation.Admin Admin
@inject PenguinTwitchBot.Database.Bot.DatabaseTools.IBackupTools BackupTools
@inject IBackupSettingsService BackupSettings
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@attribute [Authorize(Roles = "Streamer")]

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Backups</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Spacing="4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h4">Backup Management</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Backup" OnClick="BackupDatabase">
                Create Backup
            </MudButton>
        </MudStack>

        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Backup Retention Settings</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Configure how many backups to keep and for how long. Both constraints are applied together when cleaning up old backups.
                </MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    Saved to the database <code>Setting</code> table.
                </MudAlert>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_maxBackups" Label="Max backups to keep" Min="1" Max="1000" Immediate="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_maxDays" Label="Max days to keep" Min="1" Max="3650" Immediate="true" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveSettingsAsync" Disabled="_saving">
                        Save Settings
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="ResetSettingsAsync">
                        Reset to Defaults
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudText Typo="Typo.h6">Existing Backups (@_backups.Count)</MudText>

        @if (_backups.Count == 0)
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="text-align: center;">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary">No backups found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Create your first backup to get started.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="@_backups" Dense="true" Hover="true" Bordered="true" Striped="true">
                <HeaderContent>
                    <MudTh>File Name</MudTh>
                    <MudTh>Creation Time</MudTh>
                    <MudTh>Size</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="File Name">@context.Name</MudTd>
                    <MudTd DataLabel="Creation Time">@context.CreationTime.ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="Size">@FormatBytes(context.Length)</MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudStack Row="true" Style="justify-content: flex-end;" Spacing="1">
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" OnClick="() => RestoreBackup(context)" StartIcon="@Icons.Material.Filled.Restore">
                                Restore
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="() => DownloadBackup(context)" StartIcon="@Icons.Material.Filled.Download">
                                Download
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudContainer>

@code {
    private List<FileInfo> _backups = new();
    private int _maxBackups = 15;
    private int _maxDays = 15;
    private bool _saving;

    [Inject] private IDialogService DialogService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        await RefreshBackupsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _maxBackups = await BackupSettings.GetBackupCountToKeepAsync(15);
        _maxDays = await BackupSettings.GetBackupDaysToKeepAsync(15);
    }

    private async Task SaveSettingsAsync()
    {
        _saving = true;
        try
        {
            _maxBackups = _maxBackups < 1 ? 1 : _maxBackups;
            _maxDays = _maxDays < 1 ? 1 : _maxDays;

            await BackupSettings.SetBackupCountToKeepAsync(_maxBackups);
            await BackupSettings.SetBackupDaysToKeepAsync(_maxDays);

            Snackbar.Add("Backup retention settings saved successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ResetSettingsAsync()
    {
        _maxBackups = 15;
        _maxDays = 15;
        await SaveSettingsAsync();
    }

    private async Task BackupDatabase()
    {
        Snackbar.Add("Database backup started...", Severity.Info);
        await Admin.BackupDatabase();
        await RefreshBackupsAsync();
        Snackbar.Add("Database backup completed.", Severity.Success);
    }

    private async Task RefreshBackupsAsync()
    {
        _backups = BackupTools.GetBackupFiles(BackupTools.BackupDirectory)
            .OrderByDescending(x => x.CreationTime)
            .ToList();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RestoreBackup(FileInfo fileInfo)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning",
            "Are you sure you want to restore this database? Doing so will wipe current data!",
            yesText: "Restore!", cancelText: "Cancel");
        if (result != null)
        {
            try
            {
                await Admin.RestoreDatabase(fileInfo.FullName);
                await DialogService.ShowMessageBoxAsync("Success", "Database restored successfully!");
            }
            catch (Exception e)
            {
                await DialogService.ShowMessageBoxAsync("Error", e.Message);
            }
        }
    }

    private async Task DownloadBackup(FileInfo fileInfo)
    {
        try
        {
            var fileName = Path.GetFileName(fileInfo.FullName);
            var stream = File.OpenRead(fileInfo.FullName);
            var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFile", fileName, streamRef);
            Snackbar.Add("Download started.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to download backup: {ex.Message}", Severity.Error);
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 0x1000000000000000) { return ((double)(bytes >> 50) / 1024).ToString("0.### EB"); }
        if (bytes >= 0x4000000000000) { return ((double)(bytes >> 40) / 1024).ToString("0.### PB"); }
        if (bytes >= 0x10000000000) { return ((double)(bytes >> 30) / 1024).ToString("0.### TB"); }
        if (bytes >= 0x40000000) { return ((double)(bytes >> 20) / 1024).ToString("0.### GB"); }
        if (bytes >= 0x100000) { return ((double)(bytes >> 10) / 1024).ToString("0.### MB"); }
        if (bytes >= 0x400) { return ((double)(bytes) / 1024).ToString("0.###") + " KB"; }
        return bytes.ToString("0 Bytes");
    }
}
