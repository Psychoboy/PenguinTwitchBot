@using PenguinTwitchBot.Bot.Actions.Triggers
@using TwitchEventConfig = PenguinTwitchBot.Bot.Actions.Triggers.TwitchEventTriggerConfig
@using MudBlazor
@using PenguinTwitchBot.Bot.TwitchServices

<MudStack Spacing="3">
    <MudText Typo="Typo.h6">Configure Twitch Event Trigger</MudText>

    <MudAutocomplete T="TwitchEventInfo" 
                     Value="@_selectedEventInfo" 
                     ValueChanged="OnEventInfoChanged"
                     Label="Select Twitch Event" 
                     Variant="Variant.Outlined" 
                     Required="true" 
                     SearchFunc="SearchEvents"
                     ToStringFunc="@(e => e?.DisplayName ?? string.Empty)"
                     MaxItems="null"
                     ResetValueOnEmptyText="true"
                     CoerceValue="false"
                     HelperText="Choose which Twitch event should trigger this action">
        <ItemTemplate Context="eventInfo">
            <MudStack Row="false" Spacing="0">
                <MudText Typo="Typo.body1">@eventInfo.DisplayName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@eventInfo.Description</MudText>
            </MudStack>
        </ItemTemplate>
    </MudAutocomplete>

    @if (!string.IsNullOrEmpty(SelectedEventName))
    {
        var eventInfo = _availableEvents.FirstOrDefault(e => e.Name == SelectedEventName);
        if (eventInfo != null)
        {
            @if (eventInfo.SupportsFiltering)
            {
                <MudText Typo="Typo.subtitle2" Class="mt-3">Filter Options (Optional)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty to trigger on ALL @eventInfo.DisplayName events</MudText>

                @* Amount Range Filters (for Cheers) *@
                @if (eventInfo.FilterOptions.Contains("MinAmount") || eventInfo.FilterOptions.Contains("MaxAmount"))
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MinAmount" 
                                         Label="Min Bits" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Minimum bits amount" />
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MaxAmount" 
                                         Label="Max Bits" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Maximum bits amount" />
                    </MudStack>
                }

                @* Viewer Range Filters (for Raids) *@
                @if (eventInfo.FilterOptions.Contains("MinViewers") || eventInfo.FilterOptions.Contains("MaxViewers"))
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MinViewers" 
                                         Label="Min Viewers" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Minimum viewer count" />
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MaxViewers" 
                                         Label="Max Viewers" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Maximum viewer count" />
                    </MudStack>
                }

                @* Gift Amount Range Filters (for Sub Gifts) *@
                @if (eventInfo.FilterOptions.Contains("MinGiftAmount") || eventInfo.FilterOptions.Contains("MaxGiftAmount"))
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MinGiftAmount" 
                                         Label="Min Gifts" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Minimum gift count" />
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MaxGiftAmount" 
                                         Label="Max Gifts" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Maximum gift count" />
                    </MudStack>
                }

                @* Reward Titles Filter (for Channel Points) *@
                @if (eventInfo.FilterOptions.Contains("RewardTitles"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Specific Reward Titles</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for ANY reward. Add multiple to trigger on any of them.</MudText>

                        @* Dropdown to select from existing rewards *@
                        <MudAutocomplete T="RewardTitleOption" 
                                         Value="_selectedRewardToAdd"
                                         Label="Add from existing rewards" 
                                         Variant="Variant.Outlined"
                                         Clearable="true"
                                         SearchFunc="SearchRewards"
                                         ToStringFunc="@(option => option?.DisplayLabel ?? string.Empty)"
                                         MaxItems="null"
                                         ResetValueOnEmptyText="true"
                                         CoerceValue="false"
                                         HelperText="Select a channel point reward title or type manually below. Duplicate titles are grouped together."
                                         ValueChanged="@(async (RewardTitleOption value) => await OnRewardSelected(value))" />

                        @for (var index = 0; index < Config.RewardTitles.Count; index++)
                        {
                            var currentIndex = index;
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField Value="@Config.RewardTitles[currentIndex]"
                                              ValueChanged="@((string value) => OnRewardTitleChanged(currentIndex, value))"
                                              Label="@($"Reward {currentIndex + 1}")" 
                                              Variant="Variant.Outlined" 
                                              Style="flex: 1" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Color="Color.Error" 
                                               OnClick="@(() => RemoveRewardTitle(currentIndex))" />
                            </MudStack>
                        }
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddRewardTitle">
                            Add Reward Title Manually
                        </MudButton>
                    </MudStack>
                }

                @* Subscription Tiers Filter *@
                @if (eventInfo.FilterOptions.Contains("SubscriptionTiers"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Subscription Tiers</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for ANY tier</MudText>

                        <MudStack Row="true" Spacing="2">
                            <MudCheckBox T="bool" Value="_tier1Selected" 
                                         Label="Tier 1" 
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnTierChanged("1000", val))" />
                            <MudCheckBox T="bool" Value="_tier2Selected" 
                                         Label="Tier 2" 
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnTierChanged("2000", val))" />
                            <MudCheckBox T="bool" Value="_tier3Selected" 
                                         Label="Tier 3" 
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnTierChanged("3000", val))" />
                        </MudStack>
                    </MudStack>
                }

                @* Ad Break Filters *@
                @if (eventInfo.FilterOptions.Contains("IsAutomatic"))
                {
                    <MudSelect T="bool?" 
                               @bind-Value="Config.IsAutomatic"
                               Label="Ad Type" 
                               Variant="Variant.Outlined"
                               Clearable="true"
                               HelperText="Filter by automatic or manual ads">
                        <MudSelectItem T="bool?" Value="@((bool?)null)">Any</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@true">Automatic</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@false">Manual</MudSelectItem>
                    </MudSelect>
                }

                @if (eventInfo.FilterOptions.Contains("MinAdDuration") || eventInfo.FilterOptions.Contains("MaxAdDuration"))
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MinAdDuration" 
                                         Label="Min Duration (sec)" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Minimum ad duration" />
                        <MudNumericField T="int?" 
                                         @bind-Value="Config.MaxAdDuration" 
                                         Label="Max Duration (sec)" 
                                         Variant="Variant.Outlined" 
                                         Min="1"
                                         HelperText="Maximum ad duration" />
                    </MudStack>
                }

                @* Bits Use Type Filter *@
                @if (eventInfo.FilterOptions.Contains("BitsTypes"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Bits Use Type</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for ANY type</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudCheckBox T="bool" Value="_cheerSelected"
                                         Label="Cheer"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnBitsTypeChanged("cheer", val))" />
                            <MudCheckBox T="bool" Value="_powerUpSelected"
                                         Label="Power Up"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnBitsTypeChanged("power_up", val))" />
                            <MudCheckBox T="bool" Value="_customPowerUpSelected"
                                         Label="Custom Power Up"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnBitsTypeChanged("custom_power_up", val))" />
                        </MudStack>
                    </MudStack>
                }

                @* Power Up Type Filter *@
                @if (eventInfo.FilterOptions.Contains("PowerUpTypes"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Power Up Type</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for ANY power-up type</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudCheckBox T="bool" Value="_messageEffectSelected"
                                         Label="Message Effect"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnPowerUpTypeChanged("message_effect", val))" />
                            <MudCheckBox T="bool" Value="_celebrationSelected"
                                         Label="Celebration"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnPowerUpTypeChanged("celebration", val))" />
                            <MudCheckBox T="bool" Value="_gigantifySelected"
                                         Label="Gigantify Emote"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnPowerUpTypeChanged("gigantify_an_emote", val))" />
                        </MudStack>
                    </MudStack>
                }

                @* Custom Power Up Titles Filter *@
                @if (eventInfo.FilterOptions.Contains("CustomPowerUpTitles"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Custom Power Up Titles</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for ANY custom power-up. Add multiple to match any of them.</MudText>
                        @foreach (var (title, index) in Config.CustomPowerUpTitles.Select((t, i) => (t, i)))
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField @bind-Value="Config.CustomPowerUpTitles[index]"
                                              Label="@($"Title {index + 1}")"
                                              Variant="Variant.Outlined"
                                              Style="flex: 1" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveCustomPowerUpTitle(index))" />
                            </MudStack>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddCustomPowerUpTitle">
                            Add Title
                        </MudButton>
                    </MudStack>
                }

                @* Custom Power Up Reward IDs Filter *@
                @if (eventInfo.FilterOptions.Contains("CustomPowerUpRewardIds"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Custom Power Up Reward IDs</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for ANY reward ID. Add multiple to match any of them.</MudText>
                        @foreach (var (rewardId, index) in Config.CustomPowerUpRewardIds.Select((r, i) => (r, i)))
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField @bind-Value="Config.CustomPowerUpRewardIds[index]"
                                              Label="@($"Reward ID {index + 1}")"
                                              Variant="Variant.Outlined"
                                              Style="flex: 1" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveCustomPowerUpRewardId(index))" />
                            </MudStack>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddCustomPowerUpRewardId">
                            Add Reward ID
                        </MudButton>
                    </MudStack>
                }

                @* Notice Type Filter (for ChannelChatNotification) *@
                @if (eventInfo.FilterOptions.Contains("NoticeTypes"))
                {
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">Notice Type</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Select at least one notice type — leaving empty means the trigger will never fire</MudText>
                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                            <MudCheckBox T="bool" Value="_subNoticeSelected"
                                         Label="Sub"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("sub", val))" />
                            <MudCheckBox T="bool" Value="_resubNoticeSelected"
                                         Label="Resub"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("resub", val))" />
                            <MudCheckBox T="bool" Value="_subGiftNoticeSelected"
                                         Label="Sub Gift"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("sub_gift", val))" />
                            <MudCheckBox T="bool" Value="_communitySubGiftNoticeSelected"
                                         Label="Community Sub Gift"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("community_sub_gift", val))" />
                            <MudCheckBox T="bool" Value="_giftPaidUpgradeNoticeSelected"
                                         Label="Gift Paid Upgrade"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("gift_paid_upgrade", val))" />
                            <MudCheckBox T="bool" Value="_primePaidUpgradeNoticeSelected"
                                         Label="Prime Paid Upgrade"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("prime_paid_upgrade", val))" />
                            <MudCheckBox T="bool" Value="_raidNoticeSelected"
                                         Label="Raid"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("raid", val))" />
                            <MudCheckBox T="bool" Value="_unraidNoticeSelected"
                                         Label="Unraid"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("unraid", val))" />
                            <MudCheckBox T="bool" Value="_payItForwardNoticeSelected"
                                         Label="Pay It Forward"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("pay_it_forward", val))" />
                            <MudCheckBox T="bool" Value="_announcementNoticeSelected"
                                         Label="Announcement"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("announcement", val))" />
                            <MudCheckBox T="bool" Value="_bitsBadgeTierNoticeSelected"
                                         Label="Bits Badge Tier"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("bits_badge_tier", val))" />
                            <MudCheckBox T="bool" Value="_charityDonationNoticeSelected"
                                         Label="Charity Donation"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("charity_donation", val))" />
                            <MudCheckBox T="bool" Value="_watchStreakNoticeSelected"
                                         Label="Watch Streak"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnNoticeTypeChanged("watch_streak", val))" />
                        </MudStack>
                    </MudStack>
                }

                @* Require at least one notice type *@
                @if (eventInfo.FilterOptions.Contains("NoticeTypes") && Config.NoticeTypes.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        At least one notice type must be selected — without a selection this trigger will never fire.
                    </MudAlert>
                }

                @* Sub Tier Filter - shown when any tier-based notice type is selected *@
                @if (eventInfo.FilterOptions.Contains("SubTiers") && (_subNoticeSelected || _resubNoticeSelected || _subGiftNoticeSelected || _communitySubGiftNoticeSelected || _primePaidUpgradeNoticeSelected))
                {
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body2">Sub Tier</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for any tier</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudCheckBox T="bool" Value="_subTier1Selected"
                                         Label="Tier 1"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnSubTierChanged("1000", val))" />
                            <MudCheckBox T="bool" Value="_subTier2Selected"
                                         Label="Tier 2"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnSubTierChanged("2000", val))" />
                            <MudCheckBox T="bool" Value="_subTier3Selected"
                                         Label="Tier 3"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnSubTierChanged("3000", val))" />
                        </MudStack>
                    </MudStack>
                }

                @* Resub Cumulative Months Range - shown only when resub is selected *@
                @if ((eventInfo.FilterOptions.Contains("MinCumulativeMonths") || eventInfo.FilterOptions.Contains("MaxCumulativeMonths")) && _resubNoticeSelected)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MinCumulativeMonths"
                                         Label="Min Total Months"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Minimum cumulative months subscribed" />
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MaxCumulativeMonths"
                                         Label="Max Total Months"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Maximum cumulative months subscribed" />
                    </MudStack>
                }

                @* Community Sub Gift Count Range - shown only when community_sub_gift is selected *@
                @if ((eventInfo.FilterOptions.Contains("MinCommunityGiftCount") || eventInfo.FilterOptions.Contains("MaxCommunityGiftCount")) && _communitySubGiftNoticeSelected)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MinCommunityGiftCount"
                                         Label="Min Subs Gifted"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Minimum number of subs in the gift bomb" />
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MaxCommunityGiftCount"
                                         Label="Max Subs Gifted"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Maximum number of subs in the gift bomb" />
                    </MudStack>
                }

                @* Raid Viewer Count Filter - shown only when raid is selected *@
                @if ((eventInfo.FilterOptions.Contains("MinRaidViewers") || eventInfo.FilterOptions.Contains("MaxRaidViewers")) && _raidNoticeSelected)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MinRaidViewers"
                                         Label="Min Raid Viewers"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Minimum viewer count in the raid" />
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MaxRaidViewers"
                                         Label="Max Raid Viewers"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Maximum viewer count in the raid" />
                    </MudStack>
                }

                @* Charity Donation Amount Range - shown only when charity_donation is selected *@
                @if ((eventInfo.FilterOptions.Contains("MinCharityAmount") || eventInfo.FilterOptions.Contains("MaxCharityAmount")) && _charityDonationNoticeSelected)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MinCharityAmount"
                                         Label="Min Amount (minor units)"
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         HelperText="e.g. 500 = $5.00 USD" />
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MaxCharityAmount"
                                         Label="Max Amount (minor units)"
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         HelperText="e.g. 10000 = $100.00 USD" />
                    </MudStack>
                }

                @* Bits Badge Tier Range - shown only when bits_badge_tier is selected *@
                @if ((eventInfo.FilterOptions.Contains("MinBitsBadgeTier") || eventInfo.FilterOptions.Contains("MaxBitsBadgeTier")) && _bitsBadgeTierNoticeSelected)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MinBitsBadgeTier"
                                         Label="Min Bits Badge Tier"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="e.g. 100, 1000, 10000" />
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MaxBitsBadgeTier"
                                         Label="Max Bits Badge Tier"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="e.g. 100, 1000, 10000" />
                    </MudStack>
                }

                @* Watch Streak Range Filter - shown only when watch_streak is selected *@
                @if ((eventInfo.FilterOptions.Contains("MinWatchStreak") || eventInfo.FilterOptions.Contains("MaxWatchStreak")) && _watchStreakNoticeSelected)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MinWatchStreak"
                                         Label="Min Watch Streak"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Minimum consecutive streams watched" />
                        <MudNumericField T="int?"
                                         @bind-Value="Config.MaxWatchStreak"
                                         Label="Max Watch Streak"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Maximum consecutive streams watched" />
                    </MudStack>
                }

                @* Announcement Color Filter - shown only when announcement is selected *@
                @if (eventInfo.FilterOptions.Contains("AnnouncementColors") && _announcementNoticeSelected)
                {
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body2">Announcement Color</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Leave empty for any color</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudCheckBox T="bool" Value="_announcementBlueSelected"
                                         Label="Blue"
                                         Color="Color.Info"
                                         ValueChanged="@((bool val) => OnAnnouncementColorChanged("blue", val))" />
                            <MudCheckBox T="bool" Value="_announcementGreenSelected"
                                         Label="Green"
                                         Color="Color.Success"
                                         ValueChanged="@((bool val) => OnAnnouncementColorChanged("green", val))" />
                            <MudCheckBox T="bool" Value="_announcementOrangeSelected"
                                         Label="Orange"
                                         Color="Color.Warning"
                                         ValueChanged="@((bool val) => OnAnnouncementColorChanged("orange", val))" />
                            <MudCheckBox T="bool" Value="_announcementPurpleSelected"
                                         Label="Purple"
                                         Color="Color.Secondary"
                                         ValueChanged="@((bool val) => OnAnnouncementColorChanged("purple", val))" />
                            <MudCheckBox T="bool" Value="_announcementPrimarySelected"
                                         Label="Primary"
                                         Color="Color.Primary"
                                         ValueChanged="@((bool val) => OnAnnouncementColorChanged("primary", val))" />
                        </MudStack>
                    </MudStack>
                }

            }

            @* Show available variables *@
            <MudPaper Class="pa-3 mt-3" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Available Variables</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">These variables can be used in your actions:</MudText>
                @foreach (var variable in GetVisibleVariables(eventInfo))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@($"%{variable}%")" />
                }
            </MudPaper>
        }
    }
</MudStack>

@code {
    [Parameter]
    public string SelectedEventName { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SelectedEventNameChanged { get; set; }

    [Parameter]
    public TwitchEventConfig Config { get; set; } = new();

    [Parameter]
    public EventCallback<TwitchEventConfig> ConfigChanged { get; set; }

    [Inject]
    private ITwitchService TwitchService { get; set; } = null!;

    private List<TwitchEventInfo> _availableEvents = new();
    private List<TwitchLib.Api.Helix.Models.ChannelPoints.CustomReward> _availableRewards = new();
    private RewardTitleOption? _selectedRewardToAdd;
    private TwitchEventInfo? _selectedEventInfo;
    private bool _tier1Selected;
    private bool _tier2Selected;
    private bool _tier3Selected;
    private bool _cheerSelected;
    private bool _powerUpSelected;
    private bool _customPowerUpSelected;
    private bool _messageEffectSelected;
    private bool _celebrationSelected;
    private bool _gigantifySelected;
    private bool _subNoticeSelected;
    private bool _resubNoticeSelected;
    private bool _subGiftNoticeSelected;
    private bool _communitySubGiftNoticeSelected;
    private bool _giftPaidUpgradeNoticeSelected;
    private bool _primePaidUpgradeNoticeSelected;
    private bool _raidNoticeSelected;
    private bool _unraidNoticeSelected;
    private bool _payItForwardNoticeSelected;
    private bool _announcementNoticeSelected;
    private bool _bitsBadgeTierNoticeSelected;
    private bool _charityDonationNoticeSelected;
    private bool _watchStreakNoticeSelected;
    // Sub tier selections (for sub/resub/sub_gift/community_sub_gift/prime_paid_upgrade)
    private bool _subTier1Selected;
    private bool _subTier2Selected;
    private bool _subTier3Selected;
    // Announcement color selections
    private bool _announcementBlueSelected;
    private bool _announcementGreenSelected;
