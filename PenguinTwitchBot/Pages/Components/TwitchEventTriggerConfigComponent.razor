    protected override async Task OnInitializedAsync()
    {
        _availableEvents = TwitchEventTypeInfo.GetAvailableEvents();
        await LoadChannelPointRewards();
        UpdateTierSelections();
        UpdateBitsTypeSelections();
        UpdatePowerUpTypeSelections();
        UpdateNoticeTypeSelections();

        // Set initial selected event if SelectedEventName is already set
        if (!string.IsNullOrEmpty(SelectedEventName))
        {
            _selectedEventInfo = _availableEvents.FirstOrDefault(e => e.Name == SelectedEventName);
        }
    }

    protected override void OnParametersSet()
    {
        // Fix: Update tier selections when Config is replaced via parameters
        UpdateTierSelections();
        UpdateBitsTypeSelections();
        UpdatePowerUpTypeSelections();
        UpdateNoticeTypeSelections();

        // Update selected event info when SelectedEventName changes
        if (!string.IsNullOrEmpty(SelectedEventName))
        {
            var newSelection = _availableEvents.FirstOrDefault(e => e.Name == SelectedEventName);
            if (newSelection != _selectedEventInfo)
            {
                _selectedEventInfo = newSelection;
            }
        }
    }

    private async Task LoadChannelPointRewards()
    {
        try
        {
            var rewards = await TwitchService.GetChannelPointRewards();
            _availableRewards = rewards.OrderBy(r => r.Title).ToList();
        }
        catch (Exception)
        {
            // If loading fails, just continue with empty list
            _availableRewards = new List<TwitchLib.Api.Helix.Models.ChannelPoints.CustomReward>();
        }
    }

    private Task<IEnumerable<TwitchEventInfo>> SearchEvents(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(_availableEvents.AsEnumerable());
        }

        var filtered = _availableEvents.Where(e => 
            e.DisplayName.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            e.Description.Contains(value, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(filtered);
    }

    private Task<IEnumerable<RewardTitleOption>> SearchRewards(string value, CancellationToken token)
    {
        var rewardTitles = _availableRewards
            .Select(r => r.Title)
            .Select(t => t.Trim())
            .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
            .Select(g => new RewardTitleOption(g.First(), g.Count()))
            .OrderBy(option => option.Title);

        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(rewardTitles.AsEnumerable());
        }

        var filtered = rewardTitles.Where(t => 
            t.Title.Contains(value, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(filtered.AsEnumerable());
    }

    private async Task OnEventInfoChanged(TwitchEventInfo? eventInfo)
    {
        _selectedEventInfo = eventInfo;
        var eventName = eventInfo?.Name ?? string.Empty;

        SelectedEventName = eventName;
        await SelectedEventNameChanged.InvokeAsync(eventName);

        // Reset config when event type changes
        Config = new TwitchEventConfig { EventName = eventName };
        UpdateTierSelections(); // Fix: Recalculate tier checkbox state
        UpdateBitsTypeSelections();
        UpdatePowerUpTypeSelections();
        UpdateNoticeTypeSelections();
        await ConfigChanged.InvokeAsync(Config);
    }

    private async Task OnRewardSelected(RewardTitleOption? reward)
    {
        var normalizedTitle = reward?.Title.Trim();
        if (!string.IsNullOrWhiteSpace(normalizedTitle)
            && !Config.RewardTitles.Any(t => t.Equals(normalizedTitle, StringComparison.OrdinalIgnoreCase)))
        {
            Config.RewardTitles.Add(normalizedTitle);
            await ConfigChanged.InvokeAsync(Config); // Fix: Invoke ConfigChanged when mutating
        }

        // Clear the autocomplete after a selection so it does not re-fire with stale value.
        _selectedRewardToAdd = null;
        StateHasChanged();
    }

    private sealed record RewardTitleOption(string Title, int Count)
    {
        public string DisplayLabel => Count > 1 ? $"{Title} ({Count} rewards)" : Title;
    }

    private async Task AddRewardTitle()
    {
        Config.RewardTitles.Add("");
        await ConfigChanged.InvokeAsync(Config); // Fix: Invoke ConfigChanged when mutating
        StateHasChanged();
    }

    private Task OnRewardTitleChanged(int index, string? value)
    {
        if (index >= 0 && index < Config.RewardTitles.Count)
        {
            Config.RewardTitles[index] = value ?? string.Empty;
        }

        return Task.CompletedTask;
    }

    private async Task RemoveRewardTitle(int index)
    {
        if (index >= 0 && index < Config.RewardTitles.Count)
        {
            Config.RewardTitles.RemoveAt(index);
            await ConfigChanged.InvokeAsync(Config); // Fix: Invoke ConfigChanged when mutating
            StateHasChanged();
        }
    }

    private async Task OnTierChanged(string tier, bool selected)
    {
        if (selected && !Config.SubscriptionTiers.Contains(tier))
        {
            Config.SubscriptionTiers.Add(tier);
        }
        else if (!selected && Config.SubscriptionTiers.Contains(tier))
        {
            Config.SubscriptionTiers.Remove(tier);
        }

        UpdateTierSelections();
        await ConfigChanged.InvokeAsync(Config); // Fix: Invoke ConfigChanged when mutating
        StateHasChanged();
    }

