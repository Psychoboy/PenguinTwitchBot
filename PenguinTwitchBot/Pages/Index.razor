@page "/"
@using PenguinTwitchBot.Models
@using PenguinTwitchBot.Pages.Components
@using PenguinTwitchBot.Helpers
@using Microsoft.AspNetCore.SignalR.Client
@using PenguinTwitchBot.Bot;
@using PenguinTwitchBot.Pages.ViewerViews.Components;
@inject PenguinTwitchBot.Bot.Commands.Moderation.Admin Admin
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject PenguinTwitchBot.Bot.Commands.Music.YtPlayer YtPlayer
@inject PenguinTwitchBot.Bot.Core.Leaderboards leaderBoards
@inject PenguinTwitchBot.Bot.Commands.Metrics.SongRequests SongRequestMetrics
@inject PenguinTwitchBot.Bot.Core.IChatHistory ChatHistory
@inject PenguinTwitchBot.Bot.StreamSchedule.ISchedule Schedule
@inject ISnackbar Snackbar
@inject ILogger<Index> logger
@implements IAsyncDisposable

<CascadingAuthenticationState>  
    <MudContainer Class="pa-4 pa-md-6" MaxWidth="MaxWidth.ExtraLarge">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudStack Spacing="3">
                    <BonusTickets/>
                    <GiveawayPreview/>
                </MudStack>
            </MudItem>
            <AuthorizeView Roles="Streamer">
                <Authorized>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-4" Elevation="3">
                            <QuickTools />
                            <MudDivider />
                            <SendMessage />
                        </MudPaper>
                    </MudItem>
                </Authorized>
                <NotAuthorized/>
            </AuthorizeView>
            <MudItem xs="12" sm="6">
                <StreamSchedule />
            </MudItem>
            <MudItem xs="12" sm="6">
                <SongRequests IsPreview="true" LimitNumberOfSongs="5" Title="Next 5 Song Requests" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <TopRequestedSongs IsPreview="true" Title="Top 5 Requested Songs" />
            </MudItem>
        </MudGrid>
    </MudContainer>
</CascadingAuthenticationState>

@code {
    private List<Song> songRequests = new();
    private HubConnection? ythub;
    private CancellationTokenSource? _hubConnectionCts;
    private List<Bot.Models.Metrics.SongRequestHistoryWithRank> topSongRequests = new();
    protected override async Task OnInitializedAsync()
    {
        topSongRequests = await SongRequestMetrics.GetTopN(5);
        UpdateSongList(await YtPlayer.GetRequestedSongs());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;

        _hubConnectionCts = new CancellationTokenSource();

        // Configure SignalR with automatic reconnect and retry policy
        ythub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/ythub"), options =>
            {
                // Allow fallback to other transports if WebSockets fail
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | 
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.ServerSentEvents |
                                     Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
                options.SkipNegotiation = false;
            })
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
            .Build();

        ythub.On<List<Song>>("CurrentSongRequests", async (playlist) =>
        {
            if (songRequests.Count == 0 && playlist.Count == 0) return;
            UpdateSongList(playlist);
            await InvokeAsync(StateHasChanged);
        });

        await ythub.StartWithExpectedExceptionHandlingAsync(logger, Snackbar, _hubConnectionCts.Token);
    }

    private void UpdateSongList(List<Song> songs)
    {
        if (songs.Count > 5)
        {
            songs = songs.Slice(0, 5);
        }
        songRequests = songs;
    }

    public async ValueTask DisposeAsync()
    {
        // Cancel any pending reconnection attempts
        _hubConnectionCts?.Cancel();

        await ythub.DisposeGracefullyAsync(logger);

        _hubConnectionCts?.Dispose();
    }

    private string GetYoutubeLink(string songId)
    {
        return $"https://youtu.be/{songId}";
    }
}