@page "/giveaway/manage"
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Draw Giveaway (Redirecting...)</PageTitle>

<MudContainer Class="pa-4" MaxWidth="MaxWidth.Medium">
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Forward">
        Giveaway drawing moved to <MudLink Href="/giveaway/draw">/giveaway/draw</MudLink>. Redirecting...
    </MudAlert>
</MudContainer>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Snackbar.Add("Giveaway drawing moved to /giveaway/draw.", Severity.Info);
        Navigation.NavigateTo("/giveaway/draw", forceLoad: false, replace: true);
    }
}