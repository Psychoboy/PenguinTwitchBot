@page "/viewergiveaway"
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Giveaway (Redirecting...)</PageTitle>

<MudContainer Class="pa-4" MaxWidth="MaxWidth.Medium">
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Forward">
        Giveaway moved to <MudLink Href="/giveaway">/giveaway</MudLink>. Redirecting...
    </MudAlert>
</MudContainer>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Snackbar.Add("Giveaway moved to /giveaway.", Severity.Info);
        Navigation.NavigateTo("/giveaway", forceLoad: false, replace: true);
    }
}