@page "/overlay/editor"
@using Microsoft.EntityFrameworkCore
@using PenguinTwitchBot.Bot.Models.Overlay
@using PenguinTwitchBot.Repository
@using System.Text.Json
@using System.Globalization
@using Microsoft.Extensions.DependencyInjection
@attribute [Authorize(Roles = "Streamer, Editor")]
@inject IServiceScopeFactory ScopeFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PenguinTwitchBot.Bot.Notifications.IWebSocketMessenger WebSocketMessenger
@implements IAsyncDisposable

<PageTitle>Overlay Editor</PageTitle>

<div class="editor-root">

    <!-- ===================== LEFT: Layout list ===================== -->
    <div class="layouts-panel">
        <div class="panel-header">
            <MudText Typo="Typo.subtitle1"><b>Layouts</b></MudText>
            <MudTooltip Text="New layout">
                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                               Size="Size.Small" OnClick="ShowNewLayoutDialog" />
            </MudTooltip>
        </div>

        @if (_layouts.Count == 0)
        {
            <MudText Typo="Typo.caption" Class="pa-2 text-disabled">No layouts yet — click + to create one.</MudText>
        }

        @foreach (var layoutItem in _layouts)
        {
            <div class="layout-item @(_currentLayoutId == layoutItem.Id ? "layout-item--active" : "")"
                 @onclick="() => LoadLayout(layoutItem.Id)">
                <div class="layout-item__name">
                    @layoutItem.Name
                    @if (layoutItem.IsDefault)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                 Class="ml-1" Style="height:16px;font-size:10px;">Default</MudChip>
                    }
                </div>
                <div class="layout-item__actions" @onclick:stopPropagation="true">
                    @if (!layoutItem.IsDefault)
                    {
                        <MudTooltip Text="Set as default">
                            <MudIconButton Icon="@Icons.Material.Filled.Star" Size="Size.Small"
                                           Color="Color.Warning" OnClick="() => SetDefault(layoutItem.Id)" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Rename layout">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Default" OnClick="() => ShowRenameDialog(layoutItem.Id, layoutItem.Name)" />
                    </MudTooltip>
                    <MudTooltip Text="Duplicate layout">
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                       Color="Color.Info" OnClick="() => DuplicateLayout(layoutItem.Id)" />
                    </MudTooltip>
                    <MudTooltip Text="Delete layout">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error" OnClick="() => DeleteLayout(layoutItem.Id)" />
                    </MudTooltip>
                </div>
            </div>
        }
    </div>

    <!-- ===================== CENTER: Toolbar + Canvas ===================== -->
    <div class="canvas-area">
        <div class="canvas-toolbar">
            @if (_currentLayoutId.HasValue)
            {
                <MudMenu Label="Add Widget" StartIcon="@Icons.Material.Filled.Add"
                         Variant="Variant.Filled" Color="Color.Secondary" Dense="true"
                         Class="mr-2">
                    @foreach (var def in WidgetRegistry.All)
                    {
                        <MudMenuItem OnClick="() => AddWidget(def)">@def.DisplayName</MudMenuItem>
                    }
                </MudMenu>

                <MudButton StartIcon="@Icons.Material.Filled.Save"
                           Variant="Variant.Filled" Color="Color.Success"
                           OnClick="SaveLayout" Disabled="_saving">
                    @(_saving ? "Saving…" : "Save")
                </MudButton>

                <MudTooltip Text="Opens overlay.html in a new tab — save first!">
                    <MudButton StartIcon="@Icons.Material.Filled.OpenInNew"
                               Variant="Variant.Outlined"
                               OnClick="OpenPreview" Class="ml-2">
                        Preview
                    </MudButton>
                </MudTooltip>
                <MudTooltip Text="Copy OBS browser source URL to clipboard — save first!">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                   Variant="Variant.Outlined"
                                   OnClick="CopyUrl" Class="ml-1" />
                </MudTooltip>

                <MudDivider Vertical="true" Class="mx-2" />

                <MudTooltip Text="Zoom out">
                    <MudIconButton Icon="@Icons.Material.Filled.ZoomOut"
                                   Variant="Variant.Outlined"
                                   OnClick="ZoomOut"
                                   Disabled="@(_zoomPercent <= MinZoomPercent)" />
                </MudTooltip>
                <MudText Typo="Typo.body2" Class="px-2" Style="min-width:60px; text-align:center;">@_zoomPercent%</MudText>
                <MudTooltip Text="Zoom in">
                    <MudIconButton Icon="@Icons.Material.Filled.ZoomIn"
                                   Variant="Variant.Outlined"
                                   OnClick="ZoomIn"
                                   Disabled="@(_zoomPercent >= MaxZoomPercent)" />
                </MudTooltip>
                <MudTooltip Text="Reset zoom">
                    <MudIconButton Icon="@Icons.Material.Filled.CenterFocusStrong"
                                   Variant="Variant.Outlined"
                                   OnClick="ResetZoom"
                                   Class="ml-1" />
                </MudTooltip>

                <MudDivider Vertical="true" Class="mx-2" />

                <MudTooltip Text="Pan left">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   Variant="Variant.Outlined"
                                   OnClick="PanLeft" />
                </MudTooltip>
                <MudTooltip Text="Pan up">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                   Variant="Variant.Outlined"
                                   OnClick="PanUp"
                                   Class="ml-1" />
                </MudTooltip>
                <MudTooltip Text="Pan down">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                   Variant="Variant.Outlined"
                                   OnClick="PanDown"
                                   Class="ml-1" />
                </MudTooltip>
                <MudTooltip Text="Pan right">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Variant="Variant.Outlined"
                                   OnClick="PanRight"
                                   Class="ml-1" />
                </MudTooltip>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="ml-2 text-disabled">← Select or create a layout</MudText>
            }
        </div>

        <div class="canvas-scroll-wrapper" id="canvas-scroll-wrapper">
            <div id="overlay-canvas" class="overlay-canvas"
                 style="width:@(DisplayCanvasWidthPx)px; height:@(DisplayCanvasHeightPx)px;"
                 @onclick="() => _selected = null">
                @foreach (var w in _widgets.OrderBy(x => x.ZIndex))
                {
                    <div class="widget-tile @(w == _selected ? "widget-tile--selected" : "") @(!w.IsEnabled ? "widget-tile--disabled" : "") @(w.IsLocked ? "widget-tile--locked" : "") @(w.WidgetType == "chat" ? "widget-tile--chat-preview" : "")"
                         data-widget-id="@w.TempId"
                         data-x="@((w.X * Scale).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"
                         data-y="@((w.Y * Scale).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))"
                         style="left:@((w.X * Scale).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))px; top:@((w.Y * Scale).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))px; width:@((w.Width * Scale).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))px; height:@((w.Height * Scale).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))px; z-index:@w.ZIndex; background-color:@GetWidgetColor(w.WidgetType);"
                         @key="w.TempId"
                         @onclick:stopPropagation="true"
                         @onclick="() => SelectWidget(w)">
                        @if (w.IsLocked)
                        {
                            <span class="widget-lock-badge" title="Locked — click-through enabled">🔒</span>
                        }
                        @if (w.WidgetType == "chat")
                        {
                            var preview = GetPreviewChatSettings(w);
                            var badgeSizePx = GetPreviewBadgeSizePx(preview);
                            <div class="chat-preview @(preview.Direction == "horizontal" ? "chat-preview--horizontal" : "chat-preview--vertical") @(preview.Direction == "vertical" && preview.Valign == "bottom" ? "chat-preview--valign-bottom" : "chat-preview--valign-top")"
                                 style="@BuildChatPreviewContainerStyle(preview)">
                                @if (preview.Direction == "horizontal")
                                {
                                    <div class="chat-preview-row" style="@BuildChatPreviewRowStyle(preview)">
                                        <span class="chat-preview-badge" style="width:@(badgeSizePx)px; height:@(badgeSizePx)px;"></span>
                                        <span class="chat-preview-user" style="color:#73C9FF;">PenguinBot</span>
                                        <span class="chat-preview-sep">:</span>
                                        <span class="chat-preview-text">Welcome to stream chat!</span>
                                    </div>
                                    <div class="chat-preview-row" style="@BuildChatPreviewRowStyle(preview)">
                                        <span class="chat-preview-user" style="color:#F3B562;">mod_jane</span>
                                        <span class="chat-preview-sep">:</span>
                                        <span class="chat-preview-text">wheel spin in 5...</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="chat-preview-row" style="@BuildChatPreviewRowStyle(preview)">
                                        <span class="chat-preview-badge" style="width:@(badgeSizePx)px; height:@(badgeSizePx)px;"></span>
                                        <span class="chat-preview-user" style="color:#73C9FF;">PenguinBot</span>
                                        <span class="chat-preview-sep">:</span>
                                        <span class="chat-preview-text">Just landed a huge fish!</span>
                                    </div>
                                    <div class="chat-preview-row" style="@BuildChatPreviewRowStyle(preview)">
                                        <span class="chat-preview-user" style="color:#9FF2A1;">viewer123</span>
                                        <span class="chat-preview-sep">:</span>
                                        <span class="chat-preview-text">GG everyone</span>
                                    </div>
                                    <div class="chat-preview-row" style="@BuildChatPreviewRowStyle(preview)">
                                        <span class="chat-preview-user" style="color:#F3B562;">mod_jane</span>
                                        <span class="chat-preview-sep">:</span>
                                        <span class="chat-preview-text">Hydrate check</span>
                                    </div>
                                }
                            </div>
                            <span class="widget-label widget-label--corner">@w.DisplayName</span>
                        }
                        else
                        {
                            <span class="widget-label">@w.DisplayName</span>
                        }
                    </div>
                }
            </div>
        </div>

        <MudText Typo="Typo.caption" Class="canvas-hint">@_canvasWidth × @_canvasHeight (fit: @((int)(FitScale * 100))% | zoom: @_zoomPercent% | display: @((int)(Scale * 100))%)</MudText>
    </div>

    <!-- ===================== RIGHT: Properties panel ===================== -->
    <div class="props-panel">

        <!-- Widget list (select by name instead of clicking canvas) -->
        @if (_widgets.Count > 0)
        {
            <div class="panel-header">
                <MudText Typo="Typo.subtitle2"><b>Widgets</b></MudText>
            </div>
            @foreach (var wi in _widgets.OrderByDescending(x => x.ZIndex))
            {
                <div class="widget-list-item @(wi == _selected ? "widget-list-item--active" : "")"
                     @onclick="() => SelectWidget(wi)">
                    <span class="widget-list-dot" style="background:@GetWidgetColor(wi.WidgetType);"></span>
                    <span class="widget-list-name">@wi.DisplayName</span>
                    <span class="widget-list-z">z:@wi.ZIndex</span>
                    <span @onclick:stopPropagation="true" style="flex-shrink:0; margin-left:2px;">
                        <MudTooltip Text="@(wi.IsLocked ? "Unlock widget" : "Lock widget")">
                            <MudIconButton Icon="@(wi.IsLocked ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                                           Size="Size.Small"
                                           Color="@(wi.IsLocked ? Color.Warning : Color.Default)"
                                           OnClick="() => wi.IsLocked = !wi.IsLocked" />
                        </MudTooltip>
                    </span>
                </div>
            }
            <MudDivider Class="my-2" />
        }

        @if (_selected != null)
        {
            <MudText Typo="Typo.subtitle1" Class="mb-2"><b>@_selected.DisplayName</b></MudText>
            <MudDivider Class="mb-3" />

            <MudSwitch @bind-Value="_selected.IsEnabled" Label="Enabled"
                       Color="Color.Success" Class="mb-3" />

            <MudNumericField T="int" Label="X" @bind-Value="_selected.X"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2" />
            <MudNumericField T="int" Label="Y" @bind-Value="_selected.Y"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2" />
            <MudNumericField T="int" Label="Width" @bind-Value="_selected.Width"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                             Min="10" />
            <MudNumericField T="int" Label="Height" @bind-Value="_selected.Height"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                             Min="10" />
            <MudNumericField T="int" Label="Z-Index" @bind-Value="_selected.ZIndex"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-4"
                             Min="1" />

            @* ── Alerts widget configuration ── *@
            @if (_selected.WidgetType == "alerts")
            {
                <MudDivider Class="mb-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Alert Settings</b></MudText>
                <MudTextField Label="Alert channel"
                              Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                              HelperText="Optional channel name to route this alert to a specific overlay; leave blank for default"
                              Value="_alertChannel"
                              ValueChanged="@((string v) => { _alertChannel = v; SaveAlertChannel(); })" />
            }

            @* ── Chat widget configuration ── *@
            @if (_selected.WidgetType == "chat" && _chatSettings != null)
            {
                <MudDivider Class="mb-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Chat Settings</b></MudText>

                <MudSelect T="string" Label="Direction"
                           Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                           Value="_chatSettings.Direction"
                           ValueChanged="@(v => { _chatSettings.Direction = v; SaveChatSettings(); })">
                    <MudSelectItem Value="@("vertical")">Vertical (stack)</MudSelectItem>
                    <MudSelectItem Value="@("horizontal")">Horizontal (push-left)</MudSelectItem>
                </MudSelect>

                @if (_chatSettings.Direction == "vertical")
                {
                    <MudSelect T="string" Label="Align"
                               Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                               Value="_chatSettings.Valign"
                               ValueChanged="@(v => { _chatSettings.Valign = v; SaveChatSettings(); })">
                        <MudSelectItem Value="@("bottom")">New messages at bottom</MudSelectItem>
                        <MudSelectItem Value="@("top")">New messages at top</MudSelectItem>
                    </MudSelect>
                }

                <div class="d-flex align-center gap-2 mb-2">
                    <input type="color"
                           value="@_chatSettings.MsgColor"
                           @oninput="@(e => { _chatSettings.MsgColor = e.Value?.ToString() ?? "#ffffff"; SaveChatSettings(); })"
                           title="Pick message colour"
                           style="width:36px; height:36px; padding:2px; border:1px solid rgba(255,255,255,0.23); border-radius:4px; cursor:pointer; background:none; flex-shrink:0;" />
                    <MudTextField Label="Message color"
                                  Margin="Margin.Dense" Variant="Variant.Outlined"
                                  Value="_chatSettings.MsgColor"
                                  ValueChanged="@((string v) => { _chatSettings.MsgColor = v; SaveChatSettings(); })"
                                  Style="flex:1; min-width:0;" />
                </div>

                <MudTextField Label="Background color"
                              Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                              HelperText="Use 'transparent' for OBS, or e.g. rgba(0,0,0,0.6)"
                              Value="_chatSettings.BgColor"
                              ValueChanged="@((string v) => { _chatSettings.BgColor = v; SaveChatSettings(); })" />

                <MudTextField Label="Row background"
                              Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                              HelperText="Per-message row bg, e.g. rgba(0,0,0,0.4)"
                              Value="_chatSettings.RowBg"
                              ValueChanged="@((string v) => { _chatSettings.RowBg = v; SaveChatSettings(); })" />

                <MudNumericField T="int" Label="Font size (px)"
                                 Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                                 Min="8" Max="72"
                                 Value="_chatSettings.FontSize"
                                 ValueChanged="@(v => { _chatSettings.FontSize = v; SaveChatSettings(); })" />

                <MudAutocomplete T="string"
                                 Label="Font family"
                                 Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                                 HelperText="Pick a common web font or type a custom family"
                                 Value="_chatSettings.FontFamily"
                                 ValueChanged="@((string v) => { _chatSettings.FontFamily = v; SaveChatSettings(); })"
                                 SearchFunc="SearchFontFamilies"
                                 CoerceText="false"
                                 CoerceValue="false"
                                 ResetValueOnEmptyText="true"
                                 MinCharacters="0"
                                 MaxItems="12"
                                 Dense="true"
                                 Clearable="true" />

                <MudNumericField T="int" Label="Font weight"
                                 Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                                 Min="100" Max="900" Step="100"
                                 HelperText="100-900, e.g. 400 = normal, 700 = bold"
                                 Value="_chatSettings.FontWeight"
                                 ValueChanged="@(v => { _chatSettings.FontWeight = v; SaveChatSettings(); })" />

                <MudNumericField T="int" Label="Max messages"
                                 Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                                 Min="1" Max="200"
                                 Value="_chatSettings.MaxMessages"
                                 ValueChanged="@(v => { _chatSettings.MaxMessages = v; SaveChatSettings(); })" />

                <MudNumericField T="int" Label="Badge size (px)"
                                 Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                                 Min="0" Max="48"
                                 Value="_chatSettings.BadgeSize"
                                 ValueChanged="@(v => { _chatSettings.BadgeSize = v; SaveChatSettings(); })" />

                <MudNumericField T="int" Label="Message timeout (s)"
                                 Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                                 HelperText="0 = messages stay forever"
                                 Min="0"
                                 Value="_chatSettings.Timeout"
                                 ValueChanged="@(v => { _chatSettings.Timeout = v; SaveChatSettings(); })" />

                <MudCheckBox T="bool" Label="Hide commands (messages starting with !)"
                             Class="mb-2"
                             Value="_chatSettings.HideCommands"
                             ValueChanged="@(v => { _chatSettings.HideCommands = v; SaveChatSettings(); })" />

                <MudTextField Label="Ignored users"
                              Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2"
                              HelperText="Comma-separated login names to hide"
                              Value="_chatSettings.IgnoredUsers"
                              ValueChanged="@((string v) => { _chatSettings.IgnoredUsers = v; SaveChatSettings(); })" />

            }

            <MudDivider Class="mb-3" />
            <MudButton FullWidth="true" Color="Color.Error" Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="RemoveSelectedWidget">
                Remove Widget
            </MudButton>
        }
        else if (_currentLayoutId.HasValue)
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Canvas Size</b></MudText>
            <MudDivider Class="mb-2" />
            <div class="preset-row mb-3">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick='() => SetCanvasSize(1280,  720)'>720p</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick='() => SetCanvasSize(1920, 1080)'>1080p</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick='() => SetCanvasSize(2560, 1440)'>1440p</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick='() => SetCanvasSize(3840, 2160)'>4K</MudButton>
            </div>
            <MudNumericField T="int" Label="Width (px)" @bind-Value="_canvasWidth"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-2" Min="100" />
            <MudNumericField T="int" Label="Height (px)" @bind-Value="_canvasHeight"
                             Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-1" Min="100" />
            <MudText Typo="Typo.caption" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Display scale: @((int)(Scale * 100))% (fit @((int)(FitScale * 100))% × zoom @_zoomPercent%)</MudText>
            <MudDivider Class="mb-3" />
            <div class="props-empty">
                <MudIcon Icon="@Icons.Material.Filled.TouchApp"
                         Style="font-size:2.5rem; color: var(--mud-palette-text-disabled);" />
                <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-disabled); text-align:center;">
                    Click a widget to edit its properties.
                </MudText>
            </div>
        }
        else
        {
            <div class="props-empty">
                <MudIcon Icon="@Icons.Material.Filled.Layers"
                         Style="font-size:2.5rem; color: var(--mud-palette-text-disabled);" />
                <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-disabled); text-align:center;">
                    Select a layout to begin.
                </MudText>
            </div>
        }
    </div>
</div>

<!-- ===================== New Layout dialog ===================== -->
@if (_showNewLayoutDialog)
{
    <div class="dialog-backdrop" @onclick="() => _showNewLayoutDialog = false">
        <MudPaper Class="dialog-box" @onclick:stopPropagation="true" Elevation="8">
            <MudText Typo="Typo.h6" Class="mb-4">New Layout</MudText>
            <MudTextField @bind-Value="_newLayoutName"
                          Label="Layout name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          @onkeydown="OnNewLayoutKeyDown"
                          AutoFocus="true" />
            <div class="dialog-actions mt-4">
                <MudButton OnClick="() => _showNewLayoutDialog = false">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="CreateLayout"
                           Disabled="@string.IsNullOrWhiteSpace(_newLayoutName)">
                    Create
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

<!-- ===================== Rename Layout dialog ===================== -->
@if (_showRenameDialog)
{
    <div class="dialog-backdrop" @onclick="() => _showRenameDialog = false">
        <MudPaper Class="dialog-box" @onclick:stopPropagation="true" Elevation="8">
            <MudText Typo="Typo.h6" Class="mb-4">Rename Layout</MudText>
            <MudTextField @bind-Value="_renameLayoutName"
                          Label="New name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          @onkeydown="OnRenameKeyDown"
                          AutoFocus="true" />
            <div class="dialog-actions mt-4">
                <MudButton OnClick="() => _showRenameDialog = false">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="RenameLayout"
                           Disabled="@string.IsNullOrWhiteSpace(_renameLayoutName)">
                    Rename
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    private const double MaxDisplayWidth  = 960;
    private const double MaxDisplayHeight = 540;
    private const int MinZoomPercent = 25;
    private const int MaxZoomPercent = 300;
    private const int ZoomStepPercent = 25;
    private const int WheelZoomStepPercent = 10;
    private const int PanStepPx = 120;

    // Scale to fit the layout's canvas inside MaxDisplay dimensions
    private double FitScale => Math.Min(MaxDisplayWidth / _canvasWidth, MaxDisplayHeight / _canvasHeight);
    private double Scale => FitScale * (_zoomPercent / 100.0);
    private int DisplayCanvasWidthPx  => (int)(_canvasWidth  * Scale);
    private int DisplayCanvasHeightPx => (int)(_canvasHeight * Scale);

    private List<LayoutListItem> _layouts = [];
    private int? _currentLayoutId;
    private int  _canvasWidth  = 1920;
    private int  _canvasHeight = 1080;
    private List<WidgetModel> _widgets = [];
    private WidgetModel? _selected;
    private bool _saving;
    private bool _jsInitialized;
    private bool _jsNeedsReinit;
    private bool _showNewLayoutDialog;
    private string _newLayoutName = "";
    private bool _showRenameDialog;
    private int _renameLayoutId;
    private string _renameLayoutName = "";
    private int _zoomPercent = 100;
    private bool _pendingWheelZoomAnchor;
    private double _wheelAnchorX;
    private double _wheelAnchorY;
    private double _wheelOldScale;
    private double _wheelNewScale;
    private DotNetObjectReference<OverlayEditor>? _dotNetRef;

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await RefreshLayouts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if ((!_jsInitialized || _jsNeedsReinit) && _dotNetRef != null)
        {
            _jsInitialized = true;
            _jsNeedsReinit = false;
            await JS.InvokeVoidAsync("overlayEditor.init", _dotNetRef, Scale);
        }

        if (_pendingWheelZoomAnchor)
        {
            _pendingWheelZoomAnchor = false;
            await JS.InvokeVoidAsync(
                "overlayEditor.applyZoomAnchor",
                "canvas-scroll-wrapper",
                _wheelAnchorX,
                _wheelAnchorY,
                _wheelOldScale,
                _wheelNewScale);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("overlayEditor.destroy");
        }
        catch (JSDisconnectedException) { /* circuit already gone — safe to ignore */ }
        _dotNetRef?.Dispose();
    }

