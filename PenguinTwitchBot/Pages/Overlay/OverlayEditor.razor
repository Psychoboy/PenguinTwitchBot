    [JSInvokable]
    public void OnWidgetMoved(string tempId, int x, int y)
    {
        var w = _widgets.FirstOrDefault(w => w.TempId == tempId);
        if (w != null) { w.X = x; w.Y = y; }
    }

    [JSInvokable]
    public void OnWidgetResized(string tempId, int x, int y, int width, int height)
    {
        var w = _widgets.FirstOrDefault(w => w.TempId == tempId);
        if (w != null) { w.X = x; w.Y = y; w.Width = width; w.Height = height; }
    }

    [JSInvokable]
    public async Task OnDragEnd()
    {
        // Refresh property panel to show the final position after drag/resize.
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task AdjustZoomFromWheel(int direction, double anchorX, double anchorY)
    {
        var oldScale = Scale;
        var delta = direction > 0 ? WheelZoomStepPercent : -WheelZoomStepPercent;
        var next = Math.Clamp(_zoomPercent + delta, MinZoomPercent, MaxZoomPercent);
        if (next == _zoomPercent) return;

        _zoomPercent = next;
        var newScale = Scale;

        _wheelAnchorX = anchorX;
        _wheelAnchorY = anchorY;
        _wheelOldScale = oldScale;
        _wheelNewScale = newScale;
        _pendingWheelZoomAnchor = true;

        _jsNeedsReinit = true;
        await InvokeAsync(StateHasChanged);
    }

    // ── Data ────────────────────────────────────────────────────────────────────

    private async Task RefreshLayouts()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
        var all = await db.OverlayLayouts.GetAllWithWidgetsAsync();
        _layouts = all.Select(l => new LayoutListItem(l.Id, l.Name, l.IsDefault)).ToList();
    }

    private async Task LoadLayout(int id)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
        var layout = await db.OverlayLayouts.GetByIdWithWidgetsAsync(id);
        if (layout == null) return;

        _currentLayoutId = id;
        _canvasWidth  = layout.CanvasWidth;
        _canvasHeight = layout.CanvasHeight;
        _selected = null;
        _jsNeedsReinit = true;
        _widgets = layout.Widgets.Select(w =>
        {
            var def = WidgetRegistry.Find(w.WidgetType);
            var model = new WidgetModel
            {
                WidgetType  = w.WidgetType,
                DisplayName = def?.DisplayName ?? w.WidgetType,
                IsEnabled   = w.IsEnabled,
                IsLocked    = w.IsLocked,
                X           = w.X,
                Y           = w.Y,
                Width       = w.Width,
                Height      = w.Height,
                ZIndex      = w.ZIndex,
                CustomSettings = w.CustomSettings
            };

            if (w.WidgetType == "alerts" && !string.IsNullOrWhiteSpace(w.CustomSettings))
            {
                try
                {
                    var dict = JsonSerializer.Deserialize<Dictionary<string, string?>>(w.CustomSettings, _chatJsonOptions);
                    if (dict != null && dict.TryGetValue("alertChannel", out var channel) && !string.IsNullOrWhiteSpace(channel))
                    {
                        model.DisplayName = $"{model.DisplayName} ({channel})";
                    }
                }
                catch { }
            }

            return model;
        }).ToList();
    }

    private async Task SaveLayout()
    {
        if (!_currentLayoutId.HasValue) return;
        _saving = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();

            // Save canvas dimensions on the layout entity
            var layoutEntity = await db.OverlayLayouts.GetByIdAsync(_currentLayoutId.Value);
            if (layoutEntity != null)
            {
                layoutEntity.CanvasWidth  = _canvasWidth;
                layoutEntity.CanvasHeight = _canvasHeight;
            }

            // Replace all widgets
            var existing = await db.OverlayWidgets
                .Find(w => w.OverlayLayoutId == _currentLayoutId.Value)
                .ToListAsync();
            db.OverlayWidgets.RemoveRange(existing);

            foreach (var w in _widgets)
            {
                db.OverlayWidgets.Add(new OverlayWidget
                {
                    OverlayLayoutId = _currentLayoutId.Value,
                    WidgetType      = w.WidgetType,
                    IsEnabled       = w.IsEnabled,
                    IsLocked        = w.IsLocked,
                    X               = w.X,
                    Y               = w.Y,
                    Width           = w.Width,
                    Height          = w.Height,
                    ZIndex          = w.ZIndex,
                    CustomSettings  = w.CustomSettings
                });
            }

            await db.SaveChangesAsync();

            // Notify any overlay.html page showing this layout to reload
            var layoutName = _layouts.FirstOrDefault(l => l.Id == _currentLayoutId.Value)?.Name ?? "";
            var reloadJson = System.Text.Json.JsonSerializer.Serialize(new { type = "overlay_reload", layout = layoutName });
            await WebSocketMessenger.AddToQueue(reloadJson);

            Snackbar.Add("Layout saved!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to save: " + ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CreateLayout()
    {
        if (string.IsNullOrWhiteSpace(_newLayoutName)) return;

        var trimmed = _newLayoutName.Trim();
        if (_layouts.Any(l => l.Name.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add($"A layout named '{trimmed}' already exists.", Severity.Warning);
            return;
        }

        _showNewLayoutDialog = false;

        var isFirst = _layouts.Count == 0;
        var layout = new OverlayLayout
        {
            Name      = trimmed,
            IsDefault = isFirst
        };
        await using (var scope = ScopeFactory.CreateAsyncScope())
        {
            var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
            await db.OverlayLayouts.AddAsync(layout);
            await db.SaveChangesAsync();
        }
        await RefreshLayouts();
        await LoadLayout(layout.Id);
        Snackbar.Add($"Layout '{layout.Name}' created.", Severity.Success);
    }

    private async Task SetDefault(int id)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
        var all = await db.OverlayLayouts.GetAllWithWidgetsAsync();
        foreach (var l in all)
        {
            l.IsDefault = (l.Id == id);
            db.OverlayLayouts.Update(l);
        }
        await db.SaveChangesAsync();
        await RefreshLayouts();
        Snackbar.Add("Default layout updated.", Severity.Success);
    }

    private async Task DuplicateLayout(int id)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
        var source = await db.OverlayLayouts.GetByIdWithWidgetsAsync(id);
        if (source == null) return;

        // Generate a unique name: "Copy of X", then "Copy of X (2)", etc.
        var baseName = $"Copy of {source.Name}";
        var candidateName = baseName;
        var counter = 2;
        while (_layouts.Any(l => l.Name.Equals(candidateName, StringComparison.OrdinalIgnoreCase)))
        {
            candidateName = $"{baseName} ({counter++})";
        }

        var copy = new OverlayLayout
        {
            Name         = candidateName,
            IsDefault    = false,
            CanvasWidth  = source.CanvasWidth,
            CanvasHeight = source.CanvasHeight,
            Widgets      = source.Widgets.Select(w => new OverlayWidget
            {
                WidgetType     = w.WidgetType,
                IsEnabled      = w.IsEnabled,
                IsLocked       = w.IsLocked,
                X              = w.X,
                Y              = w.Y,
                Width          = w.Width,
                Height         = w.Height,
                ZIndex         = w.ZIndex,
                CustomSettings = w.CustomSettings
            }).ToList()
        };
        await db.OverlayLayouts.AddAsync(copy);
        await db.SaveChangesAsync();
        await RefreshLayouts();
        Snackbar.Add($"Duplicated as '{copy.Name}'.", Severity.Success);
    }

    private async Task DeleteLayout(int id)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
        var layout = await db.OverlayLayouts.GetByIdWithWidgetsAsync(id);
        if (layout == null) return;
        db.OverlayLayouts.Remove(layout);
        await db.SaveChangesAsync();
        if (_currentLayoutId == id) { _currentLayoutId = null; _widgets = []; _selected = null; }
        await RefreshLayouts();
        Snackbar.Add("Layout deleted.", Severity.Warning);
    }

