    private ChatSettings? _chatSettings;
    private string _alertChannel = "";

    private static readonly string[] _fontFamilyOptions =
    [
        "Arial",
        "Verdana",
        "Tahoma",
        "Trebuchet MS",
        "Segoe UI",
        "Georgia",
        "Times New Roman",
        "Courier New",
        "Roboto",
        "Open Sans",
        "Lato",
        "Montserrat",
        "Poppins",
        "Nunito",
        "Merriweather",
        "Oswald",
        "Bebas Neue",
        "Raleway",
        "Playfair Display",
        "Inter"
    ];

    private static readonly JsonSerializerOptions _chatJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = false,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
    };

    private Task<IEnumerable<string>> SearchFontFamilies(string? value, CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();

        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(_fontFamilyOptions.AsEnumerable());

        var matches = _fontFamilyOptions.Where(f =>
            CultureInfo.InvariantCulture.CompareInfo.IndexOf(f, value, CompareOptions.IgnoreCase) >= 0);

        return Task.FromResult(matches);
    }

    private ChatSettings GetPreviewChatSettings(WidgetModel widget)
    {
        if (widget.WidgetType != "chat") return new ChatSettings();

        try
        {
            return string.IsNullOrWhiteSpace(widget.CustomSettings)
                ? new ChatSettings()
                : (JsonSerializer.Deserialize<ChatSettings>(widget.CustomSettings, _chatJsonOptions) ?? new ChatSettings());
        }
        catch
        {
            return new ChatSettings();
        }
    }

    private int GetPreviewFontSizePx(ChatSettings settings)
        => Math.Clamp((int)Math.Round(settings.FontSize * Scale), 7, 32);

    private int GetPreviewBadgeSizePx(ChatSettings settings)
        => Math.Clamp((int)Math.Round(settings.BadgeSize * Scale), 0, 32);

    private string BuildChatPreviewContainerStyle(ChatSettings settings)
    {
        var fontFamily = string.IsNullOrWhiteSpace(settings.FontFamily) ? "inherit" : settings.FontFamily;
        return $"background:{settings.BgColor}; color:{settings.MsgColor}; font-size:{GetPreviewFontSizePx(settings)}px; font-weight:{settings.FontWeight}; font-family:{fontFamily};";
    }

    private string BuildChatPreviewRowStyle(ChatSettings settings)
        => $"background:{settings.RowBg};";

    private void LoadChatSettings()
    {
        if (_selected?.WidgetType == "chat")
        {
            try
            {
                _chatSettings = string.IsNullOrWhiteSpace(_selected.CustomSettings)
                    ? new ChatSettings()
                    : (JsonSerializer.Deserialize<ChatSettings>(_selected.CustomSettings, _chatJsonOptions) ?? new ChatSettings());
            }
            catch
            {
                _chatSettings = new ChatSettings();
            }
        }
        else
        {
            _chatSettings = null;
        }
    }

    private void SaveChatSettings()
    {
        if (_selected != null && _chatSettings != null)
            _selected.CustomSettings = JsonSerializer.Serialize(_chatSettings, _chatJsonOptions);
    }

    private void LoadAlertChannel()
    {
        if (_selected?.WidgetType == "alerts")
        {
            try
            {
                _alertChannel = string.IsNullOrWhiteSpace(_selected.CustomSettings)
                    ? ""
                    : JsonSerializer.Deserialize<Dictionary<string, string?>>(_selected.CustomSettings, _chatJsonOptions) is var dict && dict != null && dict.TryGetValue("alertChannel", out var val)
                        ? val ?? ""
                        : "";
            }
            catch
            {
                _alertChannel = "";
            }

            var def = WidgetRegistry.Find("alerts");
            var baseName = def?.DisplayName ?? "Alerts";
            _selected.DisplayName = string.IsNullOrWhiteSpace(_alertChannel)
                ? baseName
                : $"{baseName} ({_alertChannel})";
        }
        else
        {
            _alertChannel = "";
        }
    }

    private void SaveAlertChannel()
    {
        if (_selected == null) return;
        var dict = new Dictionary<string, string?>();
        if (!string.IsNullOrWhiteSpace(_alertChannel))
            dict["alertChannel"] = _alertChannel;
        _selected.CustomSettings = JsonSerializer.Serialize(dict, _chatJsonOptions);

        if (_selected.WidgetType == "alerts")
        {
            var def = WidgetRegistry.Find("alerts");
            var baseName = def?.DisplayName ?? "Alerts";
            _selected.DisplayName = string.IsNullOrWhiteSpace(_alertChannel)
                ? baseName
                : $"{baseName} ({_alertChannel})";
        }
    }

