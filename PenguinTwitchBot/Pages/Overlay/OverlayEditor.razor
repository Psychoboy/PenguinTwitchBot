    private void SetCanvasSize(int w, int h)
    {
        _canvasWidth  = w;
        _canvasHeight = h;
        _jsNeedsReinit = true;
    }

    private void ShowNewLayoutDialog()
    {
        _newLayoutName = "";
        _showNewLayoutDialog = true;
    }

    private void ZoomIn()
    {
        var next = Math.Min(MaxZoomPercent, _zoomPercent + ZoomStepPercent);
        if (next == _zoomPercent) return;
        _zoomPercent = next;
        _jsNeedsReinit = true;
    }

    private void ZoomOut()
    {
        var next = Math.Max(MinZoomPercent, _zoomPercent - ZoomStepPercent);
        if (next == _zoomPercent) return;
        _zoomPercent = next;
        _jsNeedsReinit = true;
    }

    private void ResetZoom()
    {
        if (_zoomPercent == 100) return;
        _zoomPercent = 100;
        _jsNeedsReinit = true;
    }

    private Task PanLeft() => PanViewport(-PanStepPx, 0);
    private Task PanRight() => PanViewport(PanStepPx, 0);
    private Task PanUp() => PanViewport(0, -PanStepPx);
    private Task PanDown() => PanViewport(0, PanStepPx);

    private async Task PanViewport(int deltaX, int deltaY)
    {
        try
        {
            await JS.InvokeVoidAsync("panScrollElementById", "canvas-scroll-wrapper", deltaX, deltaY);
        }
        catch (JSException)
        {
            Snackbar.Add("Pan controls are not ready yet. Refresh the page and try again.", Severity.Warning);
        }
    }

    private async Task OnNewLayoutKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  await CreateLayout();
        if (e.Key == "Escape") _showNewLayoutDialog = false;
    }

    private void ShowRenameDialog(int id, string currentName)
    {
        _renameLayoutId   = id;
        _renameLayoutName = currentName;
        _showRenameDialog = true;
    }

    private async Task RenameLayout()
    {
        var trimmed = _renameLayoutName.Trim();
        if (string.IsNullOrWhiteSpace(trimmed)) return;

        if (_layouts.Any(l => l.Id != _renameLayoutId && l.Name.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add($"A layout named '{trimmed}' already exists.", Severity.Warning);
            return;
        }

        _showRenameDialog = false;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<IUnitOfWork>();
        var layout = await db.OverlayLayouts.GetByIdAsync(_renameLayoutId);
        if (layout == null) return;
        layout.Name = trimmed;
        db.OverlayLayouts.Update(layout);
        await db.SaveChangesAsync();
        await RefreshLayouts();
        Snackbar.Add($"Renamed to '{trimmed}'.", Severity.Success);
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  await RenameLayout();
        if (e.Key == "Escape") _showRenameDialog = false;
    }

    private async Task OpenPreview()
    {
        var name = _layouts.FirstOrDefault(l => l.Id == _currentLayoutId)?.Name ?? "";
        await JS.InvokeVoidAsync("open", $"/overlay.html?layout={Uri.EscapeDataString(name)}", "_blank");
    }

    private async Task CopyUrl()
    {
        var name = _layouts.FirstOrDefault(l => l.Id == _currentLayoutId)?.Name ?? "";
        var url = Navigation.BaseUri.TrimEnd('/') + $"/overlay.html?layout={Uri.EscapeDataString(name)}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
        Snackbar.Add("URL copied to clipboard!", Severity.Info);
    }

