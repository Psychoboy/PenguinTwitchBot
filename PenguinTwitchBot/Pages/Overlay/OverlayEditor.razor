    private sealed class WidgetModel
    {
        public string TempId      { get; } = Guid.NewGuid().ToString("N")[..8];
        public string WidgetType  { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool   IsEnabled   { get; set; } = true;
        public bool   IsLocked    { get; set; } = false;
        public int    X           { get; set; }
        public int    Y           { get; set; }
        public int    Width       { get; set; }
        public int    Height      { get; set; }
        public int    ZIndex      { get; set; } = 1;
        public string? CustomSettings { get; set; }
    }

    private sealed class ChatSettings
    {
        public string Direction  { get; set; } = "vertical";
        public string Valign     { get; set; } = "bottom";
        public string MsgColor   { get; set; } = "#ffffff";
        public string BgColor    { get; set; } = "transparent";
        public string RowBg      { get; set; } = "transparent";
        public int    FontSize      { get; set; } = 16;
        public string FontFamily    { get; set; } = "";
        public int    FontWeight    { get; set; } = 700;
        public int    MaxMessages   { get; set; } = 30;
        public int    BadgeSize     { get; set; } = 20;
        public int    Timeout       { get; set; } = 0;
        public bool   HideCommands  { get; set; } = false;
        public string IgnoredUsers  { get; set; } = "";
    }
