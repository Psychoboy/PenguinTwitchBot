@page "/settings/loyalty-bonuses"
@attribute [Authorize(Roles = "Streamer, Editor")]
@using PenguinTwitchBot.Pages.PointGameSettings
@using PenguinTwitchBot.Pages.PointGameSettings.Providers
@using PenguinTwitchBot.Bot.Features
@implements IDisposable
@inject IFeatureRuntimeCoordinator FeatureRuntimeCoordinator

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Loyalty Bonuses</PageTitle>
<CascadingAuthenticationState>
    <MudContainer Class="pa-6" MaxWidth="MaxWidth.False">
        <MudGrid>
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h5">Loyalty Bonuses</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Configure points awarded for Twitch events (subs, cheers) and the one-time per-stream bonus point claim.
                            Dynamic variables like <code>{Name}</code> and <code>{Amount}</code> are replaced at runtime.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @if (_selectedProvider == null)
            {
                @foreach (var provider in VisibleProviders)
                {
                    var p = provider;
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-3" Elevation="2" Style="cursor:pointer;"
                                  tabindex="0"
                                  @onclick="() => _selectedProvider = p"
                                  @onkeydown="@((e) => { if (e.Key == "Enter" || e.Key == " ") _selectedProvider = p; })">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@p.Icon" Color="Color.Primary" Size="Size.Large" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle1"><b>@p.DisplayName</b></MudText>
                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@p.Description</MudText>
                                    }
                                </MudStack>
                                <MudSpacer />
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@(() => _selectedProvider = null)">
                            All Settings
                        </MudButton>
                        <MudIcon Icon="@_selectedProvider.Icon" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">@_selectedProvider.DisplayName</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12">
                    <GameSettingsPanel Provider="@(_selectedProvider!)" />
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</CascadingAuthenticationState>

@code {
    private IGameSettingsFormProvider? _selectedProvider;
    private bool _disposed;

    private readonly List<IGameSettingsFormProvider> _providers =
    [
        new TwitchEventBonusSettingsProvider(),
        new BonusTicketsSettingsProvider(),
    ];

    private IEnumerable<IGameSettingsFormProvider> VisibleProviders => _providers.Where(IsProviderVisible);

    protected override void OnInitialized()
    {
        FeatureRuntimeCoordinator.StateChangedAsync += HandleFeatureStateChangedAsync;
    }

    private bool IsProviderVisible(IGameSettingsFormProvider provider)
    {
        return provider switch
        {
            TwitchEventBonusSettingsProvider => FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.TwitchEventsBonus),
            BonusTicketsSettingsProvider => FeatureRuntimeCoordinator.IsEnabled(FeatureKeys.BonusTickets),
            _ => true
        };
    }

    private async Task HandleFeatureStateChangedAsync()
    {
        if (_disposed)
        {
            return;
        }

        if (_selectedProvider != null && !IsProviderVisible(_selectedProvider))
        {
            _selectedProvider = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _disposed = true;
        FeatureRuntimeCoordinator.StateChangedAsync -= HandleFeatureStateChangedAsync;
    }
}

