@page "/gamesettings"
@using PenguinTwitchBot.Pages.PointGameSettings.Providers
@attribute [Authorize(Roles = "Streamer, Editor")]
<PageTitle>Penguin Twitch Bot - Game Settings</PageTitle>
<CascadingAuthenticationState>
    <MudContainer Class="pa-6" MaxWidth="MaxWidth.False">
        <MudGrid>
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h5">Game Settings</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Configure each game's costs, point type, and messages. Dynamic variables like <code>{Cost}</code> and <code>{PointType}</code> are replaced at runtime.
                            Use the Point Type selector within each game's settings to choose which point type it uses.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @if (_selectedProvider == null)
            {
                @foreach (var provider in _providers)
                {
                    var p = provider;
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Class="pa-3" Elevation="2" Style="cursor:pointer;"
                              tabindex="0"
                              @onclick="() => _selectedProvider = p"
                              @onkeydown="@((e) => { if (e.Key == "Enter" || e.Key == " ") _selectedProvider = p; })">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@p.Icon" Color="Color.Primary" Size="Size.Large" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle1"><b>@p.DisplayName</b></MudText>
                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@p.Description</MudText>
                                    }
                                </MudStack>
                                <MudSpacer />
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@(() => _selectedProvider = null)">
                            All Games
                        </MudButton>
                        <MudIcon Icon="@_selectedProvider.Icon" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">@_selectedProvider.DisplayName</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12">
                    <GameSettingsPanel Provider="@(_selectedProvider!)" />
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</CascadingAuthenticationState>
@code {
    private IGameSettingsFormProvider? _selectedProvider;

    private readonly List<IGameSettingsFormProvider> _providers =
    [
        new AddActiveSettingsProvider(),
        new BonusTicketsSettingsProvider(),
        new DefuseSettingsProvider(),
        new FFASettingsProvider(),
        new GambleSettingsProvider(),
        new HeistSettingsProvider(),
        new MarkovSettingsProvider(),
        new ModSpamSettingsProvider(),
        new RouletteSettingsProvider(),
        new SlotsSettingsProvider(),
        new TwitchEventBonusSettingsProvider(),
        new ViewersInChatBonusProvider(),
    ];
}
