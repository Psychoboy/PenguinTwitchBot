@page "/pointsettings"
@using PenguinTwitchBot.Bot.Core.Points
@using PenguinTwitchBot.Database.Bot.Models.Points
@attribute [Authorize(Roles = "Streamer, Editor")]

<PageTitle>@(AppConfiguration["ApplicationTitle"] ?? "Penguin Twitch Bot") - Point Settings</PageTitle>

<MudContainer Class="pa-6" MaxWidth="MaxWidth.False">
    <MudGrid>

        @* -- Page header -- *@
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h5">Point Settings</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Manage your point types and configure which point type each game uses.
                        You can create as many point types as you like (e.g. one for casual fun games, one for
                        giveaway tickets) and assign them individually per game. The first point type cannot be
                        deleted - rename or repurpose it as needed.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

                @* -- Tab 1: Point Types -- *@
                <MudTabPanel Text="Point Types" Icon="@Icons.Material.Filled.MonetizationOn">
                    <MudGrid>
                        <MudItem xs="12" md="8">
                            <MudPaper Elevation="1">
                                <MudTable Items="@PointTypes" Elevation="0" Hover="true">
                                    <ToolBarContent>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.h6">Point Types</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                Each type has its own set of chat commands. Expand a row to view them.
                                            </MudText>
                                        </MudStack>
                                    </ToolBarContent>
                                    <HeaderContent>
                                        <MudTh>Id</MudTh>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Description</MudTh>
                                        <MudTh></MudTh>
                                        <MudTh></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Id">@context.Id</MudTd>
                                        <MudTd DataLabel="Name"><b>@context.Name</b></MudTd>
                                        <MudTd DataLabel="Description">@context.Description</MudTd>
                                        <MudTd>
                                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => EditPointType(context)" />
                                        </MudTd>
                                        <MudTd>
                                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeletePointType(context)" />
                                        </MudTd>
                                    </RowTemplate>
                                    <ChildRowContent>
                                        <MudTr>
                                            <td colspan="5">
                                                <MudCard Elevation="0" Class="pa-2 ml-4">
                                                    <MudCardHeader>
                                                        <CardHeaderContent>
                                                            <MudText Typo="Typo.subtitle2">Chat commands for <strong>@context.Name</strong></MudText>
                                                        </CardHeaderContent>
                                                    </MudCardHeader>
                                                    <MudCardContent Class="pa-0">
                                                        <MudTable Items="@context.PointCommands.ToList()" Context="CommandContext" Elevation="0" Dense="true">
                                                            <HeaderContent>
                                                                <MudTh>Command</MudTh>
                                                                <MudTh>Type</MudTh>
                                                            </HeaderContent>
                                                            <RowTemplate>
                                                                <MudTd><code>!@CommandContext.CommandName</code></MudTd>
                                                                <MudTd>@CommandContext.CommandType</MudTd>
                                                            </RowTemplate>
                                                        </MudTable>
                                                    </MudCardContent>
                                                </MudCard>
                                            </td>
                                        </MudTr>
                                    </ChildRowContent>
                                </MudTable>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-4" Elevation="1">
                                <MudText Typo="Typo.h6" Class="mb-3">
                                    @(newPointType.Id == null ? "Create Point Type" : $"Editing: {newPointType.Name}")
                                </MudText>
                                <EditForm Model="@newPointType" OnValidSubmit="SavePointType">
                                    <DataAnnotationsValidator />
                                    <MudStack Spacing="2">
                                        <MudTextField Label="Name" @bind-Value="newPointType.Name" Variant="Variant.Outlined" />
                                        <MudTextField Label="Description" @bind-Value="newPointType.Description" Variant="Variant.Outlined" Lines="2" />
                                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                                                   OnClick="GenerateCommands" StartIcon="@Icons.Material.Filled.AutoAwesome">
                                            Auto-Generate Commands
                                        </MudButton>
                                        <MudDivider />
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                            Chat Commands <MudText Typo="Typo.caption" Color="Color.Secondary" Inline="true">(stored without ! prefix)</MudText>
                                        </MudText>
                                        <MudTextField Label="Add" @bind-Value="newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Add).CommandName" Variant="Variant.Outlined" HelperText="e.g. addpoints" />
                                        <MudTextField Label="Remove" @bind-Value="newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Remove).CommandName" Variant="Variant.Outlined" HelperText="e.g. removepoints" />
                                        <MudTextField Label="Get (viewers check balance)" @bind-Value="newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Get).CommandName" Variant="Variant.Outlined" HelperText="e.g. points" />
                                        <MudTextField Label="Set (mod override)" @bind-Value="newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Set).CommandName" Variant="Variant.Outlined" HelperText="e.g. setpoints" />
                                        <MudTextField Label="Add Active" @bind-Value="newPointType.PointCommands.First(x => x.CommandType == PointCommandType.AddActive).CommandName" Variant="Variant.Outlined" HelperText="e.g. addactivepoints" />
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit"
                                                   FullWidth="true" StartIcon="@Icons.Material.Filled.Save">
                                            Save
                                        </MudButton>
                                        @if (newPointType.Id != null)
                                        {
                                            <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true" OnClick="CancelEdit">
                                                Cancel
                                            </MudButton>
                                        }
                                    </MudStack>
                                </EditForm>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* -- Tab 2: Game Assignments -- *@
                <MudTabPanel Text="Game Assignments" Icon="@Icons.Material.Filled.SportsEsports">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <GamePointSettings />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="1">
                                <MudText Typo="Typo.h6" Class="mb-1">About the Games</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                    Games were originally designed around two separate point pools - a casual pool for fun
                                    and a more serious pool used for giveaways and raffles. You can configure any game to use
                                    any point type, or consolidate everything into one. The groupings below are suggestions only.
                                </MudText>
                                <MudExpansionPanels MultiExpansion="true">
                                    <MudExpansionPanel Text="Suggested &quot;Fun&quot; Games" Icon="@Icons.Material.Filled.Casino">
                                        <MudList T="string" Dense="true">
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Defuse</b> - Defuse a bomb by choosing the correct color. Quick, simple fun.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>FFA</b> - Free-for-all battle; last one standing takes all the points.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Gamble</b> - Risk points for a chance to double up or lose it all.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Heist</b> - Group event where some participants succeed and some fail.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Roll</b> - Roll dice for a chance to win points.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Slots</b> - Spin the wheel. More emotes configured means lower win odds.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Steal</b> - Attempt to steal points directly from another viewer.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Tax</b> - Post-stream tax that removes a small percentage (up to a cap) from viewers who missed the stream.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>Top</b> - Display top 5/10 leaderboards for watch time, points, and messages.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.Casino"><b>LoyaltyFeature</b> - Awards passive points periodically just for being in chat.</MudListItem>
                                        </MudList>
                                    </MudExpansionPanel>
                                    <MudExpansionPanel Text="Suggested Giveaway / Ticket Games" Icon="@Icons.Material.Filled.ConfirmationNumber">
                                        <MudList T="string" Dense="true">
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>AddActive</b> - Awards points to all active viewers at once. Can be stacked and distributed after a short delay.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>Bonus</b> - Viewers claim a one-time bonus per stream through the web interface.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>DuelGame</b> - Challenge another viewer; the opponent must accept. Winner gains, loser loses.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>First</b> - First-to-respond command; earlier responders earn proportionally more points.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>GiveawayFeature</b> - Runs and manages giveaways using point redemptions.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>Raffle</b> - Run point-based raffles in chat.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>Roulette</b> - Gamble points with a configurable per-stream maximum.</MudListItem>
                                            <MudListItem Icon="@Icons.Material.Filled.ConfirmationNumber"><b>TicketsFeature</b> - Periodically awards points with bonuses for active chatters, subscribers, etc.</MudListItem>
                                        </MudList>
                                    </MudExpansionPanel>
                                </MudExpansionPanels>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

            </MudTabs>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private IEnumerable<PointType> PointTypes { get; set; } = [];
    private PointType newPointType = CreateNewPointType();
    [Inject] IPointsSystem pointSystem { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        PointTypes = await pointSystem.GetPointTypes();
        newPointType = CreateNewPointType();
    }

    private async Task SavePointType()
    {
        await pointSystem.UpdatePointType(newPointType);
        newPointType = CreateNewPointType();
        PointTypes = await pointSystem.GetPointTypes();
    }

    private static PointType CreateNewPointType()
    {
        return new PointType
            {
                PointCommands = new List<PointCommand>
                {
                    new PointCommand { CommandType = PointCommandType.Add },
                    new PointCommand { CommandType = PointCommandType.Remove },
                    new PointCommand { CommandType = PointCommandType.Get },
                    new PointCommand { CommandType = PointCommandType.Set },
                    new PointCommand { CommandType = PointCommandType.AddActive }
                }
            };
    }

    private void EditPointType(PointType pointType)
    {
        var requiredTypes = new[] { PointCommandType.Add, PointCommandType.Remove, PointCommandType.Get, PointCommandType.Set, PointCommandType.AddActive };
        foreach (var type in requiredTypes)
        {
            if (!pointType.PointCommands.Any(c => c.CommandType == type))
                pointType.PointCommands.Add(new PointCommand { CommandType = type });
        }
        newPointType = pointType;
    }

    private void CancelEdit()
    {
        newPointType = CreateNewPointType();
    }

    private async Task DeletePointType(PointType pointType)
    {
        if (pointType.Id == 1)
        {
            Snackbar.Add("You can not delete the primary points. You can edit/rename it only.", Severity.Error);
            return;
        }
        await pointSystem.DeletePointType(pointType.Id.GetValueOrDefault());
        PointTypes = await pointSystem.GetPointTypes();
    }

    private void GenerateCommands()
    {
        if (string.IsNullOrWhiteSpace(newPointType.Name)) return;
        var name = newPointType.Name.ToLower();
        newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Add).CommandName = $"add{name}";
        newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Remove).CommandName = $"remove{name}";
        newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Get).CommandName = $"get{name}";
        newPointType.PointCommands.First(x => x.CommandType == PointCommandType.Set).CommandName = $"set{name}";
        newPointType.PointCommands.First(x => x.CommandType == PointCommandType.AddActive).CommandName = $"addactive{name}";
    }
}
